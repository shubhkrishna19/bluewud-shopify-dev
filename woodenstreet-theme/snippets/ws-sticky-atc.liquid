{% comment %}
  Wooden Sticky Add-To-Cart Bar (E-01)
{% endcomment %}

{% assign sticky_atc_image_alt = product.title | escape %}

<div class="ws-sticky-atc" data-ws-sticky-atc>
  <div class="ws-sticky-atc__inner page-width">
    <div class="ws-sticky-atc__product">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 100, height: 100 | image_tag: class: 'ws-sticky-atc__image', alt: sticky_atc_image_alt, width: 100, height: 100, loading: 'lazy' }}
      {% endif %}
      <div class="ws-sticky-atc__info">
        <span class="ws-sticky-atc__title">{{ product.title }}</span>
        <span class="ws-sticky-atc__price">{{ product.price | money }}</span>
      </div>
    </div>

    <div class="ws-sticky-atc__actions">
      <!-- Quantity Selector (Desktop Only) -->
      <div class="ws-sticky-atc__qty">
        <button type="button" class="ws-sticky-atc__qty-btn" data-ws-sticky-qty-change="-1" aria-label="Decrease quantity">-</button>
        <input type="number" class="ws-sticky-atc__qty-input" value="1" min="1" readonly data-ws-sticky-qty aria-label="Quantity">
        <button type="button" class="ws-sticky-atc__qty-btn" data-ws-sticky-qty-change="1" aria-label="Increase quantity">+</button>
      </div>

      <button type="button" class="ws-sticky-atc__btn" data-ws-sticky-add>
        Add to Cart
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const stickyBar = document.querySelector('[data-ws-sticky-atc]');
    const trigger = document.querySelector('[data-product-form-area]'); // Observe main buy button area
    const mainForm = document.querySelector('form[data-product-form]');
    const mainQuantity = mainForm ? mainForm.querySelector('[data-product-quantity]') : null;
    const mainAddButton = mainForm ? mainForm.querySelector('[data-product-atc]') : null;
    const addBtn = document.querySelector('[data-ws-sticky-add]');
    const stickyQuantity = stickyBar ? stickyBar.querySelector('[data-ws-sticky-qty]') : null;
    const quantityControls = stickyBar ? stickyBar.querySelectorAll('[data-ws-sticky-qty-change]') : [];
    
    if (!trigger || !stickyBar || !mainForm) return;

    const syncQuantities = (value) => {
      const nextValue = Math.max(1, parseInt(value, 10) || 1);
      if (stickyQuantity) stickyQuantity.value = String(nextValue);
      if (mainQuantity) mainQuantity.value = String(nextValue);
      return nextValue;
    };

    syncQuantities(mainQuantity ? mainQuantity.value : stickyQuantity ? stickyQuantity.value : 1);

    if (mainQuantity) {
      mainQuantity.addEventListener('input', () => {
        syncQuantities(mainQuantity.value);
      });

      mainQuantity.addEventListener('change', () => {
        syncQuantities(mainQuantity.value);
      });
    }

    quantityControls.forEach((button) => {
      button.addEventListener('click', () => {
        const delta = parseInt(button.getAttribute('data-ws-sticky-qty-change'), 10) || 0;
        const currentValue = stickyQuantity ? parseInt(stickyQuantity.value || '1', 10) : 1;
        syncQuantities(currentValue + delta);
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        stickyBar.classList.toggle('is-visible', !entry.isIntersecting && entry.boundingClientRect.top < 0);
      });
    }, { threshold: 0 });

    observer.observe(trigger);

    // Sync Add to Cart
    addBtn.addEventListener('click', () => {
      if (mainQuantity && stickyQuantity) {
        mainQuantity.value = stickyQuantity.value || '1';
      }

      if (typeof mainForm.requestSubmit === 'function') {
        mainForm.requestSubmit(mainAddButton || undefined);
      } else if (mainAddButton) {
        mainAddButton.click();
      } else {
        mainForm.submit();
      }
    });
  });
</script>
