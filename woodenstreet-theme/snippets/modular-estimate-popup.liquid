{% liquid
  assign modal_id = modal_id | default: 'bw-estimate-popup'
  assign modal_title = modal_title | default: 'Get a free estimate'
  assign context_label = context_label | default: 'Bluewud modular project'
%}

<style>
  .bw-estimate-modal {
    position: fixed;
    inset: 0;
    z-index: 12000;
    display: none;
  }
  .bw-estimate-modal.is-open {
    display: block;
  }
  .bw-estimate-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(22, 15, 12, 0.58);
    backdrop-filter: blur(10px);
  }
  .bw-estimate-modal__dialog {
    position: relative;
    z-index: 1;
    width: min(760px, calc(100vw - 32px));
    margin: 4vh auto;
    max-height: 92vh;
    overflow: auto;
    padding: 26px 28px;
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.98);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 28px 90px rgba(23, 17, 14, 0.24);
  }
  .bw-estimate-modal__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }
  .bw-estimate-modal__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-estimate-modal__title {
    margin: 8px 0 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 38px);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }
  .bw-estimate-modal__copy {
    margin: 10px 0 0;
    color: #66554c;
    font-size: 15px;
    line-height: 1.75;
    max-width: 60ch;
  }
  .bw-estimate-modal__close {
    width: 42px;
    height: 42px;
    border: 0;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    cursor: pointer;
  }
  .bw-estimate-modal__summary {
    display: grid;
    gap: 8px;
    padding: 18px 20px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    margin-bottom: 18px;
  }
  .bw-estimate-modal__summary-label {
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-estimate-modal__summary-text {
    color: #201713;
    font-size: 14px;
    line-height: 1.7;
  }
  .bw-estimate-modal__summary-visual {
    display: grid;
    gap: 8px;
  }
  .bw-estimate-modal__summary-visual[hidden] {
    display: none;
  }
  .bw-estimate-modal__summary-media {
    min-height: 180px;
    border-radius: 18px;
    overflow: hidden;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-estimate-modal__summary-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-estimate-modal__summary-caption {
    color: #66554c;
    font-size: 13px;
    line-height: 1.65;
  }
  .bw-estimate-modal__details {
    display: grid;
    gap: 10px;
    margin-bottom: 18px;
  }
  .bw-estimate-modal__details[hidden] {
    display: none;
  }
  .bw-estimate-modal__detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .bw-estimate-modal__detail-card {
    display: grid;
    gap: 4px;
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(32, 23, 19, 0.04);
  }
  .bw-estimate-modal__detail-label {
    color: #8a684f;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-estimate-modal__detail-value {
    color: #201713;
    font-size: 13px;
    line-height: 1.6;
  }
  .bw-estimate-modal__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-estimate-modal__field {
    display: grid;
    gap: 8px;
  }
  .bw-estimate-modal__field--full {
    grid-column: 1 / -1;
  }
  .bw-estimate-modal__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .bw-estimate-modal__field input,
  .bw-estimate-modal__field select,
  .bw-estimate-modal__field textarea {
    width: 100%;
    min-height: 50px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fffdfb;
    color: #201713;
    font-size: 14px;
  }
  .bw-estimate-modal__field textarea {
    min-height: 120px;
    padding-top: 14px;
    padding-bottom: 14px;
    resize: vertical;
  }
  .bw-estimate-modal__submit {
    min-height: 48px;
    padding: 0 22px;
    border: 0;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-estimate-modal__helper {
    margin: 12px 0 0;
    color: #7b6659;
    font-size: 13px;
    line-height: 1.7;
  }
  @media (max-width: 720px) {
    .bw-estimate-modal__dialog {
      width: min(100vw - 20px, 760px);
      margin: 10px auto;
      padding: 22px 20px;
      border-radius: 24px;
    }
    .bw-estimate-modal__grid {
      grid-template-columns: 1fr;
    }
    .bw-estimate-modal__field--full {
      grid-column: auto;
    }
  }
</style>

<div class="bw-estimate-modal" id="{{ modal_id }}" data-bw-estimate-modal data-context-label="{{ context_label }}">
  <div class="bw-estimate-modal__backdrop" data-bw-estimate-close></div>
  <div class="bw-estimate-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="{{ modal_id }}-title">
    <div class="bw-estimate-modal__top">
      <div>
        <div class="bw-estimate-modal__eyebrow">{{ context_label }}</div>
        <h2 class="bw-estimate-modal__title" id="{{ modal_id }}-title">{{ modal_title }}</h2>
        <p class="bw-estimate-modal__copy">Share your details and the Bluewud team will follow up with the right next step based on the layout, materials, and options you selected.</p>
      </div>
      <button class="bw-estimate-modal__close" type="button" aria-label="Close estimate popup" data-bw-estimate-close>&times;</button>
    </div>

    <div class="bw-estimate-modal__summary">
      <div class="bw-estimate-modal__summary-label">Project brief</div>
      <div class="bw-estimate-modal__summary-text" data-bw-estimate-summary-text>No options selected yet.</div>
      <div class="bw-estimate-modal__summary-visual" data-bw-estimate-preview hidden>
        <div class="bw-estimate-modal__summary-media">
          <img src="" alt="" loading="lazy" width="900" height="675" data-bw-estimate-preview-image>
        </div>
        <div class="bw-estimate-modal__summary-caption" data-bw-estimate-preview-caption></div>
      </div>
    </div>
    <div class="bw-estimate-modal__details" data-bw-estimate-details hidden>
      <div class="bw-estimate-modal__summary-label">Selected options</div>
      <div class="bw-estimate-modal__detail-grid" data-bw-estimate-detail-grid></div>
    </div>

    {% form 'contact' %}
      <input type="hidden" name="contact[project_type]" value="" data-bw-estimate-type-input>
      <input type="hidden" name="contact[project_context]" value="{{ context_label }}" data-bw-estimate-context-input>
      <input type="hidden" name="contact[selected_brief]" value="" data-bw-estimate-summary-input>
      <input type="hidden" name="contact[reference_source]" value="" data-bw-estimate-source-input>
      <input type="hidden" name="contact[project_route]" value="" data-bw-estimate-route-input>
      <input type="hidden" name="contact[selected_options_json]" value="" data-bw-estimate-payload-input>

      <div class="bw-estimate-modal__grid">
        <div class="bw-estimate-modal__field">
          <label for="{{ modal_id }}-name">Full name</label>
          <input id="{{ modal_id }}-name" type="text" name="contact[name]" required>
        </div>
        <div class="bw-estimate-modal__field">
          <label for="{{ modal_id }}-phone">Phone number</label>
          <input id="{{ modal_id }}-phone" type="tel" name="contact[phone]" required>
        </div>
        <div class="bw-estimate-modal__field">
          <label for="{{ modal_id }}-email">Email</label>
          <input id="{{ modal_id }}-email" type="email" name="contact[email]">
        </div>
        <div class="bw-estimate-modal__field">
          <label for="{{ modal_id }}-city">City</label>
          <input id="{{ modal_id }}-city" type="text" name="contact[city]">
        </div>
        <div class="bw-estimate-modal__field">
          <label for="{{ modal_id }}-timeline">Project timeline</label>
          <select id="{{ modal_id }}-timeline" name="contact[timeline]">
            <option value="">Select timeline</option>
            <option value="Immediate">Immediate</option>
            <option value="Within 1 month">Within 1 month</option>
            <option value="1 to 3 months">1 to 3 months</option>
            <option value="Just exploring">Just exploring</option>
          </select>
        </div>
        <div class="bw-estimate-modal__field">
          <label for="{{ modal_id }}-budget">Budget expectation</label>
          <select id="{{ modal_id }}-budget" name="contact[budget]">
            <option value="">Select budget</option>
            <option value="Value led">Value led</option>
            <option value="Mid premium">Mid premium</option>
            <option value="Premium">Premium</option>
            <option value="Need guidance">Need guidance</option>
          </select>
        </div>
        <div class="bw-estimate-modal__field bw-estimate-modal__field--full">
          <label for="{{ modal_id }}-message">Anything else we should know?</label>
          <textarea id="{{ modal_id }}-message" name="contact[body]" placeholder="Room size, style direction, storage needs, or any specific priorities."></textarea>
        </div>
      </div>

      <div style="margin-top:18px;">
        <button class="bw-estimate-modal__submit" type="submit">Send Project Brief</button>
      </div>
    {% endform %}
  </div>
</div>

<script>
  (function () {
    if (window.BluewudProjectBriefStore) return;

    var storageKey = 'bluewud-project-brief';

    function safeRead() {
      try {
        var raw = window.localStorage.getItem(storageKey);
        return raw ? JSON.parse(raw) : null;
      } catch (error) {
        return null;
      }
    }

    function safeWrite(payload) {
      try {
        window.localStorage.setItem(storageKey, JSON.stringify(payload));
      } catch (error) {
        return;
      }
    }

    function serializeOptions(options) {
      if (!options) return '';
      if (typeof options === 'string') return options;
      try {
        return JSON.stringify(options);
      } catch (error) {
        return '';
      }
    }

    function fillModal(modal, payload) {
      if (!modal || !payload) return;

      var summaryText = modal.querySelector('[data-bw-estimate-summary-text]');
      var summaryInput = modal.querySelector('[data-bw-estimate-summary-input]');
      var contextInput = modal.querySelector('[data-bw-estimate-context-input]');
      var sourceInput = modal.querySelector('[data-bw-estimate-source-input]');
      var typeInput = modal.querySelector('[data-bw-estimate-type-input]');
      var routeInput = modal.querySelector('[data-bw-estimate-route-input]');
      var payloadInput = modal.querySelector('[data-bw-estimate-payload-input]');
      var detailsWrap = modal.querySelector('[data-bw-estimate-details]');
      var detailGrid = modal.querySelector('[data-bw-estimate-detail-grid]');
      var previewWrap = modal.querySelector('[data-bw-estimate-preview]');
      var previewImage = modal.querySelector('[data-bw-estimate-preview-image]');
      var previewCaption = modal.querySelector('[data-bw-estimate-preview-caption]');

      function optionLabel(key) {
        var map = {
          layout: 'Layout',
          property_type: 'Property',
          usage_level: 'Usage',
          wall_a_ft: 'Wall A',
          wall_b_ft: 'Wall B',
          wall_c_ft: 'Wall C',
          ceiling_ft: 'Ceiling',
          upper_cabinets: 'Upper cabinets',
          carcass_material: 'Carcass',
          shutter_material: 'Shutter',
          countertop: 'Countertop',
          addons: 'Add-ons',
          appliances: 'Appliances',
          wardrobe_type: 'Wardrobe type',
          room_type: 'Room type',
          storage_intensity: 'Storage',
          width_ft: 'Width',
          height_ft: 'Height',
          depth_ft: 'Depth',
          loft: 'Loft',
          finish: 'Finish',
          internals: 'Internals',
          mirror_need: 'Mirror',
          rooms: 'Rooms',
          intent: 'Intent',
          budget_posture: 'Budget',
          timeline: 'Timeline'
        };
        return map[key] || key.replace(/_/g, ' ').replace(/\b\w/g, function (char) { return char.toUpperCase(); });
      }

      function optionValue(value) {
        if (Array.isArray(value)) return value.filter(Boolean).join(', ');
        if (value && typeof value === 'object') return '';
        return value == null ? '' : String(value);
      }
      function normalizeKitchenLayout(value) {
        if (!value) return '';
        var layout = String(value).toLowerCase();
        if (layout === 'l-shape' || layout === 'l shape') return 'l-shape';
        if (layout === 'u-shape' || layout === 'u shape') return 'u-shape';
        if (layout === 'parallel') return 'parallel';
        if (layout === 'straight') return 'straight';
        if (layout === 'island') return 'island';
        return '';
      }
      function kitchenPreviewFor(layout) {
        var previews = {
          'l-shape': {
            src: {{ 'modular-kitchen-light-oak-l-shape.png' | asset_url | json }},
            alt: 'Bluewud L-shape kitchen preview',
            caption: 'L-shape keeps the room open while still supporting a strong daily kitchen rhythm.'
          },
          'u-shape': {
            src: {{ 'modular-kitchen-walnut-u-shape.png' | asset_url | json }},
            alt: 'Bluewud U-shape kitchen preview',
            caption: 'U-shape suits storage-heavy kitchens where prep and counter continuity matter more.'
          },
          'parallel': {
            src: {{ 'modular-kitchen-galley-light-wood.png' | asset_url | json }},
            alt: 'Bluewud parallel kitchen preview',
            caption: 'Parallel layouts are strongest when two efficient runs need to do most of the work.'
          },
          'straight': {
            src: {{ 'modular-kitchen-sage-u-shape.png' | asset_url | json }},
            alt: 'Bluewud straight kitchen preview',
            caption: 'Straight kitchens work best when one disciplined wall has to carry the full brief.'
          },
          'island': {
            src: {{ 'modular-kitchen-navy-luxury.png' | asset_url | json }},
            alt: 'Bluewud island kitchen preview',
            caption: 'Island planning becomes premium when prep, hosting, and circulation all matter together.'
          }
        };
        return previews[layout] || null;
      }

      if (summaryText && payload.selectedBrief) summaryText.textContent = payload.selectedBrief;
      if (summaryInput) summaryInput.value = payload.selectedBrief || '';
      if (contextInput) contextInput.value = payload.projectContext || modal.getAttribute('data-context-label') || '';
      if (sourceInput) sourceInput.value = payload.referenceSource || '';
      if (typeInput) typeInput.value = payload.projectType || '';
      if (routeInput) routeInput.value = payload.projectRoute || '';
      if (payloadInput) payloadInput.value = serializeOptions(payload.selectedOptions);
      if (previewWrap && previewImage && previewCaption) {
        var layoutKey = normalizeKitchenLayout(payload.selectedOptions && (payload.selectedOptions.layout || payload.selectedOptions.kitchen_layout));
        var preview = payload.projectType && String(payload.projectType).toLowerCase().indexOf('kitchen') !== -1 ? kitchenPreviewFor(layoutKey) : null;
        if (preview) {
          previewWrap.hidden = false;
          previewImage.src = preview.src;
          previewImage.alt = preview.alt;
          previewCaption.textContent = preview.caption;
        } else {
          previewWrap.hidden = true;
          previewImage.removeAttribute('src');
          previewImage.alt = '';
          previewCaption.textContent = '';
        }
      }
      if (detailsWrap && detailGrid) {
        var cards = [];
        if (payload.selectedOptions && typeof payload.selectedOptions === 'object') {
          Object.keys(payload.selectedOptions).forEach(function (key) {
            if (key === 'source_trigger' || key === 'page_family' || key === 'estimate_form') return;
            var formatted = optionValue(payload.selectedOptions[key]);
            if (!formatted) return;
            cards.push('<div class="bw-estimate-modal__detail-card"><span class="bw-estimate-modal__detail-label">' + optionLabel(key) + '</span><span class="bw-estimate-modal__detail-value">' + formatted + '</span></div>');
          });
        }
        if (cards.length) {
          detailsWrap.hidden = false;
          detailGrid.innerHTML = cards.join('');
        } else {
          detailsWrap.hidden = true;
          detailGrid.innerHTML = '';
        }
      }
    }

    window.BluewudProjectBriefStore = {
      read: safeRead,
      clear: function () {
        try {
          window.localStorage.removeItem(storageKey);
        } catch (error) {
          return;
        }
      },
      save: function (payload) {
        if (!payload) return;
        safeWrite({
          updatedAt: new Date().toISOString(),
          projectType: payload.projectType || '',
          projectContext: payload.projectContext || '',
          referenceSource: payload.referenceSource || '',
          projectRoute: payload.projectRoute || '',
          selectedBrief: payload.selectedBrief || '',
          selectedOptions: payload.selectedOptions || {},
          trigger: payload.trigger || ''
        });
      },
      fillModal: fillModal
    };
  })();
</script>
