{% liquid
  assign wardrobe_page_url = '/collections/wardrobe'
  assign kitchen_page_url = '/collections/kitchen-racks'
  assign wardrobe_calculator_url = '/collections/wardrobe#wardrobe-calculator'
  assign kitchen_calculator_url = '/collections/kitchen-racks#kitchen-calculator'
  assign interiors_calculator_url = '/pages/home-interiors-cost-calculator'
  assign wardrobe_design_url = '/pages/modular-wardrobe-designs'
  assign kitchen_design_url = '/pages/modular-kitchen-designs'
  assign estimate_url = '/pages/get-free-estimate'

  if pages['modular-wardrobe-designs'] != blank
    assign wardrobe_page_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['modular-kitchen-designs'] != blank
    assign kitchen_page_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign wardrobe_design_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['modular-kitchen-designs'] != blank
    assign kitchen_design_url = pages['modular-kitchen-designs'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif

  assign estimate_context_title = 'Project brief'
  assign estimate_context_copy = 'Share the basics first. We will use these details to understand whether you need a modular kitchen, wardrobe plan, or a broader interior discussion.'
%}

<style>
  .bw-estimate {
    display: grid;
    gap: 22px;
  }
  .bw-estimate__workflow {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-estimate__workflow-card {
    display: grid;
    gap: 10px;
    padding: 20px 22px;
    border-radius: 24px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.05);
  }
  .bw-estimate__workflow-step {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #6f584c;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-estimate__workflow-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
  }
  .bw-estimate__workflow-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-estimate__hero,
  .bw-estimate__form,
  .bw-estimate__info,
  .bw-estimate__journey {
    padding: 26px 28px;
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-estimate__hero {
    display: grid;
    gap: 16px;
    background:
      radial-gradient(circle at top right, rgba(79, 120, 143, 0.12), transparent 28%),
      linear-gradient(180deg, #fffaf6 0%, #f6ede5 100%);
  }
  .bw-estimate__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-estimate__title {
    margin: 0;
    color: #201713;
    font-size: clamp(32px, 4vw, 50px);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }
  .bw-estimate__copy {
    margin: 0;
    max-width: 72ch;
    color: #66554c;
    font-size: 15px;
    line-height: 1.85;
  }
  .bw-estimate__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 16px;
    align-items: stretch;
  }
  .bw-estimate__brief {
    display: grid;
    gap: 14px;
    align-content: start;
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.05);
  }
  .bw-estimate__brief-title {
    margin: 0;
    color: #201713;
    font-size: 18px;
    font-weight: 700;
  }
  .bw-estimate__brief-copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.8;
  }
  .bw-estimate__brief-list {
    display: grid;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .bw-estimate__brief-list li {
    position: relative;
    padding-left: 16px;
    color: #66554c;
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-estimate__brief-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #a66a43;
  }
  .bw-estimate__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-estimate__pill {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(32, 23, 19, 0.1);
    background: rgba(32, 23, 19, 0.04);
    color: #201713;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  .bw-estimate__pill--highlight {
    background: #201713;
    border-color: #201713;
    color: #fff7f1;
  }
  .bw-estimate__context {
    display: grid;
    gap: 10px;
    padding: 22px;
    border-radius: 24px;
    background: linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
  }
  .bw-estimate__context-label {
    display: inline-flex;
    width: fit-content;
    min-height: 32px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 247, 241, 0.08);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bw-estimate__context-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .bw-estimate__context-list li {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 247, 241, 0.12);
    color: rgba(255, 247, 241, 0.8);
    font-size: 13px;
    line-height: 1.6;
  }
  .bw-estimate__context-list li a {
    color: inherit;
    text-decoration: none;
  }
  .bw-estimate__context-list strong {
    color: #fff7f1;
    text-align: right;
    font-size: 13px;
  }
  .bw-estimate__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: 22px;
  }
  .bw-estimate__form,
  .bw-estimate__info {
    display: grid;
    gap: 18px;
  }
  .bw-estimate__head {
    display: grid;
    gap: 10px;
  }
  .bw-estimate__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-estimate__field {
    display: grid;
    gap: 8px;
  }
  .bw-estimate__field--full {
    grid-column: 1 / -1;
  }
  .bw-estimate__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .bw-estimate__field input,
  .bw-estimate__field select,
  .bw-estimate__field textarea {
    width: 100%;
    min-height: 50px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fffdfb;
    color: #201713;
    font-size: 14px;
  }
  .bw-estimate__field textarea {
    min-height: 140px;
    padding-top: 14px;
    padding-bottom: 14px;
    resize: vertical;
  }
  .bw-estimate__section {
    display: grid;
    gap: 12px;
  }
  .bw-estimate__section-title {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .bw-estimate__choices {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-estimate__choice {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    border: 1px solid transparent;
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-estimate__choice input {
    display: none;
  }
  .bw-estimate__choice.is-selected {
    background: #201713;
    color: #fff7f1;
    border-color: #201713;
  }
  .bw-estimate__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border: 0;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-estimate__helper {
    margin: 0;
    color: #6a5850;
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-estimate__list {
    display: grid;
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .bw-estimate__note {
    padding: 18px 18px 16px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-estimate__note strong {
    display: block;
    margin-bottom: 6px;
    color: #201713;
    font-size: 16px;
  }
  .bw-estimate__list li {
    padding: 16px 18px;
    border-radius: 20px;
    background: rgba(32, 23, 19, 0.04);
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-estimate__list strong {
    display: block;
    margin-bottom: 6px;
    color: #201713;
    font-size: 16px;
  }
  .bw-estimate__contact {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-estimate__contact a,
  .bw-estimate__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(32, 23, 19, 0.1);
    background: rgba(32, 23, 19, 0.04);
    color: #201713;
    text-decoration: none;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-estimate__contact a.is-primary,
  .bw-estimate__cta.is-primary {
    background: #201713;
    color: #fff7f1;
    border-color: #201713;
  }
  @media (max-width: 980px) {
    .bw-estimate__workflow,
    .bw-estimate__hero-grid,
    .bw-estimate__layout {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 720px) {
    .bw-estimate__hero,
    .bw-estimate__form,
    .bw-estimate__info,
    .bw-estimate__journey {
      padding: 22px 20px;
      border-radius: 24px;
    }
    .bw-estimate__grid {
      grid-template-columns: 1fr;
    }
    .bw-estimate__field--full {
      grid-column: auto;
    }
  }
</style>

<div class="bw-estimate">
  <section class="bw-estimate__hero">
    <span class="bw-estimate__eyebrow">{{ estimate_context_title }}</span>
    <h2 class="bw-estimate__title">Get Free Estimate</h2>
    <p class="bw-estimate__copy">{{ estimate_context_copy }}</p>

    <div class="bw-estimate__hero-grid">
      <div class="bw-estimate__brief">
        <p class="bw-estimate__brief-title">Choose the project direction first</p>
        <p class="bw-estimate__brief-copy">This estimate page works best when the customer already has a room type or layout in mind. Use the links below to keep the journey tight and consistent.</p>
        <ul class="bw-estimate__brief-list">
          <li>Pick a modular kitchen, wardrobe, or broader interiors route.</li>
          <li>Share the room context so the team can narrow scope faster.</li>
          <li>Move into the contact form once the brief feels ready.</li>
        </ul>
        <div class="bw-estimate__pills">
          <a class="bw-estimate__pill bw-estimate__pill--highlight" href="{{ kitchen_design_url }}">Modular Kitchen</a>
          <a class="bw-estimate__pill" href="{{ wardrobe_design_url }}">Modular Wardrobe</a>
          <a class="bw-estimate__pill" href="{{ interiors_calculator_url }}">Home Interiors</a>
        </div>
      </div>

      <div class="bw-estimate__context">
        <span class="bw-estimate__context-label">Conversion endpoint</span>
        <ul class="bw-estimate__context-list">
          <li><span>Kitchen route</span><strong><a class="bw-estimate__pill" href="{{ kitchen_calculator_url }}">Open calculator</a></strong></li>
          <li><span>Wardrobe route</span><strong><a class="bw-estimate__pill" href="{{ wardrobe_calculator_url }}">Open calculator</a></strong></li>
          <li><span>Interiors route</span><strong><a class="bw-estimate__pill" href="{{ interiors_calculator_url }}">Open calculator</a></strong></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bw-estimate__workflow" aria-label="Estimate workflow">
    <article class="bw-estimate__workflow-card">
      <span class="bw-estimate__workflow-step">1. Scope</span>
      <h3>Define the room or layout family</h3>
      <p>Tell us whether this is kitchen-led, wardrobe-led, or a bigger home interiors brief so the next response stays relevant.</p>
    </article>
    <article class="bw-estimate__workflow-card">
      <span class="bw-estimate__workflow-step">2. Context</span>
      <h3>Share city, timing, and budget posture</h3>
      <p>Those basics let Bluewud respond with a more grounded next step instead of a generic callback.</p>
    </article>
    <article class="bw-estimate__workflow-card">
      <span class="bw-estimate__workflow-step">3. Follow-up</span>
      <h3>Move into a clearer project conversation</h3>
      <p>Once the brief is captured, the team can discuss material direction, finish levels, and execution in a much cleaner way.</p>
    </article>
  </section>

  <div class="bw-estimate__layout">
    <section class="bw-estimate__form">
      <div class="bw-estimate__head">
        <span class="bw-estimate__eyebrow">Project brief</span>
        <h3 class="bw-estimate__section-title">Tell us what you are planning</h3>
        <p class="bw-estimate__copy">The more directly you map your requirements here, the faster the team can respond with a useful estimate direction instead of a generic callback.</p>
      </div>

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="bw-estimate__helper">Your request has been sent. The Bluewud team will review it and get back to you.</p>
        {% endif %}

        {{ form.errors | default_errors }}

        <input type="hidden" name="contact[estimate_type]" value="Bluewud Estimate Request">
        <input type="hidden" name="contact[project_context]" value="Modular planning brief">
        <input type="hidden" name="contact[selected_brief]" value="" data-bw-estimate-brief>

        <div class="bw-estimate__section" data-bw-estimate-type>
          <p class="bw-estimate__section-title">Project type</p>
          <div class="bw-estimate__choices">
            <label class="bw-estimate__choice is-selected"><input type="radio" name="contact[project_type]" value="Modular Kitchen" checked>Modular Kitchen</label>
            <label class="bw-estimate__choice"><input type="radio" name="contact[project_type]" value="Modular Wardrobe">Modular Wardrobe</label>
            <label class="bw-estimate__choice"><input type="radio" name="contact[project_type]" value="Home Interiors">Home Interiors</label>
            <label class="bw-estimate__choice"><input type="radio" name="contact[project_type]" value="Furniture + Interiors">Furniture + Interiors</label>
          </div>
        </div>

        <div class="bw-estimate__grid">
          <div class="bw-estimate__field">
            <label for="EstimateName">Full name</label>
            <input id="EstimateName" type="text" name="contact[name]" value="{{ form.name }}" required>
          </div>
          <div class="bw-estimate__field">
            <label for="EstimatePhone">Phone</label>
            <input id="EstimatePhone" type="tel" name="contact[phone]" value="{{ form.phone }}" required>
          </div>
          <div class="bw-estimate__field">
            <label for="EstimateEmail">Email</label>
            <input id="EstimateEmail" type="email" name="contact[email]" value="{{ form.email }}">
          </div>
          <div class="bw-estimate__field">
            <label for="EstimateCity">City</label>
            <input id="EstimateCity" type="text" name="contact[city]" required>
          </div>
          <div class="bw-estimate__field">
            <label for="EstimateBudget">Budget range</label>
            <select id="EstimateBudget" name="contact[budget_range]">
              <option>Under Rs. 1 lakh</option>
              <option>Rs. 1 lakh to Rs. 2 lakh</option>
              <option>Rs. 2 lakh to Rs. 4 lakh</option>
              <option>Rs. 4 lakh and above</option>
            </select>
          </div>
          <div class="bw-estimate__field">
            <label for="EstimateTimeline">Timeline</label>
            <select id="EstimateTimeline" name="contact[timeline]">
              <option>Just exploring</option>
              <option>Within 1 month</option>
              <option>Within 3 months</option>
              <option>Flexible / still planning</option>
            </select>
          </div>
          <div class="bw-estimate__field">
            <label for="EstimatePincode">Pincode</label>
            <input id="EstimatePincode" type="text" name="contact[pincode]">
          </div>
          <div class="bw-estimate__field">
            <label for="EstimateReference">Reference source</label>
            <select id="EstimateReference" name="contact[reference_source]">
              <option>Website planning page</option>
              <option>Kitchen calculator</option>
              <option>Wardrobe calculator</option>
              <option>Home interiors calculator</option>
            </select>
          </div>
          <div class="bw-estimate__field bw-estimate__field--full">
            <label for="EstimateMessage">Room size, preferred format, and notes</label>
            <textarea id="EstimateMessage" name="contact[body]" placeholder="Share wardrobe type, kitchen shape, approximate room size, finish direction, storage needs, or any reference links.">{{ form.body }}</textarea>
          </div>
        </div>

        <div style="margin-top:18px; display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
          <button class="bw-estimate__submit" type="submit">Request Estimate</button>
          <a class="bw-estimate__cta" href="{{ kitchen_calculator_url }}">Kitchen calculator</a>
          <a class="bw-estimate__cta" href="{{ wardrobe_calculator_url }}">Wardrobe calculator</a>
        </div>
        <p class="bw-estimate__helper">For faster routing, mention whether this is for a wardrobe, modular kitchen, or a larger interiors requirement.</p>
      {% endform %}
    </section>

    <aside class="bw-estimate__info">
      <div class="bw-estimate__head">
        <span class="bw-estimate__eyebrow">What happens next</span>
        <h3 class="bw-estimate__section-title">We use this page to shorten the planning cycle</h3>
        <p class="bw-estimate__copy">The faster we understand format, room size, city, and budget direction, the faster we can give you useful guidance instead of generic replies.</p>
      </div>

      <div class="bw-estimate__note">
        <strong>Best results come from a brief, not a guess.</strong>
        Mention the room type, likely layout, and any reference links you already like. That lets the Bluewud team start from something real.
      </div>

      <ul class="bw-estimate__list">
        <li><strong>1. Project triage</strong>We identify whether your requirement is wardrobe-led, kitchen-led, or a broader interiors conversation.</li>
        <li><strong>2. Estimate direction</strong>We use your budget, city, and scope details to frame the most relevant next step and price direction.</li>
        <li><strong>3. Deeper consultation</strong>If the project is viable, the next layer is material, finish, storage, and execution refinement with the Bluewud team.</li>
      </ul>

      <div class="bw-estimate__section">
        <p class="bw-estimate__section-title">Direct next steps</p>
        <div class="bw-estimate__contact">
          <a class="is-primary" href="{{ kitchen_design_url }}">Kitchen planning</a>
          <a href="{{ wardrobe_design_url }}">Wardrobe planning</a>
          <a href="{{ interiors_calculator_url }}">Interiors calculator</a>
          <a href="/pages/contact-us">Contact Bluewud</a>
          <a href="tel:+918800609609">Call +91-8800-609-609</a>
        </div>
      </div>
    </aside>
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('.bw-estimate');
    if (!root) return;
    var params = new URLSearchParams(window.location.search);
    var typeChoices = Array.prototype.slice.call(root.querySelectorAll('[data-bw-estimate-type] .bw-estimate__choice'));
    var referenceField = root.querySelector('#EstimateReference');
    var cityField = root.querySelector('#EstimateCity');
    var messageField = root.querySelector('#EstimateMessage');
    var hiddenBrief = root.querySelector('[data-bw-estimate-brief]');
    var timelineField = root.querySelector('#EstimateTimeline');
    var budgetField = root.querySelector('#EstimateBudget');

    function syncProjectType(targetChoice) {
      typeChoices.forEach(function (item) {
        item.classList.toggle('is-selected', item === targetChoice);
      });
    }

    function selectProjectType(project) {
      if (!project) return;
      var normalized = project.toLowerCase();
      var match = typeChoices.find(function (choice) {
        var input = choice.querySelector('input');
        return input && input.value.toLowerCase() === normalized;
      });
      if (!match) return;
      var input = match.querySelector('input');
      if (!input) return;
      input.checked = true;
      syncProjectType(match);
    }

    typeChoices.forEach(function (choice) {
      var input = choice.querySelector('input');
      if (!input) return;

      function sync() {
        syncProjectType(choice);
      }

      input.addEventListener('change', sync);
      choice.addEventListener('click', function () {
        input.checked = true;
        sync();
      });
    });

    selectProjectType(params.get('project'));

    if (referenceField && params.get('source')) {
      referenceField.value = params.get('source');
    }
    if (cityField && params.get('city')) {
      cityField.value = params.get('city');
    }
    if (timelineField && params.get('timeline')) {
      timelineField.value = params.get('timeline');
    }
    if (budgetField && params.get('budget')) {
      budgetField.value = params.get('budget');
    }
    if (messageField && params.get('summary')) {
      messageField.value = params.get('summary');
    }
    if (hiddenBrief && params.get('summary')) {
      hiddenBrief.value = params.get('summary');
    }
  })();
</script>
