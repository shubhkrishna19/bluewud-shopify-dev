<style>
  .bw-contact {
    display: grid;
    gap: 24px;
  }

  .bw-contact__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .bw-contact__card,
  .bw-contact__panel {
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-contact__card {
    padding: 22px;
    display: grid;
    gap: 10px;
  }

  .bw-contact__card-eyebrow {
    color: #8a684f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-contact__card-title {
    margin: 0;
    color: #201713;
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .bw-contact__card-copy {
    margin: 0;
    color: #64544a;
    font-size: 14px;
    line-height: 1.8;
  }

  .bw-contact__card-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-contact__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 24px;
  }

  .bw-contact__panel {
    padding: 28px;
  }

  .bw-contact__panel-header {
    display: grid;
    gap: 10px;
    margin-bottom: 22px;
  }

  .bw-contact__eyebrow {
    color: #8a684f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-contact__title {
    margin: 0;
    color: #201713;
    font-size: clamp(24px, 3vw, 34px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .bw-contact__copy {
    margin: 0;
    color: #64544a;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-contact__form {
    display: grid;
    gap: 16px;
  }

  .bw-contact__field {
    display: grid;
    gap: 8px;
  }

  .bw-contact__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .bw-contact__field input,
  .bw-contact__field textarea {
    width: 100%;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: rgba(255, 255, 255, 0.92);
    color: #201713;
    font-size: 14px;
    box-sizing: border-box;
  }

  .bw-contact__field textarea {
    min-height: 160px;
    resize: vertical;
  }

  .bw-contact__submit {
    width: fit-content;
    min-height: 48px;
    padding: 0 22px;
    border: 0;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-contact__message {
    padding: 14px 16px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-contact__message--success {
    background: rgba(60, 140, 83, 0.08);
    border: 1px solid rgba(60, 140, 83, 0.18);
    color: #225934;
  }

  .bw-contact__message--error {
    background: rgba(183, 79, 74, 0.08);
    border: 1px solid rgba(183, 79, 74, 0.18);
    color: #7b2f2a;
  }

  .bw-contact__info-grid {
    display: grid;
    gap: 16px;
  }

  .bw-contact__info-block {
    padding: 18px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    display: grid;
    gap: 8px;
  }

  .bw-contact__info-title {
    margin: 0;
    color: #201713;
    font-size: 17px;
  }

  .bw-contact__info-copy,
  .bw-contact__info-copy a {
    color: #64544a;
    font-size: 14px;
    line-height: 1.8;
    text-decoration: none;
  }

  .bw-contact__info-link {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bw-contact__support-list {
    margin: 0;
    padding-left: 18px;
    color: #64544a;
    font-size: 14px;
    line-height: 1.9;
  }

  @media (max-width: 980px) {
    .bw-contact__cards,
    .bw-contact__layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .bw-contact {
      gap: 18px;
    }

    .bw-contact__card,
    .bw-contact__panel {
      padding: 20px;
      border-radius: 24px;
    }
  }
</style>

<div class="bw-contact">
  <div class="bw-contact__cards">
    <article class="bw-contact__card">
      <span class="bw-contact__card-eyebrow">General support</span>
      <h2 class="bw-contact__card-title">Call or WhatsApp for quick help.</h2>
      <p class="bw-contact__card-copy">For any query, call or WhatsApp us at +91-8800-609-609. We are available between 09:00 AM and 06:00 PM on weekdays.</p>
      <a class="bw-contact__card-link" href="tel:+918800609609">Call +91-8800-609-609</a>
    </article>

    <article class="bw-contact__card">
      <span class="bw-contact__card-eyebrow">Installation support</span>
      <h2 class="bw-contact__card-title">Need installation guidance?</h2>
      <p class="bw-contact__card-copy">For installation support, call or WhatsApp us on the same support number so the Bluewud team can guide the next step quickly.</p>
      <a class="bw-contact__card-link" href="https://wa.me/918800609609">Open WhatsApp</a>
    </article>

    <article class="bw-contact__card">
      <span class="bw-contact__card-eyebrow">Email support</span>
      <h2 class="bw-contact__card-title">Prefer writing to us?</h2>
      <p class="bw-contact__card-copy">Mail us at care@bluewud.com for order follow-up, support questions, or anything that needs a written trail.</p>
      <a class="bw-contact__card-link" href="mailto:care@bluewud.com">Email Bluewud</a>
    </article>
  </div>

  <div class="bw-contact__layout">
    <section class="bw-contact__panel">
      <div class="bw-contact__panel-header">
        <span class="bw-contact__eyebrow">Send a message</span>
        <h2 class="bw-contact__title">Write to the Bluewud team directly.</h2>
        <p class="bw-contact__copy">Use this form for product questions, order follow-up, support requests, or business enquiries. The cleaner this page feels, the easier it is for customers to trust that help is close when they need it.</p>
      </div>

      {% form 'contact', id: 'BluewudContactForm', class: 'bw-contact__form' %}
        {% if form.posted_successfully? %}
          <div class="bw-contact__message bw-contact__message--success">Your message has been sent. The Bluewud team will get back to you soon.</div>
        {% endif %}

        {% if form.errors %}
          <div class="bw-contact__message bw-contact__message--error">{{ form.errors | default_errors }}</div>
        {% endif %}

        <div class="bw-contact__field">
          <label for="BluewudContactName">Name</label>
          <input id="BluewudContactName" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% endif %}" autocomplete="name">
        </div>

        <div class="bw-contact__field">
          <label for="BluewudContactEmail">Email</label>
          <input id="BluewudContactEmail" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% endif %}" autocomplete="email" required>
        </div>

        <div class="bw-contact__field">
          <label for="BluewudContactPhone">Phone Number</label>
          <input id="BluewudContactPhone" type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% endif %}" autocomplete="tel">
        </div>

        <div class="bw-contact__field">
          <label for="BluewudContactMessage">Message</label>
          <textarea id="BluewudContactMessage" name="contact[body]" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button class="bw-contact__submit" type="submit">Send message</button>
      {% endform %}
    </section>

    <aside class="bw-contact__panel">
      <div class="bw-contact__panel-header">
        <span class="bw-contact__eyebrow">Visit or reach us</span>
        <h2 class="bw-contact__title">Corporate details placed where customers expect them.</h2>
        <p class="bw-contact__copy">The live Bluewud contact information is now separated into clearer blocks so it reads like support infrastructure rather than a text dump.</p>
      </div>

      <div class="bw-contact__info-grid">
        <div class="bw-contact__info-block">
          <h3 class="bw-contact__info-title">Corporate Office Address</h3>
          <div class="bw-contact__info-copy">Bluewud Concepts Pvt. Ltd.<br>A-108, Sector 65<br>Noida, Uttar Pradesh 201301</div>
        </div>

        <div class="bw-contact__info-block">
          <h3 class="bw-contact__info-title">Support availability</h3>
          <div class="bw-contact__info-copy">Weekdays, 09:00 AM to 06:00 PM<br><a href="tel:+918800609609">+91-8800-609-609</a><br><a href="mailto:care@bluewud.com">care@bluewud.com</a></div>
        </div>

        <div class="bw-contact__info-block">
          <h3 class="bw-contact__info-title">What we can help with</h3>
          <ul class="bw-contact__support-list">
            <li>Order support and delivery follow-up</li>
            <li>Installation-related queries</li>
            <li>Product clarification before purchase</li>
            <li>Bulk and business requirements</li>
          </ul>
          <a class="bw-contact__info-link" href="/pages/help-center">Open help center</a>
        </div>
      </div>
    </aside>
  </div>
</div>
