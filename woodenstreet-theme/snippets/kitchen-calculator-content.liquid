{% liquid
  assign is_embedded = embedded | default: false
  assign contact_url = '/pages/contact-us'
  assign main_url = '/collections/kitchen-racks'
  assign l_url = '/collections/kitchen-racks#l-shape'
  assign u_url = '/collections/kitchen-racks#u-shape'
  assign parallel_url = '/collections/kitchen-racks#parallel'
  assign straight_url = '/collections/kitchen-racks#straight'
  assign island_url = '/collections/kitchen-racks#island'
  assign calculator_url = '/collections/kitchen-racks?planner=kitchen-calculator'
  assign estimate_url = contact_url
  assign kitchen_image_l_url = 'modular-kitchen-light-oak-l-shape.png' | asset_url
  assign kitchen_image_u_url = 'modular-kitchen-walnut-u-shape.png' | asset_url
  assign kitchen_image_parallel_url = 'modular-kitchen-galley-light-wood.png' | asset_url
  assign kitchen_image_straight_url = 'modular-kitchen-sage-u-shape.png' | asset_url
  assign kitchen_image_island_url = 'modular-kitchen-navy-luxury.png' | asset_url
  assign kitchen_collection = collections['kitchen-racks']
  assign kitchen_collection_image_url = kitchen_image_l_url
  assign kitchen_collection_image_alt = 'Bluewud modular kitchen reference'
  assign kitchen_collection_product_one = kitchen_collection.products.first
  assign kitchen_collection_product_two = kitchen_collection.products[1]
  assign kitchen_collection_product_three = kitchen_collection.products[2]
  assign kitchen_collection_product_four = kitchen_collection.products[3]
  assign kitchen_collection_product_one_image_url = kitchen_image_u_url
  assign kitchen_collection_product_one_image_alt = 'Bluewud modular kitchen reference'
  assign kitchen_collection_product_two_image_url = kitchen_image_parallel_url
  assign kitchen_collection_product_two_image_alt = 'Bluewud modular kitchen reference'
  assign kitchen_collection_product_three_image_url = kitchen_image_straight_url
  assign kitchen_collection_product_three_image_alt = 'Bluewud modular kitchen reference'
  assign kitchen_collection_product_four_image_url = kitchen_image_island_url
  assign kitchen_collection_product_four_image_alt = 'Bluewud modular kitchen reference'
  if kitchen_collection != blank
    if kitchen_collection.image != blank
      assign kitchen_collection_image_url = kitchen_collection.image | image_url: width: 900
      assign kitchen_collection_image_alt = kitchen_collection.title | default: 'Bluewud modular kitchen'
    endif
    if kitchen_collection_product_one != blank and kitchen_collection_product_one.featured_image != blank
      assign kitchen_collection_product_one_image_url = kitchen_collection_product_one.featured_image | image_url: width: 900
      assign kitchen_collection_product_one_image_alt = kitchen_collection_product_one.title | default: 'Bluewud kitchen reference'
    endif
    if kitchen_collection_product_two != blank and kitchen_collection_product_two.featured_image != blank
      assign kitchen_collection_product_two_image_url = kitchen_collection_product_two.featured_image | image_url: width: 900
      assign kitchen_collection_product_two_image_alt = kitchen_collection_product_two.title | default: 'Bluewud kitchen reference'
    endif
    if kitchen_collection_product_three != blank and kitchen_collection_product_three.featured_image != blank
      assign kitchen_collection_product_three_image_url = kitchen_collection_product_three.featured_image | image_url: width: 900
      assign kitchen_collection_product_three_image_alt = kitchen_collection_product_three.title | default: 'Bluewud kitchen reference'
    endif
    if kitchen_collection_product_four != blank and kitchen_collection_product_four.featured_image != blank
      assign kitchen_collection_product_four_image_url = kitchen_collection_product_four.featured_image | image_url: width: 900
      assign kitchen_collection_product_four_image_alt = kitchen_collection_product_four.title | default: 'Bluewud kitchen reference'
    endif
  endif
  assign kitchen_image_property_apartment_url = kitchen_image_l_url
  assign kitchen_image_property_villa_url = kitchen_collection_image_url
  assign kitchen_image_property_floor_url = kitchen_collection_product_one_image_url
  assign kitchen_image_property_rental_url = kitchen_collection_product_two_image_url
  assign kitchen_image_usage_light_url = kitchen_image_parallel_url
  assign kitchen_image_usage_daily_url = kitchen_collection_image_url
  assign kitchen_image_usage_heavy_url = kitchen_collection_product_four_image_url
  assign kitchen_image_upper_yes_url = kitchen_collection_image_url
  assign kitchen_image_upper_selected_url = kitchen_collection_product_one_image_url
  assign kitchen_image_upper_no_url = kitchen_collection_product_two_image_url
  assign kitchen_image_carcass_engineered_url = kitchen_collection_product_one_image_url
  assign kitchen_image_carcass_plywood_url = kitchen_collection_product_three_image_url
  assign kitchen_image_carcass_guidance_url = kitchen_collection_image_url
  assign kitchen_image_shutter_laminate_url = kitchen_image_straight_url
  assign kitchen_image_shutter_acrylic_url = kitchen_collection_product_two_image_url
  assign kitchen_image_shutter_membrane_url = kitchen_image_parallel_url
  assign kitchen_image_shutter_glass_url = kitchen_collection_product_four_image_url
  assign kitchen_image_countertop_granite_url = kitchen_collection_image_url
  assign kitchen_image_countertop_quartz_url = kitchen_collection_product_one_image_url
  assign kitchen_image_countertop_stone_url = kitchen_collection_product_four_image_url

  if pages['modular-kitchen-designs'] != blank
    assign main_url = pages['modular-kitchen-designs'].url
    assign l_url = main_url | append: '#l-shape'
    assign u_url = main_url | append: '#u-shape'
    assign parallel_url = main_url | append: '#parallel'
    assign straight_url = main_url | append: '#straight'
    assign island_url = main_url | append: '#island'
  endif
  if pages['l-shape-modular-kitchen-design'] != blank
    assign l_url = pages['l-shape-modular-kitchen-design'].url
  endif
  if pages['u-shape-modular-kitchen-design'] != blank
    assign u_url = pages['u-shape-modular-kitchen-design'].url
  endif
  if pages['parallel-modular-kitchen-design'] != blank
    assign parallel_url = pages['parallel-modular-kitchen-design'].url
  endif
  if pages['straight-modular-kitchen'] != blank
    assign straight_url = pages['straight-modular-kitchen'].url
  endif
  if pages['kitchen-island-design'] != blank
    assign island_url = pages['kitchen-island-design'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
  if pages['get-free-estimate'] == blank and pages['contact-us'] != blank
    assign estimate_url = pages['contact-us'].url
  endif
%}

<style>
  .bw-flow { display: grid; gap: 22px; }
  .bw-flow__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 20px;
  }
  .bw-flow__panel,
  .bw-flow__summary {
    padding: 26px 28px;
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__summary {
    position: sticky;
    top: 92px;
    background: linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
    height: fit-content;
    max-height: calc(100vh - 160px);
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
  }
  .bw-flow__summary-visual {
    min-height: 132px;
    margin-bottom: 10px;
    border-radius: 24px;
    overflow: hidden;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,247,241,0.1);
  }
  .bw-flow__summary-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__summary-caption {
    margin: -2px 0 10px;
    color: rgba(255, 247, 241, 0.72);
    font-size: 12px;
    line-height: 1.6;
  }
  .bw-flow__summary-cues {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-bottom: 12px;
  }
  .bw-flow__summary-cue {
    display: grid;
    gap: 4px;
    padding: 10px 12px;
    border-radius: 18px;
    background: rgba(255, 247, 241, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.12);
  }
  .bw-flow__summary-cue span {
    color: rgba(255, 247, 241, 0.66);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-flow__summary-cue strong {
    color: #fff7f1;
    font-size: 13px;
    line-height: 1.45;
  }
  .bw-flow__head { display: grid; gap: 10px; margin-bottom: 18px; }
  .bw-flow__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-flow__summary .bw-flow__eyebrow,
  .bw-flow__summary .bw-flow__title,
  .bw-flow__summary .bw-flow__copy { color: inherit; }
  .bw-flow__title {
    margin: 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }
  .bw-flow__copy {
    margin: 0;
    max-width: 62ch;
    color: #66554c;
    font-size: 15px;
    line-height: 1.8;
  }
  .bw-flow__journey {
    display: grid;
    gap: 12px;
    margin-bottom: 22px;
    padding: 18px;
    border-radius: 24px;
    background: linear-gradient(180deg, #fffaf6 0%, #f7efe7 100%);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }
  .bw-flow__journey-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-flow__journey-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
    margin-top: 4px;
  }
  .bw-flow__journey-card {
    display: grid;
    gap: 10px;
    padding: 12px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(32, 23, 19, 0.08);
    text-decoration: none;
    color: inherit;
  }
  .bw-flow__journey-card-media {
    display: block;
    overflow: hidden;
    border-radius: 16px;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-flow__journey-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__journey-card-title {
    margin: 0;
    color: #201713;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
  }
  .bw-flow__journey-card-copy {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.6;
  }
  .bw-flow__progress {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 20px;
  }
  .bw-flow__step {
    display: grid;
    gap: 6px;
    padding: 14px;
    border-radius: 20px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid transparent;
  }
  .bw-flow__step.is-active {
    background: rgba(79, 120, 143, 0.12);
    border-color: rgba(79, 120, 143, 0.22);
  }
  .bw-flow__step.is-complete { background: rgba(32, 23, 19, 0.08); }
  .bw-flow__step-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }
  .bw-flow__step-label {
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-flow__stage { display: none; gap: 16px; }
  .bw-flow__stage.is-active { display: grid; }
  .bw-flow__stage-head { display: grid; gap: 8px; }
  .bw-flow__stage-title {
    margin: 0;
    color: #201713;
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }
  .bw-flow__stage-copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-flow__section { display: grid; gap: 12px; }
  .bw-flow__decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .bw-flow__decision-card {
    display: grid;
    gap: 10px;
    padding: 12px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(32, 23, 19, 0.08);
  }
  .bw-flow__decision-media {
    display: block;
    overflow: hidden;
    border-radius: 16px;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-flow__decision-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__decision-card strong {
    color: #201713;
    font-size: 15px;
    line-height: 1.2;
  }
  .bw-flow__decision-card p {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.6;
  }
  .bw-flow__label {
    color: #201713;
    font-size: 16px;
    font-weight: 700;
  }
  .bw-flow__choices {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 10px;
  }
  .bw-flow__choice {
    display: grid;
    align-content: start;
    gap: 6px;
    min-height: 72px;
    padding: 14px 16px;
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 251, 247, 0.94));
    border: 1px solid rgba(32, 23, 19, 0.08);
    box-shadow: 0 12px 26px rgba(35, 24, 19, 0.05);
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: left;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }
  .bw-flow__choice input { display: none; }
  .bw-flow__choice.is-selected {
    background:
      linear-gradient(180deg, #241814 0%, #3a2921 100%);
    color: #fff7f1;
    border-color: #241814;
    box-shadow: 0 16px 34px rgba(35, 24, 19, 0.16);
  }
  .bw-flow__choice:hover,
  .bw-flow__choice:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(32, 23, 19, 0.16);
    box-shadow: 0 16px 32px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__choices[data-flow-group="layout"],
  .bw-flow__choices[data-flow-group="property"],
  .bw-flow__choices[data-flow-group="usage"],
  .bw-flow__choices[data-flow-group="uppers"],
  .bw-flow__choices[data-flow-group="carcass"],
  .bw-flow__choices[data-flow-group="shutter"],
  .bw-flow__choices[data-flow-group="countertop"],
  .bw-flow__choices[data-flow-group="appliances"] {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .bw-flow__choices[data-flow-group="addons"] {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }
  .bw-flow__choices[data-flow-group="layout"] {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }
  .bw-flow__choice--visual {
    gap: 10px;
    padding: 10px;
    min-height: 0;
    letter-spacing: 0;
    text-transform: none;
  }
  .bw-flow__choice--context {
    gap: 12px;
    padding: 12px;
    min-height: 0;
    letter-spacing: 0;
    text-transform: none;
  }
  .bw-flow__choice-media {
    min-height: 128px;
    border-radius: 16px;
    overflow: hidden;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-flow__choice-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__choice-copy {
    display: grid;
    gap: 4px;
    align-content: start;
  }
  .bw-flow__choice--context .bw-flow__choice-media {
    min-height: 124px;
    border-radius: 16px;
  }
  .bw-flow__choice--context .bw-flow__choice-title {
    font-size: 16px;
    line-height: 1.18;
  }
  .bw-flow__choice--context .bw-flow__choice-note {
    font-size: 12px;
    line-height: 1.55;
  }
  .bw-flow__section-note {
    margin: -4px 0 0;
    color: #7a655a;
    font-size: 12px;
    line-height: 1.6;
  }
  .bw-flow__choice-title {
    color: inherit;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
  }
  .bw-flow__choice-note {
    color: #66554c;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.55;
    text-transform: none;
  }
  .bw-flow__choice.is-selected .bw-flow__choice-note {
    color: rgba(255, 247, 241, 0.84);
  }
  .bw-flow__utility-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-flow__utility-card {
    display: grid;
    gap: 14px;
    padding: 14px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.03);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }
  .bw-flow__utility-media {
    min-height: 148px;
    border-radius: 18px;
    overflow: hidden;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-flow__utility-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__utility-title {
    margin: 0;
    color: #201713;
    font-size: 16px;
    font-weight: 800;
    line-height: 1.25;
  }
  .bw-flow__utility-copy {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-flow__utility-choices {
    display: grid;
    gap: 10px;
  }
  .bw-flow__utility-choices .bw-flow__choice {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    min-height: 0;
    padding: 10px 12px;
    border-radius: 18px;
    text-transform: none;
    letter-spacing: 0;
  }
  .bw-flow__utility-choices .bw-flow__choice-media {
    min-height: 80px;
    border-radius: 14px;
  }
  .bw-flow__utility-choices .bw-flow__choice-copy {
    gap: 3px;
  }
  .bw-flow__utility-choices .bw-flow__choice-title {
    font-size: 13px;
    line-height: 1.2;
  }
  .bw-flow__utility-choices .bw-flow__choice-note {
    font-size: 11px;
    line-height: 1.45;
  }
  .bw-flow__utility-choices .bw-flow__choice.is-selected {
    box-shadow: 0 18px 32px rgba(35, 24, 19, 0.12);
  }
  .bw-flow__utility-choices .bw-flow__choice.is-selected .bw-flow__choice-media img {
    transform: scale(1.02);
    transition: transform 0.18s ease;
  }
  .bw-flow__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-flow__field {
    display: grid;
    gap: 8px;
  }
  .bw-flow__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
  }
  .bw-flow__field input,
  .bw-flow__field select {
    width: 100%;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fffdfb;
    color: #201713;
    font-size: 14px;
  }
  .bw-flow__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 6px;
  }
  .bw-flow__button,
  .bw-flow__button--secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-flow__button {
    border: 0;
    background: #201713;
    color: #fff7f1;
  }
  .bw-flow__button--secondary {
    border: 1px solid rgba(32, 23, 19, 0.14);
    background: rgba(32, 23, 19, 0.04);
    color: #201713;
  }
  .bw-flow__summary .bw-flow__button--secondary {
    border-color: rgba(255, 247, 241, 0.26);
    background: rgba(255, 247, 241, 0.14);
    color: #fff7f1;
  }
  .bw-flow__summary .bw-flow__button--secondary:hover,
  .bw-flow__summary .bw-flow__button--secondary:focus-visible {
    background: rgba(255, 247, 241, 0.22);
    border-color: rgba(255, 247, 241, 0.38);
  }
  .bw-flow__summary-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px 14px;
    margin-top: 16px;
  }
  .bw-flow__summary-line:nth-child(n + 5) {
    display: none;
  }
  .bw-flow__summary-line {
    display: grid;
    gap: 4px;
    align-content: start;
    min-width: 0;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 247, 241, 0.12);
    color: rgba(255, 247, 241, 0.88);
    font-size: 14px;
  }
  .bw-flow__summary-line strong {
    color: #fff7f1;
    text-align: left;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .bw-flow__summary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .bw-flow__summary-tag {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 247, 241, 0.12);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .bw-flow__badge {
