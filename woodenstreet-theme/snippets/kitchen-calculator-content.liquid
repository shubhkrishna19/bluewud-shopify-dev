{% render 'modular-estimate-popup', modal_id: 'bw-kitchen-calc-popup', modal_title: 'Get a kitchen estimate', context_label: 'Bluewud modular kitchen' %}

<script>
  (function () {
    var root = document.querySelector('[data-bw-kitchen-flow]');
    if (!root) return;
    var step = 1;
    var maxStep = 5;
    var hasInteracted = false;
    var stageNodes = Array.prototype.slice.call(root.querySelectorAll('[data-step-panel]'));
    var indicatorNodes = Array.prototype.slice.call(root.querySelectorAll('[data-step-indicator]'));
    var modal = document.getElementById('bw-kitchen-calc-popup');
    var summaryText = modal ? modal.querySelector('[data-bw-estimate-summary-text]') : null;
    var summaryInput = modal ? modal.querySelector('[data-bw-estimate-summary-input]') : null;
    var contextInput = modal ? modal.querySelector('[data-bw-estimate-context-input]') : null;
    var sourceInput = modal ? modal.querySelector('[data-bw-estimate-source-input]') : null;
    var bandNode = root.querySelector('[data-kitchen-band]');
    var summaryImageNode = root.querySelector('[data-kitchen-summary-image]');
    var summaryCaptionNode = root.querySelector('[data-kitchen-summary-caption]');
    var layoutVisualMap = {
      'L-shape': {
        src: {{ kitchen_image_l_url | json }},
        alt: 'Bluewud L-shape modular kitchen preview',
        caption: 'L-shape keeps the room efficient without making the kitchen feel heavy.'
      },
      'U-shape': {
        src: {{ kitchen_image_u_url | json }},
        alt: 'Bluewud U-shape modular kitchen preview',
        caption: 'U-shape adds stronger storage and prep depth for more serious daily cooking.'
      },
      'Parallel': {
        src: {{ kitchen_image_parallel_url | json }},
        alt: 'Bluewud parallel modular kitchen preview',
        caption: 'Parallel layouts work well when two clean runs need to carry the kitchen efficiently.'
      },
      'Straight': {
        src: {{ kitchen_image_straight_url | json }},
        alt: 'Bluewud straight modular kitchen preview',
        caption: 'Straight kitchens suit compact homes that need one disciplined, visually calm run.'
      },
      'Island': {
        src: {{ kitchen_image_island_url | json }},
        alt: 'Bluewud island modular kitchen preview',
        caption: 'Island planning is strongest when prep, hosting, and movement all matter together.'
      }
    };

    function selectedRadio(name) {
      var node = root.querySelector('input[name="' + name + '"]:checked');
      return node ? node.value : '';
    }
    function setRadioValue(name, value) {
      var node = root.querySelector('input[name="' + name + '"][value="' + value + '"]');
      if (node) node.checked = true;
    }
    function normalizeLayout(layout) {
      if (!layout) return '';
      var key = String(layout).toLowerCase();
      if (key === 'all') return 'L-shape';
      if (key === 'l-shape' || key === 'l shape') return 'L-shape';
      if (key === 'u-shape' || key === 'u shape') return 'U-shape';
      if (key === 'parallel') return 'Parallel';
      if (key === 'straight') return 'Straight';
      if (key === 'island') return 'Island';
      return '';
    }
    function selectedChecks(group) {
      return Array.prototype.slice.call(root.querySelectorAll('[data-flow-group="' + group + '"] input[type="checkbox"]:checked')).map(function (input) {
        return input.value;
      });
    }
    function selectedAppliances() {
      var appliances = selectedChecks('appliances');
      return appliances.length ? appliances.join(', ') : 'Not specified';
    }
    function setCheckboxValues(group, values) {
      var valueMap = Array.isArray(values) ? values : [];
      root.querySelectorAll('[data-flow-group="' + group + '"] input[type="checkbox"]').forEach(function (input) {
        input.checked = valueMap.indexOf(input.value) > -1;
      });
    }
    function inputValue(key) {
      var node = root.querySelector('[data-flow-input="' + key + '"]');
      return node ? node.value : '';
    }
    function toggleChoiceStates() {
      root.querySelectorAll('.bw-flow__choice').forEach(function (choice) {
        var input = choice.querySelector('input');
        if (!input) return;
        choice.classList.toggle('is-selected', !!input.checked);
      });
    }
    function markInteracted() {
      hasInteracted = true;
    }
    function projectBand() {
      var premiumSignals = 0;
      if (selectedRadio('kitchen_layout') === 'Island') premiumSignals += 2;
      if (selectedRadio('carcass_material') === 'Plywood') premiumSignals += 1;
      if (selectedRadio('shutter_material') === 'Glass / premium') premiumSignals += 2;
      if (selectedRadio('countertop') === 'Premium stone') premiumSignals += 2;
      premiumSignals += selectedChecks('addons').length;
      if (premiumSignals >= 5) return 'Statement premium direction';
      if (premiumSignals >= 3) return 'Balanced premium direction';
      return 'Value-led practical direction';
    }
    function finishCue() {
      var shutter = selectedRadio('shutter_material');
      var countertop = selectedRadio('countertop');
      if (shutter === 'Glass / premium' || countertop === 'Premium stone') return 'Statement premium finish';
      if (shutter === 'Acrylic front' || countertop === 'Quartz') return 'Sharper modern finish';
      if (shutter === 'Membrane / profile') return 'Soft profile-led finish';
      return 'Warm laminate-led balance';
    }
    function storageCue() {
      var addons = selectedChecks('addons');
      var uppers = selectedRadio('upper_cabinets');
      if (addons.length >= 4) return 'Storage-heavy utility brief';
      if (uppers === 'Only on selected walls') return 'Open + closed balance';
      if (uppers === 'No') return 'Lighter visual line';
      return 'Balanced everyday storage';
    }
    function applianceCue() {
      var appliances = selectedChecks('appliances');
      if (appliances.length >= 4) return 'High-integration appliance plan';
      if (appliances.length >= 2) return 'Core appliance-ready setup';
      if (appliances.length === 1) return appliances[0] + ' integration';
      return 'Appliance plan to be defined';
    }
    function updateSummary() {
      toggleChoiceStates();
      var neutralState = !hasInteracted;
      var layout = selectedRadio('kitchen_layout');
      var property = selectedRadio('property_type');
      var usage = selectedRadio('usage_level');
      var wallA = inputValue('wall_a') || '0';
      var wallB = inputValue('wall_b') || '0';
      var wallC = inputValue('wall_c') || '0';
      var summaryMap = neutralState ? {
        layout: 'Choose a layout',
        property: 'Add property type',
        measurements: 'Enter wall lengths',
        build: 'Pick materials and finish',
        utility: 'Set storage needs',
        appliances: 'Add appliances or leave blank'
      } : {
        layout: layout || 'L-shape',
        property: property ? property + ' � ' + usage : 'Apartment � Daily family use',
        measurements: [wallA + ' ft', wallB + ' ft', wallC + ' ft'].join(' / '),
        build: [selectedRadio('carcass_material'), selectedRadio('shutter_material'), selectedRadio('countertop')].filter(Boolean).join(' / ') || 'Engineered wood / Laminate front / Granite',
        utility: selectedChecks('addons').length ? selectedChecks('addons').slice(0, 3).join(', ') : 'Core cabinetry only',
        appliances: selectedAppliances()
      };
      Object.keys(summaryMap).forEach(function (key) {
        var node = root.querySelector('[data-summary-' + key + ']');
        if (node) node.textContent = summaryMap[key];
      });
      var layoutVisual = layoutVisualMap[neutralState ? 'L-shape' : (summaryMap.layout || 'L-shape')] || layoutVisualMap['L-shape'];
      if (summaryImageNode && layoutVisual) {
        summaryImageNode.src = layoutVisual.src;
        summaryImageNode.alt = layoutVisual.alt;
      }
      if (summaryCaptionNode) {
        summaryCaptionNode.textContent = neutralState ? 'Start with the layout choice. The rest of the brief stays neutral until you make selections.' : layoutVisual.caption;
      }
      var finishCueNode = root.querySelector('[data-summary-finish-cue]');
      var storageCueNode = root.querySelector('[data-summary-storage-cue]');
      var applianceCueNode = root.querySelector('[data-summary-appliance-cue]');
      if (finishCueNode) finishCueNode.textContent = neutralState ? 'Choose a finish direction' : finishCue();
      if (storageCueNode) storageCueNode.textContent = neutralState ? 'Set the storage need' : storageCue();
      if (applianceCueNode) applianceCueNode.textContent = neutralState ? 'Select appliance integrations' : applianceCue();
      if (bandNode) bandNode.textContent = neutralState ? 'Ready for your brief' : projectBand();
      var tagsNode = root.querySelector('[data-summary-tags]');
      if (tagsNode) {
        var tags = neutralState ? [] : [
          summaryMap.layout,
          summaryMap.property,
          summaryMap.build.split(' / ')[1] || selectedRadio('countertop'),
          summaryMap.utility,
          summaryMap.appliances
        ].filter(Boolean).slice(0, 5);
        tagsNode.innerHTML = tags.length ? tags
          .map(function (item) { return '<span class="bw-flow__summary-tag">' + item + '</span>'; })
          .join('') : '';
      }
      persistPayload('calculator-progress');
    }
    function briefSummary() {
      return [
        'Project: Modular Kitchen',
        'Layout: ' + selectedRadio('kitchen_layout'),
        'Property: ' + selectedRadio('property_type'),
        'Usage: ' + selectedRadio('usage_level'),
        'Wall lengths: ' + inputValue('wall_a') + 'ft / ' + inputValue('wall_b') + 'ft / ' + inputValue('wall_c') + 'ft',
        'Ceiling: ' + inputValue('ceiling') + 'ft',
        'Upper cabinets: ' + selectedRadio('upper_cabinets'),
        'Carcass: ' + selectedRadio('carcass_material'),
        'Shutter: ' + selectedRadio('shutter_material'),
        'Countertop: ' + selectedRadio('countertop'),
        'Add-ons: ' + (selectedChecks('addons').length ? selectedChecks('addons').join(', ') : 'None'),
        'Appliances: ' + selectedAppliances(),
        'City: ' + (inputValue('city') || 'Not shared yet'),
        'Timeline: ' + (inputValue('timeline') || 'Immediate'),
        'Direction: ' + projectBand()
      ].join(' | ');
    }
    function buildPayload(trigger) {
      return {
        projectType: 'Modular Kitchen',
        projectContext: 'Bluewud modular kitchen',
        referenceSource: 'Kitchen calculator',
        projectRoute: window.location.pathname + window.location.search,
        selectedBrief: briefSummary(),
        selectedOptions: {
          layout: selectedRadio('kitchen_layout'),
          property_type: selectedRadio('property_type'),
          usage_level: selectedRadio('usage_level'),
          wall_a_ft: inputValue('wall_a'),
          wall_b_ft: inputValue('wall_b'),
          wall_c_ft: inputValue('wall_c'),
          ceiling_ft: inputValue('ceiling'),
          upper_cabinets: selectedRadio('upper_cabinets'),
          carcass_material: selectedRadio('carcass_material'),
          shutter_material: selectedRadio('shutter_material'),
          countertop: selectedRadio('countertop'),
          addons: selectedChecks('addons'),
          appliances: selectedChecks('appliances'),
          city: inputValue('city'),
          timeline: inputValue('timeline') || 'Immediate',
          project_direction: projectBand(),
          source_trigger: trigger || 'calculator-progress'
        },
        trigger: trigger || 'calculator-progress'
      };
    }
    function persistPayload(trigger) {
      var payload = buildPayload(trigger);
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.save(payload);
      }
      return payload;
    }
    function applyLayoutPreset(layout) {
      var normalized = normalizeLayout(layout);
      if (!normalized) return;
      setRadioValue('kitchen_layout', normalized);
      step = 1;
      updateSummary();
      paintSteps();
    }
    function applyDirectionPreset(direction) {
      if (!direction) return;
      var presets = {
        'everyday-family': {
          layout: 'L-shape',
          property: 'Apartment',
          usage: 'Daily family use',
          uppers: 'Yes',
          carcass: 'Engineered wood',
          shutter: 'Laminate front',
          countertop: 'Granite',
          addons: ['Tandem drawers'],
          appliances: ['Hob', 'Chimney']
        },
        'storage-heavy': {
          layout: 'U-shape',
          property: 'Apartment',
          usage: 'Heavy cooking',
          uppers: 'Yes',
          carcass: 'Engineered wood',
          shutter: 'Laminate front',
          countertop: 'Granite',
          addons: ['Tall unit', 'Pantry pull-out', 'Tandem drawers'],
          appliances: ['Hob', 'Chimney', 'Microwave']
        },
        'clean-modern': {
          layout: 'Parallel',
          property: 'Apartment',
          usage: 'Daily family use',
          uppers: 'Only on selected walls',
          carcass: 'Plywood',
          shutter: 'Acrylic front',
          countertop: 'Quartz',
          addons: ['Premium hardware', 'Refrigerator housing'],
          appliances: ['Hob', 'Chimney', 'Water purifier provision']
        },
        'hosting-premium': {
          layout: 'Island',
          property: 'Villa',
          usage: 'Heavy cooking',
          uppers: 'Yes',
          carcass: 'Plywood',
          shutter: 'Glass / premium',
          countertop: 'Premium stone',
          addons: ['Tall unit', 'Premium hardware', 'Appliance tower'],
          appliances: ['Hob', 'Chimney', 'Built-in oven', 'Dishwasher']
        }
      };
      var preset = presets[direction];
      if (!preset) return;
      setRadioValue('kitchen_layout', preset.layout);
      setRadioValue('property_type', preset.property);
      setRadioValue('usage_level', preset.usage);
      setRadioValue('upper_cabinets', preset.uppers);
      setRadioValue('carcass_material', preset.carcass);
      setRadioValue('shutter_material', preset.shutter);
      setRadioValue('countertop', preset.countertop);
      setCheckboxValues('addons', preset.addons);
      setCheckboxValues('appliances', preset.appliances);
      step = 3;
      updateSummary();
      paintSteps();
      root.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    function paintSteps() {
      stageNodes.forEach(function (panel) {
        panel.classList.toggle('is-active', Number(panel.getAttribute('data-step-panel')) === step);
      });
      indicatorNodes.forEach(function (indicator) {
        var indicatorStep = Number(indicator.getAttribute('data-step-indicator'));
        indicator.classList.toggle('is-active', indicatorStep === step);
        indicator.classList.toggle('is-complete', indicatorStep < step);
      });
    }
    function openPopup() {
      if (!modal) return;
      var payload = persistPayload('calculator-submit');
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.fillModal(modal, payload);
      } else {
        if (summaryText) summaryText.textContent = payload.selectedBrief;
        if (summaryInput) summaryInput.value = payload.selectedBrief;
        if (contextInput) contextInput.value = payload.projectContext;
        if (sourceInput) sourceInput.value = payload.referenceSource;
      }
      modal.classList.add('is-open');
      document.body.classList.add('bw-header-drawer-open');
    }
    function closePopup() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('bw-header-drawer-open');
    }

    root.addEventListener('click', function (event) {
      var choice = event.target.closest('.bw-flow__choice');
      if (choice) {
        var input = choice.querySelector('input');
        if (input) {
          if (input.type === 'checkbox') input.checked = !input.checked;
          else input.checked = true;
          updateSummary();
        }
        return;
      }
      if (event.target.closest('[data-flow-next]')) {
        if (step < maxStep) step += 1;
        paintSteps();
        return;
      }
      if (event.target.closest('[data-flow-back]')) {
        if (step > 1) step -= 1;
        paintSteps();
        return;
      }
      if (event.target.closest('[data-bw-kitchen-popup-open]')) {
        openPopup();
        return;
      }
      var directionCard = event.target.closest('[data-kitchen-direction]');
      if (directionCard) {
        applyDirectionPreset(directionCard.getAttribute('data-kitchen-direction'));
      }
    });

    root.addEventListener('change', function () {
      markInteracted();
      updateSummary();
    });
    root.addEventListener('input', function () {
      markInteracted();
      updateSummary();
    });
    root.addEventListener('bw:kitchen-layout-select', function (event) {
      if (event.detail && event.detail.layout) {
        applyLayoutPreset(event.detail.layout);
      }
    });

    if (modal) {
      modal.querySelectorAll('[data-bw-estimate-close]').forEach(function (control) {
        control.addEventListener('click', closePopup);
      });
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closePopup();
      });
    }

    updateSummary();
    var params = new URLSearchParams(window.location.search);
    applyLayoutPreset(params.get('layout'));
    paintSteps();
  })();
</script>
