<style>
  .bw-help-center {
    display: grid;
    gap: 26px;
  }

  .bw-help-center__hero {
    display: grid;
    gap: 12px;
  }

  .bw-help-center__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-help-center__title {
    margin: 0;
    color: #201713;
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }

  .bw-help-center__intro {
    margin: 0;
    max-width: 72ch;
    color: #64544a;
    font-size: 16px;
    line-height: 1.8;
  }

  .bw-help-center__cards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .bw-help-center__card {
    position: relative;
    display: grid;
    gap: 10px;
    padding: 18px;
    border-radius: 24px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    background:
      radial-gradient(circle at top left, rgba(53, 90, 109, 0.08), transparent 45%),
      rgba(255, 255, 255, 0.94);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.06);
    cursor: pointer;
    text-align: left;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .bw-help-center__card:hover,
  .bw-help-center__card.is-active {
    transform: translateY(-2px);
    border-color: rgba(53, 90, 109, 0.24);
    box-shadow: 0 24px 58px rgba(35, 24, 19, 0.1);
  }

  .bw-help-center__card-kicker {
    color: #8a684f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-help-center__card-title {
    margin: 0;
    color: #201713;
    font-size: 19px;
    line-height: 1.16;
    letter-spacing: -0.02em;
  }

  .bw-help-center__card-copy {
    margin: 0;
    color: #64544a;
    font-size: 13px;
    line-height: 1.65;
  }

  .bw-help-center__card-meta {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-help-center__panel {
    display: none;
    gap: 18px;
    padding: 26px;
    border-radius: 30px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    background: rgba(255, 251, 247, 0.96);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-help-center__panel.is-active {
    display: grid;
  }

  .bw-help-center__panel-header {
    display: grid;
    gap: 8px;
  }

  .bw-help-center__panel-eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-help-center__panel-title {
    margin: 0;
    color: #201713;
    font-size: clamp(26px, 3.5vw, 38px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .bw-help-center__panel-copy {
    margin: 0;
    max-width: 72ch;
    color: #64544a;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-help-center__faq {
    display: grid;
    gap: 12px;
  }

  .bw-help-center__faq-item {
    border-radius: 20px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    background: #fff;
    overflow: hidden;
  }

  .bw-help-center__faq-question {
    width: 100%;
    border: 0;
    background: transparent;
    text-align: left;
    padding: 18px 20px;
    color: #201713;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.35;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .bw-help-center__faq-icon {
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #355a6d;
    background: rgba(53, 90, 109, 0.08);
    transition: transform 0.2s ease;
  }

  .bw-help-center__faq-item.is-open .bw-help-center__faq-icon {
    transform: rotate(45deg);
  }

  .bw-help-center__faq-answer {
    display: none;
    padding: 0 20px 20px;
    color: #5e4d44;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-help-center__faq-item.is-open .bw-help-center__faq-answer {
    display: block;
  }

  .bw-help-center__support {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .bw-help-center__support-card {
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 48px rgba(35, 24, 19, 0.06);
    display: grid;
    gap: 10px;
  }

  .bw-help-center__support-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
  }

  .bw-help-center__support-card p {
    margin: 0;
    color: #64544a;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-help-center__support-card a {
    color: #8a684f;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }

  @media (max-width: 1100px) {
    .bw-help-center__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bw-help-center__support {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .bw-help-center__cards {
      grid-template-columns: 1fr;
    }

    .bw-help-center__panel {
      padding: 18px;
      border-radius: 22px;
    }

    .bw-help-center__faq-question {
      padding: 16px;
      font-size: 15px;
    }

    .bw-help-center__faq-answer {
      padding: 0 16px 16px;
    }
  }
</style>

<div class="bw-help-center" data-help-center>
  <div class="bw-help-center__hero">
    <span class="bw-help-center__eyebrow">Bluewud help center</span>
    <h2 class="bw-help-center__title">Find the right answer faster.</h2>
    <p class="bw-help-center__intro">Browse the most common Bluewud support questions by topic. Tap a category card to open a focused set of answers instead of scrolling a single long page.</p>
  </div>

  <div class="bw-help-center__cards" role="tablist" aria-label="Help center categories">
    <button
      class="bw-help-center__card is-active"
      type="button"
      role="tab"
      aria-selected="true"
      aria-controls="help-panel-my-order"
      data-help-tab="my-order"
    >
      <span class="bw-help-center__card-kicker">Order guidance</span>
      <h3 class="bw-help-center__card-title">My Order</h3>
      <p class="bw-help-center__card-copy">Placement, payment confirmation, and what to do if an order needs support after checkout.</p>
      <span class="bw-help-center__card-meta">5 answers</span>
    </button>

    <button
      class="bw-help-center__card"
      type="button"
      role="tab"
      aria-selected="false"
      aria-controls="help-panel-shipping-delivery"
      data-help-tab="shipping-delivery"
    >
      <span class="bw-help-center__card-kicker">Delivery timeline</span>
      <h3 class="bw-help-center__card-title">Shipping &amp; Delivery</h3>
      <p class="bw-help-center__card-copy">Shipping approach, dispatch timing, delivery estimates, and tracking details.</p>
      <span class="bw-help-center__card-meta">6 answers</span>
    </button>

    <button
      class="bw-help-center__card"
      type="button"
      role="tab"
      aria-selected="false"
      aria-controls="help-panel-cancellations-related"
      data-help-tab="cancellations-related"
    >
      <span class="bw-help-center__card-kicker">Order changes</span>
      <h3 class="bw-help-center__card-title">Cancellations &amp; Related Queries</h3>
      <p class="bw-help-center__card-copy">Cancellation rules, refund handling, and what happens when an order is already shipped.</p>
      <span class="bw-help-center__card-meta">4 answers</span>
    </button>

    <button
      class="bw-help-center__card"
      type="button"
      role="tab"
      aria-selected="false"
      aria-controls="help-panel-installation"
      data-help-tab="installation"
    >
      <span class="bw-help-center__card-kicker">Setup support</span>
      <h3 class="bw-help-center__card-title">Installation</h3>
      <p class="bw-help-center__card-copy">Self-installation details and the support available if setup needs help.</p>
      <span class="bw-help-center__card-meta">1 answer</span>
    </button>
  </div>

  <div class="bw-help-center__panel is-active" id="help-panel-my-order" role="tabpanel" data-help-panel="my-order">
    <div class="bw-help-center__panel-header">
      <span class="bw-help-center__panel-eyebrow">My Order</span>
      <h3 class="bw-help-center__panel-title">Order placement, payment, and confirmation</h3>
      <p class="bw-help-center__panel-copy">Use this section for the most common order questions from browsing to payment confirmation and post-purchase changes.</p>
    </div>
    <div class="bw-help-center__faq">
      <div class="bw-help-center__faq-item is-open">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="true">
          <span>How do I place my order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Browse through the range, open the product you like, choose the size, color, and variant, add it to the cart, and continue browsing or check out from the cart icon in the upper right corner.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>How do I determine the size of the product?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Detailed dimensions are shown under the product description, and the site also uses an image size scale to help with fit.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>How will I receive my order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Orders are packed with three-layer protection and shipped through partnered courier companies to keep delivery reliable.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>How will I get confirmation of my order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">You will receive email and SMS updates after purchase. The order is confirmed after payment verification is complete.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>Can I add an item to my order after I have placed my order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">No. Once the order is placed, items cannot be added to it.</div>
      </div>
    </div>
  </div>

  <div class="bw-help-center__panel" id="help-panel-shipping-delivery" role="tabpanel" data-help-panel="shipping-delivery">
    <div class="bw-help-center__panel-header">
      <span class="bw-help-center__panel-eyebrow">Shipping &amp; Delivery</span>
      <h3 class="bw-help-center__panel-title">Delivery timing, shipping modes, and tracking</h3>
      <p class="bw-help-center__panel-copy">This section groups the logistics questions shoppers ask most before and after dispatch.</p>
    </div>
    <div class="bw-help-center__faq">
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>What is the shipping ideology of BLUEWUD?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Products go through a three-step quality check before shipping, and Bluewud uses partner courier companies to deliver orders.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>When is my Order Shipped?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Orders are generally shipped within a day or two. If there are delays, relevant information is shared.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>When is the order delivered?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">The live page notes an estimated 10-12 working days from shipment, though delivery often happens sooner.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>What's the difference in Air shipping &amp; Surface Shipping?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Items under 1.5 kg ship by air with an estimated 2-4 working day delivery. Heavier volumetric items ship by surface with an estimated 10-12 working day delivery.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>How Do I Track My Order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">A tracking ID is shared once the order is dispatched from the warehouse.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>Can I expect delivery on all days of the week?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Deliveries are expected on all seven days except national and state holidays.</div>
      </div>
    </div>
  </div>

  <div class="bw-help-center__panel" id="help-panel-cancellations-related" role="tabpanel" data-help-panel="cancellations-related">
    <div class="bw-help-center__panel-header">
      <span class="bw-help-center__panel-eyebrow">Cancellations &amp; Related Queries</span>
      <h3 class="bw-help-center__panel-title">Order edits, cancellation rules, and refunds</h3>
      <p class="bw-help-center__panel-copy">A focused area for shoppers who need to change or stop an order after purchase.</p>
    </div>
    <div class="bw-help-center__faq">
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>How do I cancel my order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">COD orders can be canceled from the registered account before shipping. For prepaid orders, contact care@bluewud.com to request a refund cancellation.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>If the order is shipped already, can I still cancel it?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Once shipped, the order cannot be canceled. If possible, refuse the shipment. If you already accepted it, you can return it and exchange it for something else.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>Can I request changes or edits in my order?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Yes. Bluewud asks customers to email the support team with change requests so the team can help wherever possible.</div>
      </div>
      <div class="bw-help-center__faq-item">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="false">
          <span>What happens if a payment was deducted but the order failed?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">Check your bank or card account first. If the account was debited, banks usually roll it back within about 10 business days. You can also write to care@bluewud.com for assistance.</div>
      </div>
    </div>
  </div>

  <div class="bw-help-center__panel" id="help-panel-installation" role="tabpanel" data-help-panel="installation">
    <div class="bw-help-center__panel-header">
      <span class="bw-help-center__panel-eyebrow">Installation</span>
      <h3 class="bw-help-center__panel-title">Setup guidance and on-call assistance</h3>
      <p class="bw-help-center__panel-copy">Help for self-installation and support if the product needs setup guidance after delivery.</p>
    </div>
    <div class="bw-help-center__faq">
      <div class="bw-help-center__faq-item is-open">
        <button class="bw-help-center__faq-question" type="button" aria-expanded="true">
          <span>Do you provide free installation of the product?</span><span class="bw-help-center__faq-icon">+</span>
        </button>
        <div class="bw-help-center__faq-answer">The live Help Center says the package includes the necessary hardware and instruction guide. Parts are pre-drilled, installation is usually straightforward, and customers can install it themselves or hire a local carpenter. For on-call assistance, contact +91-8800609609.</div>
      </div>
    </div>
  </div>

  <div class="bw-help-center__support">
    <div class="bw-help-center__support-card">
      <h3>Need direct help?</h3>
      <p>Speak with the Bluewud team for order or product support during business hours.</p>
      <a href="tel:+918800609609">Call +91-8800-609-609</a>
    </div>
    <div class="bw-help-center__support-card">
      <h3>Email support</h3>
      <p>Send order questions, cancellation requests, or payment issues to the support inbox.</p>
      <a href="mailto:care@bluewud.com">care@bluewud.com</a>
    </div>
    <div class="bw-help-center__support-card">
      <h3>Business enquiries</h3>
      <p>For office, hospitality, or GST-led orders, use the bulk purchasing route.</p>
      <a href="/pages/buy-in-bulk">Open Buy In Bulk</a>
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('[data-help-center]');
    if (!root) return;

    var tabs = Array.prototype.slice.call(root.querySelectorAll('[data-help-tab]'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('[data-help-panel]'));

    function activateTab(tabId) {
      tabs.forEach(function (tab) {
        var isActive = tab.getAttribute('data-help-tab') === tabId;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach(function (panel) {
        var isActive = panel.getAttribute('data-help-panel') === tabId;
        panel.classList.toggle('is-active', isActive);
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activateTab(tab.getAttribute('data-help-tab'));
      });
    });

    root.querySelectorAll('.bw-help-center__faq-item').forEach(function (item) {
      var button = item.querySelector('.bw-help-center__faq-question');
      if (!button) return;

      button.addEventListener('click', function () {
        var isOpen = item.classList.contains('is-open');
        item.classList.toggle('is-open', !isOpen);
        button.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });
    });
  })();
</script>
