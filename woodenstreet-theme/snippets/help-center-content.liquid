  @media (max-width: 1100px) {
    .bw-help-center__hero,
    .bw-help-center__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bw-help-center__panel-summary,
    .bw-help-center__support {
      grid-template-columns: 1fr;
    }

    .bw-help-center__support {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .bw-help-center__hero,
    .bw-help-center__cards {
      grid-template-columns: 1fr;
    }

    .bw-help-center__hero-copy,
    .bw-help-center__hero-side,
    .bw-help-center__panel {
      padding: 18px;
      border-radius: 22px;
    }

    .bw-help-center__title {
      font-size: clamp(28px, 10vw, 40px);
    }

    .bw-help-center__faq-question {
      padding: 16px;
      font-size: 15px;
    }

    .bw-help-center__faq-answer {
      padding: 0 16px 16px;
    }
  }
</style>

