              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_primary_src }}" alt="{{ wardrobe_preview_primary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">No Mirror</span><span class="bw-flow__choice-note">Choose when the wardrobe should stay quieter and more storage-first.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--image"><input type="radio" name="mirror_need" value="One mirror panel">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_secondary_src }}" alt="{{ wardrobe_preview_secondary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">One Mirror Panel</span><span class="bw-flow__choice-note">A practical dressing aid that still keeps the wardrobe face balanced.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--image"><input type="radio" name="mirror_need" value="Multiple mirror panels">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_quaternary_src }}" alt="{{ wardrobe_preview_quaternary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Multiple Mirror Panels</span><span class="bw-flow__choice-note">Best when the wardrobe should act as part storage, part room-expanding surface.</span></span>
            </label>
