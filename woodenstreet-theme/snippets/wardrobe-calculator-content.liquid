{% liquid
  assign contact_url = '/pages/contact-us'
  assign wardrobe_main_url = '/collections/wardrobe'
  assign wardrobe_sliding_url = wardrobe_main_url
  assign wardrobe_hinged_url = wardrobe_main_url
  assign wardrobe_walkin_url = wardrobe_main_url
  assign kitchen_calculator_url = '/pages/modular-kitchen-cost-calculator'
  assign interiors_calculator_url = '/pages/home-interiors-cost-calculator'
  assign estimate_url = '/pages/get-free-estimate'

  if pages['modular-wardrobe-designs'] != blank
    assign wardrobe_main_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['sliding-wardrobe-designs'] != blank
    assign wardrobe_sliding_url = pages['sliding-wardrobe-designs'].url
  endif
  if pages['hinged-wardrobes'] != blank
    assign wardrobe_hinged_url = pages['hinged-wardrobes'].url
  endif
  if pages['walk-in-wardrobes'] != blank
    assign wardrobe_walkin_url = pages['walk-in-wardrobes'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
%}

<style>
  .bw-flow { display: grid; gap: 22px; }
  .bw-flow__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 20px;
  }
  .bw-flow__panel,
  .bw-flow__summary {
    padding: 26px 28px;
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__summary {
    position: sticky;
    top: 110px;
    background: linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
    height: fit-content;
  }
  .bw-flow__head { display: grid; gap: 10px; margin-bottom: 18px; }
  .bw-flow__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-flow__summary .bw-flow__eyebrow,
  .bw-flow__summary .bw-flow__title,
  .bw-flow__summary .bw-flow__copy { color: inherit; }
  .bw-flow__title {
    margin: 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }
  .bw-flow__copy {
    margin: 0;
    max-width: 62ch;
    color: #66554c;
    font-size: 15px;
    line-height: 1.8;
  }
  .bw-flow__journey {
    display: grid;
    gap: 14px;
    margin-bottom: 18px;
    padding: 18px 20px;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(35, 24, 19, 0.06), rgba(79, 120, 143, 0.08));
    border: 1px solid rgba(45, 33, 27, 0.08);
  }
  .bw-flow__journey-head {
    display: grid;
    gap: 6px;
  }
  .bw-flow__journey-title {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .bw-flow__journey-copy {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.65;
  }
  .bw-flow__journey-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-flow__journey-link {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(32, 23, 19, 0.12);
    background: rgba(255, 255, 255, 0.68);
    color: #201713;
    text-decoration: none;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .bw-flow__journey-link:hover,
  .bw-flow__journey-link:focus-visible {
    transform: translateY(-1px);
    background: #fffdfb;
    border-color: rgba(32, 23, 19, 0.18);
  }
  .bw-flow__progress {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 20px;
  }
  .bw-flow__step {
    display: grid;
    gap: 6px;
    padding: 14px;
    border-radius: 20px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid transparent;
  }
  .bw-flow__step.is-active {
    background: rgba(79, 120, 143, 0.12);
    border-color: rgba(79, 120, 143, 0.22);
  }
  .bw-flow__step.is-complete { background: rgba(32, 23, 19, 0.08); }
  .bw-flow__step-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }
  .bw-flow__step-label {
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-flow__stage { display: none; gap: 16px; }
  .bw-flow__stage.is-active { display: grid; }
  .bw-flow__stage-head { display: grid; gap: 8px; }
  .bw-flow__stage-title {
    margin: 0;
    color: #201713;
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }
  .bw-flow__stage-copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-flow__section { display: grid; gap: 12px; }
  .bw-flow__label {
    color: #201713;
    font-size: 16px;
    font-weight: 700;
  }
  .bw-flow__choices {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-flow__choice {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    border: 1px solid transparent;
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-flow__choice input { display: none; }
  .bw-flow__choice.is-selected {
    background: #201713;
    color: #fff7f1;
    border-color: #201713;
  }
  .bw-flow__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-flow__field {
    display: grid;
    gap: 8px;
  }
  .bw-flow__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
  }
  .bw-flow__field input,
  .bw-flow__field select {
    width: 100%;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fffdfb;
    color: #201713;
    font-size: 14px;
  }
  .bw-flow__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 6px;
  }
  .bw-flow__button,
  .bw-flow__button--secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-flow__button {
    border: 0;
    background: #201713;
    color: #fff7f1;
  }
  .bw-flow__button--secondary {
    border: 1px solid rgba(32, 23, 19, 0.14);
    background: rgba(32, 23, 19, 0.04);
    color: #201713;
  }
  .bw-flow__summary .bw-flow__button--secondary {
    border-color: rgba(255, 247, 241, 0.26);
    background: rgba(255, 247, 241, 0.14);
    color: #fff7f1;
  }
  .bw-flow__summary .bw-flow__button--secondary:hover,
  .bw-flow__summary .bw-flow__button--secondary:focus-visible {
    background: rgba(255, 247, 241, 0.22);
    border-color: rgba(255, 247, 241, 0.38);
  }
  .bw-flow__summary-list {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }
  .bw-flow__summary-line {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 247, 241, 0.12);
    color: rgba(255, 247, 241, 0.88);
    font-size: 14px;
  }
  .bw-flow__summary-line strong { color: #fff7f1; text-align: right; }
  .bw-flow__badge {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 247, 241, 0.08);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bw-flow__assist {
    margin-top: 16px;
    color: rgba(255, 247, 241, 0.76);
    font-size: 13px;
    line-height: 1.7;
  }
  @media (max-width: 980px) {
    .bw-flow__shell { grid-template-columns: 1fr; }
    .bw-flow__summary { position: static; }
    .bw-flow__progress { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 720px) {
    .bw-flow__panel,
    .bw-flow__summary { padding: 22px 20px; border-radius: 24px; }
    .bw-flow__progress,
    .bw-flow__grid { grid-template-columns: 1fr; }
    .bw-flow__actions { flex-direction: column-reverse; align-items: stretch; }
  }
</style>

<div class="bw-flow" data-bw-wardrobe-flow>
  <div class="bw-flow__shell">
    <section class="bw-flow__panel">
      <div class="bw-flow__head">
        <span class="bw-flow__eyebrow">Wardrobe planning workflow</span>
        <h2 class="bw-flow__title">Wardrobe Cost Calculator</h2>
        <p class="bw-flow__copy">This is now a consultation-first workflow. Instead of pretending to give a final quote, it helps the customer build a wardrobe brief that Bluewud can actually respond to properly.</p>
      </div>

      <div class="bw-flow__journey">
        <div class="bw-flow__journey-head">
          <h3 class="bw-flow__journey-title">Move through the wardrobe planning journey</h3>
          <p class="bw-flow__journey-copy">Use these links to compare wardrobe formats, then move back into the calculators or estimate flow without leaving the planning system.</p>
        </div>
        <div class="bw-flow__journey-links">
          <a class="bw-flow__journey-link" href="{{ wardrobe_main_url }}">Wardrobe Designs</a>
          <a class="bw-flow__journey-link" href="{{ wardrobe_sliding_url }}">Sliding Wardrobes</a>
          <a class="bw-flow__journey-link" href="{{ wardrobe_hinged_url }}">Hinged Wardrobes</a>
          <a class="bw-flow__journey-link" href="{{ wardrobe_walkin_url }}">Walk-in Wardrobes</a>
          <a class="bw-flow__journey-link" href="{{ kitchen_calculator_url }}">Kitchen Calculator</a>
          <a class="bw-flow__journey-link" href="{{ interiors_calculator_url }}">Home Interiors</a>
          <a class="bw-flow__journey-link" href="{{ estimate_url }}">Get Free Estimate</a>
        </div>
      </div>

      <div class="bw-flow__progress">
        <div class="bw-flow__step is-active" data-step-indicator="1"><span class="bw-flow__step-index">01</span><span class="bw-flow__step-label">Type</span></div>
        <div class="bw-flow__step" data-step-indicator="2"><span class="bw-flow__step-index">02</span><span class="bw-flow__step-label">Measurements</span></div>
        <div class="bw-flow__step" data-step-indicator="3"><span class="bw-flow__step-index">03</span><span class="bw-flow__step-label">Build</span></div>
        <div class="bw-flow__step" data-step-indicator="4"><span class="bw-flow__step-index">04</span><span class="bw-flow__step-label">Internals</span></div>
        <div class="bw-flow__step" data-step-indicator="5"><span class="bw-flow__step-index">05</span><span class="bw-flow__step-label">Review</span></div>
      </div>

      <div class="bw-flow__stage is-active" data-step-panel="1">
        <div class="bw-flow__stage-head">
          <h3 class="bw-flow__stage-title">Start with the wardrobe format and room intent</h3>
          <p class="bw-flow__stage-copy">The first step should settle access style and room context so the rest of the discussion does not stay generic.</p>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Wardrobe type</div>
          <div class="bw-flow__choices" data-flow-group="type">
            <label class="bw-flow__choice is-selected"><input type="radio" name="wardrobe_type" value="Sliding" checked>Sliding</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_type" value="Hinged">Hinged</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_type" value="Walk-in">Walk-in</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_type" value="Floor to ceiling">Floor To Ceiling</label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Bedroom type</div>
          <div class="bw-flow__choices" data-flow-group="room">
            <label class="bw-flow__choice is-selected"><input type="radio" name="room_type" value="Master bedroom" checked>Master Bedroom</label>
            <label class="bw-flow__choice"><input type="radio" name="room_type" value="Guest bedroom">Guest Bedroom</label>
            <label class="bw-flow__choice"><input type="radio" name="room_type" value="Kids bedroom">Kids Bedroom</label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Storage intensity</div>
          <div class="bw-flow__choices" data-flow-group="storage">
            <label class="bw-flow__choice"><input type="radio" name="storage_intensity" value="Light use">Light Use</label>
            <label class="bw-flow__choice is-selected"><input type="radio" name="storage_intensity" value="Balanced daily use" checked>Balanced Daily Use</label>
            <label class="bw-flow__choice"><input type="radio" name="storage_intensity" value="High storage demand">High Storage Demand</label>
          </div>
        </div>
        <div class="bw-flow__actions">
          <span></span>
          <button class="bw-flow__button" type="button" data-flow-next>Continue</button>
        </div>
      </div>

      <div class="bw-flow__stage" data-step-panel="2">
        <div class="bw-flow__stage-head">
          <h3 class="bw-flow__stage-title">Capture the broad measurements</h3>
          <p class="bw-flow__stage-copy">These values make the enquiry much more useful even before site verification happens.</p>
        </div>
        <div class="bw-flow__grid">
          <div class="bw-flow__field">
            <label for="bw-wardrobe-width">Wardrobe width (ft)</label>
            <input id="bw-wardrobe-width" type="number" min="3" max="20" step="0.5" value="7" data-flow-input="width">
          </div>
          <div class="bw-flow__field">
            <label for="bw-wardrobe-height">Wardrobe height (ft)</label>
            <input id="bw-wardrobe-height" type="number" min="6" max="12" step="0.5" value="8" data-flow-input="height">
          </div>
          <div class="bw-flow__field">
            <label for="bw-wardrobe-depth">Wardrobe depth (ft)</label>
            <input id="bw-wardrobe-depth" type="number" min="1" max="4" step="0.5" value="2" data-flow-input="depth">
          </div>
          <div class="bw-flow__field">
            <label for="bw-wardrobe-loft">Need loft storage?</label>
            <select id="bw-wardrobe-loft" data-flow-input="loft">
              <option value="Yes">Yes</option>
              <option value="No">No</option>
              <option value="Need guidance">Need guidance</option>
            </select>
          </div>
        </div>
        <div class="bw-flow__actions">
          <button class="bw-flow__button--secondary" type="button" data-flow-back>Back</button>
          <button class="bw-flow__button" type="button" data-flow-next>Continue</button>
        </div>
      </div>

      <div class="bw-flow__stage" data-step-panel="3">
        <div class="bw-flow__stage-head">
          <h3 class="bw-flow__stage-title">Set the material and shutter direction</h3>
          <p class="bw-flow__stage-copy">This layer changes durability, visual language, and how premium the final wardrobe feels.</p>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Carcass material</div>
          <div class="bw-flow__choices" data-flow-group="carcass">
            <label class="bw-flow__choice is-selected"><input type="radio" name="wardrobe_carcass" value="Engineered wood" checked>Engineered Wood</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_carcass" value="Plywood">Plywood</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_carcass" value="Need guidance">Need Guidance</label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Shutter material</div>
          <div class="bw-flow__choices" data-flow-group="shutter_material">
            <label class="bw-flow__choice is-selected"><input type="radio" name="wardrobe_shutter_material" value="Laminate panel" checked>Laminate Panel</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_shutter_material" value="Acrylic panel">Acrylic Panel</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_shutter_material" value="Mirror / glass">Mirror / Glass</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_shutter_material" value="Profile / mixed finish">Profile / Mixed</label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Finish mood</div>
          <div class="bw-flow__choices" data-flow-group="finish">
            <label class="bw-flow__choice is-selected"><input type="radio" name="wardrobe_finish" value="Warm wood + solid shutters" checked>Warm Wood</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_finish" value="Light modern matte">Light Matte</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_finish" value="Mirror-led premium">Mirror-led Premium</label>
            <label class="bw-flow__choice"><input type="radio" name="wardrobe_finish" value="Need guidance">Need Guidance</label>
          </div>
        </div>
        <div class="bw-flow__actions">
          <button class="bw-flow__button--secondary" type="button" data-flow-back>Back</button>
          <button class="bw-flow__button" type="button" data-flow-next>Continue</button>
        </div>
      </div>

      <div class="bw-flow__stage" data-step-panel="4">
        <div class="bw-flow__stage-head">
          <h3 class="bw-flow__stage-title">Choose the internals and accessories that matter</h3>
          <p class="bw-flow__stage-copy">This step makes the brief practical, because a wardrobe is defined by its internals as much as by its shutter style.</p>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Internal requirements</div>
          <div class="bw-flow__choices" data-flow-group="internals">
            <label class="bw-flow__choice"><input type="checkbox" value="Long hanging">Long Hanging</label>
            <label class="bw-flow__choice"><input type="checkbox" value="Short hanging">Short Hanging</label>
            <label class="bw-flow__choice"><input type="checkbox" value="Drawer stack">Drawer Stack</label>
            <label class="bw-flow__choice"><input type="checkbox" value="Pull-out accessories">Pull-out Accessories</label>
            <label class="bw-flow__choice"><input type="checkbox" value="Digital locker">Digital Locker</label>
            <label class="bw-flow__choice"><input type="checkbox" value="Shoe or linen zone">Shoe / Linen Zone</label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Mirror requirement</div>
          <div class="bw-flow__choices" data-flow-group="mirror">
            <label class="bw-flow__choice is-selected"><input type="radio" name="mirror_need" value="No mirror" checked>No Mirror</label>
            <label class="bw-flow__choice"><input type="radio" name="mirror_need" value="One mirror panel">One Mirror Panel</label>
            <label class="bw-flow__choice"><input type="radio" name="mirror_need" value="Multiple mirror panels">Multiple Mirror Panels</label>
            <label class="bw-flow__choice"><input type="radio" name="mirror_need" value="Need guidance">Need Guidance</label>
          </div>
        </div>
        <div class="bw-flow__actions">
          <button class="bw-flow__button--secondary" type="button" data-flow-back>Back</button>
          <button class="bw-flow__button" type="button" data-flow-next>Continue</button>
        </div>
      </div>

      <div class="bw-flow__stage" data-step-panel="5">
        <div class="bw-flow__stage-head">
          <h3 class="bw-flow__stage-title">Review the wardrobe brief and send it to Bluewud</h3>
          <p class="bw-flow__stage-copy">The outcome here should be a clean consultation brief, not a superficial auto-price.</p>
        </div>
        <div class="bw-flow__grid">
          <div class="bw-flow__field">
            <label for="bw-wardrobe-city">Preferred city</label>
            <input id="bw-wardrobe-city" type="text" placeholder="Noida, Delhi, Bengaluru..." data-flow-input="city">
          </div>
          <div class="bw-flow__field">
            <label for="bw-wardrobe-timeline">Project stage</label>
            <select id="bw-wardrobe-timeline" data-flow-input="timeline">
              <option value="Immediate">Immediate</option>
              <option value="Within 1 month">Within 1 month</option>
              <option value="1 to 3 months">1 to 3 months</option>
              <option value="Just exploring">Just exploring</option>
            </select>
          </div>
        </div>
        <div class="bw-flow__actions">
          <button class="bw-flow__button--secondary" type="button" data-flow-back>Back</button>
          <button class="bw-flow__button" type="button" data-bw-wardrobe-popup-open>Share This Brief</button>
        </div>
      </div>
    </section>

    <aside class="bw-flow__summary">
      <div class="bw-flow__head">
        <span class="bw-flow__eyebrow">Project summary</span>
        <h2 class="bw-flow__title">Your wardrobe brief</h2>
        <p class="bw-flow__copy">This should read like a real room-led wardrobe direction, not a fake quote box.</p>
      </div>

      <div class="bw-flow__badge" data-wardrobe-band>Balanced premium direction</div>

      <div class="bw-flow__summary-list">
        <div class="bw-flow__summary-line"><span>Type</span><strong data-summary-type>Sliding</strong></div>
        <div class="bw-flow__summary-line"><span>Room</span><strong data-summary-room>Master bedroom</strong></div>
        <div class="bw-flow__summary-line"><span>Storage</span><strong data-summary-storage>Balanced daily use</strong></div>
        <div class="bw-flow__summary-line"><span>Measurements</span><strong data-summary-measurements>7 ft / 8 ft / 2 ft</strong></div>
        <div class="bw-flow__summary-line"><span>Loft</span><strong data-summary-loft>Yes</strong></div>
        <div class="bw-flow__summary-line"><span>Carcass</span><strong data-summary-carcass>Engineered wood</strong></div>
        <div class="bw-flow__summary-line"><span>Shutter</span><strong data-summary-shutter>Laminate panel</strong></div>
        <div class="bw-flow__summary-line"><span>Finish</span><strong data-summary-finish>Warm wood + solid shutters</strong></div>
        <div class="bw-flow__summary-line"><span>Internals</span><strong data-summary-internals>None selected</strong></div>
        <div class="bw-flow__summary-line"><span>Mirror</span><strong data-summary-mirror>No mirror</strong></div>
      </div>

      <p class="bw-flow__assist">Once submitted, the estimate popup will carry the wardrobe type, room dimensions, material direction, and internal requirements so Bluewud receives a usable planning brief from the start.</p>
      <div class="bw-flow__actions">
        <button class="bw-flow__button" type="button" data-bw-wardrobe-popup-open>Get Free Estimate</button>
        <a class="bw-flow__button--secondary" href="{{ contact_url }}">Talk To Bluewud</a>
      </div>
    </aside>
  </div>
</div>

{% render 'modular-estimate-popup', modal_id: 'bw-wardrobe-calc-popup', modal_title: 'Get a wardrobe estimate', context_label: 'Bluewud modular wardrobe' %}

<script>
  (function () {
    var root = document.querySelector('[data-bw-wardrobe-flow]');
    if (!root) return;

    var step = 1;
    var maxStep = 5;
    var stageNodes = Array.prototype.slice.call(root.querySelectorAll('[data-step-panel]'));
    var indicatorNodes = Array.prototype.slice.call(root.querySelectorAll('[data-step-indicator]'));
    var modal = document.getElementById('bw-wardrobe-calc-popup');
    var summaryText = modal ? modal.querySelector('[data-bw-estimate-summary-text]') : null;
    var summaryInput = modal ? modal.querySelector('[data-bw-estimate-summary-input]') : null;
    var contextInput = modal ? modal.querySelector('[data-bw-estimate-context-input]') : null;
    var bandNode = root.querySelector('[data-wardrobe-band]');

    function selectedRadio(name) {
      var node = root.querySelector('input[name="' + name + '"]:checked');
      return node ? node.value : '';
    }
    function setRadioValue(name, value) {
      var node = root.querySelector('input[name="' + name + '"][value="' + value + '"]');
      if (node) node.checked = true;
    }
    function normalizeWardrobeType(type) {
      if (!type) return '';
      var key = String(type).toLowerCase();
      if (key === 'all' || key === 'sliding') return 'Sliding';
      if (key === 'hinged') return 'Hinged';
      if (key === 'walk-in' || key === 'walk in') return 'Walk-in';
      if (key === 'floor to ceiling') return 'Floor to ceiling';
      return '';
    }

    function selectedChecks(group) {
      return Array.prototype.slice.call(root.querySelectorAll('[data-flow-group="' + group + '"] input[type="checkbox"]:checked')).map(function (input) {
        return input.value;
      });
    }

    function inputValue(key) {
      var node = root.querySelector('[data-flow-input="' + key + '"]');
      return node ? node.value : '';
    }

    function toggleChoiceStates() {
      root.querySelectorAll('.bw-flow__choice').forEach(function (choice) {
        var input = choice.querySelector('input');
        if (!input) return;
        choice.classList.toggle('is-selected', !!input.checked);
      });
    }

    function projectBand() {
      var premiumSignals = 0;
      if (selectedRadio('wardrobe_type') === 'Walk-in') premiumSignals += 2;
      if (selectedRadio('wardrobe_type') === 'Floor to ceiling') premiumSignals += 1;
      if (selectedRadio('wardrobe_carcass') === 'Plywood') premiumSignals += 1;
      if (selectedRadio('wardrobe_shutter_material') === 'Mirror / glass') premiumSignals += 2;
      premiumSignals += selectedChecks('internals').length;
      if (premiumSignals >= 5) return 'Statement premium direction';
      if (premiumSignals >= 3) return 'Balanced premium direction';
      return 'Value-led practical direction';
    }

    function updateSummary() {
      toggleChoiceStates();
      var measurements = [inputValue('width') + ' ft', inputValue('height') + ' ft', inputValue('depth') + ' ft'].join(' / ');
      var internals = selectedChecks('internals');
      var summaryMap = {
        type: selectedRadio('wardrobe_type'),
        room: selectedRadio('room_type'),
        storage: selectedRadio('storage_intensity'),
        measurements: measurements,
        loft: inputValue('loft'),
        carcass: selectedRadio('wardrobe_carcass'),
        shutter: selectedRadio('wardrobe_shutter_material'),
        finish: selectedRadio('wardrobe_finish'),
        internals: internals.length ? internals.join(', ') : 'None selected',
        mirror: selectedRadio('mirror_need')
      };

      Object.keys(summaryMap).forEach(function (key) {
        var node = root.querySelector('[data-summary-' + key + ']');
        if (node) node.textContent = summaryMap[key];
      });
      if (bandNode) bandNode.textContent = projectBand();
    }

    function briefSummary() {
      return [
        'Project: Modular Wardrobe',
        'Type: ' + selectedRadio('wardrobe_type'),
        'Room: ' + selectedRadio('room_type'),
        'Storage intensity: ' + selectedRadio('storage_intensity'),
        'Measurements: ' + inputValue('width') + 'ft / ' + inputValue('height') + 'ft / ' + inputValue('depth') + 'ft',
        'Loft: ' + inputValue('loft'),
        'Carcass: ' + selectedRadio('wardrobe_carcass'),
        'Shutter: ' + selectedRadio('wardrobe_shutter_material'),
        'Finish: ' + selectedRadio('wardrobe_finish'),
        'Internals: ' + (selectedChecks('internals').length ? selectedChecks('internals').join(', ') : 'None'),
        'Mirror: ' + selectedRadio('mirror_need'),
        'City: ' + (inputValue('city') || 'Not shared yet'),
        'Timeline: ' + (inputValue('timeline') || 'Immediate'),
        'Direction: ' + projectBand()
      ].join(' | ');
    }
    function applyWardrobePreset(type) {
      var normalized = normalizeWardrobeType(type);
      if (!normalized) return;
      setRadioValue('wardrobe_type', normalized);
      step = 1;
      updateSummary();
      paintSteps();
    }

    function paintSteps() {
      stageNodes.forEach(function (panel) {
        panel.classList.toggle('is-active', Number(panel.getAttribute('data-step-panel')) === step);
      });
      indicatorNodes.forEach(function (indicator) {
        var indicatorStep = Number(indicator.getAttribute('data-step-indicator'));
        indicator.classList.toggle('is-active', indicatorStep === step);
        indicator.classList.toggle('is-complete', indicatorStep < step);
      });
    }

    function openPopup() {
      if (!modal) return;
      var summary = briefSummary();
      if (summaryText) summaryText.textContent = summary;
      if (summaryInput) summaryInput.value = summary;
      if (contextInput) contextInput.value = 'Bluewud modular wardrobe';
      modal.classList.add('is-open');
      document.body.classList.add('bw-header-drawer-open');
    }

    function closePopup() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('bw-header-drawer-open');
    }

    root.addEventListener('click', function (event) {
      var choice = event.target.closest('.bw-flow__choice');
      if (choice) {
        var input = choice.querySelector('input');
        if (input) {
          if (input.type === 'checkbox') input.checked = !input.checked;
          else input.checked = true;
          updateSummary();
        }
        return;
      }

      if (event.target.closest('[data-flow-next]')) {
        if (step < maxStep) step += 1;
        paintSteps();
        return;
      }

      if (event.target.closest('[data-flow-back]')) {
        if (step > 1) step -= 1;
        paintSteps();
        return;
      }

      if (event.target.closest('[data-bw-wardrobe-popup-open]')) {
        openPopup();
      }
    });

    root.addEventListener('change', updateSummary);
    root.addEventListener('bw:wardrobe-type-select', function (event) {
      if (event.detail && event.detail.type) {
        applyWardrobePreset(event.detail.type);
      }
    });

    if (modal) {
      modal.querySelectorAll('[data-bw-estimate-close]').forEach(function (control) {
        control.addEventListener('click', closePopup);
      });
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closePopup();
      });
    }

    updateSummary();
    var params = new URLSearchParams(window.location.search);
    applyWardrobePreset(params.get('type'));
    paintSteps();
  })();
</script>
