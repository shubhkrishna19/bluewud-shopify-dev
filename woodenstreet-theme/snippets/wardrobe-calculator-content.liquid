{% liquid
  assign is_embedded = embedded | default: false
  assign contact_url = '/pages/contact-us'
  assign wardrobe_main_url = '/collections/wardrobe'
  assign wardrobe_sliding_url = wardrobe_main_url
  assign wardrobe_hinged_url = wardrobe_main_url
  assign wardrobe_walkin_url = wardrobe_main_url
  assign calculator_url = '/collections/wardrobe?planner=wardrobe-calculator'
  assign kitchen_calculator_url = '/collections/kitchen-racks?planner=kitchen-calculator'
  assign interiors_calculator_url = '/collections/kitchen-racks?planner=home-interiors'
  assign estimate_url = '/pages/get-free-estimate'
  assign wardrobe_collection = collections['wardrobe']
  assign bedroom_collection = collections['bed-room']
  assign wardrobe_preview_primary = blank
  assign wardrobe_preview_secondary = blank
  assign wardrobe_preview_tertiary = blank
  assign wardrobe_preview_quaternary = blank
  assign wardrobe_preview_fallback = blank
  assign wardrobe_preview_primary_src = blank
  assign wardrobe_preview_secondary_src = blank
  assign wardrobe_preview_tertiary_src = blank
  assign wardrobe_preview_quaternary_src = blank
  assign wardrobe_preview_primary_alt = 'Bluewud wardrobe planning reference'
  assign wardrobe_preview_secondary_alt = 'Bluewud wardrobe planning reference'
  assign wardrobe_preview_tertiary_alt = 'Bluewud wardrobe planning reference'
  assign wardrobe_preview_quaternary_alt = 'Bluewud wardrobe planning reference'

  if pages['modular-wardrobe-designs'] != blank
    assign wardrobe_main_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['sliding-wardrobe-designs'] != blank
    assign wardrobe_sliding_url = pages['sliding-wardrobe-designs'].url
  endif
  if pages['hinged-wardrobes'] != blank
    assign wardrobe_hinged_url = pages['hinged-wardrobes'].url
  endif
  if pages['walk-in-wardrobes'] != blank
    assign wardrobe_walkin_url = pages['walk-in-wardrobes'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
  if pages['get-free-estimate'] == blank and pages['contact-us'] != blank
    assign estimate_url = pages['contact-us'].url
  endif

  if wardrobe_collection != blank
    if wardrobe_collection.image != blank
      assign wardrobe_preview_fallback = wardrobe_collection.image
    endif
    assign wardrobe_preview_primary = wardrobe_collection.products.first
    if wardrobe_collection.products.size > 1
      assign wardrobe_preview_secondary = wardrobe_collection.products[1]
    endif
    if wardrobe_collection.products.size > 2
      assign wardrobe_preview_tertiary = wardrobe_collection.products[2]
    endif
    if wardrobe_collection.products.size > 3
      assign wardrobe_preview_quaternary = wardrobe_collection.products[3]
    endif
  endif

  if wardrobe_preview_fallback == blank and bedroom_collection != blank
    if bedroom_collection.image != blank
      assign wardrobe_preview_fallback = bedroom_collection.image
    elsif bedroom_collection.products.first.featured_image != blank
      assign wardrobe_preview_fallback = bedroom_collection.products.first.featured_image
    endif
  endif

  if wardrobe_preview_primary != blank and wardrobe_preview_primary.featured_image != blank
    assign wardrobe_preview_primary_src = wardrobe_preview_primary.featured_image | image_url: width: 900
    assign wardrobe_preview_primary_alt = wardrobe_preview_primary.title | default: wardrobe_preview_primary_alt
  elsif wardrobe_preview_fallback != blank
    assign wardrobe_preview_primary_src = wardrobe_preview_fallback | image_url: width: 900
    assign wardrobe_preview_primary_alt = wardrobe_collection.title | default: wardrobe_preview_primary_alt
  else
    assign wardrobe_preview_primary_src = 'modular-kitchen-light-oak-l-shape.png' | asset_url
  endif

  if wardrobe_preview_secondary != blank and wardrobe_preview_secondary.featured_image != blank
    assign wardrobe_preview_secondary_src = wardrobe_preview_secondary.featured_image | image_url: width: 900
    assign wardrobe_preview_secondary_alt = wardrobe_preview_secondary.title | default: wardrobe_preview_secondary_alt
  elsif wardrobe_preview_primary_src != blank
    assign wardrobe_preview_secondary_src = wardrobe_preview_primary_src
    assign wardrobe_preview_secondary_alt = wardrobe_preview_primary_alt
  endif

  if wardrobe_preview_tertiary != blank and wardrobe_preview_tertiary.featured_image != blank
    assign wardrobe_preview_tertiary_src = wardrobe_preview_tertiary.featured_image | image_url: width: 900
    assign wardrobe_preview_tertiary_alt = wardrobe_preview_tertiary.title | default: wardrobe_preview_tertiary_alt
  elsif wardrobe_preview_secondary_src != blank
    assign wardrobe_preview_tertiary_src = wardrobe_preview_secondary_src
    assign wardrobe_preview_tertiary_alt = wardrobe_preview_secondary_alt
  elsif wardrobe_preview_fallback != blank
    assign wardrobe_preview_tertiary_src = wardrobe_preview_fallback | image_url: width: 900
  else
    assign wardrobe_preview_tertiary_src = 'modular-kitchen-navy-luxury.png' | asset_url
  endif

  if wardrobe_preview_secondary_src == blank
    assign wardrobe_preview_secondary_src = wardrobe_preview_primary_src
    assign wardrobe_preview_secondary_alt = wardrobe_preview_primary_alt
  endif

  if wardrobe_preview_quaternary != blank and wardrobe_preview_quaternary.featured_image != blank
    assign wardrobe_preview_quaternary_src = wardrobe_preview_quaternary.featured_image | image_url: width: 900
    assign wardrobe_preview_quaternary_alt = wardrobe_preview_quaternary.title | default: wardrobe_preview_quaternary_alt
  elsif wardrobe_preview_primary_src != blank
    assign wardrobe_preview_quaternary_src = wardrobe_preview_primary_src
    assign wardrobe_preview_quaternary_alt = wardrobe_preview_primary_alt
  endif
%}

<style>
  .bw-flow { display: grid; gap: 22px; }
  .bw-flow__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 20px;
  }
  .bw-flow__panel,
  .bw-flow__summary {
    padding: 26px 28px;
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__summary {
    position: sticky;
    top: 92px;
    background: linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
    height: fit-content;
    max-height: calc(100vh - 160px);
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
  }
  .bw-flow__summary-visual {
    min-height: 132px;
    margin-bottom: 10px;
    border-radius: 24px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.1);
  }
  .bw-flow__summary-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__summary-caption {
    margin: -2px 0 10px;
    color: rgba(255, 247, 241, 0.72);
    font-size: 12px;
    line-height: 1.6;
  }
  .bw-flow__head { display: grid; gap: 10px; margin-bottom: 18px; }
  .bw-flow__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-flow__summary .bw-flow__eyebrow,
  .bw-flow__summary .bw-flow__title,
  .bw-flow__summary .bw-flow__copy { color: inherit; }
  .bw-flow__title {
    margin: 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }
  .bw-flow__copy {
    margin: 0;
    max-width: 62ch;
    color: #66554c;
    font-size: 15px;
    line-height: 1.8;
  }
  .bw-flow__journey {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
    margin-bottom: 18px;
  }
  .bw-flow__showcase,
  .bw-flow__reference-grid {
    display: grid;
    gap: 12px;
  }
  .bw-flow__showcase-panel {
    display: grid;
    gap: 14px;
    padding: 20px;
    border-radius: 24px;
    background:
      radial-gradient(circle at top left, rgba(166, 106, 67, 0.18), transparent 28%),
      linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
    color: #fff7f1;
  }
  .bw-flow__showcase-head {
    display: grid;
    gap: 8px;
    max-width: 58ch;
  }
  .bw-flow__showcase-title {
    margin: 0;
    color: inherit;
    font-size: 22px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .bw-flow__showcase-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.82);
    font-size: 14px;
    line-height: 1.7;
  }
  .bw-flow__showcase-image {
    overflow: hidden;
    border-radius: 20px;
    min-height: 264px;
    background: rgba(255, 247, 241, 0.08);
  }
  .bw-flow__showcase-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bw-flow__preview-card {
    display: grid;
    grid-template-columns: 92px minmax(0, 1fr);
    gap: 12px;
    padding: 14px;
    border-radius: 20px;
    background: rgba(255, 251, 247, 0.96);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.05);
    color: #201713;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .bw-flow__preview-card:hover,
  .bw-flow__preview-card:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(79, 120, 143, 0.22);
    box-shadow: 0 22px 46px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__preview-media {
    overflow: hidden;
    min-height: 92px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(35, 24, 19, 0.08), rgba(79, 120, 143, 0.1));
  }
  .bw-flow__preview-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bw-flow__preview-fallback {
    display: grid;
    place-items: center;
    min-height: 92px;
    padding: 10px;
    color: #fff7f1;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    background: linear-gradient(135deg, rgba(35, 24, 19, 0.92), rgba(79, 120, 143, 0.72));
  }
  .bw-flow__preview-copy {
    display: grid;
    gap: 5px;
    align-content: start;
  }
  .bw-flow__preview-kicker {
    color: #8a684f;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-flow__preview-title {
    margin: 0;
    color: #201713;
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .bw-flow__preview-text {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.6;
  }
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(1) { background: rgba(255, 251, 247, 0.98); }
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(2) { background: rgba(250, 244, 239, 0.98); }
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(3) { background: rgba(245, 239, 232, 0.98); }
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(4) {
    align-content: center;
    background: linear-gradient(135deg, #241814 0%, #3a2921 100%);
    color: #fff7f1;
    border-color: rgba(255, 247, 241, 0.08);
  }
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(4) .bw-flow__preview-kicker,
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(4) .bw-flow__preview-title,
  .bw-flow__reference-grid .bw-flow__preview-card:nth-child(4) .bw-flow__preview-text {
    color: inherit;
  }
  .bw-flow__journey-head {
    display: grid;
    gap: 6px;
  }
  .bw-flow__journey-title {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .bw-flow__journey-copy {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.65;
  }
  .bw-flow__journey-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-flow__journey-link {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(32, 23, 19, 0.12);
    background: rgba(255, 255, 255, 0.68);
    color: #201713;
    text-decoration: none;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .bw-flow__journey-link:hover,
  .bw-flow__journey-link:focus-visible {
    transform: translateY(-1px);
    background: #fffdfb;
    border-color: rgba(32, 23, 19, 0.18);
  }
  .bw-flow__progress {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 20px;
  }
  .bw-flow__step {
    display: grid;
    gap: 6px;
    padding: 14px;
    border-radius: 20px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid transparent;
  }
  .bw-flow__step.is-active {
    background: rgba(79, 120, 143, 0.12);
    border-color: rgba(79, 120, 143, 0.22);
  }
  .bw-flow__step.is-complete { background: rgba(32, 23, 19, 0.08); }
  .bw-flow__step-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }
  .bw-flow__step-label {
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-flow__stage { display: none; gap: 16px; }
  .bw-flow__stage.is-active { display: grid; }
  .bw-flow__stage-head { display: grid; gap: 8px; }
  .bw-flow__stage-title {
    margin: 0;
    color: #201713;
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }
  .bw-flow__stage-copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-flow__section { display: grid; gap: 12px; }
  .bw-flow__decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .bw-flow__decision-card {
    display: grid;
    gap: 10px;
    padding: 12px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(32, 23, 19, 0.08);
  }
  .bw-flow__decision-media {
    display: block;
    overflow: hidden;
    border-radius: 16px;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-flow__decision-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__decision-card strong {
    color: #201713;
    font-size: 15px;
    line-height: 1.2;
  }
  .bw-flow__decision-card p {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.6;
  }
  .bw-flow__label {
    color: #201713;
    font-size: 16px;
    font-weight: 700;
  }
  .bw-flow__choices {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 10px;
  }
  .bw-flow__choice {
    display: grid;
    align-content: start;
    gap: 6px;
    min-height: 72px;
    padding: 14px 16px;
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 251, 247, 0.94));
    border: 1px solid rgba(32, 23, 19, 0.08);
    box-shadow: 0 12px 26px rgba(35, 24, 19, 0.05);
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: left;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }
  .bw-flow__choice input { display: none; }
  .bw-flow__choice--image {
    position: relative;
    overflow: hidden;
    min-height: 134px;
    padding: 16px;
    gap: 10px;
    letter-spacing: 0;
    text-transform: none;
    color: #fff7f1;
    background:
      linear-gradient(180deg, rgba(21, 14, 10, 0.06), rgba(21, 14, 10, 0.58)),
      var(--choice-image, linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%));
    background-size: cover;
    background-position: center;
    box-shadow: 0 18px 36px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__choice--image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 14, 10, 0.04), rgba(20, 14, 10, 0.16) 42%, rgba(20, 14, 10, 0.58) 100%);
    pointer-events: none;
  }
  .bw-flow__choice--image .bw-flow__choice-media,
  .bw-flow__choice--image .bw-flow__choice-copy {
    position: relative;
    z-index: 1;
  }
  .bw-flow__choice--image .bw-flow__choice-media {
    min-height: 92px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255, 247, 241, 0.08);
    background: rgba(255, 247, 241, 0.08);
  }
  .bw-flow__choice--image .bw-flow__choice-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__choice--image .bw-flow__choice-title,
  .bw-flow__choice--image .bw-flow__choice-note {
    color: inherit;
  }
  .bw-flow__choice--image .bw-flow__choice-note {
    color: rgba(255, 247, 241, 0.82);
  }
  .bw-flow__choice--image:hover,
  .bw-flow__choice--image:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 22px 44px rgba(35, 24, 19, 0.12);
  }
  .bw-flow__choice.is-selected {
    background:
      linear-gradient(180deg, #241814 0%, #3a2921 100%);
    color: #fff7f1;
    border-color: #241814;
    box-shadow: 0 16px 34px rgba(35, 24, 19, 0.16);
  }
  .bw-flow__choice--image.is-selected {
    background:
      linear-gradient(180deg, rgba(21, 14, 10, 0.12), rgba(21, 14, 10, 0.68)),
      var(--choice-image, linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%));
    border-color: #241814;
    box-shadow: 0 20px 40px rgba(35, 24, 19, 0.16);
  }
  .bw-flow__choice:hover,
  .bw-flow__choice:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(32, 23, 19, 0.16);
    box-shadow: 0 16px 32px rgba(35, 24, 19, 0.08);
  }
  .bw-flow__choices[data-flow-group="type"],
  .bw-flow__choices[data-flow-group="room"],
  .bw-flow__choices[data-flow-group="storage"],
  .bw-flow__choices[data-flow-group="carcass"],
  .bw-flow__choices[data-flow-group="shutter_material"],
  .bw-flow__choices[data-flow-group="finish"],
  .bw-flow__choices[data-flow-group="mirror"] {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .bw-flow__choices[data-flow-group="internals"] {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }
  .bw-flow__choices[data-flow-group="internals"] .bw-flow__choice {
    min-height: 98px;
  }
  .bw-flow__choices[data-flow-group="type"] {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .bw-flow__choice--visual {
    gap: 10px;
    padding: 10px;
    min-height: 0;
    letter-spacing: 0;
    text-transform: none;
  }
  .bw-flow__choice--visual.bw-flow__choice--image {
    padding: 16px;
    min-height: 134px;
    letter-spacing: 0;
    text-transform: none;
  }
  .bw-flow__choice-media {
    min-height: 128px;
    border-radius: 16px;
    overflow: hidden;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-flow__choice--visual.bw-flow__choice--image .bw-flow__choice-media {
    min-height: 92px;
  }
  .bw-flow__choice-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-flow__choice-copy {
    display: grid;
    gap: 4px;
    align-content: start;
  }
  .bw-flow__choice-title {
    color: inherit;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
  }
  .bw-flow__choice-note {
    color: #66554c;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.55;
    text-transform: none;
  }
  .bw-flow__choice.is-selected .bw-flow__choice-note {
    color: rgba(255, 247, 241, 0.84);
  }
  .bw-flow__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-flow__field {
    display: grid;
    gap: 8px;
  }
  .bw-flow__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
  }
  .bw-flow__field input,
  .bw-flow__field select {
    width: 100%;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fffdfb;
    color: #201713;
    font-size: 14px;
  }
  .bw-flow__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 6px;
