</div>

{% render 'modular-estimate-popup', modal_id: 'bw-wardrobe-calc-popup', modal_title: 'Get a wardrobe estimate', context_label: 'Bluewud modular wardrobe' %}

<script>
  (function () {
    var root = document.querySelector('[data-bw-wardrobe-flow]');
    if (!root) return;

    var step = 1;
    var maxStep = 5;
    var hasInteracted = false;
    var stageNodes = Array.prototype.slice.call(root.querySelectorAll('[data-step-panel]'));
    var indicatorNodes = Array.prototype.slice.call(root.querySelectorAll('[data-step-indicator]'));
    var modal = document.getElementById('bw-wardrobe-calc-popup');
    var summaryText = modal ? modal.querySelector('[data-bw-estimate-summary-text]') : null;
    var summaryInput = modal ? modal.querySelector('[data-bw-estimate-summary-input]') : null;
    var contextInput = modal ? modal.querySelector('[data-bw-estimate-context-input]') : null;
    var sourceInput = modal ? modal.querySelector('[data-bw-estimate-source-input]') : null;
    var bandNode = root.querySelector('[data-wardrobe-band]');
    var summaryImage = root.querySelector('[data-summary-visual-image]');
    var summaryCaption = root.querySelector('[data-summary-visual-caption]');
    var wardrobeVisuals = {
      'sliding': {
        src: {{ wardrobe_preview_primary_src | json }},
        alt: {{ wardrobe_preview_primary_alt | json }},
        caption: 'Sliding wardrobes work best when frontage is compact but storage still needs to feel premium and efficient.'
      },
      'hinged': {
        src: {{ wardrobe_preview_secondary_src | json }},
        alt: {{ wardrobe_preview_secondary_alt | json }},
        caption: 'Hinged wardrobes suit rooms where full-bay access and a classic opening rhythm matter more than saving aisle space.'
      },
      'walk-in': {
        src: {{ wardrobe_preview_tertiary_src | json }},
        alt: {{ wardrobe_preview_tertiary_alt | json }},
        caption: 'Walk-in wardrobes need calmer zoning and a stronger dressing flow before the estimate conversation begins.'
      },
      'floor to ceiling': {
        src: {{ wardrobe_preview_quaternary_src | json }},
        alt: {{ wardrobe_preview_quaternary_alt | json }},
        caption: 'Floor-to-ceiling wardrobes turn height into cleaner storage volume and reduce visual clutter across the room.'
      }
    };

    function selectedRadio(name) {
      var node = root.querySelector('input[name="' + name + '"]:checked');
      return node ? node.value : '';
    }
    function setRadioValue(name, value) {
      var node = root.querySelector('input[name="' + name + '"][value="' + value + '"]');
      if (node) node.checked = true;
    }
    function normalizeWardrobeType(type) {
      if (!type) return '';
      var key = String(type).toLowerCase();
      if (key === 'all' || key === 'sliding') return 'Sliding';
      if (key === 'hinged') return 'Hinged';
      if (key === 'walk-in' || key === 'walk in') return 'Walk-in';
      if (key === 'floor to ceiling') return 'Floor to ceiling';
      return '';
    }

    function selectedChecks(group) {
      return Array.prototype.slice.call(root.querySelectorAll('[data-flow-group="' + group + '"] input[type="checkbox"]:checked')).map(function (input) {
        return input.value;
      });
    }

    function applyChoiceVisuals() {
      var visualMap = {
        type: {
          Sliding: {{ wardrobe_preview_primary_src | json }},
          Hinged: {{ wardrobe_preview_secondary_src | json }},
          'Walk-in': {{ wardrobe_preview_tertiary_src | json }},
          'Floor to ceiling': {{ wardrobe_preview_quaternary_src | json }}
        },
        room: {
          'Master bedroom': {{ wardrobe_preview_primary_src | json }},
          'Guest bedroom': {{ wardrobe_preview_secondary_src | json }},
          'Kids bedroom': {{ wardrobe_preview_tertiary_src | json }}
        },
        storage: {
          'Light use': {{ wardrobe_preview_secondary_src | json }},
          'Balanced daily use': {{ wardrobe_preview_primary_src | json }},
          'High storage demand': {{ wardrobe_preview_quaternary_src | json }}
        },
        carcass: {
          'Engineered wood': {{ wardrobe_preview_primary_src | json }},
          Plywood: {{ wardrobe_preview_secondary_src | json }},
          'Need guidance': {{ wardrobe_preview_tertiary_src | json }}
        },
        shutter_material: {
          'Laminate panel': {{ wardrobe_preview_primary_src | json }},
          'Acrylic panel': {{ wardrobe_preview_secondary_src | json }},
          'Mirror / glass': {{ wardrobe_preview_quaternary_src | json }},
          'Profile / mixed finish': {{ wardrobe_preview_tertiary_src | json }}
        },
        finish: {
          'Warm wood + solid shutters': {{ wardrobe_preview_primary_src | json }},
          'Light modern matte': {{ wardrobe_preview_secondary_src | json }},
          'Mirror-led premium': {{ wardrobe_preview_quaternary_src | json }},
          'Need guidance': {{ wardrobe_preview_tertiary_src | json }}
        },
        mirror: {
          'No mirror': {{ wardrobe_preview_primary_src | json }},
          'One mirror panel': {{ wardrobe_preview_secondary_src | json }},
          'Multiple mirror panels': {{ wardrobe_preview_quaternary_src | json }},
          'Need guidance': {{ wardrobe_preview_tertiary_src | json }}
        },
        internals: {
          'Long hanging': {{ wardrobe_preview_primary_src | json }},
          'Short hanging': {{ wardrobe_preview_secondary_src | json }},
          'Drawer stack': {{ wardrobe_preview_tertiary_src | json }},
          'Pull-out accessories': {{ wardrobe_preview_quaternary_src | json }},
          'Digital locker': {{ wardrobe_preview_primary_src | json }},
          'Shoe or linen zone': {{ wardrobe_preview_secondary_src | json }}
        }
      };

      Object.keys(visualMap).forEach(function (group) {
        var cards = root.querySelectorAll('[data-flow-group="' + group + '"] .bw-flow__choice');
        cards.forEach(function (choice) {
          var input = choice.querySelector('input');
          if (!input) return;
          var src = visualMap[group][input.value];
          if (src) {
            choice.classList.add('bw-flow__choice--image');
            choice.style.setProperty('--choice-image', 'url(' + src + ')');
          }
        });
      });
    }

    function inputValue(key) {
      var node = root.querySelector('[data-flow-input="' + key + '"]');
      return node ? node.value : '';
    }

    function toggleChoiceStates() {
      root.querySelectorAll('.bw-flow__choice').forEach(function (choice) {
        var input = choice.querySelector('input');
        if (!input) return;
        choice.classList.toggle('is-selected', !!input.checked);
      });
    }
    function markInteracted() {
      hasInteracted = true;
    }

    function projectBand() {
      var premiumSignals = 0;
      if (selectedRadio('wardrobe_type') === 'Walk-in') premiumSignals += 2;
      if (selectedRadio('wardrobe_type') === 'Floor to ceiling') premiumSignals += 1;
      if (selectedRadio('wardrobe_carcass') === 'Plywood') premiumSignals += 1;
      if (selectedRadio('wardrobe_shutter_material') === 'Mirror / glass') premiumSignals += 2;
      premiumSignals += selectedChecks('internals').length;
      if (premiumSignals >= 5) return 'Statement premium direction';
      if (premiumSignals >= 3) return 'Balanced premium direction';
      return 'Value-led practical direction';
    }

    function updateSummary() {
      toggleChoiceStates();
      var neutralState = !hasInteracted;
      var typeKey = (selectedRadio('wardrobe_type') || '').toLowerCase();
      var room = selectedRadio('room_type');
      var measurements = [inputValue('width') + ' ft', inputValue('height') + ' ft', inputValue('depth') + ' ft'].join(' / ');
      var internals = selectedChecks('internals');
      var loftValue = inputValue('loft');
      var summaryMap = neutralState ? {
        type: 'Choose a type',
        room: 'Add room type',
        measurements: 'Enter width, height, depth',
        build: 'Pick materials and finish',
        features: 'Set storage features',
        mirror: 'Choose mirror direction'
      } : {
        type: selectedRadio('wardrobe_type') || 'Sliding',
        room: room ? room + ' • ' + selectedRadio('storage_intensity') : 'Master bedroom • Balanced daily use',
        measurements: measurements,
        build: [selectedRadio('wardrobe_carcass'), selectedRadio('wardrobe_shutter_material'), selectedRadio('wardrobe_finish')].filter(Boolean).join(' / ') || 'Engineered wood / Laminate panel / Warm wood + solid shutters',
        features: [loftValue, internals.length ? internals.slice(0, 3).join(', ') : 'None selected'].join(' • '),
        mirror: selectedRadio('mirror_need') || 'No mirror'
      };
      Object.keys(summaryMap).forEach(function (key) {
        var node = root.querySelector('[data-summary-' + key + ']');
        if (node) node.textContent = summaryMap[key];
      });
      var visual = wardrobeVisuals[neutralState ? 'sliding' : typeKey] || wardrobeVisuals['sliding'];
      if (summaryImage && visual && visual.src) {
        summaryImage.src = visual.src;
        summaryImage.alt = visual.alt || summaryMap.type;
      }
      if (summaryCaption && visual && visual.caption) {
        summaryCaption.textContent = neutralState ? 'Start with the wardrobe type. The rest of the brief stays neutral until you make selections.' : visual.caption;
      }
      var tagsNode = root.querySelector('[data-summary-tags]');
      if (tagsNode) {
        var tags = neutralState ? [] : [
          summaryMap.type,
          summaryMap.room,
          summaryMap.build.split(' / ')[1] || selectedRadio('wardrobe_shutter_material'),
          summaryMap.features,
          summaryMap.mirror
        ].filter(Boolean).slice(0, 5);
        tagsNode.innerHTML = tags.length ? tags.map(function (tag) {
          return '<span class="bw-flow__summary-tag">' + tag + '</span>';
        }).join('') : '';
      }
      var bandText = projectBand();
      if (bandNode) bandNode.textContent = neutralState ? 'Ready for your brief' : bandText;
      persistPayload('calculator-progress');
    }

    function briefSummary() {
      return [
        'Project: Modular Wardrobe',
        'Type: ' + selectedRadio('wardrobe_type'),
        'Room: ' + selectedRadio('room_type'),
        'Storage intensity: ' + selectedRadio('storage_intensity'),
        'Measurements: ' + inputValue('width') + 'ft / ' + inputValue('height') + 'ft / ' + inputValue('depth') + 'ft',
        'Loft: ' + inputValue('loft'),
        'Carcass: ' + selectedRadio('wardrobe_carcass'),
        'Shutter: ' + selectedRadio('wardrobe_shutter_material'),
        'Finish: ' + selectedRadio('wardrobe_finish'),
        'Internals: ' + (selectedChecks('internals').length ? selectedChecks('internals').join(', ') : 'None'),
        'Mirror: ' + selectedRadio('mirror_need'),
        'City: ' + (inputValue('city') || 'Not shared yet'),
        'Timeline: ' + (inputValue('timeline') || 'Immediate'),
        'Direction: ' + projectBand()
      ].join(' | ');
    }
    function buildPayload(trigger) {
      return {
        projectType: 'Modular Wardrobe',
        projectContext: 'Bluewud modular wardrobe',
        referenceSource: 'Wardrobe calculator',
        projectRoute: window.location.pathname + window.location.search,
        selectedBrief: briefSummary(),
        selectedOptions: {
          wardrobe_type: selectedRadio('wardrobe_type'),
          room_type: selectedRadio('room_type'),
          storage_intensity: selectedRadio('storage_intensity'),
          width_ft: inputValue('width'),
          height_ft: inputValue('height'),
          depth_ft: inputValue('depth'),
          loft: inputValue('loft'),
          carcass_material: selectedRadio('wardrobe_carcass'),
          shutter_material: selectedRadio('wardrobe_shutter_material'),
          finish: selectedRadio('wardrobe_finish'),
          internals: selectedChecks('internals'),
          mirror_need: selectedRadio('mirror_need'),
          city: inputValue('city'),
          timeline: inputValue('timeline') || 'Immediate',
          project_direction: projectBand(),
          source_trigger: trigger || 'calculator-progress'
        },
        trigger: trigger || 'calculator-progress'
      };
    }
    function persistPayload(trigger) {
      var payload = buildPayload(trigger);
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.save(payload);
      }
      return payload;
    }
    function applyWardrobePreset(type) {
      var normalized = normalizeWardrobeType(type);
      if (!normalized) return;
      setRadioValue('wardrobe_type', normalized);
      step = 1;
      updateSummary();
      paintSteps();
    }

    function paintSteps() {
      stageNodes.forEach(function (panel) {
        panel.classList.toggle('is-active', Number(panel.getAttribute('data-step-panel')) === step);
      });
      indicatorNodes.forEach(function (indicator) {
        var indicatorStep = Number(indicator.getAttribute('data-step-indicator'));
        indicator.classList.toggle('is-active', indicatorStep === step);
        indicator.classList.toggle('is-complete', indicatorStep < step);
      });
    }

    function openPopup() {
      if (!modal) return;
      var payload = persistPayload('calculator-submit');
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.fillModal(modal, payload);
      } else {
        if (summaryText) summaryText.textContent = payload.selectedBrief;
        if (summaryInput) summaryInput.value = payload.selectedBrief;
        if (contextInput) contextInput.value = payload.projectContext;
        if (sourceInput) sourceInput.value = payload.referenceSource;
      }
      modal.classList.add('is-open');
      document.body.classList.add('bw-header-drawer-open');
    }

    function closePopup() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('bw-header-drawer-open');
    }

    root.addEventListener('click', function (event) {
      var choice = event.target.closest('.bw-flow__choice');
      if (choice) {
        var input = choice.querySelector('input');
        if (input) {
          if (input.type === 'checkbox') input.checked = !input.checked;
          else input.checked = true;
          updateSummary();
        }
        return;
      }

      if (event.target.closest('[data-flow-next]')) {
        if (step < maxStep) step += 1;
        paintSteps();
        return;
      }

      if (event.target.closest('[data-flow-back]')) {
        if (step > 1) step -= 1;
        paintSteps();
        return;
      }

      if (event.target.closest('[data-bw-wardrobe-popup-open]')) {
        openPopup();
      }
    });

    root.addEventListener('change', function () {
      markInteracted();
      updateSummary();
    });
    root.addEventListener('input', function () {
      markInteracted();
      updateSummary();
    });
    root.addEventListener('bw:wardrobe-type-select', function (event) {
      if (event.detail && event.detail.type) {
        applyWardrobePreset(event.detail.type);
      }
    });

    if (modal) {
      modal.querySelectorAll('[data-bw-estimate-close]').forEach(function (control) {
        control.addEventListener('click', closePopup);
      });
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closePopup();
      });
    }

    applyChoiceVisuals();
    updateSummary();
    var params = new URLSearchParams(window.location.search);
    applyWardrobePreset(params.get('type'));
    paintSteps();
  })();
</script>
