<div class="bw-flow" data-bw-wardrobe-flow>
  {% unless is_embedded %}
    <section class="bw-planning-rail">
      <div class="bw-planning-rail__items" aria-label="Wardrobe planning navigation">
        <a class="bw-planning-rail__link" href="{{ wardrobe_main_url }}">All wardrobes</a>
        <a class="bw-planning-rail__link" href="{{ wardrobe_sliding_url }}">Sliding</a>
        <a class="bw-planning-rail__link" href="{{ wardrobe_hinged_url }}">Hinged</a>
        <a class="bw-planning-rail__link" href="{{ wardrobe_walkin_url }}">Walk-in</a>
        <a class="bw-planning-rail__link bw-planning-rail__link--accent is-current" href="{{ calculator_url }}">Wardrobe Calculator</a>
      </div>
    </section>
  {% endunless %}

  <div class="bw-flow__shell">
    <section class="bw-flow__panel">
      <div class="bw-flow__head">
        <span class="bw-flow__eyebrow">Wardrobe planning workflow</span>
        <h2 class="bw-flow__title">Wardrobe Cost Calculator</h2>
        <p class="bw-flow__copy">Choose the wardrobe format, capture the room basics, and keep the brief focused enough for Bluewud to respond well.</p>
      </div>

      <div class="bw-flow__journey">
        <a class="bw-flow__preview-card" href="{{ wardrobe_sliding_url }}">
          <div class="bw-flow__preview-media">
            <img src="{{ wardrobe_preview_primary_src }}" alt="{{ wardrobe_preview_primary_alt }}" loading="lazy" width="900" height="675">
          </div>
          <div class="bw-flow__preview-copy">
            <span class="bw-flow__preview-kicker">Space-saving format</span>
            <h3 class="bw-flow__preview-title">Sliding wardrobes</h3>
            <p class="bw-flow__preview-text">Compact frontage, clean movement, and a room-saving door system.</p>
          </div>
        </a>
        <a class="bw-flow__preview-card" href="{{ wardrobe_hinged_url }}">
          <div class="bw-flow__preview-media">
            <img src="{{ wardrobe_preview_secondary_src }}" alt="{{ wardrobe_preview_secondary_alt }}" loading="lazy" width="900" height="675">
          </div>
          <div class="bw-flow__preview-copy">
            <span class="bw-flow__preview-kicker">Full-access format</span>
            <h3 class="bw-flow__preview-title">Hinged wardrobes</h3>
            <p class="bw-flow__preview-text">Full opening, direct access, and a classic wardrobe read.</p>
          </div>
        </a>
        <a class="bw-flow__preview-card" href="{{ wardrobe_walkin_url }}">
          <div class="bw-flow__preview-media">
            <img src="{{ wardrobe_preview_tertiary_src }}" alt="{{ wardrobe_preview_tertiary_alt }}" loading="lazy" width="900" height="675">
          </div>
          <div class="bw-flow__preview-copy">
            <span class="bw-flow__preview-kicker">Suite-led format</span>
            <h3 class="bw-flow__preview-title">Walk-in wardrobes</h3>
            <p class="bw-flow__preview-text">Dedicated dressing flow, larger zoning, and premium storage intent.</p>
          </div>
        </a>
        <a class="bw-flow__preview-card" href="{{ wardrobe_main_url }}#floor-to-ceiling">
          <div class="bw-flow__preview-media">
            <img src="{{ wardrobe_preview_quaternary_src }}" alt="{{ wardrobe_preview_quaternary_alt }}" loading="lazy" width="900" height="675">
          </div>
          <div class="bw-flow__preview-copy">
            <span class="bw-flow__preview-kicker">Built-in format</span>
            <h3 class="bw-flow__preview-title">Floor-to-ceiling wardrobes</h3>
            <p class="bw-flow__preview-text">Full-height storage, loft-ready planning, and a more seamless built-in room line.</p>
          </div>
        </a>
      </div>

      <div class="bw-flow__progress">
        <div class="bw-flow__step is-active" data-step-indicator="1"><span class="bw-flow__step-index">01</span><span class="bw-flow__step-label">Type</span></div>
        <div class="bw-flow__step" data-step-indicator="2"><span class="bw-flow__step-index">02</span><span class="bw-flow__step-label">Measurements</span></div>
        <div class="bw-flow__step" data-step-indicator="3"><span class="bw-flow__step-index">03</span><span class="bw-flow__step-label">Build</span></div>
        <div class="bw-flow__step" data-step-indicator="4"><span class="bw-flow__step-index">04</span><span class="bw-flow__step-label">Internals</span></div>
        <div class="bw-flow__step" data-step-indicator="5"><span class="bw-flow__step-index">05</span><span class="bw-flow__step-label">Review</span></div>
      </div>

      <div class="bw-flow__stage is-active" data-step-panel="1">
        <div class="bw-flow__stage-head">
          <h3 class="bw-flow__stage-title">Start with the wardrobe format and room intent</h3>
          <p class="bw-flow__stage-copy">Set the access style and room context first so the rest of the discussion stays specific.</p>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Wardrobe type</div>
          <div class="bw-flow__choices" data-flow-group="type">
            <label class="bw-flow__choice bw-flow__choice--visual is-selected">
              <input type="radio" name="wardrobe_type" value="Sliding" checked>
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_primary_src }}" alt="{{ wardrobe_preview_primary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Sliding</span><span class="bw-flow__choice-note">Best when the room needs cleaner movement and tighter frontage clearance.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--visual">
              <input type="radio" name="wardrobe_type" value="Hinged">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_secondary_src }}" alt="{{ wardrobe_preview_secondary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Hinged</span><span class="bw-flow__choice-note">Great for full-bay access and more familiar daily use in larger bedrooms.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--visual">
              <input type="radio" name="wardrobe_type" value="Walk-in">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_tertiary_src }}" alt="{{ wardrobe_preview_tertiary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Walk-in</span><span class="bw-flow__choice-note">For premium suites that need dressing flow, open access, and broader zoning.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--visual">
              <input type="radio" name="wardrobe_type" value="Floor to ceiling">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_quaternary_src }}" alt="{{ wardrobe_preview_quaternary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Floor to ceiling</span><span class="bw-flow__choice-note">Use when the brief prioritizes full-height storage, loft integration, and a built-in look.</span></span>
            </label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Bedroom type</div>
          <div class="bw-flow__choices" data-flow-group="room">
            <label class="bw-flow__choice bw-flow__choice--image is-selected"><input type="radio" name="room_type" value="Master bedroom" checked>
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_primary_src }}" alt="{{ wardrobe_preview_primary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Master Bedroom</span><span class="bw-flow__choice-note">Primary suite planning with calmer storage balance and daily-use comfort.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--image"><input type="radio" name="room_type" value="Guest bedroom">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_secondary_src }}" alt="{{ wardrobe_preview_secondary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Guest Bedroom</span><span class="bw-flow__choice-note">Cleaner storage depth for a lighter-use room that still needs to look polished.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--image"><input type="radio" name="room_type" value="Kids bedroom">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_tertiary_src }}" alt="{{ wardrobe_preview_tertiary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Kids Bedroom</span><span class="bw-flow__choice-note">Flexible storage that can handle changing needs without making the room feel heavy.</span></span>
            </label>
          </div>
        </div>
        <div class="bw-flow__section">
          <div class="bw-flow__label">Storage intensity</div>
          <div class="bw-flow__choices" data-flow-group="storage">
            <label class="bw-flow__choice bw-flow__choice--image"><input type="radio" name="storage_intensity" value="Light use">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_secondary_src }}" alt="{{ wardrobe_preview_secondary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Light Use</span><span class="bw-flow__choice-note">For simpler storage needs, fewer modules, and a lighter visual footprint.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--image is-selected"><input type="radio" name="storage_intensity" value="Balanced daily use" checked>
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_primary_src }}" alt="{{ wardrobe_preview_primary_alt }}" loading="lazy" width="720" height="540"></span>
              <span class="bw-flow__choice-copy"><span class="bw-flow__choice-title">Balanced Daily Use</span><span class="bw-flow__choice-note">The practical middle ground for most bedrooms and family wardrobe briefs.</span></span>
            </label>
            <label class="bw-flow__choice bw-flow__choice--image"><input type="radio" name="storage_intensity" value="High storage demand">
              <span class="bw-flow__choice-media"><img src="{{ wardrobe_preview_quaternary_src }}" alt="{{ wardrobe_preview_quaternary_alt }}" loading="lazy" width="720" height="540"></span>
