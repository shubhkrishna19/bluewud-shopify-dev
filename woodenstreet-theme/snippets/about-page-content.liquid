<style>
  .bw-about {
    position: relative;
    display: grid;
    gap: 22px;
    overflow: hidden;
  }

  .bw-about::before,
  .bw-about::after {
    content: "";
    position: absolute;
    inset: auto;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(8px);
    opacity: 0.85;
  }

  .bw-about::before {
    top: -40px;
    right: -70px;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle, rgba(79, 120, 143, 0.14) 0%, rgba(79, 120, 143, 0.02) 58%, transparent 72%);
  }

  .bw-about::after {
    left: -80px;
    bottom: 180px;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(166, 106, 67, 0.12) 0%, rgba(166, 106, 67, 0.02) 58%, transparent 72%);
  }

  .bw-about__hero,
  .bw-about__panel,
  .bw-about__tile,
  .bw-about__editorial {
    position: relative;
    z-index: 1;
    border-radius: 30px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-about__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
    gap: 18px;
    padding: 18px;
    background: linear-gradient(135deg, rgba(255, 251, 247, 0.78), rgba(255, 251, 247, 0.92));
  }

  .bw-about__story,
  .bw-about__snapshot,
  .bw-about__panel,
  .bw-about__editorial,
  .bw-about__tile {
    background: rgba(255, 251, 247, 0.94);
  }

  .bw-about__story {
    padding: 32px;
    display: grid;
    gap: 18px;
    background:
      radial-gradient(circle at top right, rgba(79, 120, 143, 0.1), transparent 26%),
      linear-gradient(180deg, #fffaf6 0%, #f6ede5 100%);
  }

  .bw-about__eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 32px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-about__title {
    margin: 0;
    color: #201713;
    font-size: clamp(34px, 4.8vw, 60px);
    line-height: 0.98;
    letter-spacing: -0.05em;
    max-width: 11ch;
  }

  .bw-about__title span {
    color: #355a6d;
  }

  .bw-about__copy {
    margin: 0;
    color: #64544a;
    font-size: 16px;
    line-height: 1.9;
    max-width: 68ch;
  }

  .bw-about__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .bw-about__chip {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bw-about__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .bw-about__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-about__button--ghost {
    background: transparent;
    color: #201713;
    border: 1px solid rgba(32, 23, 19, 0.12);
  }

  .bw-about__signal {
    padding: 28px;
    display: grid;
    gap: 14px;
    background:
      radial-gradient(circle at top right, rgba(166, 106, 67, 0.12), transparent 28%),
      linear-gradient(180deg, #fffaf6 0%, #f7efe7 100%);
  }

  .bw-about__signal-title {
    margin: 0;
    color: #201713;
    font-size: 22px;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .bw-about__signal-copy {
    margin: 0;
    color: #64544a;
    font-size: 14px;
    line-height: 1.8;
  }

  .bw-about__signal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .bw-about__signal-tag {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-about__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .bw-about__stat {
    padding: 18px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    display: grid;
    gap: 6px;
  }

  .bw-about__stat-value {
    color: #201713;
    font-size: 28px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .bw-about__stat-label {
    margin: 0;
    color: #66554c;
    font-size: 12px;
    line-height: 1.6;
  }

  .bw-about__signal-list {
    display: grid;
    gap: 10px;
    margin: 2px 0 0;
    padding: 0;
    list-style: none;
  }

  .bw-about__signal-list li {
    position: relative;
    padding-left: 18px;
    color: #64544a;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-about__signal-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #4f788f;
  }

  .bw-about__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .bw-about__tile {
    padding: 20px;
    display: grid;
    gap: 10px;
  }

  .bw-about__tile-label {
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-about__tile-title {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .bw-about__tile-copy {
    margin: 0;
    color: #64544a;
    font-size: 14px;
    line-height: 1.75;
  }

  .bw-about__panel {
    padding: 28px;
    display: grid;
    gap: 16px;
    background: rgba(255, 251, 247, 0.94);
  }

  .bw-about__panel-header {
    display: grid;
    gap: 8px;
  }

  .bw-about__panel-kicker {
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-about__panel-title {
    margin: 0;
    color: #201713;
    font-size: 26px;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .bw-about__panel-copy {
    margin: 0;
    color: #64544a;
    font-size: 15px;
    line-height: 1.8;
    max-width: 68ch;
  }

  .bw-about__timeline {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .bw-about__step {
    padding: 18px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    display: grid;
    gap: 8px;
  }

  .bw-about__step-index {
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-about__step-title {
    margin: 0;
    color: #201713;
    font-size: 17px;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .bw-about__step-copy {
    margin: 0;
    color: #64544a;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-about__editorial {
    padding: 28px;
    display: grid;
    gap: 18px;
  }

  .bw-about__editorial-head {
    display: grid;
    gap: 8px;
  }

  .bw-about__editorial-kicker {
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-about__editorial-title {
    margin: 0;
    color: #201713;
    font-size: 26px;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .bw-about__editorial-copy {
    margin: 0;
    color: #64544a;
    font-size: 15px;
    line-height: 1.8;
    max-width: 70ch;
  }

  .bw-about__editorial-body {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 16px;
  }

  .bw-about__editorial-rte {
    color: #4d4038;
    font-size: 15px;
    line-height: 1.9;
  }

  .bw-about__editorial-rte h1,
  .bw-about__editorial-rte h2,
  .bw-about__editorial-rte h3,
  .bw-about__editorial-rte h4 {
    color: #201713;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin: 1.5em 0 0.7em;
  }

  .bw-about__editorial-rte h1:first-child,
  .bw-about__editorial-rte h2:first-child,
  .bw-about__editorial-rte h3:first-child,
  .bw-about__editorial-rte h4:first-child {
    margin-top: 0;
  }

  .bw-about__editorial-rte p,
  .bw-about__editorial-rte ul,
  .bw-about__editorial-rte ol,
  .bw-about__editorial-rte blockquote {
    margin: 0 0 1.1em;
  }

  .bw-about__editorial-rte ul,
  .bw-about__editorial-rte ol {
    padding-left: 1.25em;
  }

  .bw-about__facts {
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .bw-about__fact {
    padding: 18px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    display: grid;
    gap: 6px;
  }

  .bw-about__fact-label {
    color: #8a684f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-about__fact-title {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .bw-about__fact-copy {
    margin: 0;
    color: #64544a;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-about__note {
    padding: 18px 20px;
    border-radius: 22px;
    background: rgba(53, 90, 109, 0.08);
    color: #365464;
    font-size: 14px;
    line-height: 1.75;
  }

  @media (max-width: 1100px) {
    .bw-about__hero,
    .bw-about__grid,
    .bw-about__timeline,
    .bw-about__editorial-body {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .bw-about__hero,
    .bw-about__grid,
    .bw-about__timeline,
    .bw-about__stats,
    .bw-about__highlights,
    .bw-about__editorial-body {
      grid-template-columns: 1fr;
    }

    .bw-about__story,
    .bw-about__signal,
    .bw-about__panel,
    .bw-about__editorial,
    .bw-about__tile {
      padding: 20px;
      border-radius: 24px;
    }
  }
</style>

{% liquid
  assign about_content = page.content | strip
  assign has_about_content = false

  if about_content != blank
    assign has_about_content = true
  endif
%}

<div class="bw-about">
  <section class="bw-about__hero">
    <div class="bw-about__story">
      <span class="bw-about__eyebrow">Designs for everyone</span>
      <h2 class="bw-about__title">Bluewud <span>designs for everyone</span>.</h2>
      <p class="bw-about__copy">Bluewud designs, manufactures, and markets a range of contemporary furniture and decor products. The brand is built to connect with how modern Indian homes live, store, and present themselves every day.</p>
      <p class="bw-about__copy">What started in September 2015 with laptop tables that quickly became bestsellers has grown into a broader product family spanning living, study, storage, display, and modular planning categories.</p>

      <div class="bw-about__chips" aria-label="Bluewud product range">
        <a class="bw-about__chip" href="/collections/living-room">TV units</a>
        <a class="bw-about__chip" href="/collections/study-tables">Study tables</a>
        <a class="bw-about__chip" href="/collections/shoe-racks">Shoe racks</a>
        <a class="bw-about__chip" href="/collections/wall-shelves">Wall shelves</a>
        <a class="bw-about__chip" href="/collections/book-shelves">Book shelves</a>
        <a class="bw-about__chip" href="/collections/newest-products-1">New arrivals</a>
      </div>

      <div class="bw-about__cta">
        <a class="bw-about__button" href="/collections/newest-products-1">Explore products</a>
        <a class="bw-about__button bw-about__button--ghost" href="/pages/contact-us">Talk to Bluewud</a>
      </div>
    </div>

  <aside class="bw-about__signal">
    <p class="bw-about__signal-title">A brand story with enough structure to earn trust fast.</p>
    <p class="bw-about__signal-copy">The page is framed to communicate scale, in-house capability, and the customer-facing support that makes large furniture purchases feel more manageable.</p>
    <div class="bw-about__signal-tags" aria-label="Bluewud trust signals">
      <span class="bw-about__signal-tag">In-house design</span>
      <span class="bw-about__signal-tag">Noida manufacturing</span>
      <span class="bw-about__signal-tag">Direct support</span>
    </div>

    <div class="bw-about__stats">
        <div class="bw-about__stat">
          <div class="bw-about__stat-value">2015</div>
          <p class="bw-about__stat-label">Started with laptop tables that quickly became bestsellers.</p>
        </div>
        <div class="bw-about__stat">
          <div class="bw-about__stat-value">50</div>
          <p class="bw-about__stat-label">People across design, engineering, craft, and operations.</p>
        </div>
        <div class="bw-about__stat">
          <div class="bw-about__stat-value">30k</div>
          <p class="bw-about__stat-label">Sqft Noida manufacturing unit with specialized machinery.</p>
        </div>
        <div class="bw-about__stat">
          <div class="bw-about__stat-value">1+</div>
          <p class="bw-about__stat-label">Patent held, with more design registrations in progress.</p>
        </div>
      </div>

      <ul class="bw-about__signal-list">
        <li>In-house design, 3D visualization, engineering, and manufacturing stay close to each product launch.</li>
        <li>The business keeps expanding with practical furniture categories that still feel coherent as a brand.</li>
        <li>Direct support remains available for product questions, order guidance, and installation-related help.</li>
      </ul>
    </aside>
  </section>

  <section class="bw-about__grid">
    <article class="bw-about__tile">
      <span class="bw-about__tile-label">Leadership</span>
      <h3 class="bw-about__tile-title">Abhinav Singh leads the brand.</h3>
      <p class="bw-about__tile-copy">Bluewud is led by Abhinav Singh, Founder and CEO, a B.Tech graduate from IIT Bombay, batch of 2005, with experience across design, manufacturing, and marketing-led businesses.</p>
    </article>

    <article class="bw-about__tile">
      <span class="bw-about__tile-label">Design centre</span>
      <h3 class="bw-about__tile-title">Ideas are refined in-house.</h3>
      <p class="bw-about__tile-copy">Product designers, 3D artists, engineers, and craftsmen iterate carefully before products are released to customers.</p>
    </article>

    <article class="bw-about__tile">
      <span class="bw-about__tile-label">Manufacturing</span>
      <h3 class="bw-about__tile-title">Noida production with serious tooling.</h3>
      <p class="bw-about__tile-copy">The facility is equipped with computer-controlled cutters, edge banders, polishers, laser cutters, sanders, and other specialized machinery.</p>
    </article>

    <article class="bw-about__tile">
      <span class="bw-about__tile-label">Future range</span>
      <h3 class="bw-about__tile-title">The catalogue is still expanding.</h3>
      <p class="bw-about__tile-copy">Sofas, beds, and dining tables are under design phase while the current range continues to grow across home and decor categories.</p>
    </article>
  </section>

  <section class="bw-about__panel">
    <div class="bw-about__panel-header">
      <span class="bw-about__panel-kicker">What Bluewud makes</span>
      <h3 class="bw-about__panel-title">A practical range with enough breadth to furnish real homes.</h3>
      <p class="bw-about__panel-copy">The current assortment includes TV units, coffee tables, laptop tables, study tables, shoe racks, wall clocks, wall shelves, book shelves, key holders, remote holders, dressing table mirrors, and more.</p>
    </div>

    <div class="bw-about__timeline">
      <article class="bw-about__step">
        <span class="bw-about__step-index">01 / Origin</span>
        <h4 class="bw-about__step-title">Start from one bestseller, then expand.</h4>
        <p class="bw-about__step-copy">The brand grew from laptop tables into a broader furniture system around what customers kept choosing again.</p>
      </article>

      <article class="bw-about__step">
        <span class="bw-about__step-index">02 / Build</span>
        <h4 class="bw-about__step-title">Prototype, review, refine, then launch.</h4>
        <p class="bw-about__step-copy">Products move through design and production carefully so the final offer feels more dependable and less generic.</p>
      </article>

      <article class="bw-about__step">
        <span class="bw-about__step-index">03 / Support</span>
        <h4 class="bw-about__step-title">A customer-facing team stays reachable.</h4>
        <p class="bw-about__step-copy">Call, WhatsApp, or email the Bluewud team if you need product guidance, order support, or installation help.</p>
      </article>
    </div>
  </section>

  {% if has_about_content %}
    <section class="bw-about__editorial">
      <div class="bw-about__editorial-head">
        <span class="bw-about__editorial-kicker">Brand story, editable</span>
        <h3 class="bw-about__editorial-title">Shopify content still has a place here.</h3>
        <p class="bw-about__editorial-copy">This shell keeps the page structured and premium, while the live page body remains editable in Shopify so the team can refine wording without code changes.</p>
      </div>

      <div class="bw-about__editorial-body">
        <div class="bw-about__editorial-rte">
          {{ page.content }}
        </div>

        <div class="bw-about__facts">
          <div class="bw-about__fact">
            <span class="bw-about__fact-label">For shoppers</span>
            <h4 class="bw-about__fact-title">A calmer way to understand the brand.</h4>
            <p class="bw-about__fact-copy">The layout keeps the story, capability, and product breadth easy to scan before the customer moves back into browsing.</p>
          </div>
          <div class="bw-about__fact">
            <span class="bw-about__fact-label">For conversion</span>
            <h4 class="bw-about__fact-title">The next step stays obvious.</h4>
            <p class="bw-about__fact-copy">Browse products, talk to the team, or move into modular planning from the same page without making the user hunt for the route.</p>
          </div>
          <div class="bw-about__note">
            Bluewud keeps the visual language calm and premium, but the content remains practical: clear categories, in-house design, a working factory, and direct support when customers need it.
          </div>
        </div>
      </div>
    </section>
  {% endif %}
</div>
