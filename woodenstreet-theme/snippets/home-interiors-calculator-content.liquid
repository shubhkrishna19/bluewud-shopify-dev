  }
  .bw-hi__journey-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-hi__progress {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }
  .bw-hi__progress-card {
    display: grid;
    gap: 8px;
    padding: 18px 18px 16px;
    border-radius: 22px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.05);
  }
  .bw-hi__progress-step {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #6f584c;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-hi__progress-card h3 {
    margin: 0;
    color: #201713;
    font-size: 16px;
    line-height: 1.2;
  }
  .bw-hi__progress-card p {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-hi__journey-link,
