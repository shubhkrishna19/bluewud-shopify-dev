{% liquid
  assign contact_url = '/pages/contact-us'
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign kitchen_calculator_url = '/collections/kitchen-racks#kitchen-calculator'
  assign wardrobe_calculator_url = '/collections/wardrobe#wardrobe-calculator'
  assign estimate_url = '/pages/get-free-estimate'

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
%}

<style>
  .bw-hi { display: grid; gap: 22px; }
  .bw-hi__hero {
    padding: 28px 30px;
    border-radius: 32px;
    background:
      radial-gradient(circle at top left, rgba(166, 106, 67, 0.16), transparent 28%),
      linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
    display: grid;
    gap: 18px;
  }
  .bw-hi__hero-head {
    display: grid;
    gap: 10px;
    max-width: 80ch;
  }
  .bw-hi__hero-eyebrow {
    color: rgba(255, 247, 241, 0.78);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-hi__hero-title {
    margin: 0;
    color: #fff7f1;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }
  .bw-hi__hero-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.84);
    font-size: 15px;
    line-height: 1.8;
    max-width: 70ch;
  }
  .bw-hi__hero-surface {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 16px;
  }
  .bw-hi__hero-panel {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 247, 241, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.12);
  }
  .bw-hi__hero-panel-title {
    margin: 0 0 8px;
    color: #fff7f1;
    font-size: 18px;
    font-weight: 700;
  }
  .bw-hi__hero-panel-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.82);
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-hi__roadmap {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-hi__roadmap-card {
    display: grid;
    gap: 10px;
    padding: 20px 22px;
    border-radius: 24px;
