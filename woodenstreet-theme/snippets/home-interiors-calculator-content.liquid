{% liquid
  assign contact_url = '/pages/contact-us'
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign kitchen_calculator_url = '/pages/modular-kitchen-cost-calculator'
  assign wardrobe_calculator_url = '/pages/modular-wardrobe-cost-calculator'
  assign estimate_url = '/pages/get-free-estimate'
  assign living_collection = collections['living-room']
  assign bedroom_collection = collections['bed-room']
  assign wardrobe_collection = collections['wardrobe']
  assign kitchen_collection = collections['kitchen-racks']
  assign study_collection = collections['study-tables']
  assign dining_collection = collections['coffee-table']
  assign living_preview = blank
  assign bedroom_preview = blank
  assign wardrobe_preview = blank
  assign kitchen_preview = blank
  assign study_preview = blank
  assign dining_preview = blank
  assign living_preview_src = blank
  assign bedroom_preview_src = blank
  assign wardrobe_preview_src = blank
  assign study_preview_src = blank
  assign dining_preview_src = blank
  assign living_preview_alt = 'Bluewud living room planning preview'
  assign bedroom_preview_alt = 'Bluewud bedroom planning preview'
  assign wardrobe_preview_alt = 'Bluewud wardrobe planning preview'
  assign study_preview_alt = 'Bluewud study planning preview'
  assign dining_preview_alt = 'Bluewud dining planning preview'
  assign kitchen_preview_src = 'modular-kitchen-light-oak-l-shape.png' | asset_url
  assign kitchen_preview_alt = 'Bluewud modular kitchen planning preview'

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif

  if living_collection != blank
    if living_collection.image != blank
      assign living_preview = living_collection.image
    elsif living_collection.products.first.featured_image != blank
      assign living_preview = living_collection.products.first.featured_image
    endif
  endif
  if bedroom_collection != blank
    if bedroom_collection.image != blank
      assign bedroom_preview = bedroom_collection.image
    elsif bedroom_collection.products.first.featured_image != blank
      assign bedroom_preview = bedroom_collection.products.first.featured_image
    endif
  endif
  if wardrobe_collection != blank
    if wardrobe_collection.image != blank
      assign wardrobe_preview = wardrobe_collection.image
    elsif wardrobe_collection.products.first.featured_image != blank
      assign wardrobe_preview = wardrobe_collection.products.first.featured_image
    endif
  endif
  if kitchen_collection != blank
    if kitchen_collection.image != blank
      assign kitchen_preview = kitchen_collection.image
      assign kitchen_preview_src = kitchen_collection.image | image_url: width: 1200
      assign kitchen_preview_alt = kitchen_collection.title | default: kitchen_preview_alt
    elsif kitchen_collection.products.first.featured_image != blank
      assign kitchen_preview = kitchen_collection.products.first.featured_image
      assign kitchen_preview_src = kitchen_collection.products.first.featured_image | image_url: width: 1200
      assign kitchen_preview_alt = kitchen_collection.products.first.title | default: kitchen_preview_alt
    endif
  endif
  if study_collection != blank
    if study_collection.image != blank
      assign study_preview = study_collection.image
    elsif study_collection.products.first.featured_image != blank
      assign study_preview = study_collection.products.first.featured_image
    endif
  endif
  if dining_collection != blank
    if dining_collection.image != blank
      assign dining_preview = dining_collection.image
    elsif dining_collection.products.first.featured_image != blank
      assign dining_preview = dining_collection.products.first.featured_image
    endif
  endif

  if living_preview != blank
    assign living_preview_src = living_preview | image_url: width: 1200
    assign living_preview_alt = living_collection.title | default: living_preview_alt
  elsif bedroom_preview != blank
    assign living_preview_src = bedroom_preview | image_url: width: 1200
    assign living_preview_alt = bedroom_collection.title | default: living_preview_alt
  else
    assign living_preview_src = kitchen_preview_src
  endif

  if bedroom_preview != blank
    assign bedroom_preview_src = bedroom_preview | image_url: width: 1200
    assign bedroom_preview_alt = bedroom_collection.title | default: bedroom_preview_alt
  elsif living_preview != blank
    assign bedroom_preview_src = living_preview | image_url: width: 1200
    assign bedroom_preview_alt = living_collection.title | default: bedroom_preview_alt
  else
    assign bedroom_preview_src = kitchen_preview_src
  endif

  if wardrobe_preview != blank
    assign wardrobe_preview_src = wardrobe_preview | image_url: width: 1200
    assign wardrobe_preview_alt = wardrobe_collection.title | default: wardrobe_preview_alt
  elsif bedroom_preview != blank
    assign wardrobe_preview_src = bedroom_preview | image_url: width: 1200
    assign wardrobe_preview_alt = bedroom_collection.title | default: wardrobe_preview_alt
  else
    assign wardrobe_preview_src = kitchen_preview_src
  endif

  if study_preview != blank
    assign study_preview_src = study_preview | image_url: width: 1200
    assign study_preview_alt = study_collection.title | default: study_preview_alt
  elsif living_preview != blank
    assign study_preview_src = living_preview | image_url: width: 1200
    assign study_preview_alt = living_collection.title | default: study_preview_alt
  else
    assign study_preview_src = kitchen_preview_src
  endif

  if dining_preview != blank
    assign dining_preview_src = dining_preview | image_url: width: 1200
    assign dining_preview_alt = dining_collection.title | default: dining_preview_alt
  elsif living_preview != blank
    assign dining_preview_src = living_preview | image_url: width: 1200
    assign dining_preview_alt = living_collection.title | default: dining_preview_alt
  else
    assign dining_preview_src = kitchen_preview_src
  endif
%}

<style>
  .bw-hi { display: grid; gap: 22px; }
  .bw-hi > .bw-planning-rail { order: -2; }
  .bw-hi__shell { order: -1; }
  .bw-hi__guide { order: 0; }
  .bw-hi__hero,
  .bw-hi__progress { order: 1; }
  .bw-hi__hero {
    padding: 28px 30px;
    border-radius: 32px;
    background:
      radial-gradient(circle at top left, rgba(166, 106, 67, 0.16), transparent 28%),
      linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
    display: grid;
    gap: 18px;
  }
  .bw-hi__hero-head {
    display: grid;
    gap: 10px;
    max-width: 80ch;
  }
  .bw-hi__hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }
  .bw-hi__hero-pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 247, 241, 0.12);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-hi__hero-eyebrow {
    color: rgba(255, 247, 241, 0.78);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-hi__hero-title {
    margin: 0;
    color: #fff7f1;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }
  .bw-hi__hero-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.84);
    font-size: 15px;
    line-height: 1.8;
    max-width: 70ch;
  }
  .bw-hi__hero-surface {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 16px;
  }
  .bw-hi__hero-panel {
    display: grid;
    gap: 10px;
    align-content: start;
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 247, 241, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.12);
  }
  .bw-hi__hero-panel-title {
    margin: 0 0 8px;
    color: #fff7f1;
    font-size: 18px;
    font-weight: 700;
  }
  .bw-hi__hero-panel-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.82);
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-hi__hero-visual {
    display: grid;
    gap: 12px;
    padding: 18px;
    border-radius: 24px;
    background: rgba(255, 247, 241, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.12);
  }
  .bw-hi__hero-visual-strip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .bw-hi__hero-visual-card {
    min-height: 126px;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-hi__hero-visual-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-hi__hero-visual-card span {
    position: absolute;
    left: 12px;
    bottom: 12px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.78);
    color: #fff7f1;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-hi__hero-visual-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.84);
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-hi__roadmap {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-hi__roadmap-card {
    display: grid;
    gap: 10px;
    padding: 20px 22px;
    border-radius: 24px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.05);
  }
  .bw-hi__roadmap-step {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #6f584c;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-hi__roadmap-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
  }
  .bw-hi__roadmap-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-hi__journey {
    padding: 22px 24px;
    border-radius: 28px;
    background: linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
    display: grid;
    gap: 16px;
  }
  .bw-hi__journey-head {
    display: grid;
    gap: 8px;
    max-width: 78ch;
  }
  .bw-hi__journey-eyebrow {
    color: rgba(255, 247, 241, 0.78);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-hi__journey-title {
    margin: 0;
    color: #fff7f1;
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }
  .bw-hi__journey-copy {
    margin: 0;
    color: rgba(255, 247, 241, 0.82);
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-hi__journey-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-hi__progress {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .bw-hi__progress-card {
    display: grid;
    gap: 8px;
    padding: 18px 18px 16px;
    border-radius: 22px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.05);
  }
  .bw-hi__progress-card--visual {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 251, 247, 0.96)),
      radial-gradient(circle at top right, rgba(166, 106, 67, 0.08), transparent 26%);
  }
  .bw-hi__progress-step {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #6f584c;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .bw-hi__progress-card h3 {
    margin: 0;
    color: #201713;
    font-size: 16px;
    line-height: 1.2;
  }
  .bw-hi__progress-card p {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-hi__journey-link,
  .bw-hi__journey-link--active {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .bw-hi__journey-link {
    border: 1px solid rgba(255, 247, 241, 0.18);
    background: rgba(255, 247, 241, 0.08);
    color: #fff7f1;
  }
  .bw-hi__journey-link:hover {
    transform: translateY(-1px);
    background: rgba(255, 247, 241, 0.14);
  }
  .bw-hi__journey-link--active {
    border: 1px solid #fff7f1;
    background: #fff7f1;
    color: #201713;
  }
  .bw-hi__panel,
  .bw-hi__summary {
    padding: 26px 28px;
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-hi__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: 20px;
  }
  .bw-hi__summary {
    position: sticky;
    top: 110px;
    height: fit-content;
    background: linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
  }
  .bw-hi__head { display: grid; gap: 10px; margin-bottom: 18px; }
  .bw-hi__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-hi__summary .bw-hi__eyebrow,
  .bw-hi__summary .bw-hi__title,
  .bw-hi__summary .bw-hi__copy { color: inherit; }
  .bw-hi__title {
    margin: 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }
  .bw-hi__copy {
    margin: 0;
    color: #66554c;
    font-size: 15px;
    line-height: 1.8;
    max-width: 62ch;
  }
  .bw-hi__section { display: grid; gap: 12px; }
  .bw-hi__label {
    color: #201713;
    font-size: 16px;
    font-weight: 700;
  }
  .bw-hi__choices {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 10px;
  }
  .bw-hi__choice {
    display: grid;
    align-content: start;
    gap: 6px;
    min-height: 72px;
    padding: 14px 16px;
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 251, 247, 0.94));
    border: 1px solid rgba(32, 23, 19, 0.08);
    box-shadow: 0 12px 26px rgba(35, 24, 19, 0.05);
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: left;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }
  .bw-hi__choice input { display: none; }
  .bw-hi__choice.is-selected {
    background:
      linear-gradient(180deg, #241814 0%, #3a2921 100%);
    color: #fff7f1;
    border-color: #241814;
    box-shadow: 0 16px 34px rgba(35, 24, 19, 0.16);
  }
  .bw-hi__choice:hover,
  .bw-hi__choice:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(32, 23, 19, 0.16);
    box-shadow: 0 16px 32px rgba(35, 24, 19, 0.08);
  }
  .bw-hi__choice--visual {
    gap: 10px;
    min-height: 0;
    padding: 10px;
    letter-spacing: 0;
    text-transform: none;
  }
  .bw-hi__choice-media {
    min-height: 132px;
    border-radius: 16px;
    overflow: hidden;
    background: linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-hi__choice-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-hi__choice-copy {
    display: grid;
    gap: 4px;
    align-content: start;
    text-align: left;
  }
  .bw-hi__choice-title {
    color: inherit;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
  }
  .bw-hi__choice-note {
    color: #66554c;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.55;
  }
  .bw-hi__choice.is-selected .bw-hi__choice-note {
    color: rgba(255, 247, 241, 0.82);
  }
  .bw-hi__choices[data-hi-group="rooms"],
  .bw-hi__choices[data-hi-group="property"],
  .bw-hi__choices[data-hi-group="intent"],
  .bw-hi__choices[data-hi-group="budget"] {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .bw-hi__choices[data-hi-group="rooms"] {
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }
  .bw-hi__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-hi__field {
    display: grid;
    gap: 8px;
  }
  .bw-hi__field label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
  }
  .bw-hi__field input,
  .bw-hi__field select {
    width: 100%;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fffdfb;
    color: #201713;
    font-size: 14px;
  }
  .bw-hi__summary-list {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }
  .bw-hi__recommendation {
    margin-top: 16px;
    padding: 18px;
    border-radius: 22px;
    background: rgba(255, 247, 241, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.12);
    color: rgba(255, 247, 241, 0.86);
    font-size: 13px;
    line-height: 1.75;
  }
  .bw-hi__recommendation strong {
    display: block;
    margin-bottom: 6px;
    color: #fff7f1;
    font-size: 14px;
  }
  .bw-hi__summary-visual {
    min-height: 220px;
    margin-bottom: 16px;
    border-radius: 24px;
    overflow: hidden;
    background: rgba(255, 247, 241, 0.08);
    border: 1px solid rgba(255, 247, 241, 0.12);
  }
  .bw-hi__summary-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-hi__summary-caption {
    margin: -2px 0 14px;
    color: rgba(255, 247, 241, 0.74);
    font-size: 12px;
    line-height: 1.65;
  }
  .bw-hi__summary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 4px;
  }
  .bw-hi__summary-tag {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 247, 241, 0.12);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .bw-hi__summary-line {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 247, 241, 0.12);
    color: rgba(255, 247, 241, 0.88);
    font-size: 14px;
  }
  .bw-hi__summary-line strong { color: #fff7f1; text-align: right; }
  .bw-hi__badge {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 247, 241, 0.08);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bw-hi__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }
  .bw-hi__button,
  .bw-hi__button--secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-hi__button {
    border: 0;
    background: #fff7f1;
    color: #201713;
  }
  .bw-hi__button--secondary {
    border: 1px solid rgba(255, 247, 241, 0.22);
    background: rgba(255, 247, 241, 0.08);
    color: #fff7f1;
  }
  .bw-hi__summary .bw-hi__button--secondary {
    border-color: rgba(255, 247, 241, 0.28);
    background: rgba(255, 247, 241, 0.14);
    color: #fff7f1;
  }
  .bw-hi__summary .bw-hi__button--secondary:hover,
  .bw-hi__summary .bw-hi__button--secondary:focus-visible {
    background: rgba(255, 247, 241, 0.22);
    border-color: rgba(255, 247, 241, 0.38);
  }
  .bw-hi__guide {
    padding: 24px 28px;
    border-radius: 28px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 20px 54px rgba(35, 24, 19, 0.06);
  }
  .bw-hi__guide-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-hi__guide-card {
    display: grid;
    gap: 10px;
    align-content: start;
    padding: 18px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(32, 23, 19, 0.08);
  }
  .bw-hi__guide-card--accent {
    background:
      linear-gradient(135deg, rgba(35, 24, 19, 0.94), rgba(91, 70, 60, 0.92)),
