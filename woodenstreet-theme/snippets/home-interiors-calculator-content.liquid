    max-width: 78ch;
  }
  .bw-hi__journey-eyebrow {
    color: rgba(255, 247, 241, 0.78);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-hi__journey-title {
    margin: 0;
    color: #fff7f1;
    font-size: clamp(22px, 3vw, 32px);
