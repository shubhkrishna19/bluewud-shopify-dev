{% render 'modular-estimate-popup', modal_id: 'bw-home-interiors-popup', modal_title: 'Get a home interiors estimate', context_label: 'Bluewud home interiors' %}

<script>
  (function () {
    var root = document.querySelector('[data-bw-home-interiors-flow]');
    if (!root) return;
    var modal = document.getElementById('bw-home-interiors-popup');
    var summaryText = modal ? modal.querySelector('[data-bw-estimate-summary-text]') : null;
    var summaryInput = modal ? modal.querySelector('[data-bw-estimate-summary-input]') : null;
    var contextInput = modal ? modal.querySelector('[data-bw-estimate-context-input]') : null;
    var sourceInput = modal ? modal.querySelector('[data-bw-estimate-source-input]') : null;
    var summaryImage = root.querySelector('[data-hi-summary-image]');
    var summaryCaption = root.querySelector('[data-hi-summary-caption]');
    var summaryTags = root.querySelector('[data-hi-summary-tags]');

    function selectedRadio(name) {
      var node = root.querySelector('input[name="' + name + '"]:checked');
      return node ? node.value : '';
    }

    function selectedChecks(group) {
      return Array.prototype.slice.call(root.querySelectorAll('[data-hi-group="' + group + '"] input[type="checkbox"]:checked')).map(function (input) {
        return input.value;
      });
    }

    function inputValue(key) {
      var node = root.querySelector('[data-hi-input="' + key + '"]');
      return node ? node.value : '';
    }

    function firstSelectedRoomCard() {
      var preferred = ['Modular Kitchen', 'Wardrobe', 'Living Room', 'Bedroom', 'Study / WFH', 'Dining'];
      var cards = Array.prototype.slice.call(root.querySelectorAll('[data-hi-room-card]'));

      for (var i = 0; i < preferred.length; i += 1) {
        var match = cards.find(function (card) {
          var input = card.querySelector('input');
          return input && input.checked && input.value === preferred[i];
        });
        if (match) return match;
      }

      return cards.find(function (card) {
        var input = card.querySelector('input');
        return input && input.checked;
      }) || null;
    }

    function updateStates() {
      root.querySelectorAll('.bw-hi__choice').forEach(function (choice) {
        var input = choice.querySelector('input');
        if (!input) return;
        choice.classList.toggle('is-selected', !!input.checked);
      });

      var rooms = selectedChecks('rooms');
      var roomText = rooms.length ? rooms.join(', ') : 'Not selected yet';
      var city = inputValue('city') || 'Not shared yet';
      var timeline = inputValue('timeline') || 'Immediate';
      var property = selectedRadio('hi_property');
      var intent = selectedRadio('hi_intent');
      var budget = selectedRadio('hi_budget');

      var map = {
        rooms: roomText,
        property: property,
        intent: intent,
        budget: budget,
        city: city,
        timeline: timeline
      };

      Object.keys(map).forEach(function (key) {
        var node = root.querySelector('[data-hi-summary-' + key + ']');
        if (node) node.textContent = map[key];
      });

      var badge = root.querySelector('[data-hi-badge]');
      if (badge) badge.textContent = budget || 'Need guidance';

      if (summaryTags) {
        var tags = rooms.slice(0, 3);
        if (property) tags.push(property);
        if (budget) tags.push(budget);
        if (timeline) tags.push(timeline);
        summaryTags.innerHTML = tags.slice(0, 5).map(function (tag) {
          return '<span class="bw-hi__summary-tag">' + tag + '</span>';
        }).join('');
      }

      var featuredCard = firstSelectedRoomCard();
      if (featuredCard) {
        var previewSrc = featuredCard.getAttribute('data-preview-src');
        var previewAlt = featuredCard.getAttribute('data-preview-alt');
        var previewCaption = featuredCard.getAttribute('data-preview-caption');
        if (summaryImage && previewSrc) summaryImage.src = previewSrc;
        if (summaryImage && previewAlt) summaryImage.alt = previewAlt;
        if (summaryCaption && previewCaption) summaryCaption.textContent = previewCaption;
      } else if (summaryCaption) {
        summaryCaption.textContent = 'Choose the room mix first. The lead room will preview here so the brief feels anchored to a real space instead of abstract scope.';
      }

      var recommendation = root.querySelector('[data-hi-recommendation]');
      if (recommendation) {
        var recommendationText = 'Pick the lead room first.';
        if (rooms.indexOf('Modular Kitchen') !== -1 && rooms.indexOf('Wardrobe') !== -1) {
          recommendationText = 'This looks like a modular-core home brief.';
        } else if (rooms.indexOf('Modular Kitchen') !== -1) {
          recommendationText = 'Kitchen is leading this brief. Use the kitchen planner if the layout still needs work.';
        } else if (rooms.indexOf('Wardrobe') !== -1 && rooms.length === 1) {
          recommendationText = 'Wardrobe is leading this brief. Lock the storage format before asking for numbers.';
        } else if (rooms.length > 2) {
          recommendationText = 'This reads like a broader home interiors project.';
        } else if (rooms.indexOf('Study / WFH') !== -1) {
          recommendationText = 'Study and WFH briefs work best when storage and work rhythm are clear early.';
        } else if (rooms.indexOf('Living Room') !== -1 || rooms.indexOf('Bedroom') !== -1) {
          recommendationText = 'This is a room-led interiors brief. Keep the scope crisp and send one clean brief.';
        }
        recommendation.innerHTML = '<strong>Recommended next move</strong>' + recommendationText;
      }
      persistPayload('calculator-progress');
    }

    function briefSummary() {
      return [
        'Project: Home Interiors',
        'Rooms: ' + (selectedChecks('rooms').length ? selectedChecks('rooms').join(', ') : 'Not selected'),
        'Property: ' + selectedRadio('hi_property'),
        'Intent: ' + selectedRadio('hi_intent'),
        'Budget direction: ' + selectedRadio('hi_budget'),
        'City: ' + (inputValue('city') || 'Not shared yet'),
        'Timeline: ' + (inputValue('timeline') || 'Immediate')
      ].join(' | ');
    }
    function buildPayload(trigger) {
      return {
        projectType: 'Home Interiors',
        projectContext: 'Bluewud home interiors',
        referenceSource: 'Home interiors calculator',
        projectRoute: window.location.pathname + window.location.search,
        selectedBrief: briefSummary(),
        selectedOptions: {
          rooms: selectedChecks('rooms'),
          property_type: selectedRadio('hi_property'),
          intent: selectedRadio('hi_intent'),
          budget_posture: selectedRadio('hi_budget'),
          city: inputValue('city'),
          timeline: inputValue('timeline') || 'Immediate',
          source_trigger: trigger || 'calculator-progress'
        },
        trigger: trigger || 'calculator-progress'
      };
    }
    function persistPayload(trigger) {
      var payload = buildPayload(trigger);
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.save(payload);
      }
      return payload;
    }

    function openPopup() {
      if (!modal) return;
      var payload = persistPayload('calculator-submit');
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.fillModal(modal, payload);
      } else {
        if (summaryText) summaryText.textContent = payload.selectedBrief;
        if (summaryInput) summaryInput.value = payload.selectedBrief;
        if (contextInput) contextInput.value = payload.projectContext;
        if (sourceInput) sourceInput.value = payload.referenceSource;
      }
      modal.classList.add('is-open');
      document.body.classList.add('bw-header-drawer-open');
    }

    function closePopup() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('bw-header-drawer-open');
    }

    root.addEventListener('click', function (event) {
      var choice = event.target.closest('.bw-hi__choice');
      if (choice) {
        var input = choice.querySelector('input');
        if (input) {
          if (input.type === 'checkbox') input.checked = !input.checked;
          else input.checked = true;
          updateStates();
        }
        return;
      }
      if (event.target.closest('[data-hi-popup-open]')) {
        openPopup();
      }
    });

    root.addEventListener('change', updateStates);

    if (modal) {
      modal.querySelectorAll('[data-bw-estimate-close]').forEach(function (control) {
        control.addEventListener('click', closePopup);
      });
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closePopup();
      });
    }

    updateStates();
  })();
</script>
