{%- capture search_type -%}
  {% if enable_content %}
    article,page,product
  {% else %}
    product
  {% endif %}
{%- endcapture -%}

<div class="productgrid--search" data-live-search>
  <form
    class="productgrid--search-form"
    action="{{ routes.search_url }}"
    method="get"
    role="search"
    aria-label="Product"
    data-live-search-form
  >
    <input type="hidden" name="type" value="{{ search_type | replace: '  ', '' | strip_newlines }}">
    <div class="form-field no-label">
      {% if search_filter_string != blank %}
        <input
          type="hidden"
          value="{{ search_filter_string }}"
          data-live-search-filter
        >
      {% endif %}
      <input
        class="form-field-input productgrid--search-form-field"
        type="text"
        name="q"
        aria-label="{{ 'search.form.label' | t }}"
        placeholder="{{ 'search.form.placeholder' | t}}"
        {% if search.performed %}
          {% capture sanitized_terms %}
            {%
              render 'search-sanitizer',
              search_terms: search.terms
            %}
          {% endcapture %}

          {% assign sanitized_terms = sanitized_terms | strip %}
          value="{{ sanitized_terms }}"
        {% endif %}
        data-live-search-input>

      {% assign has_search_query = search.terms | strip | size > 0 %}
      {% if search.performed and has_search_query %}
        <a
          href="{{ routes.search_url }}?type={{ search_type | replace: '  ', '' | strip_newlines }}&q="
          class="productgrid--search-clear"
          aria-label="{{ 'accessibility.reset_search' | t }}"
        >
          {% render 'icon-close' %}
        </a>
      {% endif %}

      <button
        class="productgrid--search-button"
        type="submit"
        aria-label="{{ 'general.accessibility.search' | t }}"
        data-live-search-submit
      >
        <span class="search-icon search-icon--inactive">
          {% render 'icon-search' %}
        </span>
        <span class="search-icon search-icon--active">
          {% render 'icon-spinner' %}
        </span>
      </button>
    </div>
  </form>
</div>

{% style %}
.productgrid--search-clear {
  position: absolute;
  right: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  color: var(--color-text-light);
  text-decoration: none;
}

.productgrid--search-clear:hover {
  color: var(--color-text);
}
{% endstyle %}
