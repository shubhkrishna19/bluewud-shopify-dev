{% liquid
  assign kitchen_collection = collections['kitchen-racks']
  assign main_url = '/collections/kitchen-racks'
  assign l_url = '/collections/kitchen-racks#l-shape'
  assign u_url = '/collections/kitchen-racks#u-shape'
  assign parallel_url = '/collections/kitchen-racks#parallel'
  assign straight_url = '/collections/kitchen-racks#straight'
  assign island_url = '/collections/kitchen-racks#island'
  assign calculator_url = '/collections/kitchen-racks?planner=kitchen-calculator'
  assign wardrobe_calculator_url = '/collections/wardrobe?planner=wardrobe-calculator'
  assign interiors_calculator_url = '/collections/kitchen-racks?planner=home-interiors'
  assign estimate_url = '/pages/get-free-estimate'
  assign contact_url = '/pages/contact-us'
  assign default_variant = 'all'
  assign page_handle = blank
  assign calculator_cta_url = calculator_url
  assign calculator_source_param = 'Modular Kitchen Guide' | url_encode
  assign calculator_query_joiner = '?'

  if page != blank
    assign page_handle = page.handle
  endif

  if page_handle == 'l-shape-modular-kitchen-design'
    assign default_variant = 'l-shape'
  elsif page_handle == 'u-shape-modular-kitchen-design'
    assign default_variant = 'u-shape'
  elsif page_handle == 'parallel-modular-kitchen-design'
    assign default_variant = 'parallel'
  elsif page_handle == 'straight-modular-kitchen'
    assign default_variant = 'straight'
  elsif page_handle == 'kitchen-island-design'
    assign default_variant = 'island'
  endif

  if pages['modular-kitchen-designs'] != blank
    assign main_url = pages['modular-kitchen-designs'].url
    assign l_url = main_url | append: '#l-shape'
    assign u_url = main_url | append: '#u-shape'
    assign parallel_url = main_url | append: '#parallel'
    assign straight_url = main_url | append: '#straight'
    assign island_url = main_url | append: '#island'
  endif
  if pages['l-shape-modular-kitchen-design'] != blank
    assign l_url = pages['l-shape-modular-kitchen-design'].url
  endif
  if pages['u-shape-modular-kitchen-design'] != blank
    assign u_url = pages['u-shape-modular-kitchen-design'].url
  endif
  if pages['parallel-modular-kitchen-design'] != blank
    assign parallel_url = pages['parallel-modular-kitchen-design'].url
  endif
  if pages['straight-modular-kitchen'] != blank
    assign straight_url = pages['straight-modular-kitchen'].url
  endif
  if pages['kitchen-island-design'] != blank
    assign island_url = pages['kitchen-island-design'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
  if pages['get-free-estimate'] == blank and pages['contact-us'] != blank
    assign estimate_url = pages['contact-us'].url
  endif

  if calculator_url contains '?'
    assign calculator_query_joiner = '&'
  endif

  if default_variant == 'all'
    assign calculator_cta_url = calculator_url | append: calculator_query_joiner | append: 'source=' | append: calculator_source_param
  else
    assign calculator_cta_url = calculator_url | append: calculator_query_joiner | append: 'layout=' | append: default_variant | append: '&source=' | append: calculator_source_param
  endif

  assign hero_all = blank
  assign hero_l = blank
  assign hero_u = blank
  assign hero_parallel = blank
  assign hero_straight = blank
  assign hero_island = blank
  assign kitchen_image_all_url = 'modular-kitchen-navy-luxury.png' | asset_url
  assign kitchen_image_all_alt = 'Bluewud premium modular kitchen installation'
  assign kitchen_image_l_url = 'modular-kitchen-light-oak-l-shape.png' | asset_url
  assign kitchen_image_l_alt = 'Bluewud light oak L-shape modular kitchen'
  assign kitchen_image_u_url = 'modular-kitchen-walnut-u-shape.png' | asset_url
  assign kitchen_image_u_alt = 'Bluewud walnut U-shape modular kitchen'
  assign kitchen_image_parallel_url = 'modular-kitchen-galley-light-wood.png' | asset_url
  assign kitchen_image_parallel_alt = 'Bluewud parallel modular kitchen'
  assign kitchen_image_straight_url = 'modular-kitchen-galley-light-wood.png' | asset_url
  assign kitchen_image_straight_alt = 'Bluewud straight modular kitchen concept'
  assign kitchen_image_island_url = 'modular-kitchen-navy-luxury.png' | asset_url
  assign kitchen_image_island_alt = 'Bluewud premium modular kitchen concept'

  if kitchen_collection != blank
    assign hero_all = kitchen_collection.products.first
    for product in kitchen_collection.products
      assign title_downcase = product.title | downcase
      if hero_l == blank and title_downcase contains 'l shape'
        assign hero_l = product
      endif
      if hero_u == blank and title_downcase contains 'u shape'
        assign hero_u = product
      endif
      if hero_parallel == blank and title_downcase contains 'parallel'
        assign hero_parallel = product
      endif
      if hero_straight == blank and title_downcase contains 'straight'
        assign hero_straight = product
      endif
      if hero_island == blank and title_downcase contains 'island'
        assign hero_island = product
      endif
    endfor
  endif

  if hero_l == blank
    assign hero_l = hero_all
  endif
  if hero_u == blank
    assign hero_u = hero_all
  endif
  if hero_parallel == blank
    assign hero_parallel = hero_all
  endif
  if hero_straight == blank
    assign hero_straight = hero_all
  endif
  if hero_island == blank
    assign hero_island = hero_all
  endif
  if hero_straight != blank and hero_straight.featured_image != blank
    assign kitchen_image_straight_url = hero_straight.featured_image | image_url: width: 1200
    assign kitchen_image_straight_alt = hero_straight.title | default: kitchen_image_straight_alt
  endif
%}

<style>
  .bw-modular { display: grid; gap: 24px; }
  .bw-modular > .bw-planning-rail { order: -2; }
  .bw-modular > .bw-modular__guide { order: 2; }
  .bw-modular > .bw-modular__panel,
  .bw-modular > .bw-modular__block,
  .bw-modular > .bw-modular__band { order: 1; }
  .bw-modular__block,
  .bw-modular__band {
    padding: 26px 28px;
    border-radius: 30px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-modular__block { background: rgba(255, 251, 247, 0.94); }
  .bw-modular__guide {
    display: grid;
    gap: 18px;
  }
  .bw-modular__guide-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .bw-modular__guide-card {
    display: grid;
    gap: 10px;
    align-content: start;
    padding: 20px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(32, 23, 19, 0.08);
  }
  .bw-modular__guide-card strong {
    color: #201713;
    font-size: 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .bw-modular__guide-card p {
    margin: 0;
    color: #66554c;
    font-size: 13px;
    line-height: 1.7;
  }
  .bw-modular__band {
    background: radial-gradient(circle at top right, rgba(79, 120, 143, 0.16), transparent 24%), linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
  }
  .bw-modular__tabs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
  .bw-modular__tab {
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid rgba(32, 23, 19, 0.2);
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.1);
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
  }
  .bw-modular__tab.is-active {
    background: #201713;
    border-color: #201713;
    color: #fff7f1;
  }
  .bw-modular__panel {
    display: none;
    gap: 18px;
  }
  .bw-modular__panel.is-active {
    display: grid;
  }
  .bw-modular__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
    gap: 18px;
  }
  .bw-modular__copy-shell {
    padding: 26px 28px;
    border-radius: 28px;
    background: radial-gradient(circle at top left, rgba(79, 120, 143, 0.14), transparent 28%), linear-gradient(180deg, #fffaf6 0%, #f5ede6 100%);
  }
  .bw-modular__section-head {
    display: grid;
    gap: 10px;
    margin-bottom: 18px;
  }
  .bw-modular__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-modular__pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #6f584c;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bw-modular__title {
    margin: 12px 0 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }
  .bw-modular__copy {
    margin: 12px 0 0;
    color: #66554c;
    font-size: 15px;
    line-height: 1.82;
    max-width: 66ch;
  }
  .bw-modular__bullets {
    display: grid;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }
  .bw-modular__bullets li {
    position: relative;
    padding-left: 18px;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #4f788f;
  }
  .bw-modular__visual {
    min-height: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: radial-gradient(circle at 24% 20%, rgba(255,255,255,.22), transparent 24%), linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-modular__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-modular__cards,
  .bw-modular__products {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__card,
  .bw-modular__product {
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.04);
  }
  .bw-modular__product {
    display: grid;
    gap: 12px;
    padding: 14px;
    background: rgba(255,255,255,.72);
    border: 1px solid rgba(45, 33, 27, 0.08);
    text-decoration: none;
    color: inherit;
  }
  .bw-modular__card h3,
  .bw-modular__product h3 {
    margin: 0 0 8px;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
  }
  .bw-modular__card p,
  .bw-modular__product p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__blueprint {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__blueprint-card {
    display: grid;
    gap: 12px;
    align-content: start;
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(32, 23, 19, 0.08);
  }
  .bw-modular__blueprint-card--accent {
    background: radial-gradient(circle at top left, rgba(79, 120, 143, 0.12), transparent 28%), linear-gradient(180deg, #fffaf6 0%, #f5ede6 100%);
  }
  .bw-modular__blueprint-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
    letter-spacing: -0.03em;
  }
  .bw-modular__blueprint-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__decision-card {
    display: grid;
    gap: 12px;
    align-content: start;
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 40px rgba(35, 24, 19, 0.05);
  }
  .bw-modular__decision-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
    letter-spacing: -0.03em;
  }
  .bw-modular__decision-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__decision-tag {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    width: fit-content;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(79, 120, 143, 0.12);
    color: #4f788f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-modular__blueprint-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }
  .bw-modular__product-media {
    min-height: 220px;
    border-radius: 18px;
    overflow: hidden;
    background: radial-gradient(circle at 24% 20%, rgba(255,255,255,.22), transparent 24%), linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-modular__product-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-modular__gallery {
    display: grid;
    gap: 16px;
  }
  .bw-modular__gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__gallery-card {
    display: grid;
    gap: 12px;
    padding: 14px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(45, 33, 27, 0.08);
    text-decoration: none;
    color: inherit;
    box-shadow: 0 18px 40px rgba(35, 24, 19, 0.05);
  }
  .bw-modular__gallery-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
  }
  .bw-modular__gallery-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.7;
  }
  .bw-modular__gallery-media {
    min-height: 200px;
    border-radius: 18px;
    overflow: hidden;
    background: radial-gradient(circle at 24% 20%, rgba(255,255,255,.22), transparent 24%), linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-modular__gallery-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-modular__process {
    display: grid;
    gap: 16px;
  }
  .bw-modular__process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__process-card {
    display: grid;
    gap: 10px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }
  .bw-modular__process-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: rgba(79, 120, 143, 0.12);
    color: #4f788f;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-modular__process-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
  }
  .bw-modular__process-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.7;
  }
  .bw-modular__proof-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }
  .bw-modular__proof-pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(79, 120, 143, 0.12);
    color: #355a6d;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-modular__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }
  .bw-modular__launchpad {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__launchpad--five {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }
  .bw-modular__launch-card {
    display: grid;
    gap: 12px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(45, 33, 27, 0.06);
  }
  .bw-modular__launch-card--link {
    color: inherit;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .bw-modular__launch-card--link:hover,
  .bw-modular__launch-card--link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(45, 33, 27, 0.12);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.07);
  }
  .bw-modular__launch-media {
    min-height: 178px;
    margin: -8px -8px 4px;
    border-radius: 18px;
    overflow: hidden;
    background: radial-gradient(circle at 24% 20%, rgba(255,255,255,.22), transparent 24%), linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-modular__launch-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-modular__launch-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #201713;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .bw-modular__launch-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
  }
  .bw-modular__launch-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__tool {
    display: grid;
    gap: 18px;
    scroll-margin-top: 120px;
  }
  .bw-modular__button,
  .bw-modular__button--secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-modular__button { background: #201713; color: #fff7f1; border: 0; }
  .bw-modular__button--secondary { background: rgba(32, 23, 19, 0.05); color: #201713; border: 1px solid rgba(32, 23, 19, 0.1); }
  .bw-modular__tabs .bw-modular__button--secondary {
    background: rgba(32, 23, 19, 0.1);
    color: #201713;
    border-color: rgba(32, 23, 19, 0.2);
    line-height: 1;
    white-space: nowrap;
  }
  .bw-modular__band .bw-modular__title,
  .bw-modular__band .bw-modular__copy,
  .bw-modular__band .bw-modular__eyebrow { color: inherit; }
  .bw-modular__band .bw-modular__button { background: #fff7f1; color: #201713; }
  .bw-modular__band .bw-modular__button--secondary { background: rgba(255,247,241,.08); color: #fff7f1; border-color: rgba(255,247,241,.28); }
  @media (max-width: 1024px) {
    .bw-modular__hero,
    .bw-modular__cards,
    .bw-modular__blueprint,
    .bw-modular__products,
    .bw-modular__gallery-grid,
    .bw-modular__process-grid,
    .bw-modular__launchpad,
    .bw-modular__decision-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .bw-modular__hero { grid-template-columns: 1fr; }
    .bw-modular__guide-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .bw-modular__block,
    .bw-modular__band { padding: 22px 20px; border-radius: 24px; }
    .bw-modular__tabs { flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; }
    .bw-modular__tabs::-webkit-scrollbar { display: none; }
    .bw-modular__tab { flex: 0 0 auto; white-space: nowrap; }
    .bw-modular__cards,
    .bw-modular__blueprint,
    .bw-modular__decision-grid,
    .bw-modular__gallery-grid,
    .bw-modular__process-grid,
    .bw-modular__products,
    .bw-modular__launchpad { grid-template-columns: 1fr; }
  }
</style>

<div class="bw-modular" data-bw-modular-page data-default-variant="{{ default_variant }}">
  <section class="bw-planning-rail">
    <div class="bw-planning-rail__items" aria-label="Kitchen layouts">
      <a class="bw-planning-rail__link{% if default_variant == 'all' %} is-current{% endif %}" href="{{ main_url }}" data-variant-toggle="all">All layouts</a>
      <a class="bw-planning-rail__link{% if default_variant == 'l-shape' %} is-current{% endif %}" href="{{ l_url }}" data-variant-toggle="l-shape">L-shape</a>
