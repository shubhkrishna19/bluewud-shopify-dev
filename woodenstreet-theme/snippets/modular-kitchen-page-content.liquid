{% liquid
  assign kitchen_collection = collections['kitchen-racks']
  assign main_url = '/collections/kitchen-racks'
  assign l_url = '/collections/kitchen-racks#l-shape'
  assign u_url = '/collections/kitchen-racks#u-shape'
  assign parallel_url = '/collections/kitchen-racks#parallel'
  assign straight_url = '/collections/kitchen-racks#straight'
  assign island_url = '/collections/kitchen-racks#island'
  assign calculator_url = '/pages/contact-us'
  assign wardrobe_calculator_url = '/pages/contact-us'
  assign interiors_calculator_url = '/pages/contact-us'
  assign estimate_url = '/pages/contact-us'
  assign contact_url = '/pages/contact-us'
  assign default_variant = 'all'
  assign page_handle = blank
  assign calculator_entry_url = calculator_url
  assign wardrobe_calculator_entry_url = wardrobe_calculator_url
  assign interiors_entry_url = interiors_calculator_url
  assign show_inline_calculator = false

  if page != blank
    assign page_handle = page.handle
  else
    assign show_inline_calculator = true
  endif

  if page_handle == 'l-shape-modular-kitchen-design'
    assign default_variant = 'l-shape'
  elsif page_handle == 'u-shape-modular-kitchen-design'
    assign default_variant = 'u-shape'
  elsif page_handle == 'parallel-modular-kitchen-design'
    assign default_variant = 'parallel'
  elsif page_handle == 'straight-modular-kitchen'
    assign default_variant = 'straight'
  elsif page_handle == 'kitchen-island-design'
    assign default_variant = 'island'
  endif

  if pages['modular-kitchen-designs'] != blank
    assign main_url = pages['modular-kitchen-designs'].url
    assign l_url = main_url | append: '#l-shape'
    assign u_url = main_url | append: '#u-shape'
    assign parallel_url = main_url | append: '#parallel'
    assign straight_url = main_url | append: '#straight'
    assign island_url = main_url | append: '#island'
  endif
  if pages['l-shape-modular-kitchen-design'] != blank
    assign l_url = pages['l-shape-modular-kitchen-design'].url
  endif
  if pages['u-shape-modular-kitchen-design'] != blank
    assign u_url = pages['u-shape-modular-kitchen-design'].url
  endif
  if pages['parallel-modular-kitchen-design'] != blank
    assign parallel_url = pages['parallel-modular-kitchen-design'].url
  endif
  if pages['straight-modular-kitchen'] != blank
    assign straight_url = pages['straight-modular-kitchen'].url
  endif
  if pages['kitchen-island-design'] != blank
    assign island_url = pages['kitchen-island-design'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
  if show_inline_calculator
    assign main_url = '/collections/kitchen-racks'
    assign l_url = main_url | append: '#l-shape'
    assign u_url = main_url | append: '#u-shape'
    assign parallel_url = main_url | append: '#parallel'
    assign straight_url = main_url | append: '#straight'
    assign island_url = main_url | append: '#island'
    assign calculator_entry_url = '#kitchen-calculator'
  else
    assign calculator_entry_url = calculator_url
  endif
  if pages['modular-wardrobe-cost-calculator'] == blank
    assign wardrobe_calculator_entry_url = '/collections/wardrobe#wardrobe-calculator'
  endif
  if pages['home-interiors-cost-calculator'] == blank and show_inline_calculator
    assign interiors_entry_url = '#broader-planning'
  endif

  assign hero_all = blank
  assign hero_l = blank
  assign hero_u = blank
  assign hero_parallel = blank
  assign hero_straight = blank
  assign hero_island = blank

  if kitchen_collection != blank
    assign hero_all = kitchen_collection.products.first
    for product in kitchen_collection.products
      assign title_downcase = product.title | downcase
      if hero_l == blank and title_downcase contains 'l shape'
        assign hero_l = product
      endif
      if hero_u == blank and title_downcase contains 'u shape'
        assign hero_u = product
      endif
      if hero_parallel == blank and title_downcase contains 'parallel'
        assign hero_parallel = product
      endif
      if hero_straight == blank and title_downcase contains 'straight'
        assign hero_straight = product
      endif
      if hero_island == blank and title_downcase contains 'island'
        assign hero_island = product
      endif
    endfor
  endif

  if hero_l == blank
    assign hero_l = hero_all
  endif
  if hero_u == blank
    assign hero_u = hero_all
  endif
  if hero_parallel == blank
    assign hero_parallel = hero_all
  endif
  if hero_straight == blank
    assign hero_straight = hero_all
  endif
  if hero_island == blank
    assign hero_island = hero_all
  endif
%}

<style>
  .bw-modular { display: grid; gap: 24px; }
  .bw-modular__block,
  .bw-modular__band {
    padding: 26px 28px;
    border-radius: 30px;
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }
  .bw-modular__block { background: rgba(255, 251, 247, 0.94); }
  .bw-modular__band {
    background: radial-gradient(circle at top right, rgba(79, 120, 143, 0.16), transparent 24%), linear-gradient(135deg, #231813 0%, #3b2921 56%, #5c463c 100%);
    color: #fff7f1;
  }
  .bw-modular__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .bw-modular__tab {
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid rgba(32, 23, 19, 0.1);
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.04);
    color: #201713;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-modular__tab.is-active {
    background: #201713;
    border-color: #201713;
    color: #fff7f1;
  }
  .bw-modular__panel {
    display: none;
    gap: 18px;
  }
  .bw-modular__panel.is-active {
    display: grid;
  }
  .bw-modular__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
    gap: 18px;
  }
  .bw-modular__copy-shell {
    padding: 26px 28px;
    border-radius: 28px;
    background: radial-gradient(circle at top left, rgba(79, 120, 143, 0.14), transparent 28%), linear-gradient(180deg, #fffaf6 0%, #f5ede6 100%);
  }
  .bw-modular__section-head {
    display: grid;
    gap: 10px;
    margin-bottom: 18px;
  }
  .bw-modular__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .bw-modular__pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #6f584c;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bw-modular__title {
    margin: 12px 0 0;
    color: #201713;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }
  .bw-modular__copy {
    margin: 12px 0 0;
    color: #66554c;
    font-size: 15px;
    line-height: 1.82;
    max-width: 66ch;
  }
  .bw-modular__bullets {
    display: grid;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }
  .bw-modular__bullets li {
    position: relative;
    padding-left: 18px;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #4f788f;
  }
  .bw-modular__visual {
    min-height: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: radial-gradient(circle at 24% 20%, rgba(255,255,255,.22), transparent 24%), linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-modular__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-modular__cards,
  .bw-modular__products {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__card,
  .bw-modular__product {
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.04);
  }
  .bw-modular__product {
    display: grid;
    gap: 12px;
    padding: 14px;
    background: rgba(255,255,255,.72);
    border: 1px solid rgba(45, 33, 27, 0.08);
    text-decoration: none;
    color: inherit;
  }
  .bw-modular__card h3,
  .bw-modular__product h3 {
    margin: 0 0 8px;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
  }
  .bw-modular__card p,
  .bw-modular__product p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__product-media {
    min-height: 220px;
    border-radius: 18px;
    overflow: hidden;
    background: radial-gradient(circle at 24% 20%, rgba(255,255,255,.22), transparent 24%), linear-gradient(145deg, #e5d8cd 0%, #b69981 42%, #6e5043 100%);
  }
  .bw-modular__product-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bw-modular__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }
  .bw-modular__launchpad {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .bw-modular__launchpad--five {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }
  .bw-modular__launch-card {
    display: grid;
    gap: 12px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(45, 33, 27, 0.06);
  }
  .bw-modular__launch-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
  }
  .bw-modular__launch-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }
  .bw-modular__tool {
    display: grid;
    gap: 18px;
    scroll-margin-top: 120px;
  }
  .bw-modular__button,
  .bw-modular__button--secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .bw-modular__button { background: #201713; color: #fff7f1; border: 0; }
  .bw-modular__button--secondary { background: rgba(32, 23, 19, 0.05); color: #201713; border: 1px solid rgba(32, 23, 19, 0.1); }
  .bw-modular__band .bw-modular__title,
  .bw-modular__band .bw-modular__copy,
  .bw-modular__band .bw-modular__eyebrow { color: inherit; }
  .bw-modular__band .bw-modular__button { background: #fff7f1; color: #201713; }
  .bw-modular__band .bw-modular__button--secondary { background: rgba(255,247,241,.08); color: #fff7f1; border-color: rgba(255,247,241,.28); }
  @media (max-width: 1024px) {
    .bw-modular__hero,
    .bw-modular__cards,
    .bw-modular__products,
    .bw-modular__launchpad { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .bw-modular__hero { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .bw-modular__block,
    .bw-modular__band { padding: 22px 20px; border-radius: 24px; }
    .bw-modular__tabs { flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; }
    .bw-modular__tabs::-webkit-scrollbar { display: none; }
    .bw-modular__tab { flex: 0 0 auto; white-space: nowrap; }
    .bw-modular__cards,
    .bw-modular__products,
    .bw-modular__launchpad { grid-template-columns: 1fr; }
  }
</style>

<div class="bw-modular" data-bw-modular-page data-default-variant="{{ default_variant }}">
  <section class="bw-modular__block">
    <div class="bw-modular__tabs" aria-label="Kitchen layouts">
      <a class="bw-modular__tab" href="{{ main_url }}" data-variant-toggle="all">All layouts</a>
      <a class="bw-modular__tab" href="{{ l_url }}" data-variant-toggle="l-shape">L-shape</a>
      <a class="bw-modular__tab" href="{{ u_url }}" data-variant-toggle="u-shape">U-shape</a>
      <a class="bw-modular__tab" href="{{ parallel_url }}" data-variant-toggle="parallel">Parallel</a>
      <a class="bw-modular__tab" href="{{ straight_url }}" data-variant-toggle="straight">Straight</a>
      <a class="bw-modular__tab" href="{{ island_url }}" data-variant-toggle="island">Island</a>
      <a class="bw-modular__button--secondary" href="{{ calculator_entry_url }}">Kitchen Calculator</a>
    </div>
  </section>

  <section class="bw-modular__block">
    <div class="bw-modular__section-head">
      <div class="bw-modular__eyebrow">Calculator journey</div>
      <h2 class="bw-modular__title" style="font-size:clamp(22px, 3vw, 30px);">Move between guides, calculators, and estimate flow without losing the thread</h2>
      <p class="bw-modular__copy">The modular system should feel connected. A customer browsing layouts should be able to jump into pricing or switch to wardrobe and home-interiors planning without starting over mentally.</p>
    </div>
    <div class="bw-modular__tabs" aria-label="Planning journey">
      <a class="bw-modular__tab" href="{{ calculator_entry_url }}">Kitchen Calculator</a>
      <a class="bw-modular__tab" href="{{ wardrobe_calculator_entry_url }}">Wardrobe Calculator</a>
      <a class="bw-modular__tab" href="{{ interiors_entry_url }}">Home Interiors</a>
      <button class="bw-modular__tab" type="button" data-bw-estimate-open data-estimate-context="Modular Kitchen" data-estimate-trigger="journey">Get Free Estimate</button>
    </div>
  </section>

  <section class="bw-modular__block" id="broader-planning">
    <div class="bw-modular__section-head">
      <div class="bw-modular__eyebrow">Review shortcuts</div>
      <h2 class="bw-modular__title" style="font-size:clamp(22px, 3vw, 30px);">Use this page as the actual review hub, not just a pretty landing page</h2>
      <p class="bw-modular__copy">The biggest missing piece was discoverability. These launch cards now show where the next live tools are and which actions stay inside this page during review.</p>
    </div>
    <div class="bw-modular__launchpad">
      <article class="bw-modular__launch-card">
        <h3>Kitchen calculator</h3>
        <p>The full kitchen brief builder now lives on this same page for localhost review. Start there if you want to test the actual option-selection workflow.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button" href="{{ calculator_entry_url }}">Jump To Calculator</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>Wardrobe calculator</h3>
        <p>The wardrobe side now has the same connected planning flow. Use the wardrobe review page to see its inline calculator setup as well.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ wardrobe_calculator_entry_url }}">Open Wardrobe Flow</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>Home interiors brief</h3>
        <p>This path is for larger-scope room planning. If the dedicated page is missing in preview, use the estimate flow for now and I’ll keep tightening the route structure.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ interiors_entry_url }}">Open Interiors Path</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>Get free estimate</h3>
        <p>The estimate popup is the immediate conversion endpoint. It already carries the kitchen context and becomes more useful once the calculator options are selected.</p>
        <div class="bw-modular__actions">
          <button class="bw-modular__button--secondary" type="button" data-bw-estimate-open data-estimate-context="Modular Kitchen" data-estimate-trigger="launchpad">Open Estimate Popup</button>
        </div>
      </article>
    </div>
  </section>

  <section class="bw-modular__block">
    <div class="bw-modular__section-head">
      <div class="bw-modular__eyebrow">Layout compass</div>
      <h2 class="bw-modular__title" style="font-size:clamp(24px, 3vw, 34px);">Choose the kitchen geometry that fits the room before styling the elevation</h2>
      <p class="bw-modular__copy">Each layout solves a different spatial problem. This quick comparison keeps the customer oriented before they move into the calculator or estimate flow.</p>
    </div>
    <div class="bw-modular__launchpad bw-modular__launchpad--five">
      <article class="bw-modular__launch-card">
        <h3>L-shape</h3>
        <p>Balanced, open, and easy to live with when the room needs efficient movement without a heavy footprint.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ l_url }}">Open L-shape</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>U-shape</h3>
        <p>Best when storage demand is higher and the kitchen needs more working surface and wraparound utility.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ u_url }}">Open U-shape</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>Parallel</h3>
        <p>Efficient for tighter kitchens where prep, washing, and cooking can be split across two clear runs.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ parallel_url }}">Open Parallel</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>Straight</h3>
        <p>Minimal, disciplined, and ideal for compact homes that need clarity more than visual complexity.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ straight_url }}">Open Straight</a>
        </div>
      </article>
      <article class="bw-modular__launch-card">
        <h3>Island</h3>
        <p>Premium and social, suited to homes where the kitchen also acts as a gathering and serving zone.</p>
        <div class="bw-modular__actions">
          <a class="bw-modular__button--secondary" href="{{ island_url }}">Open Island</a>
        </div>
      </article>
    </div>
  </section>

  {% capture product_grid %}
    <section class="bw-modular__block">
      <div class="bw-modular__section-head">
        <div class="bw-modular__eyebrow">Live kitchen directions</div>
        <h2 class="bw-modular__title" style="font-size:clamp(24px, 3vw, 34px);">Browse actual kitchen-led products from the store</h2>
        <p class="bw-modular__copy">Explore live Bluewud products connected to the kitchen category while you refine the broader layout, finish, and estimate brief.</p>
      </div>
      <div class="bw-modular__products">
        {% assign shown = 0 %}
        {% if kitchen_collection != blank %}
          {% for product in kitchen_collection.products %}
            <a class="bw-modular__product" href="{{ product.url }}">
              <div class="bw-modular__product-media">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '320, 480, 640, 900', sizes: '(max-width: 720px) 100vw, 33vw', alt: product.title }}
                {% endif %}
              </div>
              <h3>{{ product.title }}</h3>
              <p>{{ product.description | strip_html | truncatewords: 20 }}</p>
            </a>
            {% assign shown = shown | plus: 1 %}
            {% if shown >= 3 %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </section>
  {% endcapture %}

  <section class="bw-modular__panel" data-variant-panel="all">
    <section class="bw-modular__block">
      <div class="bw-modular__hero">
        <div class="bw-modular__copy-shell">
          <span class="bw-modular__pill">All modular kitchens</span>
          <h2 class="bw-modular__title">Modular kitchens shaped around how your home actually cooks, stores, and moves</h2>
          <p class="bw-modular__copy">Bluewud modular kitchens begin with the plan, not only the finish. Start with room proportions, family cooking habits, appliance needs, service points, and the visual language of the rest of your home. Once the broad layout is clear, material and budget decisions become far more confident.</p>
          <ul class="bw-modular__bullets">
            <li>Compare layout suitability before finalizing shutters, handles, and countertop finish.</li>
            <li>Plan workflow, storage intensity, and appliance placement together.</li>
            <li>Use the calculator or estimate form once the project brief is specific enough to price properly.</li>
          </ul>
          <div class="bw-modular__actions">
            <a class="bw-modular__button" href="{{ calculator_entry_url }}">Start Kitchen Calculator</a>
            <button class="bw-modular__button--secondary" type="button" data-bw-estimate-open data-estimate-context="Modular Kitchen" data-estimate-trigger="landing">Get Free Estimate</button>
          </div>
        </div>
        <div class="bw-modular__visual">
          {% if hero_all and hero_all.featured_image %}
            {{ hero_all.featured_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '540,720,960,1200,1400', sizes: '(max-width: 1024px) 100vw, 38vw', alt: hero_all.title }}
          {% endif %}
        </div>
      </div>
    </section>

    <section class="bw-modular__block">
      <div class="bw-modular__section-head">
        <div class="bw-modular__eyebrow">Why Bluewud modular kitchens</div>
        <h2 class="bw-modular__title" style="font-size:clamp(24px, 3vw, 34px);">Premium kitchens work best when the planning is as strong as the visual finish</h2>
        <p class="bw-modular__copy">A good modular kitchen should feel refined on day one and still work smoothly years later. That means the design conversation has to cover layout, work zones, storage habits, material durability, and how the kitchen connects to the rest of the home.</p>
      </div>
      <div class="bw-modular__cards">
        <article class="bw-modular__card"><h3>Planned around Indian homes</h3><p>Daily cooking, appliance density, utility requirements, and storage pressure vary widely. The strongest modular kitchen starts by acknowledging how the home will actually use the space.</p></article>
        <article class="bw-modular__card"><h3>Layout first, styling second</h3><p>L-shape, U-shape, parallel, straight, and island kitchens solve different problems. Once the right geometry is chosen, finish and detailing become much easier to refine.</p></article>
        <article class="bw-modular__card"><h3>Material clarity from the start</h3><p>Carcass systems, shutter surfaces, countertop choices, and hardware expectations should be discussed early so the kitchen feels premium without becoming vague or over-specified.</p></article>
        <article class="bw-modular__card"><h3>Storage that earns its footprint</h3><p>Corner solutions, pantry planning, utility cabinets, cutlery zones, appliance pockets, and tall units should support daily use, not just make the elevation look complete.</p></article>
        <article class="bw-modular__card"><h3>Better alignment with the rest of the home</h3><p>A kitchen sits inside a larger interiors story. Finish direction, openness, and visual weight should feel intentional when seen from dining, utility, or living spaces.</p></article>
