{% render 'modular-estimate-popup', modal_id: 'bw-kitchen-estimate-popup', modal_title: 'Get a modular kitchen estimate', context_label: 'Bluewud modular kitchen' %}

<script>
  (function () {
    var root = document.querySelector('[data-bw-modular-page]');
    if (!root) return;
    var defaultVariant = root.getAttribute('data-default-variant') || 'all';
    var toggles = Array.prototype.slice.call(root.querySelectorAll('[data-variant-toggle]'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('[data-variant-panel]'));

    var modal = document.getElementById('bw-kitchen-estimate-popup');
    var closeControls = modal ? modal.querySelectorAll('[data-bw-estimate-close]') : [];
    var summaryText = modal ? modal.querySelector('[data-bw-estimate-summary-text]') : null;
    var summaryInput = modal ? modal.querySelector('[data-bw-estimate-summary-input]') : null;
    var contextInput = modal ? modal.querySelector('[data-bw-estimate-context-input]') : null;
    var sourceInput = modal ? modal.querySelector('[data-bw-estimate-source-input]') : null;

    function activate(variant) {
      toggles.forEach(function (toggle) {
        var isActive = toggle.getAttribute('data-variant-toggle') === variant;
        toggle.classList.toggle('is-active', isActive);
        toggle.classList.toggle('is-current', isActive);
        if (isActive) toggle.setAttribute('aria-current', 'page');
        else toggle.removeAttribute('aria-current');
      });
      panels.forEach(function (panel) {
        var isActive = panel.getAttribute('data-variant-panel') === variant;
        panel.classList.toggle('is-active', isActive);
      });
      persistPlanningPayload('layout-select');
    }

    function activeVariantLabel() {
      var active = root.querySelector('[data-variant-toggle].is-active');
      return active ? active.textContent.trim() : 'Modular Kitchen';
    }
    function activeVariantKey() {
      var active = root.querySelector('[data-variant-toggle].is-active');
      return active ? active.getAttribute('data-variant-toggle') : defaultVariant;
    }

    function activeSummary(trigger) {
      var label = activeVariantLabel();
      var parts = ['Project: Modular Kitchen', 'Selected layout: ' + label];
      if (trigger) parts.push('Source: ' + trigger);
      return parts.join(' | ');
    }
    function activeSource(trigger) {
      var label = activeVariantLabel();
      return ['Modular Kitchen Guide', label, trigger || 'direct'].join(' | ');
    }
    function buildPlanningPayload(trigger) {
      return {
        projectType: 'Modular Kitchen',
        projectContext: 'Bluewud modular kitchen',
        referenceSource: activeSource(trigger),
        projectRoute: window.location.pathname + window.location.search + (window.location.hash || ''),
        selectedBrief: activeSummary(trigger),
        selectedOptions: {
          layout: activeVariantLabel(),
          layout_key: activeVariantKey(),
          source_trigger: trigger || 'direct',
          page_family: 'modular-kitchen-guide'
        },
        trigger: trigger || 'direct'
      };
    }
    function persistPlanningPayload(trigger) {
      var payload = buildPlanningPayload(trigger);
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.save(payload);
      }
      return payload;
    }

    function variantFromLocation() {
      var params = new URLSearchParams(window.location.search);
      var hash = (window.location.hash || '').replace('#', '');
      var validVariants = ['all', 'l-shape', 'u-shape', 'parallel', 'straight', 'island'];
      var layout = (params.get('layout') || '').toLowerCase();
      if (layout && validVariants.indexOf(layout) !== -1) return layout;
      if (!hash || validVariants.indexOf(hash) === -1) return defaultVariant;
      return hash;
    }

    function openModal(trigger) {
      if (!modal) return;
      var payload = persistPlanningPayload(trigger);
      if (window.BluewudProjectBriefStore) {
        window.BluewudProjectBriefStore.fillModal(modal, payload);
      } else {
        if (summaryText) summaryText.textContent = payload.selectedBrief;
        if (summaryInput) summaryInput.value = payload.selectedBrief;
        if (contextInput) contextInput.value = payload.projectContext;
        if (sourceInput) sourceInput.value = payload.referenceSource;
      }
      modal.classList.add('is-open');
      document.body.classList.add('bw-header-drawer-open');
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('bw-header-drawer-open');
    }

    function updateLocationForVariant(variant) {
      var nextUrl = new URL(window.location.href);
      if (variant && variant !== 'all') nextUrl.searchParams.set('layout', variant);
      else nextUrl.searchParams.delete('layout');
      if (variant === 'all') {
        nextUrl.hash = '';
      } else {
        nextUrl.hash = variant;
      }
      window.history.replaceState({}, '', nextUrl.pathname + nextUrl.search + nextUrl.hash);
    }

    toggles.forEach(function (toggle) {
      toggle.addEventListener('click', function (event) {
        var variant = toggle.getAttribute('data-variant-toggle') || defaultVariant;
        event.preventDefault();
        activate(variant);
        updateLocationForVariant(variant);
        var activePanel = root.querySelector('[data-variant-panel="' + variant + '"]');
        if (activePanel) {
          activePanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    root.querySelectorAll('[data-calculator-link]').forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        var activeVariant = activeVariantKey();
        var nextUrl = new URL('{{ calculator_url }}', window.location.origin);
        if (activeVariant && activeVariant !== 'all') nextUrl.searchParams.set('layout', activeVariant);
        else nextUrl.searchParams.delete('layout');
        nextUrl.searchParams.set('source', 'Modular Kitchen Guide');
        persistPlanningPayload('calculator-open');
        window.location.assign(nextUrl.pathname + nextUrl.search);
      });
    });

    root.querySelectorAll('[data-bw-estimate-open]').forEach(function (button) {
      button.addEventListener('click', function () {
        openModal(button.getAttribute('data-estimate-trigger'));
      });
    });

    Array.prototype.forEach.call(closeControls, function (control) {
      control.addEventListener('click', closeModal);
    });

    if (modal) {
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closeModal();
      });
    }

    window.addEventListener('hashchange', function () {
      activate(variantFromLocation());
    });

    window.addEventListener('popstate', function () {
      activate(variantFromLocation());
    });

    activate(variantFromLocation());
    persistPlanningPayload('landing');
  })();
</script>
