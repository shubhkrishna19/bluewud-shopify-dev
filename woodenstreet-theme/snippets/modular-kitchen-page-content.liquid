    <h2 class="bw-modular__title">Shortlist the layout, then build the brief in the calculator</h2>
    <p class="bw-modular__copy">The strongest next step is not endless browsing. It is selecting the right layout and submitting a clearer requirements brief to the Bluewud team.</p>
    <div class="bw-modular__actions">
      <a class="bw-modular__button" href="{{ calculator_entry_url }}">Open Kitchen Calculator</a>
      <button class="bw-modular__button--secondary" type="button" data-bw-estimate-open data-estimate-context="Modular Kitchen" data-estimate-trigger="band">Get Free Estimate</button>
      <a class="bw-modular__button--secondary" href="{{ contact_url }}">Talk To Bluewud</a>
    </div>
  </section>

  {% if show_inline_calculator %}
    <section class="bw-modular__tool" id="kitchen-calculator">
      <div class="bw-modular__section-head">
        <div class="bw-modular__eyebrow">Inline review calculator</div>
        <h2 class="bw-modular__title" style="font-size:clamp(26px, 3vw, 36px);">The actual kitchen brief builder starts here</h2>
        <p class="bw-modular__copy">This is embedded directly on the kitchen review page so you can test the WoodenStreet-style option-selection journey without relying on a separate page setup.</p>
      </div>
      {% render 'kitchen-calculator-content' %}
    </section>
  {% endif %}
</div>

{% render 'modular-estimate-popup', modal_id: 'bw-kitchen-estimate-popup', modal_title: 'Get a modular kitchen estimate', context_label: 'Bluewud modular kitchen' %}

<script>
  (function () {
    var root = document.querySelector('[data-bw-modular-page]');
    if (!root) return;
    var defaultVariant = root.getAttribute('data-default-variant') || 'all';
    var currentPath = window.location.pathname;
    var toggles = Array.prototype.slice.call(root.querySelectorAll('[data-variant-toggle]'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('[data-variant-panel]'));

    var modal = document.getElementById('bw-kitchen-estimate-popup');
    var closeControls = modal ? modal.querySelectorAll('[data-bw-estimate-close]') : [];
    var summaryText = modal ? modal.querySelector('[data-bw-estimate-summary-text]') : null;
    var summaryInput = modal ? modal.querySelector('[data-bw-estimate-summary-input]') : null;
    var contextInput = modal ? modal.querySelector('[data-bw-estimate-context-input]') : null;

    function activate(variant) {
      toggles.forEach(function (toggle) {
        toggle.classList.toggle('is-active', toggle.getAttribute('data-variant-toggle') === variant);
      });
      panels.forEach(function (panel) {
        var isActive = panel.getAttribute('data-variant-panel') === variant;
        panel.classList.toggle('is-active', isActive);
      });
    }

    function activeVariantLabel() {
      var active = root.querySelector('[data-variant-toggle].is-active');
      return active ? active.textContent.trim() : 'Modular Kitchen';
    }
    function activeVariantKey() {
      var active = root.querySelector('[data-variant-toggle].is-active');
      return active ? active.getAttribute('data-variant-toggle') : defaultVariant;
    }

    function activeSummary(trigger) {
      var label = activeVariantLabel();
      var parts = ['Project: Modular Kitchen', 'Selected layout: ' + label];
      if (trigger) parts.push('Source: ' + trigger);
      return parts.join(' | ');
    }

    function variantFromLocation() {
      var hash = (window.location.hash || '').replace('#', '');
      var validVariants = ['all', 'l-shape', 'u-shape', 'parallel', 'straight', 'island'];
      if (!hash || validVariants.indexOf(hash) === -1) return defaultVariant;
      return hash;
    }

    function openModal(trigger) {
      if (!modal) return;
      var summary = activeSummary(trigger);
      if (summaryText) summaryText.textContent = summary;
      if (summaryInput) summaryInput.value = summary;
      if (contextInput) contextInput.value = 'Bluewud modular kitchen';
      modal.classList.add('is-open');
      document.body.classList.add('bw-header-drawer-open');
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('bw-header-drawer-open');
    }

    toggles.forEach(function (toggle) {
      toggle.addEventListener('click', function (event) {
        var href = toggle.getAttribute('href') || '';
        var variant = toggle.getAttribute('data-variant-toggle');
        if (!href) {
          event.preventDefault();
          activate(variant);
          return;
        }

        var targetUrl = new URL(href, window.location.origin);
        var isSamePath = targetUrl.pathname === currentPath;
        var isHashFallback = targetUrl.hash && (targetUrl.pathname === currentPath || targetUrl.pathname === '/collections/kitchen-racks');

        if (isSamePath || isHashFallback) {
          event.preventDefault();
          if (targetUrl.hash) {
            window.history.replaceState({}, '', targetUrl.hash);
          } else if (variant === 'all') {
            window.history.replaceState({}, '', currentPath);
          }
          activate(variant);
        }
      });
    });

    root.querySelectorAll('a[href="#kitchen-calculator"]').forEach(function (link) {
      link.addEventListener('click', function (event) {
        var target = root.querySelector('#kitchen-calculator');
        if (!target) return;
        event.preventDefault();
        var calculatorRoot = target.querySelector('[data-bw-kitchen-flow]');
        if (calculatorRoot) {
          calculatorRoot.dispatchEvent(new CustomEvent('bw:kitchen-layout-select', {
            detail: { layout: activeVariantKey() }
          }));
        }
        window.history.replaceState({}, '', '#kitchen-calculator');
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    root.querySelectorAll('[data-bw-estimate-open]').forEach(function (button) {
      button.addEventListener('click', function () {
        openModal(button.getAttribute('data-estimate-trigger'));
      });
    });

    Array.prototype.forEach.call(closeControls, function (control) {
      control.addEventListener('click', closeModal);
    });

    if (modal) {
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closeModal();
      });
    }

    activate(variantFromLocation());
  })();
</script>
