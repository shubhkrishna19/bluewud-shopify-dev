{% liquid
  assign wardrobe_collection = collections['wardrobe']
  assign wardrobe_variant = 'all'
  assign main_url = '/collections/wardrobe'
  assign sliding_url = '/collections/wardrobe'
  assign hinged_url = '/collections/wardrobe'
  assign walk_in_url = '/collections/wardrobe'
  assign calculator_url = '/collections/wardrobe#wardrobe-calculator'
  assign kitchen_calculator_url = '/collections/kitchen-racks#kitchen-calculator'
  assign interiors_calculator_url = '/collections/kitchen-racks#broader-planning'
  assign estimate_url = '/pages/get-free-estimate'
  assign contact_url = '/pages/contact-us'
  assign phone_url = 'tel:+918800609609'
  assign is_collection_context = true
  assign calculator_cta_url = calculator_url

  assign spotlight_title = 'Modular wardrobes planned around format, storage, and finish clarity'
  assign spotlight_copy = "A premium wardrobe project should begin with room-fit, opening style, internals, and budget direction, not just a shutter moodboard."
  assign spotlight_points = 'Compare sliding, hinged, and walk-in before choosing the elevation|Plan hanging, drawers, lofts, mirrors, and accessories before final approval|Use the calculator and estimate flow once the scope feels grounded' | split: '|'
  assign spotlight_tag = 'All wardrobe planning'
  assign keyword = blank

  case page.handle
    when 'sliding-wardrobe-designs'
      assign wardrobe_variant = 'sliding'
      assign spotlight_title = 'Sliding wardrobes for compact rooms, cleaner movement, and sharper elevations'
      assign spotlight_copy = 'Sliding shutters save front clearance and look refined, but they reward disciplined planning around tracks, mirror use, and partial internal access.'
      assign spotlight_points = 'Best where the bed sits close to the wardrobe line|Ideal for contemporary mirror-led or glass-led elevations|Plan internal zoning carefully because all sections do not open together' | split: '|'
      assign spotlight_tag = 'Sliding wardrobes'
      assign keyword = 'sliding'
    when 'hinged-wardrobes'
      assign wardrobe_variant = 'hinged'
      assign spotlight_title = 'Hinged wardrobes for full access, easy daily use, and classic bedroom planning'
      assign spotlight_copy = 'Hinged shutters remain the most intuitive wardrobe format when the room can spare door clearance and the buyer wants complete internal visibility.'
      assign spotlight_points = 'Best for full-width daily access and familiar use|Makes drawers, shelves, and hanging zones easier to reach|Needs enough swing clearance in front of the wardrobe line' | split: '|'
      assign spotlight_tag = 'Hinged wardrobes'
      assign keyword = 'hinged'
    when 'walk-in-wardrobes'
      assign wardrobe_variant = 'walk-in'
      assign spotlight_title = 'Walk-in wardrobes for larger suites and premium dressing-room planning'
      assign spotlight_copy = 'A walk-in wardrobe is less about one cabinet and more about zoning a room for dressing, storage, mirrors, lighting, and calmer everyday routines.'
      assign spotlight_points = 'Best for larger master suites and premium homes|Needs early planning around movement, lighting, drawers, and open versus closed storage|Usually benefits from consultation sooner than standard wardrobes' | split: '|'
      assign spotlight_tag = 'Walk-in wardrobes'
      assign keyword = 'walk in'
  endcase

  if page != blank and page.handle != blank
    assign is_collection_context = false
  endif

  if pages['modular-wardrobe-designs'] != blank
    assign main_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['sliding-wardrobe-designs'] != blank
    assign sliding_url = pages['sliding-wardrobe-designs'].url
  else
    assign sliding_url = main_url
  endif
  if pages['hinged-wardrobes'] != blank
    assign hinged_url = pages['hinged-wardrobes'].url
  else
    assign hinged_url = main_url
  endif
  if pages['walk-in-wardrobes'] != blank
    assign walk_in_url = pages['walk-in-wardrobes'].url
  else
    assign walk_in_url = main_url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if is_collection_context
    assign calculator_url = '#wardrobe-calculator'
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
  if pages['get-free-estimate'] == blank and pages['contact-us'] != blank
    assign estimate_url = pages['contact-us'].url
  endif
  if is_collection_context
    assign main_url = '#wardrobe-overview'
    assign sliding_url = '#sliding-wardrobe'
    assign hinged_url = '#hinged-wardrobe'
    assign walk_in_url = '#walk-in-wardrobe'
    assign calculator_cta_url = '#wardrobe-calculator'
  else
    assign wardrobe_source_param = 'Modular Wardrobe Guide' | url_encode
    case wardrobe_variant
      when 'sliding'
        assign calculator_cta_url = calculator_url | append: '?type=Sliding&source=' | append: wardrobe_source_param
      when 'hinged'
        assign calculator_cta_url = calculator_url | append: '?type=Hinged&source=' | append: wardrobe_source_param
      when 'walk-in'
        assign calculator_cta_url = calculator_url | append: '?type=Walk-in&source=' | append: wardrobe_source_param
      else
        assign calculator_cta_url = calculator_url | append: '?source=' | append: wardrobe_source_param
    endcase
  endif
%}

