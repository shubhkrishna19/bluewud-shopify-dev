{% liquid
  assign contact_url = '/pages/contact-us'
  assign help_center_url = '/pages/help-center'
%}

<style>
  .bw-returns {
    display: grid;
    gap: 22px;
  }

  .bw-returns__hero,
  .bw-returns__section,
  .bw-returns__aside {
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-returns__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 18px;
    overflow: hidden;
  }

  .bw-returns__hero-main {
    display: grid;
    gap: 18px;
  }

  .bw-returns__hero-copy {
    padding: 32px;
    display: grid;
    gap: 18px;
    background:
      radial-gradient(circle at top right, rgba(166, 106, 67, 0.12), transparent 28%),
      linear-gradient(135deg, #241913 0%, #3c2a20 100%);
    color: #f8f1eb;
  }

  .bw-returns__eyebrow {
    display: inline-flex;
    width: fit-content;
    min-height: 32px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(248, 241, 235, 0.84);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-returns__title {
    margin: 0;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.04;
    letter-spacing: -0.04em;
    max-width: 12ch;
  }

  .bw-returns__copy {
    margin: 0;
    color: rgba(248, 241, 235, 0.78);
    font-size: 16px;
    line-height: 1.8;
    max-width: 60ch;
  }

  .bw-returns__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .bw-returns__summary-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .bw-returns__summary-card {
    padding: 14px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: grid;
    gap: 4px;
  }

  .bw-returns__summary-label {
    color: rgba(248, 241, 235, 0.68);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-returns__summary-value {
    color: #f8f1eb;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.45;
  }

  .bw-returns__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .bw-returns__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: #f8f1eb;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-returns__action--solid {
    background: #f8f1eb;
    color: #201713;
    border-color: #f8f1eb;
  }

  .bw-returns__chip {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: #f8f1eb;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-returns__hero-side {
    padding: 28px;
    display: grid;
    gap: 14px;
  }

  .bw-returns__quick {
    display: grid;
    gap: 12px;
  }

  .bw-returns__quick-item {
    padding: 16px 18px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    display: grid;
    gap: 4px;
  }

  .bw-returns__quick-label {
    color: #8a684f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-returns__quick-value {
    color: #201713;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  .bw-returns__quick-copy {
    color: #66554c;
    font-size: 13px;
    line-height: 1.65;
  }

  .bw-returns__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(280px, 0.96fr);
    gap: 18px;
  }

  .bw-returns__process {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .bw-returns__process-card {
    padding: 20px 22px;
    border-radius: 24px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 16px 40px rgba(35, 24, 19, 0.06);
    display: grid;
    gap: 8px;
  }

  .bw-returns__process-label {
    color: #8a684f;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-returns__process-card h3 {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.18;
  }

  .bw-returns__process-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.75;
  }

  .bw-returns__section {
    padding: 28px;
    display: grid;
    gap: 16px;
  }

  .bw-returns__section-head {
    display: grid;
    gap: 8px;
  }

  .bw-returns__kicker {
    color: #8a684f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-returns__section-title {
    margin: 0;
    color: #201713;
    font-size: 26px;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .bw-returns__section-copy {
    margin: 0;
    color: #66554c;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-returns__accordions {
    display: grid;
    gap: 12px;
  }

  .bw-returns__accordion {
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    border: 1px solid rgba(45, 33, 27, 0.06);
    overflow: hidden;
  }

  .bw-returns__accordion summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 18px 16px;
    color: #201713;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .bw-returns__accordion summary::-webkit-details-marker {
    display: none;
  }

  .bw-returns__accordion-body {
    padding: 0 18px 18px;
    color: #5f4f46;
    font-size: 14px;
    line-height: 1.85;
  }

  .bw-returns__accordion-body ul {
    margin: 0;
    padding-left: 1.2em;
  }

  .bw-returns__aside {
    padding: 28px;
    display: grid;
    gap: 16px;
    align-content: start;
  }

  .bw-returns__aside-actions {
    display: grid;
    gap: 10px;
  }

  .bw-returns__aside-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    background: #201713;
    color: #f8f1eb;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
  }

  .bw-returns__aside-title {
    margin: 0;
    color: #201713;
    font-size: 20px;
    line-height: 1.18;
    letter-spacing: -0.03em;
  }

  .bw-returns__aside-copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.8;
  }

  .bw-returns__aside-list {
    margin: 0;
    padding-left: 1.2em;
    color: #5f4f46;
    font-size: 14px;
    line-height: 1.9;
  }

  .bw-returns__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    width: fit-content;
    border-radius: 999px;
    background: #201713;
    color: #f8f1eb;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-returns__note {
    padding: 20px 22px;
    background: rgba(53, 90, 109, 0.06);
    border: 1px solid rgba(53, 90, 109, 0.12);
    color: #395261;
    font-size: 14px;
    line-height: 1.8;
  }

  @media (max-width: 980px) {
    .bw-returns__hero,
    .bw-returns__grid,
    .bw-returns__process {
      grid-template-columns: 1fr;
    }

    .bw-returns__summary-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .bw-returns__hero-copy,
    .bw-returns__hero-side,
    .bw-returns__section,
    .bw-returns__aside {
      padding: 20px;
      border-radius: 24px;
    }

    .bw-returns__title {
      max-width: none;
      font-size: clamp(28px, 10vw, 38px);
    }

    .bw-returns__summary-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="bw-returns">
  <section class="bw-returns__hero">
    <div class="bw-returns__hero-copy">
      <div class="bw-returns__hero-main">
        <span class="bw-returns__eyebrow">Policy clarity</span>
        <h2 class="bw-returns__title">Returns and refunds, explained with less friction.</h2>
        <p class="bw-returns__copy">This page keeps the important parts easy to read: what qualifies for a return, when to raise a request, how cancellations work, and how larger items are handled.</p>
        <div class="bw-returns__chips">
          <span class="bw-returns__chip">Return window</span>
          <span class="bw-returns__chip">Cancellation rules</span>
          <span class="bw-returns__chip">Replacement support</span>
        </div>
        <div class="bw-returns__summary-row" aria-label="Return policy quick summary">
          <div class="bw-returns__summary-card">
          <span class="bw-returns__summary-label">When to act</span>
          <span class="bw-returns__summary-value">Raise the request as soon as you spot the issue</span>
          </div>
          <div class="bw-returns__summary-card">
          <span class="bw-returns__summary-label">What helps</span>
          <span class="bw-returns__summary-value">Photos, order ID, and product name speed up review</span>
          </div>
          <div class="bw-returns__summary-card">
          <span class="bw-returns__summary-label">Big items</span>
          <span class="bw-returns__summary-value">Large furniture usually follows replacement-first handling</span>
          </div>
        </div>
        <div class="bw-returns__actions">
          <a class="bw-returns__action bw-returns__action--solid" href="{{ contact_url }}">Talk to Bluewud</a>
          <a class="bw-returns__action" href="{{ help_center_url }}">Open Help Center</a>
        </div>
      </div>
    </div>

    <div class="bw-returns__hero-side">
      <div class="bw-returns__note">
        If you are not sure which path applies, contact support with the order ID and photos so the team can guide the next step once.
      </div>
      <div class="bw-returns__aside-actions">
        <a class="bw-returns__aside-link" href="{{ contact_url }}">Contact support</a>
        <a class="bw-returns__cta" href="{{ help_center_url }}">Open help center</a>
      </div>
    </div>
  </section>

  <div class="bw-returns__grid">
    <section class="bw-returns__section">
      <div class="bw-returns__section-head">
      <span class="bw-returns__kicker">What matters most</span>
      <h3 class="bw-returns__section-title">The policy, broken into the parts customers actually look for.</h3>
      <p class="bw-returns__section-copy">Each block below is sized for scanning, so the page feels calm and readable instead of overloaded with policy text.</p>
      </div>

      <div class="bw-returns__accordions">
        <details class="bw-returns__accordion" open>
          <summary>Cancellation before dispatch</summary>
          <div class="bw-returns__accordion-body">
            <p>Orders can be cancelled before they leave the warehouse. Once a shipment is in transit, cancellation may not be possible and shipping charges may still apply.</p>
          </div>
        </details>

        <details class="bw-returns__accordion">
          <summary>Return eligibility and timelines</summary>
          <div class="bw-returns__accordion-body">
            <p>Return or replacement requests should be raised as soon as the issue is discovered, ideally within 10 days of delivery. Damaged, defective, or incomplete shipments are reviewed first, along with items that do not match expectations.</p>
          </div>
        </details>

        <details class="bw-returns__accordion">
          <summary>How replacements are handled</summary>
          <div class="bw-returns__accordion-body">
            <p>Where a product qualifies for support, the team may arrange pickup, replacement, or another resolution based on inspection. Products should be kept in the condition required for pickup, with original or nearest available packing retained.</p>
          </div>
        </details>

        <details class="bw-returns__accordion">
          <summary>Products that follow a different path</summary>
          <div class="bw-returns__accordion-body">
            <p>Larger volumetric furniture items are generally supported through replacement rather than a standard return flow. If pickup is not available, the support team will guide the next step and explain any shipping credit limits.</p>
          </div>
        </details>
      </div>
    </section>

    <aside class="bw-returns__aside">
      <span class="bw-returns__kicker">Need help faster?</span>
      <h3 class="bw-returns__aside-title">Need a clearer next step?</h3>
      <p class="bw-returns__aside-copy">Bluewud support can help with order follow-up, pickup questions, or clarifying whether a case fits a return or replacement path.</p>
      <ul class="bw-returns__aside-list">
        <li>Call or WhatsApp: <a href="tel:+918800609609">+91-8800-609-609</a></li>
        <li>Email: <a href="mailto:care@bluewud.com">care@bluewud.com</a></li>
      </ul>
      <div class="bw-returns__aside-actions">
        <a class="bw-returns__aside-link" href="{{ contact_url }}">Contact support</a>
        <a class="bw-returns__cta" href="{{ help_center_url }}">Open help center</a>
      </div>
    </aside>
  </div>

  <div class="bw-returns__process">
    <article class="bw-returns__process-card">
      <span class="bw-returns__process-label">Step 1</span>
      <h3>Raise the request early</h3>
      <p>The faster the customer shares the issue, the easier it is to confirm eligibility against the delivery timeline.</p>
    </article>
    <article class="bw-returns__process-card">
      <span class="bw-returns__process-label">Step 2</span>
      <h3>Keep the order details ready</h3>
      <p>Order number, product name, and photos help the team route the case without unnecessary back-and-forth.</p>
    </article>
    <article class="bw-returns__process-card">
      <span class="bw-returns__process-label">Step 3</span>
      <h3>Use the right support path</h3>
      <p>Some questions resolve through a policy read, while others are faster when handled directly by support or estimate.</p>
    </article>
  </div>
</div>
