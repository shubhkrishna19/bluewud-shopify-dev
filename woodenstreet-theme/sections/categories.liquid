        <div class="bw-categories__overlay"></div>
        <div class="bw-categories__content">
          <span class="bw-categories__kicker">Living room anchor</span>
          <h3 class="bw-categories__name">{{ centre_collection.title | default: 'Centre Tables' }}</h3>
          <div class="bw-categories__meta">
            <span>
              {% if centre_collection != blank and centre_collection.all_products_count > 0 %}
                {{ centre_collection.all_products_count }} products
              {% else %}
                Coffee and centre tables with presence
              {% endif %}
            </span>
          </div>
        </div>
      </a>

      <a class="bw-categories__card bw-categories__card--small" href="{{ wfh_furniture_url }}">
        {% if wfh_media != blank %}
          <div class="bw-categories__media">
            {{ wfh_media | image_url: width: 900 | image_tag: loading: 'lazy', widths: '320, 480, 720, 900', sizes: '(max-width: 720px) 100vw, 25vw', alt: 'WFH Furniture' }}
          </div>
        {% else %}
          <div class="bw-categories__media bw-categories__media--placeholder bw-categories__media--wfh" role="img" aria-label="WFH Furniture collection preview">
            <span class="bw-categories__placeholder">Add Bluewud image</span>
          </div>
        {% endif %}
        <div class="bw-categories__overlay"></div>
        <div class="bw-categories__content">
          <span class="bw-categories__kicker">Focus-ready setups</span>
          <h3 class="bw-categories__name">{{ wfh_collection.title | default: 'WFH Furniture' }}</h3>
          <div class="bw-categories__meta">
            <span>
              {% if wfh_collection != blank and wfh_collection.all_products_count > 0 %}
                {{ wfh_collection.all_products_count }} products
              {% else %}
                Home office and study planning
              {% endif %}
            </span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

