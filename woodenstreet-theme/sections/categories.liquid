{% liquid
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif
%}

<style>
  .bw-categories {
    padding: 78px 24px 72px;
    background: #faf6f1;
  }

  .bw-categories__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-categories__header {
    max-width: 720px;
    margin: 0 auto 38px;
    text-align: center;
  }

  .bw-categories__eyebrow {
    display: inline-block;
    margin-bottom: 12px;
    color: #7f604d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-categories__title {
    margin: 0 0 12px;
    color: #201713;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .bw-categories__copy {
    margin: 0;
    color: #66554c;
    font-size: 16px;
    line-height: 1.8;
  }

  .bw-categories__grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 20px;
  }

  .bw-categories__card {
    position: relative;
    min-height: 310px;
    border-radius: 30px;
    overflow: hidden;
    color: #fff;
    text-decoration: none;
    box-shadow: 0 24px 64px rgba(35, 24, 19, 0.12);
  }

  .bw-categories__card--large {
    grid-column: span 6;
  }

  .bw-categories__card--small {
    grid-column: span 3;
  }

  .bw-categories__media,
  .bw-categories__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bw-categories__media img {
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .bw-categories__card:hover .bw-categories__media img {
    transform: scale(1.05);
  }

  .bw-categories__media--placeholder {
    display: flex;
    align-items: flex-end;
    padding: 22px;
    box-sizing: border-box;
  }

  .bw-categories__media--living {
    background:
      radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.22), transparent 26%),
      linear-gradient(145deg, #d0b9ab 0%, #9b745e 46%, #4a342b 100%);
  }

  .bw-categories__media--bedroom {
    background:
      radial-gradient(circle at 78% 20%, rgba(255, 255, 255, 0.18), transparent 24%),
      linear-gradient(145deg, #d8c8bf 0%, #b39181 42%, #5c4038 100%);
  }

  .bw-categories__media--study {
    background:
      radial-gradient(circle at 22% 24%, rgba(255, 255, 255, 0.18), transparent 24%),
      linear-gradient(145deg, #c5cdd0 0%, #7f8f95 46%, #38424a 100%);
  }

  .bw-categories__media--tv {
    background:
      radial-gradient(circle at 80% 18%, rgba(255, 255, 255, 0.18), transparent 22%),
      linear-gradient(145deg, #d7c6bb 0%, #9a7865 42%, #43342b 100%);
  }

  .bw-categories__media--bookshelves {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.18), transparent 22%),
      linear-gradient(145deg, #d0c4b7 0%, #8a6f5e 44%, #45352d 100%);
  }

  .bw-categories__media--wardrobe {
    background:
      radial-gradient(circle at 82% 18%, rgba(255, 255, 255, 0.18), transparent 22%),
      linear-gradient(145deg, #d7ccc4 0%, #aa8b7a 44%, #58433a 100%);
  }

  .bw-categories__media--kitchen {
    background:
      radial-gradient(circle at 24% 18%, rgba(255, 255, 255, 0.18), transparent 24%),
      linear-gradient(145deg, #d8d1c7 0%, #aa907f 42%, #5b4338 100%);
  }

  .bw-categories__media--dressing {
    background:
      radial-gradient(circle at 80% 18%, rgba(255, 255, 255, 0.2), transparent 22%),
      linear-gradient(145deg, #decabf 0%, #b48f81 44%, #65483d 100%);
  }

  .bw-categories__media--centre {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.18), transparent 24%),
      linear-gradient(145deg, #d9cec3 0%, #a88872 44%, #5d4437 100%);
  }

  .bw-categories__media--wfh {
    background:
      radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.18), transparent 24%),
      linear-gradient(145deg, #ced3d6 0%, #8b979d 42%, #434b52 100%);
  }

  .bw-categories__placeholder {
    display: none;
    align-items: center;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.86);
    color: #201713;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-categories__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(11, 8, 6, 0.04) 10%, rgba(11, 8, 6, 0.66) 72%, rgba(11, 8, 6, 0.82) 100%);
  }

  .bw-categories__content {
    position: relative;
    z-index: 1;
    height: 100%;
    box-sizing: border-box;
    padding: 24px 30px 42px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 8px;
    max-width: 100%;
  }

  .bw-categories__kicker {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 248, 242, 0.76);
  }

  .bw-categories__name {
    margin: 0;
    font-size: 28px;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .bw-categories__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: rgba(255, 248, 242, 0.86);
    font-size: 14px;
  }

  .bw-categories__arrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 1100px) {
    .bw-categories__card--large,
    .bw-categories__card--small {
      grid-column: span 6;
    }
  }

  @media (max-width: 720px) {
    .bw-categories {
      padding: 56px 16px 52px;
    }

    .bw-categories__grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .bw-categories__card--large {
      grid-column: 1 / -1;
      min-height: 220px;
    }

    .bw-categories__card--small {
      grid-column: auto;
      min-height: 196px;
    }

    .bw-categories__content {
      box-sizing: border-box;
      padding: 14px 14px 20px;
      gap: 6px;
    }

    .bw-categories__name {
      font-size: 19px;
      line-height: 1.08;
    }

    .bw-categories__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      font-size: 12px;
      line-height: 1.5;
    }
  }

  @media (max-width: 520px) {
    .bw-categories__grid {
      grid-template-columns: 1fr;
    }

    .bw-categories__card--small {
      min-height: 206px;
    }

    .bw-categories__card--large {
      min-height: 206px;
    }
  }
</style>

{% liquid
  assign living_collection = collections['living-room']
  assign bedroom_collection = collections['bed-room']
  assign study_collection = collections['study-tables']
  assign modular_kitchen_collection = collections['kitchen-racks']
  assign dressing_collection = collections['dressing-tables']
  assign centre_collection = collections['coffee-table']
  assign wfh_collection = collections['smartly-designed-wfh-furniture']
  assign living_room_url = '/collections/living-room'
  assign bedroom_url = '/collections/bed-room'
  assign study_room_url = '/collections/study-tables'
  assign tv_unit_url = '/collections/tv-unit-furniture'
  assign bookshelves_url = '/collections/book-shelves'
  assign dressing_tables_url = '/collections/dressing-tables'
  assign centre_tables_url = '/collections/coffee-table'
  assign wfh_furniture_url = '/collections/smartly-designed-wfh-furniture'

  if study_collection == blank
    assign study_collection = collections['study-table']
  endif

  if study_collection == blank
    assign study_collection = collections['smartly-designed-wfh-furniture']
  endif
  assign tv_collection = collections['tv-unit-furniture']
  assign bookshelves_collection = collections['book-shelves']
  assign wardrobe_collection = collections['wardrobe']

  if living_collection != blank and living_collection.url != blank
    assign living_room_url = living_collection.url
  endif
  if bedroom_collection != blank and bedroom_collection.url != blank
    assign bedroom_url = bedroom_collection.url
  endif
  if study_collection != blank and study_collection.url != blank
    assign study_room_url = study_collection.url
  endif
  if tv_collection != blank and tv_collection.url != blank
    assign tv_unit_url = tv_collection.url
  endif
  if bookshelves_collection != blank and bookshelves_collection.url != blank
    assign bookshelves_url = bookshelves_collection.url
  endif
  if modular_kitchen_collection != blank and modular_kitchen_collection.url != blank
    assign modular_kitchen_url = modular_kitchen_collection.url
  endif
  if dressing_collection != blank and dressing_collection.url != blank
    assign dressing_tables_url = dressing_collection.url
  endif
  if centre_collection != blank and centre_collection.url != blank
    assign centre_tables_url = centre_collection.url
  endif
  if wfh_collection != blank and wfh_collection.url != blank
    assign wfh_furniture_url = wfh_collection.url
  endif

  assign living_media = section.settings.living_room_image
  if living_media == blank and living_collection != blank
    assign living_media = living_collection.image
  endif
  if living_media == blank and living_collection != blank and living_collection.products.first.featured_image != blank
    assign living_media = living_collection.products.first.featured_image
  endif

  assign bedroom_media = section.settings.bedroom_image
  if bedroom_media == blank and bedroom_collection != blank
    assign bedroom_media = bedroom_collection.image
  endif
  if bedroom_media == blank and bedroom_collection != blank and bedroom_collection.products.first.featured_image != blank
    assign bedroom_media = bedroom_collection.products.first.featured_image
  endif

  assign study_media = section.settings.study_tables_image
  if study_media == blank and study_collection != blank
    assign study_media = study_collection.image
  endif
  if study_media == blank and study_collection != blank and study_collection.products.first.featured_image != blank
    assign study_media = study_collection.products.first.featured_image
  endif

  assign tv_media = section.settings.tv_units_image
  if tv_media == blank and tv_collection != blank
    assign tv_media = tv_collection.image
  endif
  if tv_media == blank and tv_collection != blank and tv_collection.products.first.featured_image != blank
    assign tv_media = tv_collection.products.first.featured_image
  endif

  assign bookshelves_media = section.settings.bookshelves_image
  if bookshelves_media == blank and bookshelves_collection != blank
    assign bookshelves_media = bookshelves_collection.image
  endif
  if bookshelves_media == blank and bookshelves_collection != blank and bookshelves_collection.products.first.featured_image != blank
    assign bookshelves_media = bookshelves_collection.products.first.featured_image
  endif

  assign wardrobe_media = section.settings.wardrobe_image
  if wardrobe_media == blank and wardrobe_collection != blank
    assign wardrobe_media = wardrobe_collection.image
  endif
  if wardrobe_media == blank and wardrobe_collection != blank and wardrobe_collection.products.first.featured_image != blank
    assign wardrobe_media = wardrobe_collection.products.first.featured_image
  endif
  if wardrobe_media == blank and bedroom_collection != blank
    assign wardrobe_media = bedroom_collection.image
  endif
  if wardrobe_media == blank and bedroom_collection != blank and bedroom_collection.products.first.featured_image != blank
    assign wardrobe_media = bedroom_collection.products.first.featured_image
  endif

  assign modular_kitchen_media = section.settings.modular_kitchen_image
  if modular_kitchen_media == blank and modular_kitchen_collection != blank
    assign modular_kitchen_media = modular_kitchen_collection.image
  endif
  if modular_kitchen_media == blank and modular_kitchen_collection != blank and modular_kitchen_collection.products.first.featured_image != blank
    assign modular_kitchen_media = modular_kitchen_collection.products.first.featured_image
  endif
  if modular_kitchen_media == blank
    assign modular_kitchen_media = 'modular-kitchen-light-oak-l-shape.png'
  endif

  assign dressing_media = section.settings.dressing_tables_image
  if dressing_media == blank and dressing_collection != blank
    assign dressing_media = dressing_collection.image
  endif
  if dressing_media == blank and dressing_collection != blank and dressing_collection.products.first.featured_image != blank
    assign dressing_media = dressing_collection.products.first.featured_image
  endif

  assign centre_media = section.settings.centre_tables_image
  if centre_media == blank and centre_collection != blank
    assign centre_media = centre_collection.image
  endif
  if centre_media == blank and centre_collection != blank and centre_collection.products.first.featured_image != blank
    assign centre_media = centre_collection.products.first.featured_image
  endif

  assign wfh_media = section.settings.wfh_furniture_image
  if wfh_media == blank and wfh_collection != blank
    assign wfh_media = wfh_collection.image
  endif
  if wfh_media == blank and wfh_collection != blank and wfh_collection.products.first.featured_image != blank
    assign wfh_media = wfh_collection.products.first.featured_image
  endif
%}

<section class="bw-categories">
  <div class="bw-categories__inner">
    <div class="bw-categories__header">
      <span class="bw-categories__eyebrow">Shop by room</span>
      <h2 class="bw-categories__title">Start with the room you want to make feel right first.</h2>
      <p class="bw-categories__copy">Choose the room, then narrow the shortlist through storage, finish, and function instead of guessing across the whole catalog.</p>
    </div>

    <div class="bw-categories__grid">
      <a class="bw-categories__card bw-categories__card--large" href="{{ living_room_url }}">
        {% if living_media != blank %}
          <div class="bw-categories__media">
            {{ living_media | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1200', sizes: '(max-width: 720px) 100vw, 50vw', alt: 'Living Room' }}
          </div>
        {% else %}
          <div class="bw-categories__media bw-categories__media--placeholder bw-categories__media--living" role="img" aria-label="Living Room collection preview">
            <span class="bw-categories__placeholder">Add Bluewud image</span>
          </div>
        {% endif %}
        <div class="bw-categories__overlay"></div>
        <div class="bw-categories__content">
          <span class="bw-categories__kicker">Signature category</span>
          <h3 class="bw-categories__name">{{ living_collection.title | default: 'Living Room' }}</h3>
          <div class="bw-categories__meta">
            <span>
              {% if living_collection != blank and living_collection.all_products_count > 0 %}
                {{ living_collection.all_products_count }} products
              {% else %}
                Sofas, tables, and media units
              {% endif %}
            </span>
          </div>
        </div>
      </a>

      <a class="bw-categories__card bw-categories__card--large" href="{{ bedroom_url }}">
        {% if bedroom_media != blank %}
          <div class="bw-categories__media">
            {{ bedroom_media | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1200', sizes: '(max-width: 720px) 100vw, 50vw', alt: 'Bedroom' }}
