<section class="account-page page-width">
  <header class="section-header">
    <h1 class="section-title">{{ 'customers.reset_password.title' | t }}</h1>
    <p>{{ 'customers.reset_password.subtext' | t: email: email }}</p>
  </header>

  <div class="account-page__card account-page__card--narrow">
    {% form 'reset_customer_password' %}
      {% if form.errors %}
        <div class="form-message form-message--error">{{ form.errors | default_errors }}</div>
      {% endif %}
      <div class="form-field">
        <label for="ResetPassword">{{ 'customers.reset_password.password' | t }}</label>
        <input id="ResetPassword" type="password" name="customer[password]">
      </div>
      <div class="form-field">
        <label for="ResetPasswordConfirmation">{{ 'customers.reset_password.password_confirm' | t }}</label>
        <input id="ResetPasswordConfirmation" type="password" name="customer[password_confirmation]">
      </div>
      <button class="button-primary" type="submit">{{ 'customers.reset_password.submit' | t }}</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Reset password"
}
{% endschema %}
