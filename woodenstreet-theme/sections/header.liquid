<style>
  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  body.bw-header-drawer-open {
    overflow: hidden;
    overscroll-behavior: none;
  }

  .bw-header-shell {
    position: relative;
    z-index: 10000;
    overflow: visible;
    background: rgba(248, 243, 237, 0.96);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 14px 28px rgba(32, 24, 19, 0.05);
  }

  .bw-header-shell a {
    text-decoration: none;
  }

  .bw-header__utility {
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
    background: rgba(255, 255, 255, 0.26);
  }

  .bw-header__utility-inner,
  .bw-header__main-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  .bw-header__utility-inner {
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .bw-header__contact,
  .bw-header__support-links,
  .bw-header__nav,
  .bw-header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .bw-header__contact {
    flex-wrap: wrap;
  }

  .bw-header__support-links {
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 12px 16px;
  }

  .bw-header__utility-link,
  .bw-header__support-link {
    color: rgba(53, 43, 36, 0.78);
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .bw-header__utility-link:hover,
  .bw-header__support-link:hover {
    color: #355a6d;
  }

  .bw-header__contact-separator {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: rgba(45, 33, 27, 0.22);
  }

  .bw-header__support-link {
    color: #2b201a;
  }

  .bw-header__main-inner {
    min-height: 96px;
    display: grid;
    grid-template-columns: minmax(200px, 270px) minmax(0, 1fr) auto;
    align-items: start;
    gap: 12px 18px;
    padding-top: 14px;
    padding-bottom: 10px;
    overflow: visible;
  }

  .bw-header__brand {
    display: block;
    min-width: 0;
    grid-column: 1 / 2;
    grid-row: 1 / 2;
    transition: transform 0.22s ease;
  }

  .bw-header__brand-visual {
    width: 56px;
    height: 56px;
    flex: 0 0 56px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.09);
    background: linear-gradient(135deg, #f7efe7 0%, #ecdfd3 54%, #dbe5ec 100%);
    box-shadow: 0 12px 22px rgba(36, 26, 21, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bw-header__brand-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }

  .bw-header__brand-seal {
    font-family: var(--bw-font-serif);
    font-size: 24px;
    font-weight: 700;
    color: #355a6d;
  }

  .bw-header__brand-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .bw-header__brand-copy--with-logo {
    gap: 4px;
  }

  .bw-header__brand-kicker {
    display: none;
  }

  .bw-header__brand-wordmark {
    display: inline-block;
    font-family: var(--bw-font-sans);
    font-size: 31px;
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.065em;
    color: #4f788f;
    transition: color 0.22s ease, background 0.22s ease, -webkit-text-fill-color 0.22s ease;
  }

  .bw-header__brand:hover,
  .bw-header__brand:focus-visible {
    transform: translateY(-1px);
  }

  .bw-header__brand:hover .bw-header__brand-wordmark,
  .bw-header__brand:focus-visible .bw-header__brand-wordmark {
    background: linear-gradient(90deg, #4f788f 0 50%, #ffffff 50% 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 1px rgba(32, 23, 19, 0.16);
  }

  .bw-header__brand-logo-frame {
    display: inline-flex;
    align-items: center;
    max-width: min(100%, 240px);
    line-height: 0;
  }

  .bw-header__brand-logo-image {
    display: block;
    width: auto;
    max-width: 100%;
    height: 34px;
    object-fit: contain;
    object-position: left center;
    transition: filter 0.22s ease, opacity 0.22s ease;
  }

  .bw-header__brand-logo-image--tinted {
    filter: brightness(0) saturate(100%) invert(31%) sepia(20%) saturate(815%) hue-rotate(159deg) brightness(90%) contrast(89%);
  }

  .bw-header__brand:hover .bw-header__brand-logo-image--tinted,
  .bw-header__brand:focus-visible .bw-header__brand-logo-image--tinted {
    filter: brightness(0) saturate(100%) invert(21%) sepia(20%) saturate(894%) hue-rotate(161deg) brightness(88%) contrast(90%);
  }

  .bw-header__brand-tagline {
    color: #6c5b51;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bw-header__nav {
    grid-column: 1 / -1;
    grid-row: 2 / 3;
    justify-self: stretch;
    justify-content: center;
    align-items: stretch;
    gap: 6px;
    min-width: 0;
    width: 100%;
    margin-top: 0;
    padding: 8px 8px 0;
    border-top: 1px solid rgba(45, 33, 27, 0.08);
    overflow: visible;
  }

  .bw-header__nav-item {
    position: relative;
    display: flex;
    align-items: stretch;
    z-index: 1;
  }

  .bw-header__nav-item:hover,
  .bw-header__nav-item:focus-within {
    z-index: 4;
  }

  .bw-header__nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #241a15;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    position: relative;
    min-height: 38px;
    padding: 0 9px 6px;
    white-space: nowrap;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .bw-header__nav-link--has-children::before {
    content: '';
    order: 1;
    width: 7px;
    height: 7px;
    border-right: 1.6px solid currentColor;
    border-bottom: 1.6px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    flex: 0 0 auto;
    opacity: 0.7;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .bw-header__nav-item:hover .bw-header__nav-link--has-children::before,
  .bw-header__nav-item:focus-within .bw-header__nav-link--has-children::before {
    transform: rotate(225deg) translateY(-1px);
    opacity: 1;
  }

  .bw-header__nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 2px;
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, #355a6d 0%, #a66a43 100%);
    transform: translateX(-50%) scaleX(0);
    transform-origin: center center;
    transition: transform 0.22s ease;
  }

  .bw-header__nav-link:hover,
  .bw-header__nav-link:focus-visible,
  .bw-header__nav-link.is-active,
  .bw-header__nav-item:hover > .bw-header__nav-link,
  .bw-header__nav-item:focus-within > .bw-header__nav-link {
    color: #355a6d;
    transform: translateY(-1px);
  }

  .bw-header__nav-link:hover::after,
  .bw-header__nav-link:focus-visible::after,
  .bw-header__nav-link.is-active::after,
  .bw-header__nav-item:hover > .bw-header__nav-link::after,
  .bw-header__nav-item:focus-within > .bw-header__nav-link::after {
    transform: translateX(-50%) scaleX(1);
  }

  .bw-header__nav-link:focus-visible,
  .bw-header__dropdown-link:focus-visible,
  .bw-header__icon-link:focus-visible,
  .bw-header__cta:focus-visible,
  .bw-header__drawer-link:focus-visible,
  .bw-header__drawer-pill:focus-visible {
    outline: 2px solid rgba(53, 90, 109, 0.42);
    outline-offset: 3px;
  }

  .bw-header__dropdown {
    position: absolute;
    top: calc(100% - 2px);
    left: 50%;
    z-index: 10010;
    min-width: 250px;
    max-width: min(360px, calc(100vw - 24px));
    padding: 10px;
    border-radius: 22px;
    border: 1px solid rgba(45, 33, 27, 0.1);
    background: rgba(255, 251, 247, 0.98);
    box-shadow: 0 20px 42px rgba(35, 24, 19, 0.12);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translate(-50%, 8px);
    transition: opacity 0.22s ease, visibility 0.22s ease, transform 0.22s ease;
    backdrop-filter: blur(16px);
  }

  .bw-header__nav-item:hover .bw-header__dropdown,
  .bw-header__nav-item:focus-within .bw-header__dropdown {
    z-index: 9400;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .bw-header__nav-item:first-child .bw-header__dropdown {
    left: 0;
    transform: translate(0, 10px);
  }

  .bw-header__nav-item:first-child:hover .bw-header__dropdown,
  .bw-header__nav-item:first-child:focus-within .bw-header__dropdown {
    transform: translate(0, 0);
  }

  .bw-header__nav-item:last-child .bw-header__dropdown {
    left: auto;
    right: 0;
    transform: translate(0, 10px);
  }

  .bw-header__nav-item:last-child:hover .bw-header__dropdown,
  .bw-header__nav-item:last-child:focus-within .bw-header__dropdown {
    transform: translate(0, 0);
  }

  .bw-header__dropdown-grid {
    display: grid;
    gap: 10px;
  }

  .bw-header__dropdown-group {
    display: grid;
    gap: 4px;
  }

  .bw-header__dropdown-heading {
    color: #8a684f;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .bw-header__dropdown-link {
    display: inline-flex;
    align-items: center;
    color: #241a15;
    font-size: 12.5px;
    font-weight: 650;
    line-height: 1.35;
    padding: 3px 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .bw-header__dropdown-link:hover,
  .bw-header__dropdown-link:focus-visible {
    color: #355a6d;
    transform: translateX(2px);
  }

  .bw-header__dropdown-link--strong {
    font-weight: 800;
  }

  .bw-header__dropdown-grid--two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 14px;
  }

  .bw-header__nav-item--wide .bw-header__dropdown {
    min-width: 300px;
  }

  .bw-header__nav-item--wider .bw-header__dropdown {
    min-width: 340px;
  }

  @media (max-width: 1280px) {
    .bw-header__nav {
      gap: 4px;
    }

    .bw-header__nav-link {
      padding: 14px 8px 11px;
      font-size: 12px;
      letter-spacing: 0.06em;
    }

    .bw-header__dropdown,
    .bw-header__nav-item--wide .bw-header__dropdown,
    .bw-header__nav-item--wider .bw-header__dropdown {
      min-width: min(320px, calc(100vw - 24px));
    }
  }

  .bw-header__actions {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
    justify-content: flex-end;
    gap: 12px;
  }

  .bw-header__icon-link,
  .bw-header__menu-button,
  .bw-header__drawer-close {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(45, 33, 27, 0.12);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #241a15;
    background: rgba(255, 255, 255, 0.72);
    cursor: pointer;
    transition: border-color 0.22s ease, transform 0.22s ease, background 0.22s ease, color 0.22s ease, box-shadow 0.22s ease;
  }

  .bw-header__icon-link:hover,
  .bw-header__menu-button:hover,
  .bw-header__drawer-close:hover {
    border-color: rgba(53, 90, 109, 0.28);
    background: #ffffff;
    color: #355a6d;
    transform: translateY(-1px);
    box-shadow: 0 10px 20px rgba(35, 24, 19, 0.08);
  }

  .bw-header__icon-link svg,
  .bw-header__menu-button svg,
  .bw-header__drawer-close svg {
    width: 18px;
    height: 18px;
  }

  .bw-header__cta {
    padding: 13px 22px;
    border-radius: 999px;
    background: linear-gradient(135deg, #231813 0%, #3c2a21 100%);
    color: #f8f0e9;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 12px 22px rgba(35, 24, 19, 0.14);
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
  }

  .bw-header__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 26px rgba(35, 24, 19, 0.18);
    filter: saturate(1.05);
  }

  .bw-header__cart {
    position: relative;
  }

  .bw-header__cart-count {
    position: absolute;
    top: -5px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    border-radius: 999px;
    padding: 0 5px;
    background: #a66a43;
    color: #fff;
    font-size: 11px;
    line-height: 18px;
    text-align: center;
    font-weight: 800;
  }

  .bw-header__menu-button {
    display: none;
  }

  .bw-header__drawer {
    position: fixed;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 9800;
    transition: opacity 0.28s ease, visibility 0.28s ease;
  }

  .bw-header__drawer.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .bw-header__drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 15, 12, 0.45);
    opacity: 0;
    transition: opacity 0.28s ease;
  }

  .bw-header__drawer-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: min(88vw, 360px);
    height: 100%;
    max-height: 100dvh;
    background: #fbf6f1;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    padding-bottom: calc(28px + env(safe-area-inset-bottom));
    box-shadow: 24px 0 48px rgba(0, 0, 0, 0.18);
    transform: translateX(-24px);
    opacity: 0;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.24s ease;
    will-change: transform, opacity;
  }

  .bw-header__drawer.is-open .bw-header__drawer-backdrop {
    opacity: 1;
  }

  .bw-header__drawer.is-open .bw-header__drawer-panel {
    transform: translateX(0);
    opacity: 1;
  }

  .bw-header__drawer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .bw-header__drawer-nav,
  .bw-header__drawer-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bw-header__drawer-planning {
    display: grid;
    gap: 10px;
  }

  .bw-header__drawer-planning-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bw-header__drawer-pill {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(35, 24, 19, 0.09);
    background: rgba(255, 255, 255, 0.74);
    color: #231813;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-header__drawer-panel > * {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.22s ease, transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bw-header__drawer.is-open .bw-header__drawer-panel > * {
    opacity: 1;
    transform: translateY(0);
  }

  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(1) { transition-delay: 0.04s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(2) { transition-delay: 0.08s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(3) { transition-delay: 0.12s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(4) { transition-delay: 0.16s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(5) { transition-delay: 0.2s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(6) { transition-delay: 0.24s; }

  .bw-header__drawer-heading {
    color: #6d5b52;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
