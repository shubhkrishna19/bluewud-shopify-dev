{% liquid
  assign brand_name = section.settings.brand_name | default: 'Bluewud'
  assign brand_wordmark = brand_name | downcase | capitalize
  assign brand_tagline = section.settings.brand_tagline | default: 'Premium furniture for modern Indian homes'
  assign brand_kicker = section.settings.brand_kicker | default: '15 years of crafted living'
  assign phone_label = section.settings.phone_label | default: '+91-8800-609-609'
  assign phone_url = section.settings.phone_url | default: 'tel:+918800609609'
  assign email_label = section.settings.email_label | default: 'care@bluewud.com'
  assign email_url = section.settings.email_url | default: 'mailto:care@bluewud.com'
  assign cta_label = section.settings.cta_label | default: 'Buy In Bulk'
  assign cta_url = section.settings.cta_url
  assign brand_logo = section.settings.brand_logo
  assign brand_logo_treatment = 'tinted'
  assign current_path = request.path
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign modular_kitchen_calculator_url = '/collections/kitchen-racks#kitchen-calculator'
  assign modular_wardrobe_calculator_url = '/collections/wardrobe#wardrobe-calculator'
  assign home_interiors_calculator_url = '/collections/kitchen-racks#broader-planning'
  assign estimate_url = '/pages/get-free-estimate'
  assign curated_nav_labels = 'Living Room|Bedroom|Study Tables|TV Units|Bookshelves|Modular Kitchen|Wardrobes' | split: '|'
  assign curated_nav_urls = '/collections/living-room|/collections/bed-room|/collections/study-tables|/collections/tv-unit-furniture|/collections/book-shelves|/collections/kitchen-racks|/collections/wardrobe' | split: '|'
  assign drawer_nav_labels = 'Living Room|Bedroom|Study Tables|TV Units|Bookshelves|Modular Kitchen|Wardrobes|New Launches|Chest of Drawer' | split: '|'
  assign drawer_nav_urls = '/collections/living-room|/collections/bed-room|/collections/study-tables|/collections/tv-unit-furniture|/collections/book-shelves|/collections/kitchen-racks|/collections/wardrobe|/collections/new_launches|/collections/chest-of-drawer' | split: '|'
  assign support_nav_labels = 'About Us|Contact Us|Visit Us|FAQs' | split: '|'
  assign support_nav_urls = '/pages/about-us|/pages/contact-us|/pages/visit-us|/pages/help-center' | split: '|'

  if brand_logo == blank and settings.checkout_logo_image != blank
    assign brand_logo = settings.checkout_logo_image
  endif

  if brand_logo == blank and settings.favicon != blank
    assign brand_logo = settings.favicon
  endif

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
    assign modular_kitchen_calculator_url = modular_kitchen_url | append: '#kitchen-calculator'
  endif

  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
    assign modular_wardrobe_calculator_url = modular_wardrobe_url | append: '#wardrobe-calculator'
  endif

  if pages['modular-kitchen-cost-calculator'] != blank
    assign modular_kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif

  if pages['modular-wardrobe-cost-calculator'] != blank
    assign modular_wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif

  if pages['home-interiors-cost-calculator'] != blank
    assign home_interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif

  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif

  if pages['get-free-estimate'] == blank and pages['contact-us'] != blank
    assign estimate_url = pages['contact-us'].url
  endif

  if cta_url == blank
    assign cta_url = '/pages/buy-in-bulk'
  endif
%}

<style>
  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  body.bw-header-drawer-open {
    overflow: hidden;
  }

  .bw-header-shell {
    background: rgba(248, 243, 237, 0.96);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 14px 28px rgba(32, 24, 19, 0.05);
  }

  .bw-header-shell a {
    text-decoration: none;
  }

  .bw-header__utility {
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
    background: rgba(255, 255, 255, 0.26);
  }

  .bw-header__utility-inner,
  .bw-header__main-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  .bw-header__utility-inner {
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .bw-header__contact,
  .bw-header__support-links,
  .bw-header__nav,
  .bw-header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .bw-header__contact {
    flex-wrap: wrap;
  }

  .bw-header__support-links {
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 12px 16px;
  }

  .bw-header__utility-link,
  .bw-header__support-link {
    color: rgba(53, 43, 36, 0.78);
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .bw-header__utility-link:hover,
  .bw-header__support-link:hover {
    color: #355a6d;
  }

  .bw-header__contact-separator {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: rgba(45, 33, 27, 0.22);
  }

  .bw-header__support-link {
    color: #2b201a;
  }

  .bw-header__main-inner {
    min-height: 96px;
    display: grid;
    grid-template-columns: minmax(250px, 320px) minmax(0, 1fr) auto;
    align-items: center;
    gap: 28px;
  }

  .bw-header__brand {
    display: block;
    min-width: 0;
    transition: transform 0.22s ease;
  }

  .bw-header__brand-visual {
    width: 56px;
    height: 56px;
    flex: 0 0 56px;
    border-radius: 18px;
    border: 1px solid rgba(45, 33, 27, 0.09);
    background: linear-gradient(135deg, #f7efe7 0%, #ecdfd3 54%, #dbe5ec 100%);
    box-shadow: 0 12px 22px rgba(36, 26, 21, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bw-header__brand-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }

  .bw-header__brand-seal {
    font-family: var(--bw-font-serif);
    font-size: 24px;
    font-weight: 700;
    color: #355a6d;
  }

  .bw-header__brand-copy {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .bw-header__brand-copy--with-logo {
    gap: 5px;
  }

  .bw-header__brand-kicker {
    color: #8a7465;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .bw-header__brand-wordmark {
    display: inline-block;
    font-family: var(--bw-font-sans);
    font-size: 31px;
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.065em;
    color: #4f788f;
    transition: color 0.22s ease, background 0.22s ease, -webkit-text-fill-color 0.22s ease;
  }

  .bw-header__brand:hover,
  .bw-header__brand:focus-visible {
    transform: translateY(-1px);
  }

  .bw-header__brand:hover .bw-header__brand-wordmark,
  .bw-header__brand:focus-visible .bw-header__brand-wordmark {
    background: linear-gradient(90deg, #4f788f 0 50%, #ffffff 50% 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 1px rgba(32, 23, 19, 0.16);
  }

  .bw-header__brand-logo-frame {
    display: inline-flex;
    align-items: center;
    max-width: min(100%, 240px);
    line-height: 0;
  }

  .bw-header__brand-logo-image {
    display: block;
    width: auto;
    max-width: 100%;
    height: 34px;
    object-fit: contain;
    object-position: left center;
    transition: filter 0.22s ease, opacity 0.22s ease;
  }

  .bw-header__brand-logo-image--tinted {
    filter: brightness(0) saturate(100%) invert(31%) sepia(20%) saturate(815%) hue-rotate(159deg) brightness(90%) contrast(89%);
  }

  .bw-header__brand:hover .bw-header__brand-logo-image--tinted,
  .bw-header__brand:focus-visible .bw-header__brand-logo-image--tinted {
    filter: brightness(0) saturate(100%) invert(21%) sepia(20%) saturate(894%) hue-rotate(161deg) brightness(88%) contrast(90%);
  }

  .bw-header__brand-tagline {
    color: #6c5b51;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bw-header__nav {
    justify-self: center;
    justify-content: center;
    gap: 18px;
    flex-wrap: nowrap;
    min-width: 0;
    width: max-content;
    max-width: 100%;
    padding-inline: 14px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .bw-header__nav::-webkit-scrollbar {
    display: none;
  }

  .bw-header__nav-link {
    display: inline-flex;
    align-items: center;
    color: #241a15;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.01em;
    position: relative;
    padding: 14px 0;
    white-space: nowrap;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .bw-header__nav-link:first-child {
    margin-left: 6px;
  }

  .bw-header__nav-link:last-child {
    margin-right: 6px;
  }

  .bw-header__nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 6px;
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, #355a6d 0%, #a66a43 100%);
    transform: translateX(-50%) scaleX(0);
    transform-origin: center center;
    transition: transform 0.22s ease;
  }

  .bw-header__nav-link:hover,
  .bw-header__nav-link:focus-visible,
  .bw-header__nav-link.is-active {
    color: #355a6d;
    transform: translateY(-1px);
  }

  .bw-header__nav-link:hover::after,
  .bw-header__nav-link:focus-visible::after,
  .bw-header__nav-link.is-active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .bw-header__actions {
    justify-content: flex-end;
    gap: 12px;
  }

  .bw-header__icon-link,
  .bw-header__menu-button,
  .bw-header__drawer-close {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(45, 33, 27, 0.12);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #241a15;
    background: rgba(255, 255, 255, 0.72);
    cursor: pointer;
    transition: border-color 0.22s ease, transform 0.22s ease, background 0.22s ease, color 0.22s ease, box-shadow 0.22s ease;
  }

  .bw-header__icon-link:hover,
  .bw-header__menu-button:hover,
  .bw-header__drawer-close:hover {
    border-color: rgba(53, 90, 109, 0.28);
    background: #ffffff;
    color: #355a6d;
    transform: translateY(-1px);
    box-shadow: 0 10px 20px rgba(35, 24, 19, 0.08);
  }

  .bw-header__icon-link svg,
  .bw-header__menu-button svg,
  .bw-header__drawer-close svg {
    width: 18px;
    height: 18px;
  }

  .bw-header__cta {
    padding: 13px 22px;
    border-radius: 999px;
    background: linear-gradient(135deg, #231813 0%, #3c2a21 100%);
    color: #f8f0e9;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 12px 22px rgba(35, 24, 19, 0.14);
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
  }

  .bw-header__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 26px rgba(35, 24, 19, 0.18);
    filter: saturate(1.05);
  }

  .bw-header__cart {
    position: relative;
  }

  .bw-header__cart-count {
    position: absolute;
    top: -5px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    border-radius: 999px;
    padding: 0 5px;
    background: #a66a43;
    color: #fff;
    font-size: 11px;
    line-height: 18px;
    text-align: center;
    font-weight: 800;
  }

  .bw-header__menu-button {
    display: none;
  }

  .bw-header__drawer {
    position: fixed;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 1100;
    transition: opacity 0.28s ease, visibility 0.28s ease;
  }

  .bw-header__drawer.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .bw-header__drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 15, 12, 0.45);
    opacity: 0;
    transition: opacity 0.28s ease;
  }

  .bw-header__drawer-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: min(88vw, 360px);
    height: 100%;
    background: #fbf6f1;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 24px 0 48px rgba(0, 0, 0, 0.18);
    transform: translateX(-24px);
    opacity: 0;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.24s ease;
    will-change: transform, opacity;
  }

  .bw-header__drawer.is-open .bw-header__drawer-backdrop {
    opacity: 1;
  }

  .bw-header__drawer.is-open .bw-header__drawer-panel {
    transform: translateX(0);
    opacity: 1;
  }

  .bw-header__drawer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .bw-header__drawer-nav,
  .bw-header__drawer-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bw-header__drawer-planning {
    display: grid;
    gap: 10px;
  }

  .bw-header__drawer-planning-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bw-header__drawer-pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(35, 24, 19, 0.09);
    background: rgba(255, 255, 255, 0.74);
    color: #231813;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-header__drawer-panel > * {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.22s ease, transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bw-header__drawer.is-open .bw-header__drawer-panel > * {
    opacity: 1;
    transform: translateY(0);
  }

  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(1) { transition-delay: 0.04s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(2) { transition-delay: 0.08s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(3) { transition-delay: 0.12s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(4) { transition-delay: 0.16s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(5) { transition-delay: 0.2s; }
  .bw-header__drawer.is-open .bw-header__drawer-panel > :nth-child(6) { transition-delay: 0.24s; }

  .bw-header__drawer-heading {
    color: #6d5b52;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .bw-header__drawer-link {
    color: #231813;
    font-size: 16px;
    font-weight: 700;
    padding: 10px 0;
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
    transition: color 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .bw-header__drawer-link:hover,
  .bw-header__drawer-link:focus-visible {
    color: #355a6d;
    border-bottom-color: rgba(53, 90, 109, 0.2);
    transform: translateX(4px);
  }

  .bw-header__drawer-contact {
    display: grid;
    gap: 10px;
    padding: 16px;
    border-radius: 18px;
    background: rgba(35, 24, 19, 0.04);
  }

  .bw-header__drawer-contact a {
    color: #231813;
    font-size: 14px;
    font-weight: 700;
  }

  @media (max-width: 1240px) {
    .bw-header__main-inner {
      grid-template-columns: minmax(230px, 300px) minmax(0, 1fr) auto;
      gap: 22px;
    }

    .bw-header__nav {
      gap: 14px;
      padding-inline: 12px;
    }

    .bw-header__nav-link {
      font-size: 12px;
    }
  }

  @media (max-width: 1024px) {
    .bw-header__utility {
      display: none;
    }

    .bw-header__main-inner {
      min-height: 78px;
      grid-template-columns: auto 1fr auto;
      gap: 14px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .bw-header__nav,
    .bw-header__cta,
    .bw-header__icon-link--account {
      display: none;
    }

    .bw-header__menu-button {
      display: inline-flex;
    }

    .bw-header__actions {
      gap: 10px;
    }

    .bw-header__brand-visual {
      width: 48px;
      height: 48px;
      flex-basis: 48px;
      border-radius: 16px;
    }

    .bw-header__brand-wordmark {
      font-size: 30px;
    }

    .bw-header__brand-logo-image {
      height: 30px;
    }

    .bw-header__brand-tagline {
      font-size: 9px;
      letter-spacing: 0.11em;
    }

    .bw-header__drawer-panel {
      width: min(92vw, 340px);
      padding: 18px 18px 28px;
      gap: 20px;
    }
  }

  @media (max-width: 640px) {
    .bw-header__brand-kicker,
    .bw-header__brand-tagline {
      display: none;
    }

    .bw-header__brand-wordmark {
      font-size: 26px;
    }

    .bw-header__brand-logo-image {
      height: 26px;
    }

    .bw-header__icon-link,
    .bw-header__menu-button,
    .bw-header__drawer-close {
      width: 42px;
      height: 42px;
    }

    .bw-header__drawer-link {
      font-size: 15px;
      padding: 11px 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bw-header__brand,
    .bw-header__brand-wordmark,
    .bw-header__nav-link,
    .bw-header__nav-link::after,
    .bw-header__icon-link,
    .bw-header__menu-button,
    .bw-header__drawer-close,
    .bw-header__cta,
    .bw-header__drawer,
    .bw-header__drawer-backdrop,
    .bw-header__drawer-panel,
    .bw-header__drawer-panel > *,
    .bw-header__drawer-link {
      transition: none !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<div class="bw-header-shell">
  <div class="bw-header__main-inner">
    <button class="bw-header__menu-button" type="button" aria-expanded="false" aria-controls="bw-header-drawer-{{ section.id }}" data-bw-header-open>
      <span class="visually-hidden">Open navigation</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M4 7h16"></path>
        <path d="M4 12h16"></path>
        <path d="M4 17h16"></path>
      </svg>
    </button>

    <a class="bw-header__brand" href="/">
      <span class="bw-header__brand-copy{% if brand_logo != blank %} bw-header__brand-copy--with-logo{% endif %}">
        <span class="bw-header__brand-kicker">{{ brand_kicker }}</span>
        {% if brand_logo != blank %}
          <span class="bw-header__brand-logo-frame">
            <img
              class="bw-header__brand-logo-image{% if brand_logo_treatment == 'tinted' %} bw-header__brand-logo-image--tinted{% endif %}"
              src="{{ brand_logo | image_url: width: 480 }}"
              alt="{{ brand_name | escape }}"
              loading="eager"
            >
          </span>
        {% else %}
          <span class="bw-header__brand-wordmark">{{ brand_wordmark }}</span>
        {% endif %}
        <span class="bw-header__brand-tagline">{{ brand_tagline }}</span>
      </span>
    </a>

    <nav class="bw-header__nav" aria-label="Primary">
      {% if section.settings.primary_menu != blank and section.settings.primary_menu.links.size > 0 %}
        {% for link in section.settings.primary_menu.links %}
          {% assign rendered_url = link.url %}
          {% assign rendered_handle = link.title | handleize %}
          {% if rendered_handle contains 'modular-kitchen' or rendered_handle == 'kitchen' %}
            {% assign rendered_url = modular_kitchen_url %}
          {% elsif rendered_handle contains 'wardrobe' %}
            {% assign rendered_url = modular_wardrobe_url %}
          {% endif %}
          <a class="bw-header__nav-link{% if link.current or current_path == rendered_url %} is-active{% endif %}" href="{{ rendered_url }}"{% if link.current or current_path == rendered_url %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      {% else %}
        {% for nav_label in curated_nav_labels %}
          {% assign nav_url = curated_nav_urls[forloop.index0] %}
          {% if nav_label == 'Modular Kitchen' %}
            {% assign nav_url = modular_kitchen_url %}
          {% elsif nav_label == 'Wardrobes' %}
            {% assign nav_url = modular_wardrobe_url %}
          {% endif %}
          <a class="bw-header__nav-link{% if current_path == nav_url %} is-active{% endif %}" href="{{ nav_url }}"{% if current_path == nav_url %} aria-current="page"{% endif %}>{{ nav_label }}</a>
        {% endfor %}
      {% endif %}
    </nav>

    <div class="bw-header__actions">
      <a class="bw-header__icon-link" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5"></path>
        </svg>
      </a>
      <a class="bw-header__icon-link bw-header__icon-link--account" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M20 21a8 8 0 0 0-16 0"></path>
          <circle cx="12" cy="8" r="4"></circle>
        </svg>
      </a>
      <a class="bw-header__icon-link bw-header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M6 7h15l-1.4 7.1a2 2 0 0 1-2 1.6H9.1a2 2 0 0 1-2-1.6L5.1 3.8H2.5"></path>
          <circle cx="10" cy="19" r="1.5"></circle>
          <circle cx="18" cy="19" r="1.5"></circle>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="bw-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <a class="bw-header__cta" href="{{ cta_url }}">{{ cta_label }}</a>
    </div>
  </div>
</div>

<div class="bw-header__drawer" id="bw-header-drawer-{{ section.id }}" data-bw-header-drawer>
  <div class="bw-header__drawer-backdrop" data-bw-header-close></div>
  <div class="bw-header__drawer-panel">
    <div class="bw-header__drawer-top">
      <div class="bw-header__brand">
        <span class="bw-header__brand-copy{% if brand_logo != blank %} bw-header__brand-copy--with-logo{% endif %}">
          <span class="bw-header__brand-kicker">{{ brand_kicker }}</span>
          {% if brand_logo != blank %}
            <span class="bw-header__brand-logo-frame">
              <img
                class="bw-header__brand-logo-image{% if brand_logo_treatment == 'tinted' %} bw-header__brand-logo-image--tinted{% endif %}"
                src="{{ brand_logo | image_url: width: 360 }}"
                alt="{{ brand_name | escape }}"
                loading="lazy"
              >
            </span>
          {% else %}
            <span class="bw-header__brand-wordmark">{{ brand_wordmark }}</span>
          {% endif %}
        </span>
      </div>
      <button class="bw-header__drawer-close" type="button" aria-label="Close navigation" data-bw-header-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M6 6l12 12"></path>
          <path d="M18 6l-12 12"></path>
        </svg>
      </button>
    </div>

    <div class="bw-header__drawer-nav">
      <div class="bw-header__drawer-heading">Shop by category</div>
      {% if section.settings.drawer_menu != blank and section.settings.drawer_menu.links.size > 0 %}
        {% for link in section.settings.drawer_menu.links %}
          {% assign rendered_url = link.url %}
          {% assign rendered_handle = link.title | handleize %}
          {% if rendered_handle contains 'modular-kitchen' or rendered_handle == 'kitchen' %}
            {% assign rendered_url = modular_kitchen_url %}
          {% elsif rendered_handle contains 'wardrobe' %}
            {% assign rendered_url = modular_wardrobe_url %}
          {% endif %}
          <a class="bw-header__drawer-link" href="{{ rendered_url }}"{% if link.current or current_path == rendered_url %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      {% elsif section.settings.primary_menu != blank and section.settings.primary_menu.links.size > 0 %}
        {% for link in section.settings.primary_menu.links %}
          {% assign rendered_url = link.url %}
          {% assign rendered_handle = link.title | handleize %}
          {% if rendered_handle contains 'modular-kitchen' or rendered_handle == 'kitchen' %}
            {% assign rendered_url = modular_kitchen_url %}
          {% elsif rendered_handle contains 'wardrobe' %}
            {% assign rendered_url = modular_wardrobe_url %}
          {% endif %}
          <a class="bw-header__drawer-link" href="{{ rendered_url }}"{% if link.current or current_path == rendered_url %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      {% else %}
        {% for nav_label in drawer_nav_labels %}
          {% assign nav_url = drawer_nav_urls[forloop.index0] %}
          {% if nav_label == 'Modular Kitchen' %}
            {% assign nav_url = modular_kitchen_url %}
          {% elsif nav_label == 'Wardrobes' %}
            {% assign nav_url = modular_wardrobe_url %}
          {% endif %}
          <a class="bw-header__drawer-link" href="{{ nav_url }}"{% if current_path == nav_url %} aria-current="page"{% endif %}>{{ nav_label }}</a>
        {% endfor %}
      {% endif %}
    </div>

    <div class="bw-header__drawer-planning">
      <div class="bw-header__drawer-heading">Planning</div>
      <div class="bw-header__drawer-planning-links">
        <a class="bw-header__drawer-pill" href="{{ modular_kitchen_url }}">Modular Kitchen</a>
        <a class="bw-header__drawer-pill" href="{{ modular_kitchen_calculator_url }}">Kitchen Calculator</a>
        <a class="bw-header__drawer-pill" href="{{ modular_wardrobe_url }}">Wardrobes</a>
        <a class="bw-header__drawer-pill" href="{{ modular_wardrobe_calculator_url }}">Wardrobe Calculator</a>
        <a class="bw-header__drawer-pill" href="{{ home_interiors_calculator_url }}">Home Interiors</a>
        <a class="bw-header__drawer-pill" href="{{ estimate_url }}">Get Free Estimate</a>
      </div>
    </div>

    <div class="bw-header__drawer-links">
      <div class="bw-header__drawer-heading">Support</div>
      {% if section.settings.support_menu != blank and section.settings.support_menu.links.size > 0 %}
        {% for link in section.settings.support_menu.links %}
          <a class="bw-header__drawer-link" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a class="bw-header__drawer-link" href="/pages/about-us">About Us</a>
        <a class="bw-header__drawer-link" href="/pages/contact-us">Contact Us</a>
        <a class="bw-header__drawer-link" href="/pages/buy-in-bulk">Buy In Bulk</a>
        <a class="bw-header__drawer-link" href="/pages/visit-us">Visit Us</a>
        <a class="bw-header__drawer-link" href="/pages/help-center">FAQs</a>
        <a class="bw-header__drawer-link" href="/pages/offers-discount">Offers & Discounts</a>
        <a class="bw-header__drawer-link" href="/pages/award-achievment">Award & Achievement</a>
        <a class="bw-header__drawer-link" href="/pages/returns-refunds">Returns & Refunds</a>
      {% endif %}
    </div>

    <div class="bw-header__drawer-links">
      <div class="bw-header__drawer-heading">Policies</div>
      {% if section.settings.policy_menu != blank and section.settings.policy_menu.links.size > 0 %}
        {% for link in section.settings.policy_menu.links %}
          <a class="bw-header__drawer-link" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a class="bw-header__drawer-link" href="/policies/terms-of-service">Terms of Service</a>
        <a class="bw-header__drawer-link" href="/pages/terms-of-use">Terms Of Use</a>
        <a class="bw-header__drawer-link" href="/pages/policies">Privacy Statement</a>
        <a class="bw-header__drawer-link" href="/pages/payment-security">Payment & Security</a>
        <a class="bw-header__drawer-link" href="/pages/help-center">Installation & Cancellation</a>
        <a class="bw-header__drawer-link" href="{{ routes.search_url }}">Search</a>
      {% endif %}
    </div>

    <div class="bw-header__drawer-contact">
      <a href="{{ phone_url }}">{{ phone_label }}</a>
      <a href="{{ email_url }}">{{ email_label }}</a>
      <a href="{{ cta_url }}">{{ cta_label }}</a>
    </div>
  </div>
</div>

<script>
  (function () {
    var drawer = document.getElementById('bw-header-drawer-{{ section.id }}');
    if (!drawer) return;

    var openButton = document.querySelector('[data-bw-header-open][aria-controls="bw-header-drawer-{{ section.id }}"]');
    var closeButtons = drawer.querySelectorAll('[data-bw-header-close]');
    drawer.setAttribute('aria-hidden', 'true');

    function setDrawerState(isOpen) {
      drawer.classList.toggle('is-open', isOpen);
      drawer.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      if (openButton) {
        openButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      }
      document.body.classList.toggle('bw-header-drawer-open', isOpen);
    }

    if (openButton) {
      openButton.addEventListener('click', function () {
        setDrawerState(true);
      });
    }

    closeButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        setDrawerState(false);
      });
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        setDrawerState(false);
      }
    });
  })();
</script>

