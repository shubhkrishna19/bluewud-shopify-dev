              <a class="bw-header__dropdown-link" href="{{ wall_mount_tv_url }}">Wall Mount TV Unit</a>
              <a class="bw-header__dropdown-link" href="{{ floor_standing_tv_url }}">Floor Standing TV Unit</a>
            </div>
            <div class="bw-header__dropdown-group">
              <div class="bw-header__dropdown-heading">Shoe Rack</div>
              <a class="bw-header__dropdown-link bw-header__dropdown-link--strong" href="{{ shoe_rack_url }}">Shoe Rack</a>
              <a class="bw-header__dropdown-link" href="{{ two_door_shoe_rack_url }}">2 Door</a>
              <a class="bw-header__dropdown-link" href="{{ three_door_shoe_rack_url }}">3 Door</a>
              <a class="bw-header__dropdown-link bw-header__dropdown-link--strong" href="{{ coffee_table_url }}">Coffee Table</a>
            </div>
          </div>
        </div>
      </div>

      <div class="bw-header__nav-item bw-header__nav-item--wider">
        <a class="bw-header__nav-link bw-header__nav-link--has-children{% if is_bedroom_active %} is-active{% endif %}" href="{{ bedroom_url }}"{% if is_bedroom_active %} aria-current="page"{% endif %}>Bedroom</a>
        <div class="bw-header__dropdown" role="presentation">
          <div class="bw-header__dropdown-grid bw-header__dropdown-grid--two">
            <div class="bw-header__dropdown-group">
              <div class="bw-header__dropdown-heading">Wardrobe</div>
              <a class="bw-header__dropdown-link bw-header__dropdown-link--strong" href="{{ modular_wardrobe_url }}">Wardrobe</a>
