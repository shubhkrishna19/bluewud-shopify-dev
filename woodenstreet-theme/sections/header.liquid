  assign is_modular_kitchen_active = false
  assign is_modular_wardrobe_active = false
  assign is_price_calculator_active = false
  assign is_living_room_active = false
  assign is_bedroom_active = false
  assign is_study_room_active = false
  assign is_tv_unit_active = false
  assign is_shoe_rack_active = false
  assign is_shelves_active = false
  assign is_coffee_table_active = false
  assign is_bookshelves_active = false

  if collection_handle == 'living-room'
    assign is_living_room_active = true
  endif
  if collection_handle == 'bed-room'
    assign is_bedroom_active = true
  endif
  if collection_handle == 'study-tables' or collection_handle == 'study-table' or collection_handle == 'smartly-designed-wfh-furniture'
    assign is_study_room_active = true
  endif
  if collection_handle == 'tv-unit-furniture'
    assign is_tv_unit_active = true
  endif
  if collection_handle == 'shoe-racks'
    assign is_shoe_rack_active = true
  endif
  if collection_handle == 'corner-shelves' or collection_handle == 'shelves'
    assign is_shelves_active = true
  endif
  if collection_handle == 'coffee-table'
    assign is_coffee_table_active = true
  endif
  if collection_handle == 'book-shelves'
    assign is_bookshelves_active = true
  endif

  if collection_handle == 'kitchen-racks' and query_string == blank
    assign is_modular_kitchen_active = true
  endif
  if page_handle == 'modular-kitchen-designs' or page_handle == 'l-shape-modular-kitchen-design' or page_handle == 'u-shape-modular-kitchen-design' or page_handle == 'parallel-modular-kitchen-design' or page_handle == 'straight-modular-kitchen' or page_handle == 'kitchen-island-design'
    assign is_modular_kitchen_active = true
  endif
  if current_path == modular_kitchen_url or current_path == modular_kitchen_calculator_url
    assign is_modular_kitchen_active = true
  endif

  if collection_handle == 'wardrobe' and query_string == blank
    assign is_modular_wardrobe_active = true
  endif
  if page_handle == 'modular-wardrobe-designs' or page_handle == 'sliding-wardrobe-designs' or page_handle == 'hinged-wardrobes' or page_handle == 'walk-in-wardrobes'
    assign is_modular_wardrobe_active = true
  endif
  if current_path == modular_wardrobe_url or current_path == modular_wardrobe_calculator_url
    assign is_modular_wardrobe_active = true
  endif

  if page_handle == 'home-interiors-cost-calculator' or page_handle == 'modular-kitchen-cost-calculator' or page_handle == 'modular-wardrobe-cost-calculator'
    assign is_price_calculator_active = true
  endif
  if current_path == home_interiors_calculator_url or current_path == modular_kitchen_calculator_url or current_path == modular_wardrobe_calculator_url
    assign is_price_calculator_active = true
  endif
  if query_string contains 'planner='
    assign is_price_calculator_active = true
  endif

  if request.page_type == 'search' and search_terms != blank
    if search_terms contains 'calculator' or search_terms contains 'estimate' or search_terms contains 'quote' or search_terms contains 'price'
      assign is_price_calculator_active = true
    elsif search_terms contains 'wardrobe' or search_terms contains 'dresser' or search_terms contains 'closet' or search_terms contains 'bedroom' or search_terms contains 'bed '
      assign is_bedroom_active = true
    elsif search_terms contains 'kitchen' or search_terms contains 'modular kitchen' or search_terms contains 'kitchen rack' or search_terms contains 'l-shape' or search_terms contains 'u-shape' or search_terms contains 'parallel' or search_terms contains 'straight' or search_terms contains 'island'
      assign is_modular_kitchen_active = true
    elsif search_terms contains 'study table' or search_terms contains 'bookshelf' or search_terms contains 'wall shelf'
      assign is_study_room_active = true
    elsif search_terms contains 'tv unit' or search_terms contains 'tv stand'
      assign is_tv_unit_active = true
    elsif search_terms contains 'shoe rack'
      assign is_shoe_rack_active = true
    elsif search_terms contains 'coffee table'
      assign is_coffee_table_active = true
    elsif search_terms contains 'book shelf' or search_terms contains 'bookshelves'
      assign is_bookshelves_active = true
    elsif search_terms contains 'shelf' or search_terms contains 'shelves'
      assign is_shelves_active = true
    elsif search_terms contains 'living room' or search_terms contains 'sofa'
      assign is_living_room_active = true
