</style>

<div class="bw-header-shell">
  <div class="bw-header__main-inner">
    <button class="bw-header__menu-button" type="button" aria-expanded="false" aria-controls="bw-header-drawer-{{ section.id }}" data-bw-header-open>
      <span class="visually-hidden">Open navigation</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M4 7h16"></path>
        <path d="M4 12h16"></path>
        <path d="M4 17h16"></path>
      </svg>
    </button>

      <a class="bw-header__brand" href="{{ routes.root_url }}">
      <span class="bw-header__brand-copy{% if brand_logo != blank %} bw-header__brand-copy--with-logo{% endif %}">
        <span class="bw-header__brand-kicker">{{ brand_kicker }}</span>
        {% if brand_logo != blank %}
          <span class="bw-header__brand-logo-frame">
            <img
              class="bw-header__brand-logo-image{% if brand_logo_treatment == 'tinted' %} bw-header__brand-logo-image--tinted{% endif %}"
              src="{{ brand_logo | image_url: width: 480 }}"
              alt="{{ brand_name | escape }}"
              loading="eager"
              width="{{ brand_logo.width | default: 240 }}"
              height="{{ brand_logo.height | default: 80 }}"
            >
          </span>
        {% else %}
          <span class="bw-header__brand-wordmark">{{ brand_wordmark }}</span>
        {% endif %}
        <span class="bw-header__brand-tagline">{{ brand_tagline }}</span>
      </span>
    </a>

    <div class="bw-header__actions">
      <a class="bw-header__icon-link" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5"></path>
        </svg>
      </a>
      <a class="bw-header__icon-link bw-header__icon-link--account" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M20 21a8 8 0 0 0-16 0"></path>
          <circle cx="12" cy="8" r="4"></circle>
        </svg>
      </a>
      <a class="bw-header__icon-link bw-header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M6 7h15l-1.4 7.1a2 2 0 0 1-2 1.6H9.1a2 2 0 0 1-2-1.6L5.1 3.8H2.5"></path>
          <circle cx="10" cy="19" r="1.5"></circle>
          <circle cx="18" cy="19" r="1.5"></circle>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="bw-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

    <nav class="bw-header__nav" aria-label="Primary">
      <div class="bw-header__nav-item bw-header__nav-item--wider">
        <a class="bw-header__nav-link bw-header__nav-link--has-children{% if is_living_room_active %} is-active{% endif %}" href="{{ living_room_url }}"{% if is_living_room_active %} aria-current="page"{% endif %}>Living Room</a>
