              <a class="bw-header__dropdown-link" href="{{ queen_size_bed_url }}">Queen Size</a>
              <a class="bw-header__dropdown-link bw-header__dropdown-link--strong" href="{{ dressers_url }}">Dressers</a>
            </div>
          </div>
        </div>
      </div>

      <div class="bw-header__nav-item">
        <a class="bw-header__nav-link bw-header__nav-link--has-children{% if is_study_room_active %} is-active{% endif %}" href="{{ study_room_url }}"{% if is_study_room_active %} aria-current="page"{% endif %}>Study Room</a>
        <div class="bw-header__dropdown" role="presentation">
          <div class="bw-header__dropdown-grid">
            <a class="bw-header__dropdown-link bw-header__dropdown-link--strong" href="{{ study_table_url }}">Study Table</a>
            <a class="bw-header__dropdown-link" href="{{ bookshelves_url }}">Bookshelves</a>
            <a class="bw-header__dropdown-link" href="{{ wall_shelf_url }}">Wall Shelf</a>
          </div>
