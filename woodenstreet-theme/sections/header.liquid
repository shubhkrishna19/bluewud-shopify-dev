  endif
  if pages['hinged-wardrobes'] != blank
    assign hinged_wardrobe_url = pages['hinged-wardrobes'].url
  endif
  if pages['walk-in-wardrobes'] != blank
    assign walk_in_wardrobe_url = pages['walk-in-wardrobes'].url
  endif
