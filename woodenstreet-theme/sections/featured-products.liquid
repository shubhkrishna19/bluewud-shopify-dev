{% liquid
  assign featured_collection = section.settings.collection

  if featured_collection == blank
    assign featured_collection = collections['hp-bluewuds-bestseller']
  endif

  if featured_collection == blank
    assign featured_collection = collections['all']
  endif
%}

<style>
  .bw-featured {
    padding: 8px 24px 70px;
    background: #faf6f1;
  }

  .bw-featured__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-featured__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    margin-bottom: 28px;
  }

  .bw-featured__eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    color: #7f604d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-featured__title {
    margin: 0 0 10px;
    color: #201713;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .bw-featured__copy {
    margin: 0;
    color: #66554c;
    font-size: 16px;
    line-height: 1.8;
    max-width: 62ch;
  }

  .bw-featured__meta {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    margin-top: 14px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #6f584f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-featured__view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 20px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid rgba(32, 23, 19, 0.14);
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .bw-featured__view-all:hover {
    transform: translateY(-1px);
    background: rgba(32, 23, 19, 0.04);
    border-color: rgba(32, 23, 19, 0.22);
  }

  .bw-featured__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .bw-featured__card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: rgba(255, 252, 248, 0.92);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 20px 50px rgba(35, 24, 19, 0.08);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bw-featured__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 70px rgba(35, 24, 19, 0.12);
  }

  .bw-featured__media {
    position: relative;
    aspect-ratio: 0.98;
    overflow: hidden;
    background: #eee2d8;
  }

  .bw-featured__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .bw-featured__card:hover .bw-featured__media img {
    transform: scale(1.04);
  }

  .bw-featured__badge {
    position: absolute;
    z-index: 1;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-featured__badge {
    top: 14px;
    left: 14px;
    padding: 8px 11px;
    background: #201713;
    color: #f8f1eb;
  }

  .bw-featured__body {
    display: grid;
    gap: 6px;
    padding: 20px;
  }

  .bw-featured__type {
    color: #8b6a57;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-featured__name {
    margin: 0;
    color: #201713;
    font-size: 18px;
    line-height: 1.4;
  }

  .bw-featured__price-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 10px;
  }

  .bw-featured__price {
    color: #201713;
    font-size: 20px;
    font-weight: 800;
  }

  .bw-featured__compare {
    color: #8c7b70;
    font-size: 14px;
    text-decoration: line-through;
  }

  .bw-featured__empty {
    padding: 32px;
    border-radius: 24px;
    background: rgba(255, 252, 248, 0.92);
    border: 1px solid rgba(45, 33, 27, 0.08);
    color: #66554c;
    font-size: 15px;
    line-height: 1.7;
  }

  @media (max-width: 1100px) {
    .bw-featured__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .bw-featured {
      padding: 8px 16px 54px;
    }

    .bw-featured__header {
      grid-template-columns: 1fr;
    }

    .bw-featured__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="bw-featured">
  <div class="bw-featured__inner">
    <div class="bw-featured__header">
      <div>
        <span class="bw-featured__eyebrow">Most-loved Bluewud picks</span>
        <h2 class="bw-featured__title">Bestsellers customers shortlist first.</h2>
        <p class="bw-featured__copy">Browse a tighter shortlist of products with price, fit, and room use visible at a glance.</p>
        <span class="bw-featured__meta">{% if featured_collection != blank and featured_collection.products.size > 0 %}{{ featured_collection.products.size }} products ready to browse{% else %}Choose a collection to feature Bluewud products here{% endif %}</span>
      </div>
      <a class="bw-featured__view-all" href="{{ featured_collection.url | default: routes.all_products_collection_url }}">Browse collection</a>
    </div>

    {% if featured_collection != blank and featured_collection.products.size > 0 %}
      <div class="bw-featured__grid">
        {% for product in featured_collection.products limit: 8 %}
          {% liquid
            assign savings_percentage = 0
            if product.compare_at_price > product.price
              assign savings_percentage = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
            endif
          %}
          <a class="bw-featured__card" href="{{ product.url }}">
            <div class="bw-featured__media">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '450, 650, 900', sizes: '(max-width: 760px) 100vw, (max-width: 1100px) 50vw, 25vw' }}
              {% endif %}
              {% if savings_percentage > 0 %}
                <span class="bw-featured__badge">Save {{ savings_percentage }}%</span>
              {% elsif product.available == false %}
                <span class="bw-featured__badge">Sold out</span>
              {% endif %}
            </div>
            <div class="bw-featured__body">
              <span class="bw-featured__type">{{ product.type | default: 'Furniture' }}</span>
              <h3 class="bw-featured__name">{{ product.title }}</h3>
              <div class="bw-featured__price-row">
                <span class="bw-featured__price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="bw-featured__compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="bw-featured__empty">
        Connect a collection in the theme editor to show the Bluewud products customers should see first.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
