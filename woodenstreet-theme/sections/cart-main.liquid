<style>
  .bw-cart {
    padding: 28px 24px 72px;
    background: linear-gradient(180deg, #faf6f1 0%, #fffdfb 100%);
  }

  .bw-cart__shell {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-cart__header {
    display: grid;
    gap: 12px;
    margin-bottom: 28px;
  }

  .bw-cart__eyebrow {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-cart__title {
    margin: 0;
    color: #201713;
    font-size: clamp(34px, 4.5vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .bw-cart__copy {
    max-width: 56ch;
    margin: 0;
    color: #6a5850;
    font-size: 16px;
    line-height: 1.8;
  }

  .bw-cart__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.62fr);
    gap: 26px;
    align-items: start;
  }

  .bw-cart__items,
  .bw-cart__summary,
  .bw-cart__empty {
    border-radius: 30px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 22px 60px rgba(35, 24, 19, 0.08);
  }

  .bw-cart__items {
    padding: 18px 22px;
  }

  .bw-cart__item {
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr);
    gap: 18px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-cart__item:last-child {
    border-bottom: none;
  }

  .bw-cart__image {
    overflow: hidden;
    border-radius: 22px;
    min-height: 132px;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.2), transparent 24%),
      linear-gradient(145deg, #dfd0c4 0%, #bb9b86 42%, #6e5043 100%);
  }

  .bw-cart__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .bw-cart__item-body {
    display: grid;
    gap: 12px;
  }

  .bw-cart__item-top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .bw-cart__item-title {
    margin: 0;
    color: #201713;
    font-size: 20px;
    line-height: 1.2;
  }

  .bw-cart__item-title a {
    color: inherit;
    text-decoration: none;
  }

  .bw-cart__item-meta {
    color: #6a5850;
    font-size: 13px;
    line-height: 1.6;
  }

  .bw-cart__item-price {
    color: #201713;
    font-size: 18px;
    font-weight: 800;
    white-space: nowrap;
  }

  .bw-cart__controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .bw-cart__quantity {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(45, 33, 27, 0.14);
    border-radius: 999px;
    background: #fff;
    overflow: hidden;
  }

  .bw-cart__qty-btn,
  .bw-cart__qty-input {
    width: 46px;
    height: 44px;
    border: none;
    background: transparent;
    color: #201713;
    font-size: 15px;
    font-weight: 700;
    text-align: center;
  }

  .bw-cart__qty-btn {
    cursor: pointer;
  }

  .bw-cart__qty-input {
    width: 54px;
    border-left: 1px solid rgba(45, 33, 27, 0.12);
    border-right: 1px solid rgba(45, 33, 27, 0.12);
    appearance: textfield;
  }

  .bw-cart__qty-input::-webkit-outer-spin-button,
  .bw-cart__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .bw-cart__remove {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bw-cart__summary {
    position: sticky;
    top: 104px;
    padding: 24px;
    display: grid;
    gap: 18px;
  }

  .bw-cart__summary-title {
    margin: 0;
    color: #201713;
    font-size: 24px;
  }

  .bw-cart__summary-copy {
    margin: 0;
    color: #6a5850;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-cart__summary-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bw-cart__summary-badge {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-cart__summary-line {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: #201713;
    font-size: 15px;
  }

  .bw-cart__summary-line span:last-child {
    font-weight: 700;
  }

  .bw-cart__summary-total {
    padding-top: 16px;
    border-top: 1px solid rgba(45, 33, 27, 0.08);
    font-size: 18px;
    font-weight: 800;
  }

  .bw-cart__note-label {
    color: #201713;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-cart__note {
    min-height: 110px;
    padding: 14px 16px;
    border-radius: 20px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fff;
    color: #201713;
    font-size: 14px;
    resize: vertical;
  }

  .bw-cart__actions {
    display: grid;
    gap: 12px;
  }

  .bw-cart__button,
  .bw-cart__secondary {
    min-height: 52px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .bw-cart__button {
    border: none;
    background: #201713;
    color: #fff7f1;
  }

  .bw-cart__secondary {
    border: 1px solid rgba(45, 33, 27, 0.14);
    background: #fff;
    color: #201713;
  }

  .bw-cart__support {
    display: grid;
    gap: 10px;
    padding: 16px 18px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-cart__support strong {
    color: #201713;
    font-size: 13px;
  }

  .bw-cart__support a,
  .bw-cart__support span {
    color: #6a5850;
    font-size: 13px;
    line-height: 1.6;
    text-decoration: none;
  }

  .bw-cart__empty {
    padding: 54px 28px;
    text-align: center;
    display: grid;
    gap: 14px;
  }

  .bw-cart__empty h2 {
    margin: 0;
    color: #201713;
    font-size: 30px;
  }

  .bw-cart__empty p {
    margin: 0;
    color: #6a5850;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-cart__empty a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 22px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    justify-self: center;
  }

  @media (max-width: 1080px) {
    .bw-cart__layout {
      grid-template-columns: 1fr;
    }

    .bw-cart__summary {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .bw-cart {
      padding: 20px 16px 56px;
    }

    .bw-cart__items {
      padding: 16px 18px;
    }

    .bw-cart__item {
      grid-template-columns: 1fr;
    }

    .bw-cart__image {
      min-height: 220px;
    }

    .bw-cart__item-top,
    .bw-cart__controls {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<section class="bw-cart">
  <div class="bw-cart__shell">
    <div class="bw-cart__header">
      <div class="bw-cart__eyebrow">Before checkout</div>
      <h1 class="bw-cart__title">Review your order.</h1>
      <p class="bw-cart__copy">Double-check quantities, add a note if needed, and continue to secure checkout when you are ready.</p>
    </div>

    {% if cart.item_count == 0 %}
      <div class="bw-cart__empty">
        <h2>Your cart is empty</h2>
        <p>Start with Bluewud bestsellers and build your cart from there.</p>
        <a href="/collections/hp-bluewuds-bestseller">Shop bestsellers</a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="bw-cart__layout">
          <div class="bw-cart__items">
            {% for item in cart.items %}
              <div class="bw-cart__item">
                <div class="bw-cart__image">
                  {% if item.image %}
                    <a href="{{ item.url }}">
                      {{ item.image | image_url: width: 480 | image_tag: loading: 'lazy', widths: '180, 240, 360, 480', sizes: '(max-width: 720px) 100vw, 132px', alt: item.product.title }}
                    </a>
                  {% endif %}
                </div>

                <div class="bw-cart__item-body">
                  <div class="bw-cart__item-top">
                    <div>
                      <h2 class="bw-cart__item-title"><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                      <div class="bw-cart__item-meta">
                        {% if item.variant.title != 'Default Title' %}
                          {{ item.variant.title }}<br>
                        {% endif %}
                        {% if item.vendor != blank %}
                          {{ item.vendor }}
                        {% endif %}
                      </div>
                    </div>
                    <div class="bw-cart__item-price">{{ item.final_line_price | money }}</div>
                  </div>

                  <div class="bw-cart__controls">
                    <div class="bw-cart__quantity">
                      <button class="bw-cart__qty-btn" type="button" data-cart-qty="-1">-</button>
                      <input class="bw-cart__qty-input" type="number" min="0" name="updates[]" value="{{ item.quantity }}" data-cart-qty-input>
                      <button class="bw-cart__qty-btn" type="button" data-cart-qty="1">+</button>
                    </div>

                    <a class="bw-cart__remove" href="{{ item.url_to_remove }}">Remove</a>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="bw-cart__summary">
            <h2 class="bw-cart__summary-title">Order summary</h2>
            <p class="bw-cart__summary-copy">Clear totals, simple updates, and support when you need it.</p>
            <div class="bw-cart__summary-badges" aria-label="Checkout reassurance">
              <span class="bw-cart__summary-badge">Secure checkout</span>
              <span class="bw-cart__summary-badge">Easy returns</span>
            </div>

            <div class="bw-cart__summary-line">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="bw-cart__summary-line">
              <span>Shipping</span>
              <span>Calculated at checkout</span>
            </div>
            <div class="bw-cart__summary-line bw-cart__summary-total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <label class="bw-cart__note-label" for="bw-cart-note-{{ section.id }}">Order note</label>
            <textarea class="bw-cart__note" id="bw-cart-note-{{ section.id }}" name="note" placeholder="Special instructions, delivery note, or project requirement">{{ cart.note }}</textarea>

            <div class="bw-cart__actions">
              <button class="bw-cart__secondary" type="submit" name="update">Update cart</button>
              <button class="bw-cart__button" type="submit" name="checkout">Proceed to checkout</button>
            </div>

            <div class="bw-cart__support">
              <strong>Need help before checkout?</strong>
              <a href="/pages/payment-security">Review payment and security details.</a>
              <a href="/pages/returns-refunds">Check returns and refund information.</a>
              <a href="/pages/contact-us">Talk to the Bluewud team if you need assistance.</a>
            </div>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('[data-cart-qty]').forEach(function (button) {
      button.addEventListener('click', function () {
        var delta = parseInt(button.getAttribute('data-cart-qty'), 10);
        var input = button.parentNode.querySelector('[data-cart-qty-input]');
        if (!input) return;

        var currentValue = parseInt(input.value || '0', 10);
        var nextValue = currentValue + delta;
        input.value = nextValue < 0 ? 0 : nextValue;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Cart Page",
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
