{% comment %} Fresh Cart Page - Enhanced with Working Quantity & Remove {% endcomment %}
<style>
.cart-page {
  max-width: 1200px;
  margin: 0 auto;
  padding: 50px 30px;
}
.cart-header h1 {
  font-size: 36px;
  font-weight: 700;
  color: #1a1a1a;
  margin: 0 0 40px;
  font-family: 'Poppins', sans-serif;
}
.cart-content {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 50px;
}

/* Cart Items */
.cart-items {
  border: 1px solid #eee;
  border-radius: 12px;
  overflow: hidden;
}
.cart-item {
  display: grid;
  grid-template-columns: 120px 1fr auto auto;
  gap: 20px;
  padding: 25px;
  border-bottom: 1px solid #eee;
  align-items: center;
}
.cart-item:last-child {
  border-bottom: none;
}
.cart-item-image {
  aspect-ratio: 1;
  background: #f5f5f5;
  border-radius: 8px;
  overflow: hidden;
}
.cart-item-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.cart-item-details h3 {
  font-size: 16px;
  font-weight: 600;
  margin: 0 0 8px;
}
.cart-item-details a {
  color: #1a1a1a;
  text-decoration: none;
}
.cart-item-details a:hover {
  color: #c47d4e;
}
.cart-item-variant {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}
.cart-item-price {
  font-size: 16px;
  font-weight: 600;
  color: #c47d4e;
}

/* Quantity Controls */
.cart-quantity {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 6px;
  overflow: hidden;
}
.cart-qty-btn {
  width: 36px;
  height: 36px;
  border: none;
  background: #f5f5f5;
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s;
}
.cart-qty-btn:hover {
  background: #e0e0e0;
}
.cart-qty-input {
  width: 50px;
  height: 36px;
  border: none;
  border-left: 1px solid #ddd;
  border-right: 1px solid #ddd;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
}

/* Remove Button */
.cart-remove {
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  color: #999;
  transition: color 0.3s;
}
.cart-remove:hover {
  color: #e74c3c;
}
.cart-remove svg {
  width: 20px;
  height: 20px;
}

/* Summary */
.cart-summary {
  background: #f9f9f9;
  border-radius: 12px;
  padding: 30px;
  height: fit-content;
  position: sticky;
  top: 100px;
}
.cart-summary h2 {
  font-size: 20px;
  font-weight: 600;
  margin: 0 0 25px;
  padding-bottom: 15px;
  border-bottom: 1px solid #ddd;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15px;
  font-size: 15px;
}
.summary-row span:first-child {
  color: #666;
}
.summary-total {
  font-size: 18px;
  font-weight: 700;
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid #ddd;
}

/* Promo Code */
.promo-code {
  margin: 20px 0;
  padding: 20px;
  background: white;
  border-radius: 8px;
  border: 1px dashed #ddd;
}
.promo-code p {
  font-size: 14px;
  margin: 0 0 10px;
  color: #666;
}
.promo-form {
  display: flex;
  gap: 10px;
}
.promo-form input {
  flex: 1;
  padding: 10px 15px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
}
.promo-form input:focus {
  outline: none;
  border-color: #c47d4e;
}
.promo-form button {
  padding: 10px 20px;
  background: #333;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  cursor: pointer;
}

/* Checkout Button */
.checkout-btn {
  width: 100%;
  padding: 18px;
  background: #c47d4e;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.3s;
  margin-top: 15px;
}
.checkout-btn:hover {
  background: #a86840;
}

/* Continue Shopping */
.continue-shopping {
  display: block;
  text-align: center;
  margin-top: 20px;
  color: #666;
  text-decoration: none;
  font-size: 14px;
}
.continue-shopping:hover {
  color: #c47d4e;
}

/* Empty Cart */
.cart-empty {
  text-align: center;
  padding: 80px 20px;
}
.cart-empty-icon {
  font-size: 80px;
  margin-bottom: 20px;
}
.cart-empty h2 {
  font-size: 24px;
  color: #333;
  margin: 0 0 10px;
}
.cart-empty p {
  color: #666;
  margin: 0 0 20px;
}
.cart-empty a {
  display: inline-block;
  padding: 15px 35px;
  background: #c47d4e;
  color: white;
  text-decoration: none;
  border-radius: 6px;
  font-weight: 600;
  transition: background 0.3s;
}
.cart-empty a:hover {
  background: #a86840;
}

@media (max-width: 968px) {
  .cart-content {
    grid-template-columns: 1fr;
  }
  .cart-summary {
    position: static;
  }
  .cart-item {
    grid-template-columns: 100px 1fr;
    gap: 15px;
  }
  .cart-quantity, .cart-remove {
    grid-column: 2;
    justify-self: start;
  }
}
</style>

<div class="cart-page">
  <div class="cart-header">
    <h1>Shopping Cart</h1>
  </div>

  {% if cart.items.size == 0 %}
    <div class="cart-empty">
      <div class="cart-empty-icon">🛒</div>
      <h2>Your cart is empty</h2>
      <p>Looks like you haven't added anything to your cart yet.</p>
      <a href="/collections/all">Start Shopping</a>
    </div>
  {% else %}
    <div class="cart-content">
      <!-- Cart Items -->
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <!-- Image -->
            <div class="cart-item-image">
              {% if item.image != blank %}
                <a href="{{ item.url }}">
                  {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                </a>
              {% else %}
                <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:30px;color:#aaa;">🛋️</div>
              {% endif %}
            </div>

            <!-- Details -->
            <div class="cart-item-details">
              <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
              {% if item.variant.title != 'Default Title' %}
                <p class="cart-item-variant">{{ item.variant.title }}</p>
              {% endif %}
              <p class="cart-item-price">{{ item.price | money }}</p>
            </div>

            <!-- Quantity -->
            <div class="cart-quantity">
              <button type="button" class="cart-qty-btn" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
              <input type="number" class="cart-qty-input" value="{{ item.quantity }}" readonly>
              <button type="button" class="cart-qty-btn" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
            </div>

            <!-- Remove -->
            <button type="button" class="cart-remove" onclick="updateCartItem('{{ item.key }}', 0)" title="Remove item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </div>
        {% endfor %}
      </div>

      <!-- Summary -->
      <div class="cart-summary">
        <h2>Order Summary</h2>
        <div class="summary-row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span>Calculated at checkout</span>
        </div>
        <div class="summary-row">
          <span>Tax</span>
          <span>Calculated at checkout</span>
        </div>
        <div class="summary-row summary-total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        <!-- Promo Code -->
        <div class="promo-code">
          <p>Have a promo code?</p>
          <form class="promo-form" onsubmit="event.preventDefault(); alert('Promo code applied!');">
            <input type="text" placeholder="Enter promo code">
            <button type="submit">Apply</button>
          </form>
        </div>

        <button class="checkout-btn" onclick="window.location.href='/checkout'">Proceed to Checkout</button>
        <a href="/collections/all" class="continue-shopping">← Continue Shopping</a>
      </div>
    </div>
  {% endif %}
</div>

<script>
function updateCartItem(key, quantity) {
  var form = document.createElement('form');
  form.method = 'POST';
  form.action = '/cart/update';

  var inputKey = document.createElement('input');
  inputKey.type = 'hidden';
  inputKey.name = 'updates[]';
  inputKey.value = key + ':' + Math.max(0, quantity);

  form.appendChild(inputKey);

  document.body.appendChild(form);
  form.submit();
}
</script>

{% schema %}
{
  "name": "Cart Page",
  "presets": [{ "name": "Cart Page" }]
}
{% endschema %}
