<style>
  .bw-newsletter {
    padding: 0 24px 78px;
    background: #faf6f1;
  }

  .bw-newsletter__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 44px 42px;
    border-radius: 32px;
    background: linear-gradient(135deg, #241913 0%, #3d2a21 100%);
    color: #f8f1eb;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 22px;
    align-items: center;
    box-shadow: 0 28px 80px rgba(35, 24, 19, 0.18);
  }

  .bw-newsletter__eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    color: rgba(248, 241, 235, 0.68);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-newsletter__title {
    margin: 0 0 12px;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.04em;
    max-width: 24ch;
  }

  .bw-newsletter__title-line {
    display: block;
  }

  .bw-newsletter__title-line:first-child {
    white-space: nowrap;
  }

  .bw-newsletter__title-line--accent {
    color: #e7c4ad;
  }

  .bw-newsletter__copy {
    margin: 0;
    color: rgba(248, 241, 235, 0.74);
    font-size: 16px;
    line-height: 1.8;
    max-width: 58ch;
  }

  .bw-newsletter__form {
    display: grid;
    gap: 10px;
    align-content: start;
  }

  .bw-newsletter__form-row {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }

  .bw-newsletter__field {
    display: block;
    box-sizing: border-box;
    width: 100%;
    min-height: 54px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(248, 241, 235, 0.16);
    background: rgba(255, 255, 255, 0.08);
    color: #f8f1eb;
    font-size: 15px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .bw-newsletter__field::placeholder {
    color: rgba(248, 241, 235, 0.5);
  }

  .bw-newsletter__field:focus {
    outline: none;
    border-color: rgba(231, 196, 173, 0.6);
    background: rgba(255, 255, 255, 0.1);
  }

  .bw-newsletter__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: auto;
    min-height: 54px;
    padding: 0 20px;
    border: 1px solid rgba(248, 241, 235, 0.1);
    border-radius: 999px;
    background: #f8f1eb;
    color: #241913;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .bw-newsletter__submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 24px rgba(0, 0, 0, 0.16);
  }

  .bw-newsletter__note,
  .bw-newsletter__message {
    margin: 0;
    color: rgba(248, 241, 235, 0.66);
    font-size: 12px;
    line-height: 1.6;
  }

  @media (max-width: 920px) {
    .bw-newsletter__inner {
      grid-template-columns: 1fr;
    }

    .bw-newsletter__form-row {
      flex-direction: column;
    }

    .bw-newsletter__submit {
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .bw-newsletter {
      padding: 0 16px 56px;
    }

    .bw-newsletter__inner {
      padding: 28px 22px;
      border-radius: 24px;
    }

    .bw-newsletter__title {
      max-width: none;
    }

    .bw-newsletter__title-line:first-child {
      white-space: normal;
    }
  }
</style>

<section class="bw-newsletter">
  <div class="bw-newsletter__inner">
    <div>
      <span class="bw-newsletter__eyebrow">Stay in the loop</span>
      <h2 class="bw-newsletter__title">
        <span class="bw-newsletter__title-line">Keep Bluewud in the shortlist</span>
        <span class="bw-newsletter__title-line bw-newsletter__title-line--accent">after the first visit.</span>
      </h2>
      <p class="bw-newsletter__copy">Get room ideas, launches, and offers when they are actually useful, so the project stays easy to return to later.</p>
    </div>

    {% form 'customer', class: 'bw-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="bw-newsletter__form-row">
        <input class="bw-newsletter__field" type="email" name="contact[email]" placeholder="Enter your email address" required>
        <button class="bw-newsletter__submit" type="submit">Join the Bluewud list</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="bw-newsletter__message">Thanks. You are now subscribed for Bluewud updates.</p>
      {% endif %}
      {% if form.errors %}
        <div class="bw-newsletter__message">{{ form.errors | default_errors }}</div>
      {% endif %}
      <p class="bw-newsletter__note">No spam. Just launches, offers, and furnishing ideas worth opening.</p>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
