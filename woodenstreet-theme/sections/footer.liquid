{% liquid
  assign footer_brand = section.settings.footer_brand | default: 'Bluewud'
  assign footer_copy = section.settings.footer_copy | default: 'Premium furniture, smarter storage, and guided room planning for modern Indian homes.'
  assign living_room_url = '/collections/living-room'
  assign bedroom_url = '/collections/bed-room'
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign about_url = '/pages/about-us'
  assign bulk_url = '/pages/buy-in-bulk'
  assign awards_url = '/pages/award-achievment'
  assign offers_url = '/pages/offers-discount'
  assign help_center_url = '/pages/help-center'
  assign contact_url = '/pages/contact-us'
  assign policies_url = '/pages/policies'
  assign returns_url = '/pages/returns-refunds'
  assign payment_security_url = '/pages/payment-security'
  assign terms_url = '/pages/terms-of-use'

  if collections['living-room'] != blank and collections['living-room'].url != blank
    assign living_room_url = collections['living-room'].url
  endif
  if collections['bed-room'] != blank and collections['bed-room'].url != blank
    assign bedroom_url = collections['bed-room'].url
  endif

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['about-us'] != blank
    assign about_url = pages['about-us'].url
  endif
  if pages['buy-in-bulk'] != blank
    assign bulk_url = pages['buy-in-bulk'].url
  endif
  if pages['award-achievment'] != blank
    assign awards_url = pages['award-achievment'].url
  endif
  if pages['offers-discount'] != blank
    assign offers_url = pages['offers-discount'].url
  endif
  if pages['help-center'] != blank
    assign help_center_url = pages['help-center'].url
  endif
  if pages['contact-us'] != blank
    assign contact_url = pages['contact-us'].url
  endif
  if pages['policies'] != blank
    assign policies_url = pages['policies'].url
  endif
  if pages['returns-refunds'] != blank
    assign returns_url = pages['returns-refunds'].url
  endif
  if pages['payment-security'] != blank
    assign payment_security_url = pages['payment-security'].url
  endif
  if pages['terms-of-use'] != blank
    assign terms_url = pages['terms-of-use'].url
  endif
%}

<style>
  .bw-footer {
    padding: 0 14px 10px;
    background: #faf6f1;
  }

  .bw-footer__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 12px 14px 10px;
    border-radius: 18px;
    background: #201713;
    color: #f8f1eb;
  }

  .bw-footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(0, 1fr));
    gap: 6px;
    padding-bottom: 7px;
    border-bottom: 1px solid rgba(248, 241, 235, 0.12);
  }

  .bw-footer__brand-name {
    display: inline-block;
    margin-bottom: 2px;
    color: #f8f1eb;
    font-size: 21px;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .bw-footer__copy {
    margin: 0 0 3px;
    color: rgba(248, 241, 235, 0.72);
    font-size: 11px;
    line-height: 1.35;
    max-width: 32ch;
  }

  .bw-footer__contact-list,
  .bw-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }

  .bw-footer__links--split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 8px;
  }

  .bw-footer__heading {
    margin: 0 0 1px;
    color: #f8f1eb;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-footer__contact-list a,
  .bw-footer__links a {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: 20px;
    color: rgba(248, 241, 235, 0.74);
    text-decoration: none;
    font-size: 10.5px;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .bw-footer__contact-list a:hover,
  .bw-footer__links a:hover {
    color: #ffffff;
  }

  .bw-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5px;
    padding-top: 4px;
    color: rgba(248, 241, 235, 0.58);
    font-size: 10px;
  }

  @media (max-width: 1080px) {
    .bw-footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
  }

  @media (max-width: 720px) {
    .bw-footer {
      padding: 0 8px 6px;
    }

    .bw-footer__inner {
      padding: 9px 8px 8px;
      border-radius: 14px;
    }

    .bw-footer__top {
      grid-template-columns: 1fr;
      gap: 5px;
      padding-bottom: 6px;
    }

    .bw-footer__links--split {
      grid-template-columns: 1fr;
    }

    .bw-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 3px;
      padding-top: 4px;
    }

    .bw-footer__contact-list a,
    .bw-footer__links a,
    .bw-footer__bottom-links a {
      min-height: 28px;
    }
  }
</style>

<footer class="bw-footer">
  <div class="bw-footer__inner">
    <div class="bw-footer__top">
      <div>
        <span class="bw-footer__brand-name">{{ footer_brand }}</span>
        <p class="bw-footer__copy">{{ footer_copy }}</p>

        <ul class="bw-footer__contact-list">
          <li><a href="tel:+918800609609">+91-8800-609-609</a></li>
          <li><a href="mailto:care@bluewud.com">care@bluewud.com</a></li>
          <li><a href="{{ contact_url }}">Contact Us</a></li>
        </ul>

      </div>

      <div>
        <h2 class="bw-footer__heading">Explore</h2>
        <ul class="bw-footer__links bw-footer__links--split">
          <li><a href="{{ living_room_url }}">Living Room</a></li>
          <li><a href="{{ bedroom_url }}">Bedroom</a></li>
          <li><a href="{{ modular_kitchen_url }}">Modular Kitchen</a></li>
          <li><a href="{{ modular_wardrobe_url }}">Wardrobes</a></li>
        </ul>
      </div>

      <div>
        <h2 class="bw-footer__heading">Company</h2>
        <ul class="bw-footer__links bw-footer__links--split">
          <li><a href="{{ about_url }}">About Us</a></li>
          <li><a href="{{ bulk_url }}">Buy In Bulk</a></li>
          <li><a href="{{ awards_url }}">Awards and Achievement</a></li>
          <li><a href="{{ offers_url }}">Offers & Discounts</a></li>
          <li><a href="{{ help_center_url }}">Help Center</a></li>
        </ul>
      </div>

      <div>
        <h2 class="bw-footer__heading">Policies</h2>
        <ul class="bw-footer__links">
          <li><a href="{{ returns_url }}">Returns and Refunds</a></li>
          <li><a href="{{ payment_security_url }}">Payment and Security</a></li>
          <li><a href="{{ terms_url }}">Terms of Use</a></li>
          <li><a href="{{ policies_url }}">Policies</a></li>
        </ul>
      </div>
    </div>

    <div class="bw-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ footer_brand }}. All rights reserved.</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_brand",
      "label": "Brand name",
      "default": "Bluewud"
    },
    {
      "type": "textarea",
      "id": "footer_copy",
      "label": "Brand copy",
      "default": "Premium furniture, smarter storage, and guided room planning for modern Indian homes."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
