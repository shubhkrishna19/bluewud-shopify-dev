{% liquid
  assign footer_brand = section.settings.footer_brand | default: 'Bluewud'
  assign footer_copy = section.settings.footer_copy | default: 'Bluewud brings premium furniture, smarter storage, and guided room planning together for modern Indian homes.'
  assign living_room_url = '/collections/living-room'
  assign bedroom_url = '/collections/bed-room'
  assign study_tables_url = '/collections/study-tables'
  assign tv_units_url = '/collections/tv-unit-furniture'
  assign bookshelves_url = '/collections/book-shelves'
  assign new_launches_url = '/collections/new_launches'
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign modular_kitchen_calculator_url = '/collections/kitchen-racks#kitchen-calculator'
  assign modular_wardrobe_calculator_url = '/collections/wardrobe#wardrobe-calculator'
  assign home_interiors_calculator_url = '/collections/kitchen-racks#broader-planning'
  assign estimate_url = '/pages/get-free-estimate'
  assign about_url = '/pages/about-us'
  assign bulk_url = '/pages/buy-in-bulk'
  assign visit_url = '/pages/visit-us'
  assign awards_url = '/pages/award-achievment'
  assign offers_url = '/pages/offers-discount'
  assign help_center_url = '/pages/help-center'
  assign contact_url = '/pages/contact-us'
  assign policies_url = '/pages/policies'
  assign returns_url = '/pages/returns-refunds'
  assign payment_security_url = '/pages/payment-security'
  assign terms_url = '/pages/terms-of-use'

  if collections['living-room'] != blank and collections['living-room'].url != blank
    assign living_room_url = collections['living-room'].url
  endif
  if collections['bed-room'] != blank and collections['bed-room'].url != blank
    assign bedroom_url = collections['bed-room'].url
  endif
  if collections['study-tables'] != blank and collections['study-tables'].url != blank
    assign study_tables_url = collections['study-tables'].url
  endif
  if collections['tv-unit-furniture'] != blank and collections['tv-unit-furniture'].url != blank
    assign tv_units_url = collections['tv-unit-furniture'].url
  endif
  if collections['book-shelves'] != blank and collections['book-shelves'].url != blank
    assign bookshelves_url = collections['book-shelves'].url
  endif
  if collections['new_launches'] != blank and collections['new_launches'].url != blank
    assign new_launches_url = collections['new_launches'].url
  endif

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign modular_kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign modular_wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign home_interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  elsif pages['contact-us'] != blank
    assign estimate_url = pages['contact-us'].url
  endif
  if pages['about-us'] != blank
    assign about_url = pages['about-us'].url
  endif
  if pages['buy-in-bulk'] != blank
    assign bulk_url = pages['buy-in-bulk'].url
  endif
  if pages['visit-us'] != blank
    assign visit_url = pages['visit-us'].url
  endif
  if pages['award-achievment'] != blank
    assign awards_url = pages['award-achievment'].url
  endif
  if pages['offers-discount'] != blank
    assign offers_url = pages['offers-discount'].url
  endif
  if pages['help-center'] != blank
    assign help_center_url = pages['help-center'].url
  endif
  if pages['contact-us'] != blank
    assign contact_url = pages['contact-us'].url
  endif
  if pages['policies'] != blank
    assign policies_url = pages['policies'].url
  endif
  if pages['returns-refunds'] != blank
    assign returns_url = pages['returns-refunds'].url
  endif
  if pages['payment-security'] != blank
    assign payment_security_url = pages['payment-security'].url
  endif
  if pages['terms-of-use'] != blank
    assign terms_url = pages['terms-of-use'].url
  endif
%}

<style>
  .bw-footer {
    padding: 0 24px 26px;
    background: #faf6f1;
  }

  .bw-footer__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 40px;
    border-radius: 32px;
    background: #201713;
    color: #f8f1eb;
  }

  .bw-footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(0, 1fr));
    gap: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(248, 241, 235, 0.12);
  }

  .bw-footer__brand-name {
    display: inline-block;
    margin-bottom: 12px;
    color: #f8f1eb;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .bw-footer__copy {
    margin: 0 0 18px;
    color: rgba(248, 241, 235, 0.72);
    font-size: 15px;
    line-height: 1.8;
    max-width: 52ch;
  }

  .bw-footer__contact-list,
  .bw-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .bw-footer__heading {
    margin: 0 0 12px;
    color: #f8f1eb;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-footer__contact-list a,
  .bw-footer__links a {
    color: rgba(248, 241, 235, 0.74);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.6;
  }

  .bw-footer__contact-list a:hover,
  .bw-footer__links a:hover {
    color: #ffffff;
  }

  .bw-footer__newsletter {
    display: grid;
    gap: 10px;
    margin-top: 20px;
  }

  .bw-footer__newsletter-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .bw-footer__newsletter-field {
    flex: 1 1 220px;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid rgba(248, 241, 235, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: #f8f1eb;
  }

  .bw-footer__newsletter-submit {
    min-height: 48px;
    padding: 0 18px;
    border: none;
    border-radius: 999px;
    background: #f8f1eb;
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .bw-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding-top: 18px;
    color: rgba(248, 241, 235, 0.58);
    font-size: 13px;
  }

  .bw-footer__bottom-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .bw-footer__bottom-links a {
    color: rgba(248, 241, 235, 0.58);
    text-decoration: none;
  }

  .bw-footer__bottom-links a:hover {
    color: #ffffff;
  }

  @media (max-width: 1080px) {
    .bw-footer__top {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .bw-footer {
      padding: 0 16px 18px;
    }

    .bw-footer__inner {
      padding: 28px 22px;
      border-radius: 24px;
    }

    .bw-footer__top {
      grid-template-columns: 1fr;
    }

    .bw-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<footer class="bw-footer">
  <div class="bw-footer__inner">
    <div class="bw-footer__top">
      <div>
        <span class="bw-footer__brand-name">{{ footer_brand }}</span>
        <p class="bw-footer__copy">{{ footer_copy }}</p>

        <ul class="bw-footer__contact-list">
          <li><a href="tel:+918800609609">+91-8800-609-609</a></li>
          <li><a href="mailto:care@bluewud.com">care@bluewud.com</a></li>
          <li><a href="{{ contact_url }}">Contact Us</a></li>
          <li><a href="{{ visit_url }}">Visit Us</a></li>
        </ul>

        <div class="bw-footer__newsletter">
          <div class="bw-footer__heading">Get project updates</div>
          {% form 'customer', class: 'bw-footer__newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input class="bw-footer__newsletter-field" type="email" name="contact[email]" placeholder="Email for project updates" required>
            <button class="bw-footer__newsletter-submit" type="submit">Join Updates</button>
          {% endform %}
        </div>
      </div>

      <div>
        <h2 class="bw-footer__heading">Shop</h2>
        <ul class="bw-footer__links">
          <li><a href="{{ living_room_url }}">Living Room</a></li>
          <li><a href="{{ bedroom_url }}">Bedroom</a></li>
          <li><a href="{{ study_tables_url }}">Study Tables</a></li>
          <li><a href="{{ tv_units_url }}">TV Units</a></li>
          <li><a href="{{ bookshelves_url }}">Bookshelves</a></li>
          <li><a href="{{ modular_kitchen_url }}">Modular Kitchen</a></li>
          <li><a href="{{ modular_wardrobe_url }}">Wardrobes</a></li>
          <li><a href="{{ new_launches_url }}">New Launches</a></li>
        </ul>
      </div>

      <div>
        <h2 class="bw-footer__heading">Company</h2>
        <ul class="bw-footer__links">
          <li><a href="{{ about_url }}">About Us</a></li>
          <li><a href="{{ bulk_url }}">Buy In Bulk</a></li>
          <li><a href="{{ visit_url }}">Visit Us</a></li>
          <li><a href="{{ awards_url }}">Awards and Achievement</a></li>
          <li><a href="{{ offers_url }}">Offers & Discounts</a></li>
          <li><a href="{{ modular_kitchen_calculator_url }}">Kitchen Calculator</a></li>
          <li><a href="{{ modular_wardrobe_calculator_url }}">Wardrobe Calculator</a></li>
          <li><a href="{{ home_interiors_calculator_url }}">Home Interiors Calculator</a></li>
          <li><a href="{{ estimate_url }}">Get Free Estimate</a></li>
          <li><a href="{{ help_center_url }}">Help Center</a></li>
        </ul>
      </div>

      <div>
        <h2 class="bw-footer__heading">Policies</h2>
        <ul class="bw-footer__links">
          <li><a href="{{ policies_url }}">Policies</a></li>
          <li><a href="{{ returns_url }}">Returns and Refunds</a></li>
          <li><a href="{{ payment_security_url }}">Payment and Security</a></li>
          <li><a href="{{ terms_url }}">Terms of Use</a></li>
          <li><a href="{{ contact_url }}">Support</a></li>
        </ul>
      </div>
    </div>

    <div class="bw-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ footer_brand }}. All rights reserved.</span>
      <div class="bw-footer__bottom-links">
        <a href="{{ payment_security_url }}">Payment & Security</a>
        <a href="{{ returns_url }}">Returns & Refunds</a>
        <a href="{{ terms_url }}">Terms of Use</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_brand",
      "label": "Brand name",
      "default": "Bluewud"
    },
    {
      "type": "textarea",
      "id": "footer_copy",
      "label": "Brand copy",
      "default": "Bluewud brings premium furniture, smarter storage, and guided room planning together for modern Indian homes."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
