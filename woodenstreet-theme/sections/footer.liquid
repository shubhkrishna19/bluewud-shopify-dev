{% liquid
  assign footer_brand = section.settings.footer_brand | default: 'Bluewud'
  assign footer_copy = section.settings.footer_copy | default: 'Bluewud brings premium-value furniture, smarter storage, and room-defining pieces together in one clearer shopping journey.'
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign modular_kitchen_calculator_url = '/collections/kitchen-racks#kitchen-calculator'
  assign modular_wardrobe_calculator_url = '/collections/wardrobe#wardrobe-calculator'
  assign home_interiors_calculator_url = '/collections/kitchen-racks#broader-planning'
  assign estimate_url = '/pages/contact-us'

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif
  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif
  if pages['modular-kitchen-cost-calculator'] != blank
    assign modular_kitchen_calculator_url = pages['modular-kitchen-cost-calculator'].url
  endif
  if pages['modular-wardrobe-cost-calculator'] != blank
    assign modular_wardrobe_calculator_url = pages['modular-wardrobe-cost-calculator'].url
  endif
  if pages['home-interiors-cost-calculator'] != blank
    assign home_interiors_calculator_url = pages['home-interiors-cost-calculator'].url
  endif
  if pages['get-free-estimate'] != blank
    assign estimate_url = pages['get-free-estimate'].url
  endif
%}

<style>
  .bw-footer {
    padding: 0 24px 26px;
    background: #faf6f1;
  }

  .bw-footer__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 40px;
    border-radius: 32px;
    background: #201713;
    color: #f8f1eb;
  }

  .bw-footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(0, 1fr));
    gap: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(248, 241, 235, 0.12);
  }

  .bw-footer__brand-name {
    display: inline-block;
    margin-bottom: 12px;
    color: #f8f1eb;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .bw-footer__copy {
    margin: 0 0 18px;
    color: rgba(248, 241, 235, 0.72);
    font-size: 15px;
    line-height: 1.8;
    max-width: 52ch;
  }

  .bw-footer__contact-list,
  .bw-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .bw-footer__heading {
    margin: 0 0 12px;
    color: #f8f1eb;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-footer__contact-list a,
  .bw-footer__links a {
    color: rgba(248, 241, 235, 0.74);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.6;
  }

  .bw-footer__contact-list a:hover,
  .bw-footer__links a:hover {
    color: #ffffff;
  }

  .bw-footer__planning {
    display: grid;
    gap: 10px;
    margin-top: 18px;
    padding-top: 18px;
    border-top: 1px solid rgba(248, 241, 235, 0.12);
  }

  .bw-footer__planning-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bw-footer__planning-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(248, 241, 235, 0.14);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(248, 241, 235, 0.84);
    text-decoration: none;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bw-footer__planning-links a:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
  }

  .bw-footer__newsletter {
    display: grid;
    gap: 10px;
    margin-top: 20px;
  }

  .bw-footer__newsletter-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .bw-footer__newsletter-field {
    flex: 1 1 220px;
    min-height: 48px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid rgba(248, 241, 235, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: #f8f1eb;
  }

  .bw-footer__newsletter-submit {
    min-height: 48px;
    padding: 0 18px;
    border: none;
    border-radius: 999px;
    background: #f8f1eb;
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .bw-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding-top: 18px;
    color: rgba(248, 241, 235, 0.58);
    font-size: 13px;
  }

  .bw-footer__bottom-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .bw-footer__bottom-links a {
    color: rgba(248, 241, 235, 0.58);
    text-decoration: none;
  }

  .bw-footer__bottom-links a:hover {
    color: #ffffff;
  }

  @media (max-width: 1080px) {
    .bw-footer__top {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .bw-footer {
      padding: 0 16px 18px;
    }

    .bw-footer__inner {
      padding: 28px 22px;
      border-radius: 24px;
    }

    .bw-footer__top {
      grid-template-columns: 1fr;
    }

    .bw-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<footer class="bw-footer">
  <div class="bw-footer__inner">
    <div class="bw-footer__top">
      <div>
        <span class="bw-footer__brand-name">{{ footer_brand }}</span>
        <p class="bw-footer__copy">{{ footer_copy }}</p>

        <ul class="bw-footer__contact-list">
          <li><a href="tel:+918800609609">+91-8800-609-609</a></li>
          <li><a href="mailto:care@bluewud.com">care@bluewud.com</a></li>
          <li><a href="/pages/contact-us">Contact Us</a></li>
          <li><a href="/pages/visit-us">Visit Us</a></li>
        </ul>

        <div class="bw-footer__planning">
          <div class="bw-footer__heading">Plan Your Space</div>
          <ul class="bw-footer__planning-links" aria-label="Planning links">
            <li><a href="{{ modular_kitchen_url }}">Modular Kitchen</a></li>
            <li><a href="{{ modular_kitchen_calculator_url }}">Kitchen Calculator</a></li>
            <li><a href="{{ modular_wardrobe_url }}">Wardrobes</a></li>
            <li><a href="{{ modular_wardrobe_calculator_url }}">Wardrobe Calculator</a></li>
            <li><a href="{{ home_interiors_calculator_url }}">Home Interiors Calculator</a></li>
            <li><a href="{{ estimate_url }}">Get Free Estimate</a></li>
          </ul>
        </div>

        <div class="bw-footer__newsletter">
          <div class="bw-footer__heading">Stay connected</div>
          {% form 'customer', class: 'bw-footer__newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input class="bw-footer__newsletter-field" type="email" name="contact[email]" placeholder="Email for updates" required>
            <button class="bw-footer__newsletter-submit" type="submit">Subscribe</button>
          {% endform %}
        </div>
      </div>

      <div>
        <h2 class="bw-footer__heading">Shop</h2>
        <ul class="bw-footer__links">
          <li><a href="/collections/living-room">Living Room</a></li>
          <li><a href="/collections/bed-room">Bedroom</a></li>
          <li><a href="/collections/study-tables">Study Tables</a></li>
          <li><a href="/collections/tv-unit-furniture">TV Units</a></li>
          <li><a href="/collections/book-shelves">Bookshelves</a></li>
          <li><a href="{{ modular_kitchen_url }}">Modular Kitchen</a></li>
          <li><a href="{{ modular_wardrobe_url }}">Wardrobes</a></li>
          <li><a href="/collections/new_launches">New Launches</a></li>
        </ul>
      </div>

      <div>
        <h2 class="bw-footer__heading">Company</h2>
        <ul class="bw-footer__links">
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/pages/buy-in-bulk">Buy In Bulk</a></li>
          <li><a href="/pages/visit-us">Visit Us</a></li>
          <li><a href="/pages/award-achievment">Awards and Achievement</a></li>
          <li><a href="/pages/offers-discount">Offers and Discount</a></li>
          <li><a href="{{ modular_kitchen_calculator_url }}">Kitchen Calculator</a></li>
          <li><a href="{{ modular_wardrobe_calculator_url }}">Wardrobe Calculator</a></li>
          <li><a href="{{ home_interiors_calculator_url }}">Home Interiors Calculator</a></li>
          <li><a href="{{ estimate_url }}">Get Free Estimate</a></li>
          <li><a href="/pages/help-center">Help Center</a></li>
        </ul>
      </div>

      <div>
        <h2 class="bw-footer__heading">Policies</h2>
        <ul class="bw-footer__links">
          <li><a href="/pages/policies">Policies</a></li>
          <li><a href="/pages/returns-refunds">Returns and Refunds</a></li>
          <li><a href="/pages/payment-security">Payment and Security</a></li>
          <li><a href="/pages/terms-of-use">Terms of Use</a></li>
          <li><a href="/pages/contact-us">Support</a></li>
        </ul>
      </div>
    </div>

    <div class="bw-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ footer_brand }}. All rights reserved.</span>
      <div class="bw-footer__bottom-links">
        <a href="/pages/payment-security">Payment and Security</a>
        <a href="/pages/returns-refunds">Returns</a>
        <a href="/pages/terms-of-use">Terms</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_brand",
      "label": "Brand name",
      "default": "Bluewud"
    },
    {
      "type": "textarea",
      "id": "footer_copy",
      "label": "Brand copy",
      "default": "Bluewud brings premium-value furniture, smarter storage, and room-defining pieces together in one clearer shopping journey."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
