{% liquid
  assign current_sort = collection.sort_by | default: collection.default_sort_by
  assign current_path = request.path
  assign modular_kitchen_url = '/collections/kitchen-racks'
  assign modular_wardrobe_url = '/collections/wardrobe'
  assign hero_media = collection.image
  assign collection_handle = collection.handle
  assign hero_title = collection.title
  assign hero_copy = collection.description | strip_html
  assign collection_eyebrow = 'Explore the collection'
  assign insight_titles = 'Pan-India delivery|Easy EMI|Refined utility' | split: '|'
  assign insight_copies = 'Reliable support for furniture that needs smoother doorstep coordination.|Comfortable payment flexibility for larger purchases and room-by-room upgrades.|Thoughtfully designed pieces built for modern Indian homes.' | split: '|'

  if hero_media == blank and collection.products.size > 0
    assign hero_media = collection.products.first.featured_image
  endif

  if pages['modular-kitchen-designs'] != blank
    assign modular_kitchen_url = pages['modular-kitchen-designs'].url
  endif

  if pages['modular-wardrobe-designs'] != blank
    assign modular_wardrobe_url = pages['modular-wardrobe-designs'].url
  endif

  if hero_copy == blank
    assign hero_copy = 'Explore thoughtfully designed furniture made to bring comfort, function, and finish to every room.'
  endif

  case collection_handle
    when 'kitchen-racks'
      assign hero_title = 'Modular Kitchen'
      assign collection_eyebrow = 'Kitchen storage, simplified'
      assign hero_copy = 'Organise spices, jars, microwave units, and everyday cookware with modular kitchen storage that looks cleaner and works harder in compact Indian homes.'
      assign insight_titles = 'Wall and floor formats|Utility-first storage|Designed for compact kitchens' | split: '|'
      assign insight_copies = 'Browse wall-mounted cabinets, spice racks, display shelves, and floor-supported utility units in one place.|A practical mix of microwave stands, bottle racks, and modular organisers built for daily use.|Thoughtful proportions and engineered wood finishes that help busy kitchens feel calmer and more intentional.' | split: '|'
    when 'wardrobe'
      assign hero_title = 'Wardrobes'
      assign collection_eyebrow = 'Bedroom storage with structure'
      assign hero_copy = 'Discover 2 door, 3 door, and 4 door wardrobes designed to bring cleaner storage, stronger organisation, and a more premium bedroom feel without wasting floor space.'
      assign insight_titles = '2, 3 and 4 door options|Storage-first bedroom planning|Made for everyday use' | split: '|'
      assign insight_copies = 'Choose from compact to full-format wardrobes based on room size, clothing volume, and access needs.|Balanced internal layouts for folded essentials, hanging storage, and a tidier visual presence in the room.|Engineered wood finishes, dependable utility, and delivery support suited to larger furniture purchases.' | split: '|'
  endcase
%}

<style>
  .bw-collection {
    padding: 28px 24px 72px;
    background: linear-gradient(180deg, #faf6f1 0%, #fffdfb 100%);
  }

  .bw-collection__shell {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-collection__hero {
    position: relative;
    overflow: hidden;
    border-radius: 34px;
    min-height: 360px;
    margin-bottom: 26px;
    background:
      radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.2), transparent 24%),
      linear-gradient(145deg, #dccbbf 0%, #bf9b86 40%, #6d4d40 100%);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.1);
  }

  .bw-collection__hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bw-collection__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14, 10, 8, 0.08) 0%, rgba(14, 10, 8, 0.74) 100%);
  }

  .bw-collection__hero-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 34px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 14px;
    color: #fff7f1;
  }

  .bw-collection__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: rgba(255, 247, 241, 0.78);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-collection__breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .bw-collection__title {
    margin: 0;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .bw-collection__copy {
    max-width: 56ch;
    margin: 0;
    color: rgba(255, 247, 241, 0.88);
    font-size: 16px;
    line-height: 1.8;
  }

  .bw-collection__hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 4px;
  }

  .bw-collection__hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    background: #fff7f1;
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(20, 13, 9, 0.14);
  }

  .bw-collection__hero-button.is-secondary {
    background: rgba(255, 255, 255, 0.12);
    color: #fff7f1;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: none;
  }

  .bw-collection__hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 2px;
  }

  .bw-collection__hero-badge {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 247, 241, 0.92);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-collection__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 24px;
  }

  .bw-collection__chip {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bw-collection__chip.is-current {
    background: #201713;
    color: #fff7f1;
  }

  .bw-collection__insights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin: 0 0 24px;
  }

  .bw-collection__insight {
    padding: 22px 22px 20px;
    border-radius: 24px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 40px rgba(35, 24, 19, 0.05);
  }

  .bw-collection__insight-title {
    margin: 0 0 8px;
    color: #201713;
    font-size: 18px;
    line-height: 1.2;
  }

  .bw-collection__insight-copy {
    margin: 0;
    color: #6b5b53;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-collection__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    padding: 20px 22px;
    border-radius: 26px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 40px rgba(35, 24, 19, 0.06);
  }

  .bw-collection__toolbar-main {
    display: grid;
    gap: 6px;
  }

  .bw-collection__eyebrow {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-collection__count {
    color: #201713;
    font-size: 18px;
    font-weight: 700;
  }

  .bw-collection__sort {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .bw-collection__sort label {
    color: #5d4c43;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-collection__sort select {
    min-height: 46px;
    padding: 0 42px 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(45, 33, 27, 0.14);
    background: #fff;
    color: #201713;
    font-size: 14px;
    font-weight: 600;
  }

  .bw-collection__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .bw-collection__card {
    display: grid;
    gap: 14px;
    padding: 16px;
    border-radius: 28px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 50px rgba(35, 24, 19, 0.06);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .bw-collection__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 60px rgba(35, 24, 19, 0.1);
  }

  .bw-collection__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 22px;
    min-height: 280px;
    background:
      radial-gradient(circle at 20% 16%, rgba(255, 255, 255, 0.2), transparent 24%),
      linear-gradient(145deg, #dfd0c4 0%, #bb9b86 42%, #6e5043 100%);
  }

  .bw-collection__image-wrap img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .bw-collection__pill {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 1;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.84);
    color: #fff7f1;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-collection__card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 100%;
  }

  .bw-collection__card-title {
    margin: 0;
    color: #201713;
    font-size: 20px;
    line-height: 1.2;
  }

  .bw-collection__card-meta {
    color: #6b5b53;
    font-size: 13px;
    line-height: 1.6;
  }

  .bw-collection__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .bw-collection__details {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .bw-collection__detail {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 1 auto;
    max-width: 100%;
    min-height: 28px;
    min-width: fit-content;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #5f4f46;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
    white-space: nowrap;
  }

  .bw-collection__price {
    color: #201713;
    font-size: 20px;
    font-weight: 800;
  }

  .bw-collection__compare {
    color: #8b7a71;
    font-size: 14px;
    text-decoration: line-through;
  }

  .bw-collection__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    margin-top: auto;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: auto;
  }

  .bw-collection__empty {
    padding: 56px 28px;
    border-radius: 28px;
    text-align: center;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-collection__empty h2 {
    margin: 0 0 10px;
    color: #201713;
    font-size: 28px;
  }

  .bw-collection__empty p {
    margin: 0;
    color: #6a5850;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-collection__pagination {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 30px;
  }

  .bw-collection__pagination a,
  .bw-collection__pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.1);
    color: #201713;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
  }

  .bw-collection__pagination .is-current {
    background: #201713;
    color: #fff7f1;
    border-color: #201713;
  }

  @media (max-width: 1180px) {
    .bw-collection__insights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bw-collection__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .bw-collection__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .bw-collection {
      padding: 20px 16px 56px;
    }

    .bw-collection__hero {
      min-height: 320px;
    }

    .bw-collection__hero-content,
    .bw-collection__toolbar {
      padding: 22px 20px;
    }

    .bw-collection__chips {
      flex-wrap: nowrap;
      overflow-x: auto;
      margin-bottom: 18px;
      padding-bottom: 4px;
      scrollbar-width: none;
    }

    .bw-collection__chips::-webkit-scrollbar {
      display: none;
    }

    .bw-collection__chip {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .bw-collection__toolbar {
      gap: 12px;
      border-radius: 20px;
    }

    .bw-collection__insights {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .bw-collection__insight {
      padding: 18px 18px 16px;
      border-radius: 20px;
    }

    .bw-collection__sort {
      width: 100%;
      flex-wrap: wrap;
    }

    .bw-collection__sort select {
      width: 100%;
    }

    .bw-collection__grid {
      grid-template-columns: 1fr;
    }

    .bw-collection__card {
      padding: 14px;
      border-radius: 22px;
    }

    .bw-collection__image-wrap {
      min-height: 240px;
      border-radius: 18px;
    }

    .bw-collection__details {
      gap: 7px;
    }

    .bw-collection__detail {
      font-size: 9px;
      padding: 0 10px;
    }
  }
</style>

{% if collection_handle == 'kitchen-racks' %}
  <section class="bw-collection">
    <div class="bw-collection__shell">
      {% render 'modular-kitchen-page-content' %}
    </div>
  </section>
{% elsif collection_handle == 'wardrobe' %}
  <section class="bw-collection">
    <div class="bw-collection__shell">
      {% render 'wardrobe-page-content' %}
    </div>
  </section>
{% else %}
  <section class="bw-collection">
    <div class="bw-collection__shell">
      <div class="bw-collection__hero">
      {% if hero_media %}
        {{ hero_media | image_url: width: 1800 | image_tag: loading: 'eager', widths: '720, 1080, 1440, 1800', sizes: '100vw', alt: collection.title }}
      {% endif %}
      <div class="bw-collection__hero-overlay"></div>
      <div class="bw-collection__hero-content">
        <div class="bw-collection__breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span>/</span>
          <a href="{{ routes.all_products_collection_url }}">Collections</a>
          <span>/</span>
          <span>{{ collection.title }}</span>
        </div>
        <h1 class="bw-collection__title">{{ hero_title }}</h1>
        <p class="bw-collection__copy">{{ hero_copy }}</p>
        <div class="bw-collection__hero-actions">
          <a class="bw-collection__hero-button" href="/collections/hp-bluewuds-bestseller">Shop bestsellers</a>
          <a class="bw-collection__hero-button is-secondary" href="/pages/contact-us">Talk to Bluewud</a>
        </div>
        <div class="bw-collection__hero-trust" aria-label="Collection trust cues">
          <span class="bw-collection__hero-badge">Easy EMI</span>
          <span class="bw-collection__hero-badge">Secure checkout</span>
          <span class="bw-collection__hero-badge">Pan-India delivery</span>
        </div>
      </div>
    </div>

    <div class="bw-collection__chips">
      <a class="bw-collection__chip{% if collection_handle == 'living-room' %} is-current{% endif %}" href="/collections/living-room">Living Room</a>
      <a class="bw-collection__chip{% if collection_handle == 'bed-room' %} is-current{% endif %}" href="/collections/bed-room">Bedroom</a>
      <a class="bw-collection__chip{% if collection_handle == 'study-tables' %} is-current{% endif %}" href="/collections/study-tables">Study Tables</a>
      <a class="bw-collection__chip{% if collection_handle == 'tv-unit-furniture' %} is-current{% endif %}" href="/collections/tv-unit-furniture">TV Units</a>
      <a class="bw-collection__chip{% if collection_handle == 'book-shelves' %} is-current{% endif %}" href="/collections/book-shelves">Bookshelves</a>
      <a class="bw-collection__chip{% if current_path == modular_kitchen_url %} is-current{% endif %}" href="{{ modular_kitchen_url }}">Modular Kitchen</a>
      <a class="bw-collection__chip{% if current_path == modular_wardrobe_url %} is-current{% endif %}" href="{{ modular_wardrobe_url }}">Wardrobes</a>
      <a class="bw-collection__chip{% if collection_handle == 'new_launches' %} is-current{% endif %}" href="/collections/new_launches">New Launches</a>
      <a class="bw-collection__chip" href="/collections/hp-bluewuds-bestseller">Bestsellers</a>
    </div>

    <div class="bw-collection__insights">
      {% for insight_title in insight_titles %}
        <article class="bw-collection__insight">
          <h2 class="bw-collection__insight-title">{{ insight_title }}</h2>
          <p class="bw-collection__insight-copy">{{ insight_copies[forloop.index0] }}</p>
        </article>
      {% endfor %}
    </div>

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="bw-collection__toolbar">
        <div class="bw-collection__toolbar-main">
          <div class="bw-collection__eyebrow">{{ collection_eyebrow }}</div>
          <div class="bw-collection__count">{{ paginate.items }} item{% if paginate.items != 1 %}s{% endif %} in this collection</div>
        </div>

        <form class="bw-collection__sort" method="get">
          <label for="bw-sort-{{ section.id }}">Sort by</label>
          <select id="bw-sort-{{ section.id }}" name="sort_by" onchange="this.form.submit()">
            {% for option in collection.sort_options %}
              <option value="{{ option.value }}" {% if option.value == current_sort %}selected{% endif %}>{{ option.name }}</option>
            {% endfor %}
          </select>
        </form>
      </div>

      {% if paginate.items > 0 %}
        <div class="bw-collection__grid">
          {% for product in collection.products %}
            {% liquid
              assign product_subtitle = product.metafields.my_fields.product_subtitle
              assign free_delivery_note = product.metafields.my_fields.free_delivery
              assign emi_from_note = product.metafields.my_fields.emi_from
            %}
            <a class="bw-collection__card" href="{{ product.url | within: collection }}">
              <div class="bw-collection__image-wrap">
                {% if product.featured_image %}
                  {% if product.compare_at_price > product.price %}
                    <span class="bw-collection__pill">On Sale</span>
                  {% elsif product.available == false %}
                    <span class="bw-collection__pill">Sold Out</span>
                  {% else %}
                    <span class="bw-collection__pill">Premium Pick</span>
                  {% endif %}
                  {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 720px) 100vw, 25vw', alt: product.title }}
                {% else %}
                  <span class="bw-collection__pill">Bluewud image</span>
                {% endif %}
              </div>

              <div class="bw-collection__card-body">
                <h2 class="bw-collection__card-title">{{ product.title }}</h2>
                <div class="bw-collection__card-meta">
                  {% if product_subtitle != blank %}
                    {{ product_subtitle }}
                  {% elsif product.product_type != blank %}
                    {{ product.product_type }}
                  {% elsif product.vendor != blank %}
                    {{ product.vendor }}
                  {% else %}
                    Designed for everyday comfort and refined living.
                  {% endif %}
                </div>
                <div class="bw-collection__price-row">
                  <span class="bw-collection__price">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="bw-collection__compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
                <div class="bw-collection__details">
                  <span class="bw-collection__detail">{% if product.available %}Ready to order{% else %}Sold out{% endif %}</span>
                  {% if emi_from_note != blank %}
                    <span class="bw-collection__detail">{{ emi_from_note }}</span>
                  {% else %}
                    <span class="bw-collection__detail">Easy EMI</span>
                  {% endif %}
                  {% if free_delivery_note != blank %}
                    <span class="bw-collection__detail">{{ free_delivery_note }}</span>
                  {% else %}
                    <span class="bw-collection__detail">Secure checkout</span>
                  {% endif %}
                </div>
                <span class="bw-collection__cta">View details</span>
              </div>
            </a>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="bw-collection__pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}">Previous</a>
            {% endif %}

            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {% else %}
                <span class="{% if part.title == paginate.current_page %}is-current{% endif %}">{{ part.title }}</span>
              {% endif %}
            {% endfor %}

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}">Next</a>
            {% endif %}
          </div>
        {% endif %}
      {% else %}
        <div class="bw-collection__empty">
          <h2>No products are live here yet</h2>
          <p>Products for this collection will appear here soon.</p>
        </div>
      {% endif %}
    {% endpaginate %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Collection Page"
    }
  ]
}
{% endschema %}
