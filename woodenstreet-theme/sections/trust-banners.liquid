{% liquid
  assign help_center_url = '/pages/help-center'
  assign contact_url = '/pages/contact-us'
  assign bestsellers_url = '/collections/hp-bluewuds-bestseller'
  assign payment_security_url = '/pages/payment-security'

  if pages['help-center'] != blank
    assign help_center_url = pages['help-center'].url
  endif
  if pages['contact-us'] != blank
    assign contact_url = pages['contact-us'].url
  endif
  if collections['hp-bluewuds-bestseller'] != blank and collections['hp-bluewuds-bestseller'].url != blank
    assign bestsellers_url = collections['hp-bluewuds-bestseller'].url
  endif
  if pages['payment-security'] != blank
    assign payment_security_url = pages['payment-security'].url
  endif
%}

<style>
  .bw-trust {
    padding: 18px 24px 4px;
    background:
      radial-gradient(circle at 50% 0%, rgba(166, 106, 67, 0.08), transparent 44%),
      linear-gradient(180deg, #f3ece4 0%, #faf6f1 100%);
  }

  .bw-trust__shell {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    gap: 16px;
  }

  .bw-trust__intro {
    display: grid;
    gap: 8px;
    max-width: 56ch;
  }

  .bw-trust__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-trust__headline {
    margin: 0;
    color: #211711;
    font-size: clamp(24px, 3vw, 31px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .bw-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .bw-trust__card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 14px;
    padding: 22px;
    border-radius: 30px;
    background:
      linear-gradient(180deg, rgba(249, 244, 238, 0.98) 0%, rgba(244, 237, 229, 0.94) 100%);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 14px 34px rgba(35, 24, 19, 0.06);
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .bw-trust__card::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 2px;
    background: linear-gradient(90deg, #355a6d 0%, #a66a43 100%);
    opacity: 0.55;
  }

  .bw-trust__card:hover {
    transform: translateY(-2px);
    border-color: rgba(53, 90, 109, 0.16);
    box-shadow: 0 24px 54px rgba(35, 24, 19, 0.09);
  }

  .bw-trust__card:focus-visible {
    outline: 2px solid rgba(53, 90, 109, 0.45);
    outline-offset: 4px;
  }

  .bw-trust__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .bw-trust__icon {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    background: linear-gradient(180deg, #2a1d16 0%, #4b3528 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f8f1eb;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .bw-trust__icon svg {
    width: 20px;
    height: 20px;
  }

  .bw-trust__tag {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 11px;
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.58);
    color: #7a5e4d;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .bw-trust__body {
    display: grid;
    gap: 7px;
  }

  .bw-trust__title {
    margin: 0;
    color: #211711;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .bw-trust__copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.7;
  }

  @media (max-width: 1100px) {
    .bw-trust__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .bw-trust {
      padding: 14px 16px 2px;
    }

    .bw-trust__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .bw-trust__card {
      padding: 16px;
      border-radius: 26px;
    }

    .bw-trust__tag {
      display: none;
    }

    .bw-trust__copy {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
      line-height: 1.6;
    }
  }

  @media (max-width: 460px) {
    .bw-trust__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="bw-trust">
  <div class="bw-trust__shell">
    <div class="bw-trust__intro">
      <span class="bw-trust__eyebrow">What helps shoppers decide</span>
      <h2 class="bw-trust__headline">The detail cues customers look for before they commit.</h2>
    </div>

    <div class="bw-trust__grid">
      <a class="bw-trust__card" href="{{ help_center_url }}">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M3 7h13l4 4v6a2 2 0 0 1-2 2h-1"></path>
              <path d="M8 19H6a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2"></path>
              <circle cx="17" cy="19" r="2"></circle>
              <circle cx="9" cy="19" r="2"></circle>
            </svg>
          </div>
          <span class="bw-trust__tag">Fulfilment</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Pan-India delivery</h2>
          <p class="bw-trust__copy">Reliable delivery coordination that keeps larger orders predictable from checkout to arrival.</p>
        </div>
      </a>

      <a class="bw-trust__card" href="{{ contact_url }}">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 5h16v10H9l-5 4V5z"></path>
            </svg>
          </div>
          <span class="bw-trust__tag">Guidance</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Need help choosing?</h2>
          <p class="bw-trust__copy">The team can help narrow the room, format, or finish before you commit.</p>
        </div>
      </a>

      <a class="bw-trust__card" href="{{ bestsellers_url }}">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 3l7 4v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V7l7-4z"></path>
              <path d="M9.5 12.5l1.8 1.8 3.7-3.8"></path>
            </svg>
          </div>
          <span class="bw-trust__tag">Craft</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Trusted quality</h2>
          <p class="bw-trust__copy">Thoughtful finishes, sturdy build decisions, and a look that stays premium in daily use.</p>
        </div>
      </a>

      <a class="bw-trust__card" href="{{ payment_security_url }}">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M7 4h10a3 3 0 0 1 3 3v10l-4-3H7a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3z"></path>
            </svg>
          </div>
          <span class="bw-trust__tag">Payment</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Easy EMI</h2>
          <p class="bw-trust__copy">Flexible payment support that helps bigger purchases feel more manageable.</p>
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Banners",
  "presets": [
    {
      "name": "Trust Banners"
    }
  ]
}
{% endschema %}
