<style>
  .bw-trust {
    padding: 22px 24px 4px;
    background:
      radial-gradient(circle at 50% 0%, rgba(166, 106, 67, 0.08), transparent 44%),
      linear-gradient(180deg, #f3ece4 0%, #faf6f1 100%);
  }

  .bw-trust__shell {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    gap: 14px;
  }

  .bw-trust__intro {
    display: grid;
    gap: 6px;
    max-width: 48ch;
  }

  .bw-trust__eyebrow {
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-trust__headline {
    margin: 0;
    color: #211711;
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .bw-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .bw-trust__card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 16px;
    padding: 20px;
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(247, 240, 233, 0.96) 0%, rgba(243, 235, 226, 0.92) 100%);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 14px 34px rgba(35, 24, 19, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .bw-trust__card::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 2px;
    background: linear-gradient(90deg, #355a6d 0%, #a66a43 100%);
    opacity: 0.55;
  }

  .bw-trust__card:hover {
    transform: translateY(-2px);
    border-color: rgba(53, 90, 109, 0.16);
    box-shadow: 0 24px 54px rgba(35, 24, 19, 0.09);
  }

  .bw-trust__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .bw-trust__icon {
    width: 56px;
    height: 56px;
    border-radius: 20px;
    background: linear-gradient(180deg, #2a1d16 0%, #4b3528 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f8f1eb;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .bw-trust__icon svg {
    width: 22px;
    height: 22px;
  }

  .bw-trust__tag {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.58);
    color: #7a5e4d;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .bw-trust__body {
    display: grid;
    gap: 8px;
  }

  .bw-trust__title {
    margin: 0;
    color: #211711;
    font-size: 19px;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .bw-trust__copy {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.65;
  }

  @media (max-width: 1100px) {
    .bw-trust__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .bw-trust {
      padding: 16px 16px 2px;
    }

    .bw-trust__grid {
      grid-template-columns: 1fr;
    }

    .bw-trust__card {
      padding: 20px;
      border-radius: 24px;
    }
  }
</style>

<section class="bw-trust">
  <div class="bw-trust__shell">
    <div class="bw-trust__intro">
      <span class="bw-trust__eyebrow">Why Bluewud feels dependable</span>
      <h2 class="bw-trust__headline">Clear trust signals before purchase.</h2>
    </div>

    <div class="bw-trust__grid">
      <article class="bw-trust__card">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M3 7h13l4 4v6a2 2 0 0 1-2 2h-1"></path>
              <path d="M8 19H6a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2"></path>
              <circle cx="17" cy="19" r="2"></circle>
              <circle cx="9" cy="19" r="2"></circle>
            </svg>
          </div>
          <span class="bw-trust__tag">Fulfilment</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Pan-India delivery</h2>
          <p class="bw-trust__copy">Reliable delivery coordination with clearer support and fewer doubts.</p>
        </div>
      </article>

      <article class="bw-trust__card">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M9 14l-4-4 4-4"></path>
              <path d="M5 10h8a6 6 0 1 1 0 12h-1"></path>
            </svg>
          </div>
          <span class="bw-trust__tag">Aftercare</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Warranty and support</h2>
          <p class="bw-trust__copy">Helpful policies and responsive assistance after the purchase.</p>
        </div>
      </article>

      <article class="bw-trust__card">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 3l7 4v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V7l7-4z"></path>
              <path d="M9.5 12.5l1.8 1.8 3.7-3.8"></path>
            </svg>
          </div>
          <span class="bw-trust__tag">Craft</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Trusted quality</h2>
          <p class="bw-trust__copy">Thoughtful finishes and dependable craftsmanship for everyday living.</p>
        </div>
      </article>

      <article class="bw-trust__card">
        <div class="bw-trust__card-top">
          <div class="bw-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 18h16"></path>
              <path d="M7 14l3-3 2 2 5-5"></path>
            </svg>
          </div>
          <span class="bw-trust__tag">Discovery</span>
        </div>
        <div class="bw-trust__body">
          <h2 class="bw-trust__title">Easy to explore</h2>
          <p class="bw-trust__copy">Clear categories and cleaner browsing that make choices easier.</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Banners",
  "presets": [
    {
      "name": "Trust Banners"
    }
  ]
}
{% endschema %}
