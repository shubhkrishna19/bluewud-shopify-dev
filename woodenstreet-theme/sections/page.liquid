{% liquid
  assign page_intro = page.content | strip_html | truncatewords: 40
  assign page_eyebrow = 'Bluewud information'

  if page_intro == blank
    assign page_intro = 'Discover everything you need to know about Bluewud, from support and policies to business and contact information.'
  endif

  assign is_help_center = false
  assign is_about_page = false
  assign is_returns_refunds = false
  assign is_offers_page = false
  assign is_contact_page = false
  assign is_business_support_page = false
  assign is_kitchen_page = false
  assign is_kitchen_calculator = false
  assign is_home_interiors_calculator = false
  assign is_wardrobe_page = false
  assign is_wardrobe_calculator = false
  assign is_estimate_page = false

  if page.handle == 'about-us'
    assign is_about_page = true
    assign page_eyebrow = 'Bluewud story'
    assign page_intro = 'Bluewud designs, manufactures, and markets innovative furniture and decor for modern Indian homes, with in-house design, a Noida manufacturing base, and a product story that began with bestseller laptop tables in 2015.'
  endif

  if page.handle == 'help-center'
    assign is_help_center = true
    assign page_eyebrow = 'Bluewud support'
    assign page_intro = 'Browse Bluewud support questions by topic with quick answers for orders, shipping, cancellations, and installation.'
  endif

  if page.handle == 'returns-refunds'
    assign is_returns_refunds = true
    assign page_eyebrow = 'Returns, refunds and replacements'
    assign page_intro = 'A clear view of Bluewud return eligibility, cancellation timing, exchange support, and the product categories that are handled through replacement instead of full return.'
  endif

  if page.handle == 'offers-discount'
    assign is_offers_page = true
    assign page_eyebrow = 'Bluewud offers'
    assign page_intro = 'See current coupon savings, payment offers, and key terms in one place before checkout.'
  endif

  if page.handle == 'contact-us'
    assign is_contact_page = true
    assign page_eyebrow = 'Bluewud contact'
    assign page_intro = 'Reach Bluewud for order assistance, installation support, product questions, or purchase guidance through phone, WhatsApp, email, or the contact form below.'
  endif

  if page.handle == 'buy-in-bulk'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud business desk'
    assign page_intro = 'Use this page for bulk, GST-led, project, hospitality, or office furniture requirements that need a more direct commercial conversation than a normal storefront order.'
  endif

  if page.handle == 'visit-us'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud studio visit'
    assign page_intro = 'Plan a more useful Bluewud visit by bringing the right shortlist, room context, and project questions before you arrive.'
  endif

  if page.handle == 'award-achievment'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud credibility'
    assign page_intro = 'Recognition, milestones, and achievements should strengthen customer trust and connect naturally back into the buying journey.'
  endif

  if page.handle == 'policies'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud policy desk'
    assign page_intro = 'This page should make ordering expectations, support boundaries, and customer confidence easier to understand before purchase.'
  endif

  if page.handle == 'payment-security'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud payment confidence'
    assign page_intro = 'This page should reduce payment hesitation and help larger furniture buyers feel more secure before they complete checkout.'
  endif

  if page.handle == 'privacy-statement' or page.handle == 'privacy-policy'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud privacy'
    assign page_intro = 'A privacy page should be readable, customer-safe, and clear about what Bluewud collects, why it matters, and where support steps in when the customer wants clarification.'
  endif

  if page.handle == 'installation-cancellation' or page.handle == 'installation-cancellation-policy'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud installation and cancellation'
    assign page_intro = 'This page should explain assembly support, visit expectations, and cancellation timing in a way that reduces confusion before larger furniture purchases.'
  endif

  if page.handle == 'terms-of-use'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud terms'
    assign page_intro = 'A cleaner terms page should stay readable, structured, and connected to real help paths when customers need practical clarification.'
  endif

  if page.handle == 'terms-of-service'
    assign is_business_support_page = true
    assign page_eyebrow = 'Bluewud service terms'
    assign page_intro = 'Service terms should feel structured and readable, while still routing customers back to help quickly when their question is practical rather than legal.'
  endif

  if page.handle == 'modular-kitchen-designs'
    assign is_kitchen_page = true
    assign page_eyebrow = 'Bluewud kitchen studio'
    assign page_intro = 'Explore Bluewud modular kitchen planning through layout-led guidance, finish direction, workflow decisions, and estimate-ready paths for modern Indian homes.'
  endif

  if page.handle == 'l-shape-modular-kitchen-design'
    assign is_kitchen_page = true
    assign page_eyebrow = 'L-shape kitchen planning'
    assign page_intro = 'One of the most versatile kitchen formats for homes that need efficient movement, cleaner zoning, and practical countertop continuity.'
  endif

  if page.handle == 'u-shape-modular-kitchen-design'
    assign is_kitchen_page = true
    assign page_eyebrow = 'U-shape kitchen planning'
    assign page_intro = 'A stronger option when you want more storage, deeper work triangles, and a kitchen that feels serious about utility.'
  endif

  if page.handle == 'parallel-modular-kitchen-design'
    assign is_kitchen_page = true
    assign page_eyebrow = 'Parallel kitchen planning'
    assign page_intro = 'A practical format for tighter layouts where opposite counters help separate prep, cooking, and utility with better efficiency.'
  endif

  if page.handle == 'straight-modular-kitchen'
    assign is_kitchen_page = true
    assign page_eyebrow = 'Straight kitchen planning'
    assign page_intro = 'A compact linear kitchen format that works best when space is restricted but daily function still needs to feel composed and premium.'
  endif

  if page.handle == 'kitchen-island-design'
    assign is_kitchen_page = true
    assign page_eyebrow = 'Kitchen island planning'
    assign page_intro = 'An island kitchen is about presence, prep space, and circulation, and works best when room dimensions support generous movement around the core.'
  endif

  if page.handle == 'modular-kitchen-cost-calculator'
    assign is_kitchen_calculator = true
    assign page_eyebrow = 'Kitchen price planning'
    assign page_intro = 'Use this directional modular kitchen calculator to shortlist layout, finish, and hardware choices before getting a refined Bluewud estimate.'
  endif

  if page.handle == 'home-interiors-cost-calculator'
    assign is_home_interiors_calculator = true
    assign page_eyebrow = 'Home interiors planning'
    assign page_intro = 'Build a first interiors brief by selecting the rooms, scope, and furnishing priorities you want Bluewud to help plan.'
  endif

  if page.handle == 'modular-wardrobe-designs'
    assign is_wardrobe_page = true
    assign page_eyebrow = 'Bluewud wardrobe studio'
    assign page_intro = 'Explore Bluewud wardrobe planning through format-led guidance, material decisions, storage ideas, and estimate-ready pathways for modern Indian bedrooms.'
  endif

  if page.handle == 'sliding-wardrobe-designs'
    assign is_wardrobe_page = true
    assign page_eyebrow = 'Sliding wardrobe planning'
    assign page_intro = 'A sharper direction for compact bedrooms and contemporary master suites where door swing space is limited but storage still needs to feel premium.'
  endif

  if page.handle == 'hinged-wardrobes'
    assign is_wardrobe_page = true
    assign page_eyebrow = 'Hinged wardrobe planning'
    assign page_intro = 'Classic full-access shutters, strong internal visibility, and practical daily storage for bedrooms that have enough front clearance.'
  endif

  if page.handle == 'walk-in-wardrobes'
    assign is_wardrobe_page = true
    assign page_eyebrow = 'Walk-in wardrobe planning'
    assign page_intro = 'A more luxurious storage format for larger bedrooms where organization, dressing, and interior presence need to work together.'
  endif

  if page.handle == 'modular-wardrobe-cost-calculator'
    assign is_wardrobe_calculator = true
    assign page_eyebrow = 'Wardrobe price planning'
    assign page_intro = 'Use this directional wardrobe calculator to shortlist format, size, and finish choices before speaking with the Bluewud team for a more accurate estimate.'
  endif

  if page.handle == 'get-free-estimate' or page.handle == 'free-estimate'
    assign is_estimate_page = true
    assign page_eyebrow = 'Bluewud estimate desk'
    assign page_intro = 'Share your project details with the Bluewud team so we can help scope budget, format, finishes, and the best next planning step for your home.'
  endif

  assign page_content_class = 'bw-page__content'

  if is_help_center
    assign page_content_class = page_content_class | append: ' bw-page__content--help-center'
  endif

  if is_about_page
    assign page_content_class = page_content_class | append: ' bw-page__content--about'
  endif

  if is_offers_page
    assign page_content_class = page_content_class | append: ' bw-page__content--offers'
  endif

  if is_returns_refunds
    assign page_content_class = page_content_class | append: ' bw-page__content--returns'
  endif

  if is_contact_page
    assign page_content_class = page_content_class | append: ' bw-page__content--contact'
  endif

  if is_business_support_page
    assign page_content_class = page_content_class | append: ' bw-page__content--contact'
  endif

  if is_kitchen_page
    assign page_content_class = page_content_class | append: ' bw-page__content--wardrobe'
  endif

  if is_kitchen_calculator
    assign page_content_class = page_content_class | append: ' bw-page__content--wardrobe'
  endif

  if is_home_interiors_calculator
    assign page_content_class = page_content_class | append: ' bw-page__content--wardrobe'
  endif

  if is_wardrobe_page
    assign page_content_class = page_content_class | append: ' bw-page__content--wardrobe'
  endif

  if is_wardrobe_calculator
    assign page_content_class = page_content_class | append: ' bw-page__content--wardrobe'
  endif

  if is_estimate_page
    assign page_content_class = page_content_class | append: ' bw-page__content--contact'
  endif
%}

<style>
  .bw-page {
    background:
      radial-gradient(circle at top left, rgba(166, 106, 67, 0.1), transparent 30%),
      linear-gradient(180deg, #f8f2ec 0%, #faf6f1 100%);
    padding: 24px 24px 72px;
  }

  .bw-page__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    gap: 24px;
  }

  .bw-page__hero,
  .bw-page__content,
  .bw-page__support {
    border-radius: 32px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-page__hero {
    padding: 28px 32px;
    display: grid;
    gap: 14px;
  }

  .bw-page__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: #7b6659;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-page__breadcrumbs a {
    color: #7b6659;
    text-decoration: none;
  }

  .bw-page__eyebrow {
    display: inline-block;
    color: #8a684f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-page__title {
    margin: 0;
    color: #201713;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.03;
    letter-spacing: -0.04em;
  }

  .bw-page__intro {
    margin: 0;
    color: #64544a;
    font-size: 16px;
    line-height: 1.8;
    max-width: 64ch;
  }

  .bw-page__content {
    padding: 28px 32px;
  }

  .bw-page__content--help-center {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .bw-page__content--about {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .bw-page__content--offers {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .bw-page__content--returns {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .bw-page__content--contact {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .bw-page__content--wardrobe {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .bw-page__rte {
    color: #4d4038;
    font-size: 16px;
    line-height: 1.9;
  }

  .bw-page__rte h1,
  .bw-page__rte h2,
  .bw-page__rte h3,
  .bw-page__rte h4 {
    color: #201713;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin: 1.6em 0 0.7em;
  }

  .bw-page__rte h1:first-child,
  .bw-page__rte h2:first-child,
  .bw-page__rte h3:first-child,
  .bw-page__rte h4:first-child {
    margin-top: 0;
  }

  .bw-page__rte p,
  .bw-page__rte ul,
  .bw-page__rte ol,
  .bw-page__rte blockquote {
    margin: 0 0 1.1em;
  }

  .bw-page__rte ul,
  .bw-page__rte ol {
    padding-left: 1.3em;
  }

  .bw-page__rte a {
    color: #8a684f;
    text-decoration: none;
  }

  .bw-page__rte table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.4em 0;
    background: #fffdfa;
    border-radius: 18px;
    overflow: hidden;
  }

  .bw-page__rte th,
  .bw-page__rte td {
    padding: 14px 16px;
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
    text-align: left;
  }

  .bw-page__support {
    padding: 24px 28px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .bw-page__support-card {
    padding: 22px;
    border-radius: 22px;
    background: rgba(32, 23, 19, 0.04);
    display: grid;
    gap: 10px;
  }

  .bw-page__support-card h2 {
    margin: 0;
    color: #201713;
    font-size: 18px;
  }

  .bw-page__support-card p {
    margin: 0;
    color: #66554c;
    font-size: 14px;
    line-height: 1.7;
  }

  .bw-page__support-card a {
    color: #8a684f;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    .bw-page {
      padding: 18px 16px 54px;
    }

    .bw-page__hero,
    .bw-page__content,
    .bw-page__support {
      padding: 20px;
      border-radius: 24px;
    }

    .bw-page__support {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="bw-page">
  <div class="bw-page__inner">
    <div class="bw-page__hero">
      <div class="bw-page__breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a>
        <span>/</span>
        <span>{{ page.title }}</span>
      </div>
      <span class="bw-page__eyebrow">{{ page_eyebrow }}</span>
      <h1 class="bw-page__title">{{ page.title }}</h1>
      <p class="bw-page__intro">{{ page_intro }}</p>
    </div>

    <div class="{{ page_content_class }}">
      {% if is_help_center %}
        {% render 'help-center-content' %}
      {% elsif is_about_page %}
        {% render 'about-page-content' %}
      {% elsif is_returns_refunds %}
        {% render 'returns-refunds-content' %}
      {% elsif is_offers_page %}
        {% render 'offers-page-content' %}
      {% elsif is_contact_page %}
        {% render 'contact-page-content' %}
      {% elsif is_business_support_page %}
        {% render 'business-support-page-content' %}
      {% elsif is_kitchen_page %}
        {% render 'modular-kitchen-page-content' %}
      {% elsif is_kitchen_calculator %}
        {% render 'kitchen-calculator-content' %}
      {% elsif is_home_interiors_calculator %}
        {% render 'home-interiors-calculator-content' %}
      {% elsif is_wardrobe_page %}
        {% render 'wardrobe-page-content' %}
      {% elsif is_wardrobe_calculator %}
        {% render 'wardrobe-calculator-content' %}
      {% elsif is_estimate_page %}
        {% render 'estimate-page-content' %}
      {% else %}
        <div class="bw-page__rte">
          {{ page.content }}
        </div>
      {% endif %}
    </div>

    {% unless is_help_center or is_about_page or is_returns_refunds or is_offers_page or is_contact_page or is_business_support_page or is_kitchen_page or is_kitchen_calculator or is_home_interiors_calculator or is_wardrobe_page or is_wardrobe_calculator or is_estimate_page %}
      <div class="bw-page__support">
        <div class="bw-page__support-card">
          <h2>Need direct help?</h2>
          <p>Speak with the Bluewud team for quick assistance with orders, support, or product questions.</p>
          <a href="tel:+918800609609">Call +91-8800-609-609</a>
        </div>

        <div class="bw-page__support-card">
          <h2>Visit the help center</h2>
          <p>Find answers to delivery, returns, payments, and other common questions.</p>
          <a href="/pages/help-center">Open help center</a>
        </div>

        <div class="bw-page__support-card">
          <h2>Business requirement?</h2>
          <p>For office, hospitality, or GST-led purchases, our bulk team is ready to help.</p>
          <a href="/pages/buy-in-bulk">Open Buy In Bulk</a>
        </div>
      </div>
    {% endunless %}
  </div>
</section>

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}
