{% liquid
  assign primary_text = section.settings.primary_text | default: 'Avail flat discount of 10%.'
  assign secondary_text = section.settings.secondary_text | default: 'Use coupon code "BWUD10".'
  assign tertiary_text = section.settings.tertiary_text | default: 'Hurry. Offer valid for limited time!'
  assign cta_label = section.settings.cta_label | default: 'View Offers'
  assign cta_url = section.settings.cta_url
  assign promo_signature = primary_text | downcase
  assign full_signature = primary_text | append: ' ' | append: secondary_text | append: ' ' | append: tertiary_text | downcase

  if full_signature contains '15 years of crafted living' or full_signature contains 'free delivery and easy emi' or full_signature contains 'explore premium furniture for modern indian homes'
    assign primary_text = 'Avail flat discount of 10%.'
    assign secondary_text = 'Use coupon code "BWUD10".'
    assign tertiary_text = 'Hurry. Offer valid for limited time!'
    assign cta_label = 'View Offers'
  endif

  if cta_url == blank
    assign cta_url = '/pages/offers-discount'
  endif
%}

<style>
  .bw-announce {
    background: linear-gradient(90deg, #171311 0%, #2b201a 50%, #171311 100%);
    color: #f6ede6;
    border-bottom: 1px solid rgba(246, 237, 230, 0.08);
  }

  .bw-announce__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 8px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .bw-announce__items {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    min-width: 0;
  }

  .bw-announce__item {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(246, 237, 230, 0.84);
    white-space: nowrap;
  }

  .bw-announce__item--lead {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(246, 237, 230, 0.16);
    font-weight: 700;
  }

  .bw-announce__divider {
    width: 1px;
    height: 14px;
    background: rgba(246, 237, 230, 0.16);
  }

  .bw-announce__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 38px;
    padding: 0 15px;
    border-radius: 999px;
    background: #f8f1eb;
    border: 1px solid #f8f1eb;
    box-shadow: 0 10px 24px rgba(15, 10, 8, 0.12);
    color: #ffffff;
    text-decoration: none;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .bw-announce__link::after {
    content: '\2192';
    font-size: 14px;
  }

  .bw-announce__link:hover {
    transform: translateY(-1px);
    background: #fffaf5;
    border-color: #fffaf5;
  }

  .bw-announce__link,
  .bw-announce__link:visited {
    color: #201713;
  }

  .bw-announce__link::after {
    color: #8a684f;
  }

  @media (max-width: 900px) {
    .bw-announce__inner {
      padding: 10px 16px;
      flex-direction: column;
      align-items: flex-start;
    }

    .bw-announce__items {
      gap: 10px;
      overflow-x: auto;
      flex-wrap: nowrap;
      width: 100%;
      padding-bottom: 2px;
    }

    .bw-announce__items::-webkit-scrollbar {
      display: none;
    }

    .bw-announce__divider {
      display: none;
    }

    .bw-announce__item {
      flex: 0 0 auto;
    }
  }
</style>

<section class="bw-announce">
  <div class="bw-announce__inner">
    <div class="bw-announce__items">
      <span class="bw-announce__item bw-announce__item--lead">{{ primary_text }}</span>
      <span class="bw-announce__divider" aria-hidden="true"></span>
      <span class="bw-announce__item">{{ secondary_text }}</span>
      <span class="bw-announce__divider" aria-hidden="true"></span>
      <span class="bw-announce__item">{{ tertiary_text }}</span>
    </div>
    <a class="bw-announce__link" href="{{ cta_url }}">{{ cta_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary message",
      "default": "Avail flat discount of 10%."
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary message",
      "default": "Use coupon code \"BWUD10\"."
    },
    {
      "type": "text",
      "id": "tertiary_text",
      "label": "Third message",
      "default": "Hurry. Offer valid for limited time!"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "View Offers"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
