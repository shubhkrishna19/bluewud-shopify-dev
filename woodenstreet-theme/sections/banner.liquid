{% comment %} Banner Section - Promotional CTA {% endcomment %}
<style>
.banner-section {
  padding: 40px 30px;
  background: linear-gradient(135deg, #fdfbf7 0%, #f5f0eb 100%);
}
.banner-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  align-items: center;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0,0,0,0.1);
}
.banner-content {
  padding: 60px;
  background: white;
}
.banner-tag {
  display: inline-block;
  background: #c47d4e;
  color: white;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 20px;
}
.banner-content h2 {
  font-size: 36px;
  font-weight: 800;
  color: #1a1a1a;
  margin: 0 0 15px;
  font-family: 'Poppins', sans-serif;
  line-height: 1.2;
}
.banner-content p {
  font-size: 16px;
  color: #666;
  margin: 0 0 25px;
  line-height: 1.7;
}
.banner-btn {
  display: inline-block;
  padding: 14px 32px;
  background: #c47d4e;
  color: white;
  text-decoration: none;
  border-radius: 8px;
  font-weight: 600;
  transition: all 0.3s;
}
.banner-btn:hover {
  background: #a86840;
  transform: translateY(-2px);
}
.banner-image {
  height: 100%;
  min-height: 350px;
  background: url('https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&q=80') center/cover;
}
@media (max-width: 968px) {
  .banner-inner { grid-template-columns: 1fr; }
  .banner-image { min-height: 250px; }
  .banner-content { padding: 40px; }
  .banner-content h2 { font-size: 28px; }
}
@media (max-width: 480px) {
  .banner-content { padding: 30px 20px; }
  .banner-content h2 { font-size: 24px; }
}
</style>

<div class="banner-section">
  <div class="banner-inner">
    <div class="banner-content">
      <span class="banner-tag">Limited Time Offer</span>
      <h2>Transform Your Home with Premium Furniture</h2>
      <p>Get up to 50% off on our exclusive collection. Handcrafted with love, designed for your comfort.</p>
      <a href="/collections/all" class="banner-btn">Shop Now</a>
    </div>
    <div class="banner-image"></div>
  </div>
</div>

{% schema %}
{
  "name": "Banner",
  "presets": [{ "name": "Banner" }]
}
{% endschema %}
