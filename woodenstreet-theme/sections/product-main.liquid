{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image
  assign first_collection = product.collections.first
  assign product_form_id = 'bw-product-form-' | append: section.id
  assign product_subtitle = product.metafields.my_fields.product_subtitle | default: product.description | strip_html | strip_newlines | truncatewords: 28
  assign free_delivery_note = product.metafields.my_fields.free_delivery
  assign emi_from_note = product.metafields.my_fields.emi_from
  assign estimate_shipping_time = product.metafields.my_fields.estimate_shipping_time
%}

<style>
  .bw-product {
    padding: 36px 24px 72px;
    background: linear-gradient(180deg, #faf6f1 0%, #fffdfb 100%);
  }

  .bw-product__shell {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-product__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
    color: #6a5850;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__breadcrumb a {
    color: #6a5850;
    text-decoration: none;
  }

  .bw-product__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: 36px;
    align-items: start;
  }

  .bw-product__gallery {
    position: sticky;
    top: 104px;
    display: grid;
    gap: 14px;
  }

  .bw-product__viewer {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    background: #efe7e0;
    min-height: 640px;
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.1);
  }

  .bw-product__viewer img,
  .bw-product__viewer-empty {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bw-product__viewer img {
    object-fit: cover;
  }

  .bw-product__viewer-empty {
    background:
      radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.22), transparent 24%),
      linear-gradient(145deg, #dfd0c4 0%, #b89682 42%, #6a4b3e 100%);
    display: flex;
    align-items: flex-end;
    padding: 24px;
    box-sizing: border-box;
  }

  .bw-product__viewer-note {
    display: inline-flex;
    align-items: center;
    padding: 12px 14px;
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.9);
    color: #201713;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__badge {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 1;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.86);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(88px, 1fr));
    gap: 10px;
  }

  .bw-product__thumb {
    padding: 0;
    border: 1px solid rgba(45, 33, 27, 0.1);
    border-radius: 18px;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    min-height: 88px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .bw-product__thumb.is-active {
    border-color: #201713;
    transform: translateY(-2px);
  }

  .bw-product__thumb img,
  .bw-product__thumb-empty {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bw-product__thumb img {
    object-fit: cover;
  }

  .bw-product__thumb-empty {
    background: linear-gradient(145deg, #eadfd6 0%, #c7a996 100%);
  }

  .bw-product__panel {
    display: grid;
    gap: 18px;
    padding: 34px;
    border-radius: 32px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-product__eyebrow {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-product__title {
    margin: 0;
    color: #1f1611;
    font-size: clamp(32px, 4.2vw, 48px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }

  .bw-product__subtitle {
    color: #5e4d44;
    font-size: 16px;
    line-height: 1.8;
    margin: 0;
  }

  .bw-product__proofs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .bw-product__proof {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__proof-label {
    display: block;
    color: #201713;
    font-size: 14px;
    font-weight: 700;
  }

  .bw-product__proof-copy {
    display: block;
    margin-top: 4px;
    color: #6b5b53;
    font-size: 12px;
    line-height: 1.5;
  }

  .bw-product__pricing {
    display: grid;
    gap: 10px;
    padding: 18px 0;
    border-top: 1px solid rgba(45, 33, 27, 0.08);
    border-bottom: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .bw-product__price-current {
    color: #201713;
    font-size: 34px;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .bw-product__price-compare {
    color: #8b7a71;
    font-size: 18px;
    text-decoration: line-through;
  }

  .bw-product__price-save {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.08);
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #5e4d44;
    font-size: 14px;
    font-weight: 600;
  }

  .bw-product__status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #3c8c53;
  }

  .bw-product__pricing-note {
    color: #6b5b53;
    font-size: 13px;
    line-height: 1.6;
  }

  .bw-product__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    color: #6b5b53;
    font-size: 13px;
    font-weight: 600;
  }

  .bw-product__meta strong {
    color: #201713;
  }

  .bw-product__option {
    display: grid;
    gap: 12px;
  }

  .bw-product__option-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: #201713;
    font-size: 14px;
    font-weight: 700;
  }

  .bw-product__option-value {
    color: #7a5e4d;
    font-size: 13px;
    font-weight: 600;
  }

  .bw-product__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .bw-product__option-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .bw-product__option-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fff;
    color: #201713;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .bw-product__option-input:checked + .bw-product__option-chip {
    background: #201713;
    color: #fff7f1;
    border-color: #201713;
  }

  .bw-product__purchase {
    display: grid;
    gap: 16px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__quantity {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .bw-product__quantity-label {
    color: #201713;
    font-size: 14px;
    font-weight: 700;
  }

  .bw-product__quantity-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(45, 33, 27, 0.14);
    border-radius: 999px;
    background: #fff;
    overflow: hidden;
  }

  .bw-product__qty-btn,
  .bw-product__qty-input {
    width: 48px;
    height: 46px;
    border: none;
    background: transparent;
    color: #201713;
    font-size: 16px;
    font-weight: 700;
    text-align: center;
  }

  .bw-product__qty-btn {
    cursor: pointer;
  }

  .bw-product__qty-input {
    width: 58px;
    border-left: 1px solid rgba(45, 33, 27, 0.12);
    border-right: 1px solid rgba(45, 33, 27, 0.12);
    appearance: textfield;
  }

  .bw-product__qty-input::-webkit-outer-spin-button,
  .bw-product__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .bw-product__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.8fr);
    gap: 12px;
  }

  .bw-product__atc,
  .bw-product__buy-now {
    min-height: 54px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .bw-product__atc {
    border: none;
    background: #201713;
    color: #fff7f1;
    box-shadow: 0 16px 34px rgba(32, 23, 19, 0.16);
  }

  .bw-product__buy-now {
    border: 1px solid rgba(32, 23, 19, 0.14);
    background: #fff;
    color: #201713;
  }

  .bw-product__atc:disabled,
  .bw-product__buy-now:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    box-shadow: none;
  }

  .bw-product__actions button:not(:disabled):hover {
    transform: translateY(-1px);
  }

  .bw-product__support {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .bw-product__support-card {
    padding: 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__support-card strong {
    display: block;
    color: #201713;
    font-size: 13px;
    font-weight: 700;
  }

  .bw-product__support-card span,
  .bw-product__support-card a {
    display: block;
    margin-top: 6px;
    color: #6a5850;
    font-size: 13px;
    line-height: 1.6;
    text-decoration: none;
  }

  .bw-product__details {
    display: grid;
    gap: 12px;
  }

  .bw-product__details-item {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(45, 33, 27, 0.08);
    overflow: hidden;
  }

  .bw-product__details-item summary {
    padding: 18px 20px;
    cursor: pointer;
    color: #201713;
    font-size: 14px;
    font-weight: 700;
    list-style: none;
  }

  .bw-product__details-item summary::-webkit-details-marker {
    display: none;
  }

  .bw-product__details-body {
    padding: 0 20px 20px;
    color: #5d4c43;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-product__details-body a {
    color: #201713;
    font-weight: 700;
  }

  .bw-product__buy-note {
    color: #6b5b53;
    font-size: 13px;
    line-height: 1.6;
  }

  .bw-product__buy-note a {
    color: #201713;
    font-weight: 700;
  }

  @media (max-width: 1080px) {
    .bw-product__grid {
      grid-template-columns: 1fr;
    }

    .bw-product__gallery {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .bw-product {
      padding: 24px 16px 56px;
    }

    .bw-product__breadcrumb {
      gap: 6px;
      margin-bottom: 16px;
      font-size: 11px;
    }

    .bw-product__viewer {
      min-height: 360px;
      border-radius: 22px;
    }

    .bw-product__badge {
      top: 14px;
      left: 14px;
      padding: 8px 10px;
      font-size: 10px;
    }

    .bw-product__thumbs {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }

    .bw-product__panel {
      padding: 24px 20px;
      border-radius: 24px;
    }

    .bw-product__proofs,
    .bw-product__support,
    .bw-product__actions {
      grid-template-columns: 1fr;
    }

    .bw-product__meta {
      display: grid;
      gap: 8px;
    }

    .bw-product__option-label {
      align-items: flex-start;
      flex-direction: column;
    }

    .bw-product__option-chip {
      min-height: 42px;
      padding: 0 14px;
      font-size: 12px;
    }

    .bw-product__purchase {
      padding: 18px;
      border-radius: 20px;
    }

    .bw-product__quantity {
      align-items: flex-start;
      flex-direction: column;
    }

    .bw-product__quantity-control {
      width: 100%;
      justify-content: space-between;
    }

    .bw-product__qty-btn,
    .bw-product__qty-input {
      width: auto;
      flex: 1 1 0;
    }
  }
</style>

<section class="bw-product" id="bw-product-{{ section.id }}">
  <div class="bw-product__shell">
    <div class="bw-product__breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {% if first_collection %}
        <span>/</span>
        <a href="{{ first_collection.url }}">{{ first_collection.title }}</a>
      {% endif %}
      <span>/</span>
      <span>{{ product.title }}</span>
    </div>

    <div class="bw-product__grid">
      <div class="bw-product__gallery">
        <div class="bw-product__viewer">
          {% if current_variant.compare_at_price > current_variant.price %}
            {% assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price %}
            <div class="bw-product__badge">Save {{ savings }}%</div>
          {% endif %}

          {% if featured_image %}
            <img
              src="{{ featured_image | image_url: width: 1200 }}"
              alt="{{ featured_image.alt | default: product.title | escape }}"
              loading="eager"
              data-product-main-image
            >
          {% else %}
            <div class="bw-product__viewer-empty">
              <span class="bw-product__viewer-note">Bluewud product media appears here</span>
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 0 %}
          <div class="bw-product__thumbs" role="list">
            {% for image in product.images %}
              <button
                class="bw-product__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                data-product-thumb
                data-image-url="{{ image | image_url: width: 1200 }}"
                aria-label="View image {{ forloop.index }}"
              >
                {{ image | image_url: width: 220 | image_tag: loading: 'lazy', widths: '120, 180, 220', sizes: '88px', alt: image.alt | default: product.title }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="bw-product__panel">
        <div class="bw-product__eyebrow">{{ product.vendor | default: 'Bluewud premium selection' }}</div>
        <h1 class="bw-product__title">{{ product.title }}</h1>
        <p class="bw-product__subtitle">
          {% if product_subtitle != blank %}
            {{ product_subtitle }}
          {% else %}
            Thoughtfully designed furniture for modern Indian homes, with clear details, dependable support, and finishes you will love living with.
          {% endif %}
        </p>

        <div class="bw-product__proofs">
          <div class="bw-product__proof">
            <span class="bw-product__proof-label">15+ years</span>
            <span class="bw-product__proof-copy">Crafting furniture for homes across India.</span>
          </div>
          <div class="bw-product__proof">
            <span class="bw-product__proof-label">20L+ customers</span>
            <span class="bw-product__proof-copy">Chosen by families in cities across the country.</span>
          </div>
          <div class="bw-product__proof">
            <span class="bw-product__proof-label">7 year warranty</span>
            <span class="bw-product__proof-copy">Added assurance for long-term everyday use.</span>
          </div>
        </div>

        <div class="bw-product__pricing">
          <div class="bw-product__price-row">
            <span class="bw-product__price-current" data-product-price-current>{{ current_variant.price | money }}</span>
            <span class="bw-product__price-compare" data-product-price-compare{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}>{{ current_variant.compare_at_price | money }}</span>
            <span class="bw-product__price-save" data-product-price-save{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}>
              {% if current_variant.compare_at_price > current_variant.price %}
                Save {{ current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price }}%
              {% endif %}
            </span>
          </div>
          <div class="bw-product__status">
            <span class="bw-product__status-dot" data-product-status-dot></span>
            <span data-product-status-text>{% if current_variant.available %}Available to order{% else %}Currently sold out{% endif %}</span>
          </div>
          <div class="bw-product__pricing-note">
            {% if emi_from_note != blank %}
              {{ emi_from_note }} with secure payment options and Bluewud support before and after purchase.
            {% else %}
              Easy EMI on eligible orders, secure payment options, and Bluewud support before and after purchase.
            {% endif %}
          </div>
        </div>

        <div class="bw-product__meta">
          {% if product.vendor != blank %}
            <span><strong>Brand:</strong> {{ product.vendor }}</span>
          {% endif %}
          {% if product.product_type != blank %}
            <span><strong>Category:</strong> {{ product.product_type }}</span>
          {% endif %}
          <span><strong>Status:</strong> <span data-product-meta-status>{% if current_variant.available %}Ready to order{% else %}Sold out{% endif %}</span></span>
          {% if first_collection %}
            <span><strong>Collection:</strong> {{ first_collection.title }}</span>
          {% endif %}
          {% if free_delivery_note != blank %}
            <span><strong>Delivery:</strong> {{ free_delivery_note }}</span>
          {% endif %}
          {% if estimate_shipping_time != blank %}
            <span><strong>Dispatch:</strong> {{ estimate_shipping_time }} day{% unless estimate_shipping_time == '1' %}s{% endunless %}</span>
          {% endif %}
        </div>

        {% form 'product', product, id: product_form_id, class: 'bw-product__form', data-product-form: '' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

          {% for option in product.options_with_values %}
            <div class="bw-product__option" data-option-index="{{ forloop.index0 }}">
              <div class="bw-product__option-label">
                <span>{{ option.name }}</span>
                <span class="bw-product__option-value" data-option-current>{{ option.selected_value }}</span>
              </div>
              <div class="bw-product__option-values">
                {% for value in option.values %}
                  {% capture option_input_id %}bw-product-{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}{% endcapture %}
                  <label for="{{ option_input_id }}">
                    <input
                      class="bw-product__option-input"
                      id="{{ option_input_id }}"
                      type="radio"
                      name="option-{{ option.position }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}checked{% endif %}
                    >
                    <span class="bw-product__option-chip">{{ value }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <div class="bw-product__purchase">
            <div class="bw-product__quantity">
              <span class="bw-product__quantity-label">Quantity</span>
              <div class="bw-product__quantity-control">
                <button class="bw-product__qty-btn" type="button" data-qty-change="-1">-</button>
                <input class="bw-product__qty-input" type="number" min="1" value="1" name="quantity" data-product-quantity>
                <button class="bw-product__qty-btn" type="button" data-qty-change="1">+</button>
              </div>
            </div>

            <div class="bw-product__actions">
              <button class="bw-product__atc" type="submit" name="add" data-product-atc{% unless current_variant.available %} disabled{% endunless %}>
                {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
              </button>
              <button class="bw-product__buy-now" type="button" data-product-buy-now{% unless current_variant.available %} disabled{% endunless %}>
                Buy now
              </button>
            </div>

            <div class="bw-product__buy-note">
              Need help before you place your order? Explore <a href="/pages/payment-security">payment security</a>, <a href="/pages/returns-refunds">returns</a>, or speak with the <a href="/pages/contact-us">Bluewud team</a>.
            </div>

            {% render 'wooden-delivery-estimator' %}
          </div>
        {% endform %}

        <div class="bw-product__support">
          <div class="bw-product__support-card">
            <strong>Payment confidence</strong>
            <a href="/pages/payment-security">Secure payment options and helpful checkout guidance.</a>
          </div>
          <div class="bw-product__support-card">
            <strong>Need project pricing?</strong>
            <a href="/pages/buy-in-bulk">Bulk purchase support for larger furnishing requirements.</a>
          </div>
          <div class="bw-product__support-card">
            <strong>Talk to Bluewud</strong>
            <a href="/pages/contact-us">Talk to the Bluewud team for product or order questions.</a>
          </div>
        </div>

        <div class="bw-product__details">
          {% if product.description != blank %}
            <details class="bw-product__details-item" open>
              <summary>Description</summary>
              <div class="bw-product__details-body">
                {{ product.description }}
              </div>
            </details>
          {% endif %}

          <details class="bw-product__details-item">
            <summary>Delivery, warranty, and support</summary>
            <div class="bw-product__details-body">
              {% if free_delivery_note != blank %}
                <p>{{ free_delivery_note }}</p>
              {% endif %}
              {% if estimate_shipping_time != blank %}
                <p>Estimated dispatch begins in approximately {{ estimate_shipping_time }} day{% unless estimate_shipping_time == '1' %}s{% endunless %} after order confirmation.</p>
              {% endif %}
              <p>For more information, you can <a href="/pages/visit-us">visit us</a>, explore the <a href="/pages/help-center">help center</a>, or review <a href="/pages/returns-refunds">returns and refunds</a>.</p>
            </div>
          </details>

          <details class="bw-product__details-item">
            <summary>Payment, EMI, and order confidence</summary>
            <div class="bw-product__details-body">
              <p>Bluewud supports secure payments, selected EMI options, and guided assistance for buyers who want clarity before placing an order. You can review <a href="/pages/payment-security">payment and security</a> details or reach out to the <a href="/pages/contact-us">Bluewud team</a>.</p>
            </div>
          </details>

          <details class="bw-product__details-item">
            <summary>Bulk and business orders</summary>
            <div class="bw-product__details-body">
              <p>For office, hospitality, or larger furnishing requirements, Bluewud also supports project and volume enquiries through the <a href="/pages/buy-in-bulk">Buy In Bulk</a> page.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" data-product-variants>
    {{ product.variants | json }}
  </script>
</section>

<script>
  (function () {
    var section = document.getElementById('bw-product-{{ section.id }}');
    if (!section) return;

    var variantsNode = section.querySelector('[data-product-variants]');
    var variants = variantsNode ? JSON.parse(variantsNode.textContent) : [];
    var optionGroups = Array.prototype.slice.call(section.querySelectorAll('[data-option-index]'));
    var priceCurrent = section.querySelector('[data-product-price-current]');
    var priceCompare = section.querySelector('[data-product-price-compare]');
    var priceSave = section.querySelector('[data-product-price-save]');
    var statusText = section.querySelector('[data-product-status-text]');
    var statusDot = section.querySelector('[data-product-status-dot]');
    var metaStatus = section.querySelector('[data-product-meta-status]');
    var variantInput = section.querySelector('[data-product-variant-id]');
    var addToCartButton = section.querySelector('[data-product-atc]');
    var buyNowButton = section.querySelector('[data-product-buy-now]');
    var quantityInput = section.querySelector('[data-product-quantity]');
    var mainImage = section.querySelector('[data-product-main-image]');
    var moneyFormat = {{ shop.money_format | json }};

    function formatMoney(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, moneyFormat);
      }

      var amount = (cents / 100).toFixed(2);
      return 'Rs. ' + amount;
    }

    function getSelectedOptions() {
      return optionGroups.map(function (group) {
        var checked = group.querySelector('input:checked');
        return checked ? checked.value : null;
      });
    }

    function findVariant() {
      var selected = getSelectedOptions();
      return variants.find(function (variant) {
        return selected.every(function (value, index) {
          return variant.options[index] === value;
        });
      });
    }

    function updateVariantUI(variant) {
      if (!variant) {
        addToCartButton.disabled = true;
        buyNowButton.disabled = true;
        addToCartButton.textContent = 'Unavailable';
        statusText.textContent = 'Currently unavailable';
        if (metaStatus) metaStatus.textContent = 'Unavailable';
        statusDot.style.background = '#b74f4a';
        return;
      }

      variantInput.value = variant.id;
      priceCurrent.textContent = formatMoney(variant.price);

      if (variant.compare_at_price && variant.compare_at_price > variant.price) {
        var savings = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
        priceCompare.hidden = false;
        priceSave.hidden = false;
        priceCompare.textContent = formatMoney(variant.compare_at_price);
        priceSave.textContent = 'Save ' + savings + '%';
      } else {
        priceCompare.hidden = true;
        priceSave.hidden = true;
      }

      addToCartButton.disabled = !variant.available;
      buyNowButton.disabled = !variant.available;
      addToCartButton.textContent = variant.available ? 'Add to cart' : 'Sold out';
      statusText.textContent = variant.available ? 'Available to order' : 'Currently sold out';
      if (metaStatus) metaStatus.textContent = variant.available ? 'Ready to order' : 'Sold out';
      statusDot.style.background = variant.available ? '#3c8c53' : '#b74f4a';
    }

    optionGroups.forEach(function (group) {
      var currentValue = group.querySelector('[data-option-current]');
      var radios = group.querySelectorAll('input[type="radio"]');

      radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
          if (currentValue) currentValue.textContent = radio.value;
          updateVariantUI(findVariant());
        });
      });
    });

    section.querySelectorAll('[data-qty-change]').forEach(function (button) {
      button.addEventListener('click', function () {
        var delta = parseInt(button.getAttribute('data-qty-change'), 10);
        var currentValue = parseInt(quantityInput.value || '1', 10);
        var nextValue = currentValue + delta;
        quantityInput.value = nextValue < 1 ? 1 : nextValue;
      });
    });

    section.querySelectorAll('[data-product-thumb]').forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var imageUrl = thumb.getAttribute('data-image-url');
        if (mainImage && imageUrl) {
          mainImage.setAttribute('src', imageUrl);
        }

        section.querySelectorAll('[data-product-thumb]').forEach(function (item) {
          item.classList.remove('is-active');
        });
        thumb.classList.add('is-active');
      });
    });

    if (buyNowButton) {
      buyNowButton.addEventListener('click', function () {
        var variant = findVariant();
        if (!variant || !variant.available) return;

        var formData = new FormData();
        formData.append('id', variant.id);
        formData.append('quantity', quantityInput.value || '1');

        buyNowButton.disabled = true;
        buyNowButton.textContent = 'Redirecting';

        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json'
          }
        })
          .then(function (response) {
            if (!response.ok) throw new Error('Unable to add variant');
            return response.json();
          })
          .then(function () {
            window.location.assign('/checkout');
          })
          .catch(function () {
            buyNowButton.disabled = false;
            buyNowButton.textContent = 'Buy now';
          });
      });
    }

    updateVariantUI(findVariant());
  })();
</script>

{% schema %}
{
  "name": "Product Page",
  "presets": [
    {
      "name": "Product Page"
    }
  ]
}
{% endschema %}
