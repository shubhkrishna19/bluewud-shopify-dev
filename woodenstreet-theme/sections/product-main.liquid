  .bw-product__option-current {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .bw-product__option-values {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .bw-product__option-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .bw-product__option-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(45, 33, 27, 0.12);
    background: #fff;
    color: #201713;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
