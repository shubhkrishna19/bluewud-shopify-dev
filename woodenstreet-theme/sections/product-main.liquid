  .bw-product__option-input:checked + .bw-product__option-chip {
    background: #201713;
    color: #fff7f1;
    border-color: #201713;
  }

  .bw-product__purchase {
    display: grid;
    gap: 16px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__quantity {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .bw-product__quantity-label {
    color: #201713;
    font-size: 14px;
    font-weight: 700;
  }

  .bw-product__quantity-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(45, 33, 27, 0.14);
    border-radius: 999px;
    background: #fff;
    overflow: hidden;
  }

  .bw-product__qty-btn,
  .bw-product__qty-input {
    width: 48px;
    height: 46px;
    border: none;
    background: transparent;
    color: #201713;
    font-size: 16px;
    font-weight: 700;
    text-align: center;
  }

  .bw-product__qty-btn {
    cursor: pointer;
  }

  .bw-product__qty-input {
    width: 58px;
    border-left: 1px solid rgba(45, 33, 27, 0.12);
    border-right: 1px solid rgba(45, 33, 27, 0.12);
    appearance: textfield;
  }

  .bw-product__qty-input::-webkit-outer-spin-button,
  .bw-product__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .bw-product__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.8fr);
    gap: 12px;
  }

  .bw-product__atc,
  .bw-product__buy-now {
    min-height: 54px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .bw-product__atc {
    border: none;
    background: #201713;
    color: #fff7f1;
    box-shadow: 0 16px 34px rgba(32, 23, 19, 0.16);
  }

  .bw-product__buy-now {
    border: 1px solid rgba(32, 23, 19, 0.14);
    background: #fff;
    color: #201713;
  }

  .bw-product__atc:disabled,
  .bw-product__buy-now:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    box-shadow: none;
  }

  .bw-product__actions button:not(:disabled):hover {
    transform: translateY(-1px);
  }

  .bw-product__support {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: -6px;
  }

  .bw-product__support-card {
    padding: 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__support-card strong {
    display: block;
    color: #201713;
    font-size: 13px;
    font-weight: 700;
  }

  .bw-product__support-card span,
  .bw-product__support-card a {
    display: block;
    margin-top: 6px;
    color: #6a5850;
    font-size: 13px;
    line-height: 1.6;
    text-decoration: none;
  }

  .bw-product__details {
    display: grid;
    gap: 12px;
  }

  .bw-product__details-item {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(45, 33, 27, 0.08);
    overflow: hidden;
  }

  .bw-product__details-item summary {
    padding: 18px 20px;
    cursor: pointer;
    color: #201713;
    font-size: 14px;
    font-weight: 700;
    list-style: none;
  }

  .bw-product__details-item summary::-webkit-details-marker {
    display: none;
  }

  .bw-product__details-body {
    padding: 0 20px 20px;
    color: #5d4c43;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-product__details-body a {
    color: #201713;
    font-weight: 700;
  }

  .bw-product__buy-note {
    color: #6b5b53;
    font-size: 13px;
    line-height: 1.6;
  }

  .bw-product__buy-note a {
    color: #201713;
    font-weight: 700;
  }

  .bw-product__rating-fallback {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 10px;
    min-height: 38px;
    color: inherit;
    text-decoration: none;
  }

  .bw-product__rating-stars {
    color: var(--bw-brand-warm);
    font-size: 14px;
    letter-spacing: 0.08em;
  }

  .bw-product__rating-text {
    color: #6b5b53;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .bw-product__reviews {
    margin-top: 28px;
    padding: 28px;
    border-radius: 32px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.06);
  }

  .bw-product__reviews-header {
    display: grid;
    gap: 10px;
    margin-bottom: 18px;
  }

  .bw-product__reviews-eyebrow {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-product__reviews-title {
    margin: 0;
    color: #1f1611;
    font-size: clamp(26px, 3vw, 34px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .bw-product__reviews-copy {
    margin: 0;
    color: #5e4d44;
    font-size: 15px;
    line-height: 1.8;
    max-width: 66ch;
  }

  .bw-product__reviews .jdgm-widget.jdgm-review-widget {
    padding: 20px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__related {
    margin-top: 28px;
    display: grid;
    gap: 18px;
    padding: 26px;
    border-radius: 32px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.05);
  }

  .bw-product__related-header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 14px;
  }

  .bw-product__related-copy {
    display: grid;
    gap: 8px;
    max-width: 64ch;
  }

  .bw-product__related-eyebrow {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-product__related-title {
    margin: 0;
    color: #1f1611;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .bw-product__related-text {
    margin: 0;
    color: #5e4d44;
    font-size: 15px;
    line-height: 1.8;
  }

  .bw-product__related-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bw-product__related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .bw-product__related-card {
    display: grid;
    gap: 10px;
    padding: 12px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(45, 33, 27, 0.08);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .bw-product__related-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 42px rgba(35, 24, 19, 0.08);
  }

  .bw-product__related-image {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    min-height: 220px;
    background:
      radial-gradient(circle at 20% 16%, rgba(255, 255, 255, 0.22), transparent 24%),
      linear-gradient(145deg, #dfd0c4 0%, #bb9b86 42%, #6e5043 100%);
  }

  .bw-product__related-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .bw-product__related-meta {
    display: grid;
    gap: 6px;
  }

  .bw-product__related-kicker {
    color: #7a5e4d;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-product__related-name {
    margin: 0;
    color: #201713;
    font-size: 17px;
    line-height: 1.24;
  }

  .bw-product__related-subtitle {
    color: #66554c;
    font-size: 12px;
    line-height: 1.55;
  }

  .bw-product__related-price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .bw-product__related-price {
    color: #201713;
    font-size: 18px;
    font-weight: 800;
  }

  .bw-product__related-compare {
    color: #8b7a71;
    font-size: 13px;
    text-decoration: line-through;
  }

  .bw-product__related-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    background: #201713;
    color: #fff7f1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
  }

  @media (max-width: 1080px) {
    .bw-product__grid {
      grid-template-columns: 1fr;
    }

    .bw-product__gallery {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .bw-product {
      padding: 20px 16px 50px;
    }

    .bw-product__breadcrumb {
      gap: 6px;
      margin-bottom: 14px;
      font-size: 11px;
    }

    .bw-product__viewer {
      min-height: 320px;
      border-radius: 22px;
    }

    .bw-product__badge {
      top: 14px;
      left: 14px;
      padding: 8px 10px;
      font-size: 10px;
    }

    .bw-product__thumbs {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 68px;
      overflow-x: auto;
      gap: 8px;
      padding-bottom: 4px;
      scrollbar-width: none;
      scroll-snap-type: x proximity;
    }

    .bw-product__thumbs::-webkit-scrollbar {
      display: none;
    }

    .bw-product__thumb {
      min-height: 76px;
      scroll-snap-align: start;
    }

    .bw-product__panel {
      padding: 20px 16px;
      border-radius: 22px;
    }

    .bw-product__proofs,
    .bw-product__support,
    .bw-product__actions {
      grid-template-columns: 1fr;
    }

    .bw-product__proof,
    .bw-product__support-card {
      padding: 12px 14px;
      border-radius: 16px;
    }

    .bw-product__proof-label {
      font-size: 13px;
    }

    .bw-product__proof-copy,
    .bw-product__support-card span,
    .bw-product__support-card a,
    .bw-product__pricing-note,
    .bw-product__buy-note {
      font-size: 12px;
      line-height: 1.55;
    }

    .bw-product__meta {
      display: grid;
      gap: 8px;
    }

    .bw-product__option {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .bw-product__option-label {
      min-height: auto;
      font-size: 14px;
    }

    .bw-product__option-current {
      font-size: 10px;
    }

    .bw-product__option-values {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    .bw-product__option-values::-webkit-scrollbar {
      display: none;
    }

    .bw-product__option-chip {
      min-height: 40px;
      padding: 0 12px;
      font-size: 11px;
      white-space: nowrap;
    }

    .bw-product__form {
      gap: 16px;
    }

    .bw-product__purchase {
      padding: 16px;
      border-radius: 18px;
    }

    .bw-product__actions {
      gap: 8px;
    }

    .bw-product__buy-now {
      min-height: 44px;
      font-size: 11px;
      letter-spacing: 0.06em;
    }

    .bw-product__reviews {
      margin-top: 20px;
      padding: 18px 16px;
      border-radius: 22px;
    }

    .bw-product__reviews .jdgm-widget.jdgm-review-widget {
      padding: 14px;
      border-radius: 18px;
    }

    .bw-product__related {
      margin-top: 20px;
      padding: 18px 16px;
      border-radius: 22px;
    }

    .bw-product__related-grid {
      grid-template-columns: 1fr;
    }

    .bw-product__related-image {
      min-height: 210px;
    }

    .bw-product__quantity {
      align-items: flex-start;
      flex-direction: column;
    }

    .bw-product__quantity-control {
      width: 100%;
      justify-content: space-between;
    }

    .bw-product__qty-btn,
    .bw-product__qty-input {
      width: auto;
      flex: 1 1 0;
    }

    .bw-product__trustline {
      display: none;
    }

    .bw-product__support {
      gap: 8px;
    }

    .bw-product__related-title {
      font-size: 22px;
    }

    .bw-product__related-text {
      font-size: 13px;
      line-height: 1.65;
    }
  }
</style>

<section class="bw-product" id="bw-product-{{ section.id }}">
  <div class="bw-product__shell">
    <div class="bw-product__breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {% if first_collection %}
        <span>/</span>
        <a href="{{ first_collection.url }}">{{ first_collection.title }}</a>
      {% endif %}
      <span>/</span>
      <span>{{ product.title }}</span>
    </div>

    <div class="bw-product__grid">
      <div class="bw-product__gallery">
        <div class="bw-product__viewer">
          {% if current_variant.compare_at_price > current_variant.price %}
            {% assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price %}
            <div class="bw-product__badge">Save {{ savings }}%</div>
          {% endif %}

          {% if featured_image %}
            <img
              src="{{ featured_image | image_url: width: 1200 }}"
              srcset="{{ featured_image | image_url: width: 480 }} 480w, {{ featured_image | image_url: width: 720 }} 720w, {{ featured_image | image_url: width: 960 }} 960w, {{ featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 1024px) 100vw, 50vw"
              alt="{{ featured_image.alt | default: product.title | escape }}"
              loading="eager"
              data-product-main-image
              width="{{ featured_image.width | default: 1200 }}"
              height="{{ featured_image.height | default: 1200 }}"
            >
          {% else %}
            <div class="bw-product__viewer-empty">
              <span class="bw-product__viewer-note">Bluewud product media appears here</span>
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 0 %}
          <div class="bw-product__thumbs" role="list">
            {% for image in product.images %}
              <button
                class="bw-product__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                data-product-thumb
                data-image-url="{{ image | image_url: width: 1200 }}"
                data-image-srcset="{{ image | image_url: width: 480 }} 480w, {{ image | image_url: width: 720 }} 720w, {{ image | image_url: width: 960 }} 960w, {{ image | image_url: width: 1200 }} 1200w"
                data-image-sizes="(max-width: 1024px) 100vw, 50vw"
                data-image-alt="{{ image.alt | default: product.title | escape }}"
                data-image-width="{{ image.width | default: 1200 }}"
                data-image-height="{{ image.height | default: 1200 }}"
                aria-label="View image {{ forloop.index }}"
              >
                {{ image | image_url: width: 220 | image_tag: loading: 'lazy', widths: '120, 180, 220', sizes: '88px', alt: image.alt | default: product.title }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="bw-product__panel">
        <div class="bw-product__eyebrow">{{ product.vendor | default: 'Bluewud premium selection' }}</div>
        <h1 class="bw-product__title">{{ product.title }}</h1>
        <p class="bw-product__subtitle">
          {% if product_subtitle != blank %}
            {{ product_subtitle }}
          {% else %}
            Thoughtfully designed furniture for modern Indian homes, with clear details, dependable support, and finishes made to suit everyday living.
          {% endif %}
        </p>
        <div class="bw-product__rating">
          {% if show_rating_fallback %}
            <a class="bw-product__rating-fallback" href="/pages/reviews" aria-label="Bluewud brand rating {{ brand_reviews_rating }} out of 5 across {{ brand_reviews_count }} customer reviews">
              <span class="bw-product__rating-stars" aria-hidden="true">★★★★★</span>
              <span class="bw-product__rating-text">Bluewud brand rating · {{ brand_reviews_rating }}/5 across {{ brand_reviews_count }} reviews</span>
            </a>
          {% else %}
            {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', concierge_install: true, product: product %}
          {% endif %}
        </div>

        <div class="bw-product__proofs">
          <div class="bw-product__proof">
            <span class="bw-product__proof-label">15+ years</span>
            <span class="bw-product__proof-copy">Crafting furniture for homes across India.</span>
          </div>
          <div class="bw-product__proof">
            <span class="bw-product__proof-label">7 year warranty</span>
            <span class="bw-product__proof-copy">Added assurance for long-term everyday use.</span>
          </div>
        </div>

        <div class="bw-product__pricing">
          <div class="bw-product__price-row">
            <span class="bw-product__price-current" data-product-price-current>{{ current_variant.price | money }}</span>
            <span class="bw-product__price-compare" data-product-price-compare{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}>{{ current_variant.compare_at_price | money }}</span>
            <span class="bw-product__price-save" data-product-price-save{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}>
              {% if current_variant.compare_at_price > current_variant.price %}
                Save {{ current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price }}%
              {% endif %}
            </span>
          </div>
          <div class="bw-product__status">
            <span class="bw-product__status-dot" data-product-status-dot></span>
            <span data-product-status-text>{% if current_variant.available %}Available to order{% else %}Currently sold out{% endif %}</span>
          </div>
          <div class="bw-product__pricing-note">
            {% if emi_from_note != blank %}
              {{ emi_from_note }} with secure payment options and Bluewud support before and after purchase.
            {% else %}
              Easy EMI on eligible orders, secure payment options, and Bluewud support before and after purchase.
            {% endif %}
          </div>
          <div class="bw-product__trustline" aria-label="Product trust cues">
            <span class="bw-product__trustchip">{{ brand_reviews_count }}+ reviews</span>
            <span class="bw-product__trustchip">Easy EMI</span>
            <span class="bw-product__trustchip">Secure checkout</span>
          </div>
        </div>

        {% if free_delivery_note != blank %}
          <div class="bw-product__meta">
            <span><strong>Delivery:</strong> {{ free_delivery_note }}</span>
          </div>
        {% endif %}

        {% form 'product', product, id: product_form_id, class: 'bw-product__form', data-product-form: '' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

          {% for option in product.options_with_values %}
            {% liquid
              assign is_default_title_option = false

              if option.values.size == 1 and option.values.first == 'Default Title'
                assign is_default_title_option = true
              endif
            %}
            {% unless is_default_title_option %}
              <div class="bw-product__option" data-option-index="{{ forloop.index0 }}">
                <div class="bw-product__option-label"><span>{{ option.name }}</span><span class="bw-product__option-current" data-option-current>{{ option.selected_value }}</span></div>
                <div class="bw-product__option-values">
                  {% for value in option.values %}
                    {% capture option_input_id %}bw-product-{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}{% endcapture %}
                    <label for="{{ option_input_id }}">
                      <input
                        class="bw-product__option-input"
                        id="{{ option_input_id }}"
                        type="radio"
                        name="option-{{ option.position }}"
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}checked{% endif %}
                      >
                      <span class="bw-product__option-chip">{{ value }}</span>
                    </label>
                  {% endfor %}
                </div>
              </div>
            {% endunless %}
          {% endfor %}

          <div class="bw-product__purchase" data-product-form-area>
            <div class="bw-product__quantity">
              <span class="bw-product__quantity-label">Quantity</span>
              <div class="bw-product__quantity-control">
                <button class="bw-product__qty-btn" type="button" data-qty-change="-1">-</button>
                <input class="bw-product__qty-input" type="number" min="1" value="1" name="quantity" data-product-quantity>
                <button class="bw-product__qty-btn" type="button" data-qty-change="1">+</button>
              </div>
            </div>

            <div class="bw-product__actions">
              <button class="bw-product__atc" type="submit" name="add" data-product-atc{% unless current_variant.available %} disabled{% endunless %}>
                {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
              </button>
              <button class="bw-product__buy-now" type="button" data-product-buy-now{% unless current_variant.available %} disabled{% endunless %}>
                Buy now
              </button>
            </div>

            <div class="bw-product__buy-note">
              Need help before you place your order? Explore <a href="/pages/payment-security">payment security</a>, <a href="/pages/returns-refunds">returns</a>, or speak with the <a href="/pages/contact-us">Bluewud team</a>.
            </div>

            {% render 'wooden-delivery-estimator' %}
          </div>
        {% endform %}

        <div class="bw-product__support">
        <div class="bw-product__support-card">
          <strong>Payment confidence</strong>
          <a href="/pages/payment-security">Secure payment options and clear checkout guidance.</a>
        </div>
        <div class="bw-product__support-card">
          <strong>Need project pricing?</strong>
          <a href="/pages/buy-in-bulk">Project and bulk purchase support for larger furnishing requirements.</a>
        </div>
        <div class="bw-product__support-card">
          <strong>Talk to Bluewud</strong>
          <a href="/pages/contact-us">Ask the Bluewud team about fit, finish, delivery, or orders.</a>
        </div>
        </div>

        <div class="bw-product__details">
          {% if product.description != blank %}
            <details class="bw-product__details-item" open>
              <summary>Description</summary>
              <div class="bw-product__details-body">
                {{ product.description }}
              </div>
            </details>
          {% endif %}

          <details class="bw-product__details-item">
            <summary>Delivery, warranty, and support</summary>
            <div class="bw-product__details-body">
              {% if free_delivery_note != blank %}
                <p>{{ free_delivery_note }}</p>
              {% endif %}
              {% if estimate_shipping_time != blank %}
                <p>Estimated dispatch begins in approximately {{ estimate_shipping_time }} day{% unless estimate_shipping_time == '1' %}s{% endunless %} after order confirmation.</p>
              {% endif %}
              <p>For more information, you can <a href="/pages/visit-us">visit us</a>, explore the <a href="/pages/help-center">help center</a>, or review <a href="/pages/returns-refunds">returns and refunds</a> before checking out.</p>
            </div>
          </details>

          <details class="bw-product__details-item">
            <summary>Payment, EMI, and order confidence</summary>
            <div class="bw-product__details-body">
              <p>Bluewud supports secure payments, selected EMI options, and guided assistance for buyers who want clarity before ordering. You can review <a href="/pages/payment-security">payment and security</a> details or reach out to the <a href="/pages/contact-us">Bluewud team</a> for help.</p>
            </div>
          </details>

          <details class="bw-product__details-item">
            <summary>Bulk and business orders</summary>
            <div class="bw-product__details-body">
              <p>For office, hospitality, or larger furnishing requirements, Bluewud also supports project and volume enquiries through the <a href="/pages/buy-in-bulk">Buy In Bulk</a> page.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <div class="bw-product__reviews">
      <div class="bw-product__reviews-header">
        <span class="bw-product__reviews-eyebrow">Customer reviews</span>
        <h2 class="bw-product__reviews-title">What buyers are saying before they decide.</h2>
        <p class="bw-product__reviews-copy">Live product reviews help shoppers understand finish, delivery, assembly, and everyday usability before they buy.</p>
      </div>
      {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget', concierge_install: true, product: product %}
    </div>

    {% if related_products_count > 0 and recommendation_collection %}
      <div class="bw-product__related">
        <div class="bw-product__related-header">
          <div class="bw-product__related-copy">
            <span class="bw-product__related-eyebrow">You may also like</span>
            <h2 class="bw-product__related-title">Pieces that pair well with this one.</h2>
            <p class="bw-product__related-text">A tighter set of picks from {{ recommendation_collection.title }} to help buyers continue with matching and complementary choices without crowding the page.</p>
          </div>
          <a class="bw-product__related-link" href="{{ recommendation_collection.url }}">Browse matching collection</a>
        </div>

        <div class="bw-product__related-grid">
          {% for related_product in recommendation_collection.products %}
            {% if related_product.id != product.id %}
              {% liquid
                assign related_subtitle = related_product.metafields.my_fields.product_subtitle
              %}
              <a class="bw-product__related-card" href="{{ related_product.url | within: recommendation_collection }}">
                <div class="bw-product__related-image">
                  {% if related_product.featured_image %}
                    {{ related_product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '240, 360, 540, 700', sizes: '(max-width: 720px) 100vw, 25vw', alt: related_product.title }}
                  {% endif %}
                </div>
                <div class="bw-product__related-meta">
                  <span class="bw-product__related-kicker">{{ recommendation_collection.title }}</span>
                  <h3 class="bw-product__related-name">{{ related_product.title }}</h3>
                  <div class="bw-product__related-subtitle">
                    {% if related_subtitle != blank %}
                      {{ related_subtitle | strip_html | truncatewords: 12 }}
                    {% elsif related_product.product_type != blank %}
                      {{ related_product.product_type }}
                    {% else %}
                      Thoughtfully selected to pair well with your browsing journey.
                    {% endif %}
                  </div>
                  <div class="bw-product__related-price-row">
                    <span class="bw-product__related-price">{{ related_product.price | money }}</span>
                    {% if related_product.compare_at_price > related_product.price %}
                      <span class="bw-product__related-compare">{{ related_product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                  <span class="bw-product__related-cta">View product</span>
                </div>
              </a>

              {% assign related_products_count = related_products_count | minus: 1 %}
              {% if related_products_count == 0 %}
                {% break %}
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  <script type="application/json" data-product-variants>
    {{ product.variants | json }}
  </script>
</section>

<script>
  (function () {
    var section = document.getElementById('bw-product-{{ section.id }}');
    if (!section) return;

    var variantsNode = section.querySelector('[data-product-variants]');
    var variants = variantsNode ? JSON.parse(variantsNode.textContent) : [];
    var optionGroups = Array.prototype.slice.call(section.querySelectorAll('[data-option-index]'));
    var priceCurrent = section.querySelector('[data-product-price-current]');
    var priceCompare = section.querySelector('[data-product-price-compare]');
    var priceSave = section.querySelector('[data-product-price-save]');
    var statusText = section.querySelector('[data-product-status-text]');
    var statusDot = section.querySelector('[data-product-status-dot]');
    var metaStatus = section.querySelector('[data-product-meta-status]');
    var variantInput = section.querySelector('[data-product-variant-id]');
    var addToCartButton = section.querySelector('[data-product-atc]');
    var buyNowButton = section.querySelector('[data-product-buy-now]');
    var quantityInput = section.querySelector('[data-product-quantity]');
    var mainImage = section.querySelector('[data-product-main-image]');
    var moneyFormat = {{ shop.money_format | json }};

    function formatMoney(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, moneyFormat);
      }

      var amount = (cents / 100).toFixed(2);
      return 'Rs. ' + amount;
    }

    function getSelectedOptions() {
      return optionGroups.map(function (group) {
        var checked = group.querySelector('input:checked');
        return checked ? checked.value : null;
      });
    }

    function findVariant() {
      var selected = getSelectedOptions();
      return variants.find(function (variant) {
        return selected.every(function (value, index) {
          return variant.options[index] === value;
        });
      });
    }

    function updateVariantUI(variant) {
      if (!variant) {
        addToCartButton.disabled = true;
        buyNowButton.disabled = true;
        addToCartButton.textContent = 'Unavailable';
        statusText.textContent = 'Currently unavailable';
        if (metaStatus) metaStatus.textContent = 'Unavailable';
        statusDot.style.background = '#b74f4a';
        return;
      }

      variantInput.value = variant.id;
      priceCurrent.textContent = formatMoney(variant.price);

      if (variant.compare_at_price && variant.compare_at_price > variant.price) {
        var savings = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
        priceCompare.hidden = false;
        priceSave.hidden = false;
        priceCompare.textContent = formatMoney(variant.compare_at_price);
        priceSave.textContent = 'Save ' + savings + '%';
      } else {
        priceCompare.hidden = true;
        priceSave.hidden = true;
      }

      addToCartButton.disabled = !variant.available;
      buyNowButton.disabled = !variant.available;
      addToCartButton.textContent = variant.available ? 'Add to cart' : 'Sold out';
      statusText.textContent = variant.available ? 'Available to order' : 'Currently sold out';
      if (metaStatus) metaStatus.textContent = variant.available ? 'Ready to order' : 'Sold out';
      statusDot.style.background = variant.available ? '#3c8c53' : '#b74f4a';
    }

    optionGroups.forEach(function (group) {
      var currentValue = group.querySelector('[data-option-current]');
      var radios = group.querySelectorAll('input[type="radio"]');

      radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
          if (currentValue) currentValue.textContent = radio.value;
          updateVariantUI(findVariant());
        });
      });
    });

    section.querySelectorAll('[data-qty-change]').forEach(function (button) {
      button.addEventListener('click', function () {
        var delta = parseInt(button.getAttribute('data-qty-change'), 10);
        var currentValue = parseInt(quantityInput.value || '1', 10);
        var nextValue = currentValue + delta;
        quantityInput.value = nextValue < 1 ? 1 : nextValue;
      });
    });

    section.querySelectorAll('[data-product-thumb]').forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var imageUrl = thumb.getAttribute('data-image-url');
        if (mainImage && imageUrl) {
          mainImage.setAttribute('src', imageUrl);
          mainImage.setAttribute('srcset', thumb.getAttribute('data-image-srcset') || imageUrl);
          mainImage.setAttribute('sizes', thumb.getAttribute('data-image-sizes') || '(max-width: 1024px) 100vw, 50vw');
          mainImage.setAttribute('alt', thumb.getAttribute('data-image-alt') || '{{ product.title | escape }}');
          mainImage.setAttribute('width', thumb.getAttribute('data-image-width') || '1200');
          mainImage.setAttribute('height', thumb.getAttribute('data-image-height') || '1200');
        }

        section.querySelectorAll('[data-product-thumb]').forEach(function (item) {
          item.classList.remove('is-active');
        });
        thumb.classList.add('is-active');
      });
    });

    if (buyNowButton) {
      buyNowButton.addEventListener('click', function () {
        var variant = findVariant();
        if (!variant || !variant.available) return;

        var formData = new FormData();
        formData.append('id', variant.id);
        formData.append('quantity', quantityInput.value || '1');

        buyNowButton.disabled = true;
        buyNowButton.textContent = 'Redirecting';

        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json'
          }
        })
          .then(function (response) {
            if (!response.ok) throw new Error('Unable to add variant');
            return response.json();
          })
          .then(function () {
            window.location.assign('/checkout');
          })
          .catch(function () {
            buyNowButton.disabled = false;
            buyNowButton.textContent = 'Buy now';
          });
      });
    }

    updateVariantUI(findVariant());
  })();
</script>

{% schema %}
{
  "name": "Product Page",
  "presets": [
    {
      "name": "Product Page"
    }
  ]
}
{% endschema %}
