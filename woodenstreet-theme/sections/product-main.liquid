{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image
  assign first_collection = product.collections.first
  assign recommendation_collection = blank
  assign product_form_id = 'bw-product-form-' | append: section.id
  assign product_subtitle = product.metafields.my_fields.product_subtitle | default: product.description | strip_html | strip_newlines | truncatewords: 28
  assign free_delivery_note = product.metafields.my_fields.free_delivery
  assign emi_from_note = product.metafields.my_fields.emi_from
  assign estimate_shipping_time = product.metafields.my_fields.estimate_shipping_time
  assign review_badge_markup = product.metafields.judgeme.badge | strip
  assign brand_reviews_rating = shop.metafields.judgeme.all_reviews_rating | default: 4.8
  assign brand_reviews_count = shop.metafields.judgeme.all_reviews_count | default: 650
  assign show_rating_fallback = false
  assign related_product_limit = 3
  assign related_products_count = 0

  if review_badge_markup == blank or review_badge_markup contains 'No reviews' or review_badge_markup contains 'jdgm-prev-badge__no-reviews'
    assign show_rating_fallback = true
  endif

  for related_collection in product.collections
    if related_collection.products_count > 1 and related_collection.handle != 'frontpage'
      assign recommendation_collection = related_collection
      break
    endif
  endfor

  if recommendation_collection == blank
    assign recommendation_collection = first_collection
  endif

  if recommendation_collection
    for related_product in recommendation_collection.products
      if related_product.id != product.id
        assign related_products_count = related_products_count | plus: 1

        if related_products_count >= related_product_limit
          break
        endif
      endif
    endfor
  endif
%}

<style>
  .bw-product {
    padding: 36px 24px 72px;
    background: linear-gradient(180deg, #faf6f1 0%, #fffdfb 100%);
  }

  .bw-product__shell {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-product__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
    color: #6a5850;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__breadcrumb a {
    color: #6a5850;
    text-decoration: none;
  }

  .bw-product__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: 36px;
    align-items: start;
  }

  .bw-product__gallery {
    position: sticky;
    top: 104px;
    display: grid;
    gap: 14px;
  }

  .bw-product__viewer {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    background: #efe7e0;
    min-height: 640px;
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.1);
  }

  .bw-product__viewer img,
  .bw-product__viewer-empty {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bw-product__viewer img {
    object-fit: cover;
  }

  .bw-product__viewer-empty {
    background:
      radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.22), transparent 24%),
      linear-gradient(145deg, #dfd0c4 0%, #b89682 42%, #6a4b3e 100%);
    display: flex;
    align-items: flex-end;
    padding: 24px;
    box-sizing: border-box;
  }

  .bw-product__viewer-note {
    display: inline-flex;
    align-items: center;
    padding: 12px 14px;
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.9);
    color: #201713;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__badge {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 1;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.86);
    color: #fff7f1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-product__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(88px, 1fr));
    gap: 10px;
  }

  .bw-product__thumb {
    padding: 0;
    border: 1px solid rgba(45, 33, 27, 0.1);
    border-radius: 18px;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    min-height: 88px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .bw-product__thumb.is-active {
    border-color: #201713;
    transform: translateY(-2px);
  }

  .bw-product__thumb img,
  .bw-product__thumb-empty {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bw-product__thumb img {
    object-fit: cover;
  }

  .bw-product__thumb-empty {
    background: linear-gradient(145deg, #eadfd6 0%, #c7a996 100%);
  }

  .bw-product__panel {
    display: grid;
    gap: 18px;
    padding: 34px;
    border-radius: 32px;
    background: rgba(255, 251, 247, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 24px 70px rgba(35, 24, 19, 0.08);
  }

  .bw-product__eyebrow {
    color: #7a5e4d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-product__title {
    margin: 0;
    color: #1f1611;
    font-size: clamp(32px, 4.2vw, 48px);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }

  .bw-product__subtitle {
    color: #5e4d44;
    font-size: 16px;
    line-height: 1.8;
    margin: 0;
  }

  .bw-product__rating {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-product__proofs {
