{% liquid
  assign hero_eyebrow = section.settings.eyebrow | default: 'Premium furniture for considered homes'
  assign hero_title = section.settings.title | default: 'Furniture that makes a room feel chosen.'
  assign hero_description = section.settings.description | default: 'Discover thoughtfully designed furniture for modern Indian homes, crafted to bring warmth, function, and a refined finish to every room.'
  assign primary_label = section.settings.primary_label | default: 'Shop Bestsellers'
  assign primary_url = section.settings.primary_url
  assign secondary_label = section.settings.secondary_label | default: 'Explore Living Room'
  assign secondary_url = section.settings.secondary_url
  assign badge_text = section.settings.badge_text | default: 'Most loved by modern Indian homes'
  assign hero_image = section.settings.hero_image

  if primary_url == blank
    assign primary_url = '/collections/hp-bluewuds-bestseller'
  endif

  if secondary_url == blank
    assign secondary_url = '/collections/living-room'
  endif

  assign hero_collection = collections['living-room']
  assign hero_featured_collection = collections['hp-bluewuds-bestseller']
  assign hero_featured_product = blank
  assign hero_fallback_image = blank

  if hero_collection == blank
    assign hero_collection = hero_featured_collection
  endif

  if hero_featured_collection != blank and hero_featured_collection.products.size > 0
    assign hero_featured_product = hero_featured_collection.products.first
  elsif hero_collection != blank and hero_collection.products.size > 0
    assign hero_featured_product = hero_collection.products.first
  endif

  if hero_collection != blank and hero_collection.image != blank
    assign hero_fallback_image = hero_collection.image
  elsif hero_featured_product != blank and hero_featured_product.featured_image != blank
    assign hero_fallback_image = hero_featured_product.featured_image
  endif
%}

<style>
  .bw-hero {
    background:
      radial-gradient(circle at top left, rgba(166, 106, 67, 0.18), transparent 36%),
      linear-gradient(180deg, #f7f1eb 0%, #f3ece4 100%);
    padding: 28px 24px 56px;
  }

  .bw-hero__frame {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
    gap: 28px;
    align-items: stretch;
  }

  .bw-hero__content,
  .bw-hero__visual {
    border-radius: 32px;
    overflow: hidden;
  }

  .bw-hero__content {
    background: rgba(255, 251, 247, 0.9);
    border: 1px solid rgba(45, 33, 27, 0.08);
    padding: 54px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 28px;
    box-shadow: 0 26px 80px rgba(55, 39, 29, 0.08);
  }

  .bw-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #7d5e4b;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bw-hero__eyebrow::before {
    content: '';
    width: 34px;
    height: 1px;
    background: rgba(125, 94, 75, 0.45);
  }

  .bw-hero__title {
    color: #1f1611;
    font-size: clamp(38px, 6vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.04em;
    margin: 0;
    max-width: 10ch;
  }

  .bw-hero__description {
    color: #5a4a41;
    font-size: 17px;
    line-height: 1.8;
    margin: 0;
    max-width: 60ch;
  }

  .bw-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .bw-hero__primary,
  .bw-hero__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-hero__primary {
    background: #201713;
    color: #f8f1eb;
    box-shadow: 0 18px 36px rgba(32, 23, 19, 0.18);
  }

  .bw-hero__secondary {
    background: transparent;
    color: #201713;
    border: 1px solid rgba(32, 23, 19, 0.18);
  }

  .bw-hero__proofs,
  .bw-hero__stats {
    display: grid;
    gap: 14px;
  }

  .bw-hero__proofs {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .bw-hero__proof {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(45, 33, 27, 0.08);
    color: #392a22;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.5;
  }

  .bw-hero__stats {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .bw-hero__stat {
    display: grid;
    gap: 6px;
    padding-top: 18px;
    border-top: 1px solid rgba(45, 33, 27, 0.08);
  }

  .bw-hero__stat-value {
    color: #201713;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .bw-hero__stat-label {
    color: #6f5b4f;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-hero__visual {
    position: relative;
    min-height: 620px;
    background: #d8cec6;
    box-shadow: 0 26px 80px rgba(55, 39, 29, 0.14);
  }

  .bw-hero__visual img,
  .bw-hero__fallback {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bw-hero__visual img {
    object-fit: cover;
  }

  .bw-hero__fallback {
    background:
      radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.18), transparent 26%),
      radial-gradient(circle at 82% 18%, rgba(166, 106, 67, 0.3), transparent 22%),
      linear-gradient(160deg, #d9c4b4 0%, #b98d71 44%, #6a4637 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 28px;
    box-sizing: border-box;
  }

  .bw-hero__fallback-note {
    max-width: 240px;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 250, 246, 0.9);
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .bw-hero__badge,
  .bw-hero__floating-card {
    position: absolute;
    z-index: 2;
    background: rgba(255, 250, 246, 0.94);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 20px 60px rgba(35, 24, 19, 0.14);
    backdrop-filter: blur(14px);
  }

  .bw-hero__badge {
    top: 24px;
    right: 24px;
    border-radius: 999px;
    padding: 12px 18px;
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-hero__floating-card {
    left: 24px;
    bottom: 24px;
    max-width: 280px;
    border-radius: 22px;
    padding: 20px;
    display: grid;
    gap: 10px;
  }

  .bw-hero__floating-card-title {
    color: #201713;
    font-size: 16px;
    font-weight: 700;
    margin: 0;
  }

  .bw-hero__floating-card-copy {
    color: #5f4d44;
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  .bw-hero__floating-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bw-hero__tag {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(32, 23, 19, 0.06);
    color: #201713;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 1100px) {
    .bw-hero__frame {
      grid-template-columns: 1fr;
    }

    .bw-hero__visual {
      min-height: 520px;
      order: -1;
    }
  }

  @media (max-width: 720px) {
    .bw-hero {
      padding: 20px 16px 42px;
    }

    .bw-hero__content {
      padding: 30px 22px;
      border-radius: 24px;
      gap: 22px;
    }

    .bw-hero__title {
      max-width: none;
      font-size: clamp(32px, 10vw, 46px);
    }

    .bw-hero__description {
      font-size: 15px;
      line-height: 1.7;
    }

    .bw-hero__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .bw-hero__primary,
    .bw-hero__secondary {
      width: 100%;
    }

    .bw-hero__proofs,
    .bw-hero__stats {
      grid-template-columns: 1fr;
    }

    .bw-hero__visual {
      min-height: 420px;
      border-radius: 24px;
    }

    .bw-hero__badge {
      left: 16px;
      right: auto;
      top: 16px;
    }

    .bw-hero__floating-card {
      left: 16px;
      right: 16px;
      max-width: none;
      bottom: 16px;
    }

    .bw-hero__fallback {
      padding: 20px;
    }
  }
</style>

<section class="bw-hero">
  <div class="bw-hero__frame">
    <div class="bw-hero__content">
      <div class="bw-hero__eyebrow">{{ hero_eyebrow }}</div>
      <h1 class="bw-hero__title">{{ hero_title }}</h1>
      <p class="bw-hero__description">{{ hero_description }}</p>

      <div class="bw-hero__actions">
        <a class="bw-hero__primary" href="{{ primary_url }}">{{ primary_label }}</a>
        <a class="bw-hero__secondary" href="{{ secondary_url }}">{{ secondary_label }}</a>
      </div>

      <div class="bw-hero__proofs">
        <div class="bw-hero__proof">Thoughtful designs made for everyday living.</div>
        <div class="bw-hero__proof">Curated collections for living, bedroom, study, and storage.</div>
        <div class="bw-hero__proof">Reliable delivery, warranty support, and easy assistance.</div>
      </div>

      <div class="bw-hero__stats">
        <div class="bw-hero__stat">
          <span class="bw-hero__stat-value">15+</span>
          <span class="bw-hero__stat-label">Years of trust</span>
        </div>
        <div class="bw-hero__stat">
          <span class="bw-hero__stat-value">20L+</span>
          <span class="bw-hero__stat-label">Happy customers</span>
        </div>
        <div class="bw-hero__stat">
          <span class="bw-hero__stat-value">7 Year</span>
          <span class="bw-hero__stat-label">Warranty support</span>
        </div>
      </div>
    </div>

    <div class="bw-hero__visual">
      {% if hero_image != blank %}
        {{ hero_image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '600, 900, 1200, 1400', sizes: '(max-width: 1100px) 100vw, 48vw' }}
      {% elsif hero_fallback_image != blank %}
        {{ hero_fallback_image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '600, 900, 1200, 1400', sizes: '(max-width: 1100px) 100vw, 48vw', alt: hero_collection.title | default: hero_title }}
      {% else %}
        <div class="bw-hero__fallback" role="img" aria-label="Bluewud hero placeholder until a branded lifestyle image is added">
          <span class="bw-hero__fallback-note">Add a Bluewud lifestyle image here</span>
        </div>
      {% endif %}

      <div class="bw-hero__badge">{{ badge_text }}</div>

      <div class="bw-hero__floating-card">
        <h2 class="bw-hero__floating-card-title">
          {% if hero_featured_product != blank %}
            {{ hero_featured_product.title }}
          {% else %}
            Made for contemporary homes
          {% endif %}
        </h2>
        <p class="bw-hero__floating-card-copy">
          {% if hero_featured_product != blank %}
            {{ hero_featured_product.description | strip_html | truncatewords: 18 }}
          {% else %}
            Bring together warmth, utility, and timeless silhouettes for spaces that feel complete.
          {% endif %}
        </p>
        <div class="bw-hero__floating-tags">
          {% if hero_collection != blank %}
            <span class="bw-hero__tag">{{ hero_collection.title }}</span>
          {% endif %}
          {% if hero_featured_collection != blank %}
            <span class="bw-hero__tag">{{ hero_featured_collection.title }}</span>
          {% endif %}
          {% if hero_featured_product != blank and hero_featured_product.type != blank %}
            <span class="bw-hero__tag">{{ hero_featured_product.type }}</span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium furniture for considered homes"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Furniture that makes a room feel chosen."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover thoughtfully designed furniture for modern Indian homes, crafted to bring warmth, function, and a refined finish to every room."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Bestsellers"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore Living Room"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Visual badge text",
      "default": "Most loved by modern Indian homes"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
