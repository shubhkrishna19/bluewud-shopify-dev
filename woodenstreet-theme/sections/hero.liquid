{% liquid
  assign living_room_url = '/collections/living-room'
  assign bedroom_url = '/collections/bed-room'
  assign tv_unit_url = '/collections/tv-unit-furniture'
  assign study_room_url = '/collections/study-tables'
  assign offers_url = '/pages/offers-discount'
  assign living_room_collection = collections['living-room']
  assign bedroom_collection = collections['bed-room']
  assign tv_unit_collection = collections['tv-unit-furniture']
  assign study_room_collection = collections['study-tables']

  if living_room_collection != blank and living_room_collection.url != blank
    assign living_room_url = living_room_collection.url
  endif
  if bedroom_collection != blank and bedroom_collection.url != blank
    assign bedroom_url = bedroom_collection.url
  endif
  if tv_unit_collection != blank and tv_unit_collection.url != blank
    assign tv_unit_url = tv_unit_collection.url
  endif
  if study_room_collection != blank and study_room_collection.url != blank
    assign study_room_url = study_room_collection.url
  endif
  if pages['offers-discount'] != blank
    assign offers_url = pages['offers-discount'].url
  endif

  assign default_eyebrows = 'Living Room|Bedroom|Entertainment|Study & Office|New arrivals' | split: '|'
  assign default_headings = 'Furniture that makes the|Give your bedroom|Upgrade your|Smartly designed|Fresh pieces made to' | split: '|'
  assign default_accents = 'home feel more complete|storage feel calmer|watching corner feel more ordered|WFH corner feel more focused|keep the shortlist moving' | split: '|'
  assign default_tails = '||||'
  assign default_copies = 'Explore room-defining living pieces that make the home feel balanced, polished, and easier to live with every day.|Bedroom storage and bed solutions chosen to make routines calmer, cleaner, and easier to keep in place.|Discover TV units and entertainment furniture that bring order to the setup without losing warmth or character.|Shop practical study tables, bookshelves, and WFH-ready pieces that turn a corner into a more focused, premium workspace.|Browse fresh Bluewud additions and sharper-value picks that make the next room feel easier to finish.' | split: '|'
  assign default_handles = 'living-room|bed-room|tv-unit-furniture|study-tables|new_launches' | split: '|'
  capture default_urls_string
    echo living_room_url | append: '|'
    echo bedroom_url | append: '|'
    echo tv_unit_url | append: '|'
    echo study_room_url | append: '|'
    echo offers_url
  endcapture
  assign default_urls = default_urls_string | split: '|'
  assign default_button_labels = 'Explore living room|Shop bedroom|Browse TV units|Shop WFH furniture|View offers' | split: '|'
  assign default_positions = 'right|left|right|right|center' | split: '|'
  assign has_configured_slides = false

  if section.blocks.size > 0
    for block in section.blocks
      if block.settings.heading != blank or block.settings.slide_image != blank or block.settings.collection_handle != blank
        assign has_configured_slides = true
        break
      endif
    endfor
  endif
%}

<style>
  .bw-hero {
    padding: 28px 24px 46px;
    background: linear-gradient(180deg, #f7f1eb 0%, #faf6f1 100%);
  }

  .bw-hero__shell {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-hero__slider {
    position: relative;
    border-radius: 36px;
    overflow: hidden;
    background: #ece4dd;
    box-shadow: 0 28px 80px rgba(55, 39, 29, 0.1);
    cursor: grab;
    touch-action: pan-y;
  }

  .bw-hero__slider.is-dragging {
    cursor: grabbing;
  }

  .bw-hero__viewport {
    position: relative;
    min-height: 600px;
  }

  .bw-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.45s ease, visibility 0.45s ease, transform 0.45s ease;
    transform: scale(1.02);
  }

  .bw-hero__slide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: scale(1);
  }

  .bw-hero__slide:focus-visible {
    outline: 2px solid rgba(53, 90, 109, 0.75);
    outline-offset: -8px;
  }

  .bw-hero__media,
  .bw-hero__fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .bw-hero__media {
    object-fit: cover;
  }

  .bw-hero__fallback {
    background:
      radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.26), transparent 24%),
      radial-gradient(circle at 78% 18%, rgba(166, 106, 67, 0.2), transparent 24%),
      linear-gradient(135deg, #e6dad0 0%, #d7c2b2 38%, #9b7a68 100%);
  }

  .bw-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(24, 18, 14, 0.24) 0%, rgba(24, 18, 14, 0.12) 34%, rgba(24, 18, 14, 0.05) 100%);
  }

  .bw-hero__overlay--light {
    background: linear-gradient(90deg, rgba(24, 18, 14, 0.08) 0%, rgba(24, 18, 14, 0.04) 34%, rgba(24, 18, 14, 0.02) 100%);
  }

  .bw-hero__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    padding: 48px 58px;
  }

  .bw-hero__content--left {
    justify-content: flex-start;
    text-align: left;
  }

  .bw-hero__content--right {
    justify-content: flex-end;
    text-align: right;
  }

  .bw-hero__content--center {
    justify-content: center;
    text-align: center;
  }

  .bw-hero__card {
    position: relative;
    max-width: 540px;
    padding: 26px 32px 28px;
    border-radius: 30px;
    background: rgba(255, 250, 246, 0.84);
    border: 1px solid rgba(255, 255, 255, 0.34);
    backdrop-filter: blur(10px);
    box-shadow: 0 24px 64px rgba(35, 24, 19, 0.14);
  }

  .bw-hero__content--center .bw-hero__card {
    max-width: 760px;
    background: rgba(255, 250, 246, 0.72);
  }

  .bw-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    margin: 0 0 12px;
    padding: 0 11px;
    border-radius: 999px;
    background: rgba(36, 25, 18, 0.06);
    color: #6d5346;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .bw-hero__heading {
    margin: 0;
    color: #241912;
    font-size: clamp(34px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .bw-hero__heading-line {
    display: block;
  }

  .bw-hero__accent {
    display: inline-block;
    color: #2a1e17;
    font-family: var(--bw-font-serif);
    font-style: italic;
    letter-spacing: -0.03em;
  }

  .bw-hero__tail {
    display: block;
    margin-top: 8px;
    font-size: clamp(24px, 3vw, 48px);
    letter-spacing: -0.03em;
  }

  .bw-hero__copy {
    max-width: 42ch;
    margin: 16px 0 0;
    color: #5f4d42;
    font-size: 16px;
    line-height: 1.75;
  }

  .bw-hero__actions {
    position: relative;
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .bw-hero__content--right .bw-hero__actions {
    justify-content: flex-end;
  }

  .bw-hero__content--center .bw-hero__actions {
    justify-content: center;
  }

  .bw-hero__button,
  .bw-hero__secondary {
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bw-hero__button {
    background: #c96c62;
    color: #fffaf6;
    box-shadow: 0 16px 34px rgba(201, 108, 98, 0.28);
  }

  .bw-hero__secondary {
    background: rgba(36, 25, 18, 0.08);
    color: #241912;
    border: 1px solid rgba(36, 25, 18, 0.12);
  }

  .bw-hero__nav-button {
    position: absolute;
    top: 50%;
    z-index: 4;
    width: 54px;
    height: 54px;
    margin-top: -27px;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.18);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition: background 0.22s ease, transform 0.22s ease;
  }

  .bw-hero__nav-button:hover {
    background: rgba(255, 250, 246, 0.28);
    transform: translateY(-1px);
  }

  .bw-hero__nav-button--prev {
    left: 18px;
  }

  .bw-hero__nav-button--next {
    right: 18px;
  }

  .bw-hero__nav-button svg {
    width: 24px;
    height: 24px;
  }

  .bw-hero__dots {
    position: absolute;
    left: 50%;
    bottom: 20px;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 8px;
    transform: translateX(-50%);
  }

  .bw-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 0;
    padding: 0;
    background: rgba(255, 250, 246, 0.42);
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .bw-hero__dot.is-active {
    background: #fffaf6;
    transform: scale(1.15);
  }

  @media (max-width: 980px) {
    .bw-hero__viewport {
      min-height: 500px;
    }

    .bw-hero__content {
      padding: 28px 28px 58px;
      align-items: flex-end;
    }

    .bw-hero__card,
    .bw-hero__content--center .bw-hero__card {
      max-width: 100%;
    }

    .bw-hero__heading {
      font-size: clamp(30px, 8vw, 52px);
    }

    .bw-hero__tail {
      font-size: clamp(22px, 6vw, 34px);
    }
  }

  @media (max-width: 720px) {
    .bw-hero {
      padding: 18px 16px 34px;
    }

    .bw-hero__slider {
      border-radius: 26px;
    }

    .bw-hero__viewport {
      min-height: 440px;
    }

    .bw-hero__content {
      padding: 18px 18px 60px;
    }

    .bw-hero__card {
      padding: 20px 18px 22px;
      border-radius: 24px;
      background: rgba(255, 250, 246, 0.88);
    }

    .bw-hero__copy {
      font-size: 14px;
      line-height: 1.65;
    }

    .bw-hero__nav-button {
      width: 42px;
      height: 42px;
      margin-top: -21px;
    }

    .bw-hero__nav-button--prev {
      left: 12px;
    }

    .bw-hero__nav-button--next {
      right: 12px;
    }

    .bw-hero__button,
    .bw-hero__secondary {
      min-height: 44px;
      padding: 0 16px;
      font-size: 11px;
    }
  }
</style>

<section id="bw-hero-{{ section.id }}" class="bw-hero" data-bw-hero-section>
  <div class="bw-hero__shell">
    <div class="bw-hero__slider" data-bw-hero-slider>
      <div class="bw-hero__viewport">
        {% if has_configured_slides %}
          {% for block in section.blocks %}
            {% liquid
              assign slide_collection = collections[block.settings.collection_handle]
              assign slide_url = block.settings.button_url
              assign slide_image = block.settings.slide_image
              assign slide_has_copy = false

              if slide_url == blank and slide_collection != blank
                assign slide_url = slide_collection.url
              endif

              if slide_url == blank
                assign slide_url = routes.root_url
              endif

              if slide_image == blank and slide_collection != blank and slide_collection.image != blank
                assign slide_image = slide_collection.image
              elsif slide_image == blank and slide_collection != blank and slide_collection.products.size > 0
                assign slide_image = slide_collection.products.first.featured_image
              endif

              if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.accent != blank or block.settings.tail != blank or block.settings.copy != blank or block.settings.button_label != blank
                assign slide_has_copy = true
              endif
            %}

            <article class="bw-hero__slide{% if forloop.first %} is-active{% endif %}" data-bw-hero-slide data-bw-slide-url="{{ slide_url }}" tabindex="0" role="link" aria-label="{{ block.settings.heading | default: block.settings.accent | default: 'Explore collection' }}" {{ block.shopify_attributes }}>
              {% if slide_image != blank %}
                {{ slide_image | image_url: width: 1800 | image_tag: class: 'bw-hero__media', loading: 'eager', widths: '720, 1080, 1440, 1800', sizes: '100vw', alt: block.settings.heading | default: block.settings.accent | default: shop.name }}
              {% else %}
                <div class="bw-hero__fallback" aria-hidden="true"></div>
              {% endif %}
              <div class="bw-hero__overlay{% unless slide_has_copy %} bw-hero__overlay--light{% endunless %}"></div>
              {% if slide_has_copy %}
                <div class="bw-hero__content bw-hero__content--{{ block.settings.content_position | default: 'right' }}">
                  <div class="bw-hero__card">
                    {% if block.settings.eyebrow != blank %}
                      <p class="bw-hero__eyebrow">{{ block.settings.eyebrow }}</p>
                    {% endif %}
                    <h2 class="bw-hero__heading">
                      {% if block.settings.heading != blank %}
                        <span class="bw-hero__heading-line">{{ block.settings.heading }}</span>
                      {% endif %}
                      {% if block.settings.accent != blank %}
                        <span class="bw-hero__accent">{{ block.settings.accent }}</span>
                      {% endif %}
                      {% if block.settings.tail != blank %}
                        <span class="bw-hero__tail">{{ block.settings.tail }}</span>
                      {% endif %}
                    </h2>
                    {% if block.settings.copy != blank %}
                      <p class="bw-hero__copy">{{ block.settings.copy }}</p>
                    {% endif %}
                    <div class="bw-hero__actions">
                      {% if block.settings.button_label != blank %}
                        <a class="bw-hero__button" href="{{ slide_url }}">{{ block.settings.button_label }}</a>
                      {% endif %}
                      {% if slide_collection != blank %}
                        <a class="bw-hero__secondary" href="{{ slide_collection.url }}">View collection</a>
                      {% endif %}
                    </div>
                  </div>
                </div>
              {% endif %}
            </article>
          {% endfor %}
        {% else %}
          {% for default_heading in default_headings %}
            {% liquid
              assign slide_handle = default_handles[forloop.index0]
              assign slide_collection = collections[slide_handle]
              assign slide_url = default_urls[forloop.index0]
              assign slide_image = blank

              if slide_url == blank and slide_collection != blank
                assign slide_url = slide_collection.url
              endif

              if slide_collection != blank
                if slide_collection.image != blank
                  assign slide_image = slide_collection.image
                elsif slide_collection.products.size > 0
                  assign slide_image = slide_collection.products.first.featured_image
                endif
              endif
            %}

            <article class="bw-hero__slide{% if forloop.first %} is-active{% endif %}" data-bw-hero-slide data-bw-slide-url="{{ slide_url }}" tabindex="0" role="link" aria-label="{{ default_heading }}">
              {% if slide_image != blank %}
                {{ slide_image | image_url: width: 1800 | image_tag: class: 'bw-hero__media', loading: 'eager', widths: '720, 1080, 1440, 1800', sizes: '100vw', alt: default_heading }}
              {% else %}
                <div class="bw-hero__fallback" aria-hidden="true"></div>
              {% endif %}
              <div class="bw-hero__overlay"></div>
              <div class="bw-hero__content bw-hero__content--{{ default_positions[forloop.index0] }}">
                <div class="bw-hero__card">
                  <p class="bw-hero__eyebrow">{{ default_eyebrows[forloop.index0] }}</p>
                  <h1 class="bw-hero__heading">
                    <span class="bw-hero__heading-line">{{ default_heading }}</span>
                    <span class="bw-hero__accent">{{ default_accents[forloop.index0] }}</span>
                    {% if default_tails[forloop.index0] != blank %}
                      <span class="bw-hero__tail">{{ default_tails[forloop.index0] }}</span>
                    {% endif %}
                  </h1>
                  <p class="bw-hero__copy">{{ default_copies[forloop.index0] }}</p>
                  <div class="bw-hero__actions">
                    <a class="bw-hero__button" href="{{ slide_url }}">{{ default_button_labels[forloop.index0] }}</a>
                    {% if slide_collection != blank %}
                      <a class="bw-hero__secondary" href="{{ slide_collection.url }}">View collection</a>
                    {% endif %}
                  </div>
                </div>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>

      <button class="bw-hero__nav-button bw-hero__nav-button--prev" type="button" aria-label="Previous slide" data-bw-hero-prev>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M15 5l-7 7 7 7"></path>
        </svg>
      </button>
      <button class="bw-hero__nav-button bw-hero__nav-button--next" type="button" aria-label="Next slide" data-bw-hero-next>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <div class="bw-hero__dots" data-bw-hero-dots></div>
    </div>
  </div>
</section>

<script>
  (function () {
    var sectionRoot = document.getElementById('bw-hero-{{ section.id }}');
    if (!sectionRoot) return;

    var slider = sectionRoot.querySelector('[data-bw-hero-slider]');
    var slides = slider ? Array.prototype.slice.call(slider.querySelectorAll('[data-bw-hero-slide]')) : [];
    var dotsRoot = slider ? slider.querySelector('[data-bw-hero-dots]') : null;
    var prevButton = slider ? slider.querySelector('[data-bw-hero-prev]') : null;
    var nextButton = slider ? slider.querySelector('[data-bw-hero-next]') : null;
    var activeIndex = 0;
    var autoTimer = null;
    var autoDelay = 5200;
    var wheelLocked = false;
    var dragStartX = null;
    var dragDeltaX = 0;
    var pointerActive = false;
    var pointerMoved = false;
    var dragThreshold = 58;

    if (!slider || slides.length <= 1 || !dotsRoot) return;

    function renderDots() {
      dotsRoot.innerHTML = '';

      slides.forEach(function (_, index) {
        var dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'bw-hero__dot' + (index === activeIndex ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (index + 1));
        dot.addEventListener('click', function () {
          goTo(index, true);
        });
        dotsRoot.appendChild(dot);
      });
    }

    function goTo(index, userTriggered) {
      activeIndex = (index + slides.length) % slides.length;

      slides.forEach(function (slide, slideIndex) {
        slide.classList.toggle('is-active', slideIndex === activeIndex);
      });

      renderDots();

      if (userTriggered) {
        restartAuto();
      }
    }

    function restartAuto() {
      if (autoTimer) {
        window.clearInterval(autoTimer);
      }

      autoTimer = window.setInterval(function () {
        goTo(activeIndex + 1, false);
      }, autoDelay);
    }

    function isInteractiveTarget(target) {
      return !!(target && target.closest('a, button, input, select, textarea, summary'));
    }

    slides.forEach(function (slide) {
      slide.addEventListener('click', function (event) {
        var slideUrl = slide.getAttribute('data-bw-slide-url');

        if (!slideUrl || pointerMoved || isInteractiveTarget(event.target)) return;

        window.location.assign(slideUrl);
      });

      slide.addEventListener('keydown', function (event) {
        var slideUrl = slide.getAttribute('data-bw-slide-url');

        if (!slideUrl || isInteractiveTarget(event.target)) return;

        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          window.location.assign(slideUrl);
        }
      });
    });

    prevButton.addEventListener('click', function () {
      goTo(activeIndex - 1, true);
    });

    nextButton.addEventListener('click', function () {
      goTo(activeIndex + 1, true);
    });

    slider.addEventListener('mouseenter', function () {
      if (autoTimer) {
        window.clearInterval(autoTimer);
      }
    });

    slider.addEventListener('mouseleave', function () {
      restartAuto();
    });

    slider.addEventListener('wheel', function (event) {
      var delta = Math.abs(event.deltaY) > Math.abs(event.deltaX) ? event.deltaY : event.deltaX;

      if (Math.abs(delta) < 18 || wheelLocked) return;

      event.preventDefault();
      wheelLocked = true;

      if (delta > 0) {
        goTo(activeIndex + 1, true);
      } else {
        goTo(activeIndex - 1, true);
      }

      window.setTimeout(function () {
        wheelLocked = false;
      }, 460);
    }, { passive: false });

    slider.addEventListener('pointerdown', function (event) {
      if (event.pointerType === 'mouse' && event.button !== 0) return;
      if (isInteractiveTarget(event.target)) return;

      pointerActive = true;
      pointerMoved = false;
      dragStartX = event.clientX;
      dragDeltaX = 0;
      slider.classList.add('is-dragging');

      if (slider.setPointerCapture) {
        slider.setPointerCapture(event.pointerId);
      }
    });

    slider.addEventListener('pointermove', function (event) {
      if (!pointerActive || dragStartX === null) return;
      dragDeltaX = event.clientX - dragStartX;

      if (Math.abs(dragDeltaX) > 8) {
        pointerMoved = true;
      }
    });

    function endDrag(event) {
      if (!pointerActive) return;

      pointerActive = false;
      slider.classList.remove('is-dragging');

      if (slider.releasePointerCapture) {
        try {
          slider.releasePointerCapture(event.pointerId);
        } catch (error) {
        }
      }

      if (Math.abs(dragDeltaX) >= dragThreshold) {
        if (dragDeltaX < 0) {
          goTo(activeIndex + 1, true);
        } else {
          goTo(activeIndex - 1, true);
        }
      }

      dragStartX = null;
      dragDeltaX = 0;
      window.setTimeout(function () {
        pointerMoved = false;
      }, 0);
    }

    slider.addEventListener('pointerup', endDrag);
    slider.addEventListener('pointercancel', endDrag);

    renderDots();
    restartAuto();
  })();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "accent",
          "label": "Accent text"
        },
        {
          "type": "text",
          "id": "tail",
          "label": "Tail text"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Primary URL"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Primary button label",
          "default": "Shop now"
        },
        {
          "type": "image_picker",
          "id": "slide_image",
          "label": "Slide image"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "default": "right",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
