      </div>
    </div>

    {% if has_live_reviews %}
      <div class="bw-testimonials__live">
        <div class="bw-testimonials__live-header">
          <div class="bw-testimonials__live-copy">
            <span class="bw-testimonials__live-kicker">More customer voices</span>
            <h3 class="bw-testimonials__live-title">Browse more real Bluewud reviews.</h3>
            <p class="bw-testimonials__live-text">The curated stories above create fast confidence. This section opens the deeper review base already collected on the store for shoppers who want a little more proof before purchase.</p>
          </div>
          <div class="bw-testimonials__live-actions">
            {% render 'judgeme_widgets', widget_type: 'judgeme_all_reviews_text', concierge_install: true %}
            <a class="bw-testimonials__all-link" href="{{ reviews_page_url }}">See every review</a>
          </div>
        </div>
        <div class="bw-testimonials__live-widget">
          {% render 'judgeme_widgets', widget_type: 'judgeme_featured_carousel', concierge_install: true %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('[data-testimonials-section]');
    if (!section) return;

    var tabs = Array.prototype.slice.call(section.querySelectorAll('[data-testimonial-tab]'));
    var panels = Array.prototype.slice.call(section.querySelectorAll('[data-testimonial-panel]'));
    var dotsWrap = section.querySelector('[data-testimonial-dots]');
    var prevButton = section.querySelector('[data-testimonial-prev]');
    var nextButton = section.querySelector('[data-testimonial-next]');
    var currentIndex = 0;

    function activate(index) {
      if (!panels.length) return;

      currentIndex = (index + panels.length) % panels.length;

      tabs.forEach(function (tab) {
        var active = Number(tab.getAttribute('data-testimonial-tab')) === currentIndex;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      panels.forEach(function (panel) {
        panel.classList.toggle('is-active', Number(panel.getAttribute('data-testimonial-panel')) === currentIndex);
      });

      if (dotsWrap) {
        dotsWrap.querySelectorAll('[data-testimonial-dot]').forEach(function (dot) {
          var active = Number(dot.getAttribute('data-testimonial-dot')) === currentIndex;
          dot.classList.toggle('is-active', active);
          dot.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }
    }

    if (dotsWrap && !dotsWrap.children.length) {
      panels.forEach(function (_, index) {
        var dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'bw-testimonials__dot' + (index === 0 ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Go to review ' + (index + 1));
        dot.setAttribute('aria-pressed', index === 0 ? 'true' : 'false');
        dot.setAttribute('data-testimonial-dot', index);
        dot.addEventListener('click', function () {
          activate(index);
        });
        dotsWrap.appendChild(dot);
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(Number(tab.getAttribute('data-testimonial-tab')));
      });
    });

    if (prevButton) {
      prevButton.addEventListener('click', function () {
        activate(currentIndex - 1);
      });
    }

    if (nextButton) {
      nextButton.addEventListener('click', function () {
        activate(currentIndex + 1);
      });
    }

    activate(0);
  })();
</script>

