<style>
  .bw-testimonials {
    padding: 10px 24px 70px;
    background: #faf6f1;
  }

  .bw-testimonials__inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .bw-testimonials__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    margin-bottom: 28px;
  }

  .bw-testimonials__eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    color: #7f604d;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bw-testimonials__title {
    margin: 0 0 10px;
    color: #201713;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .bw-testimonials__copy {
    margin: 0;
    color: #66554c;
    font-size: 16px;
    line-height: 1.8;
    max-width: 62ch;
  }

  .bw-testimonials__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
  }

  .bw-testimonials__stat {
    padding: 12px 16px;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.92);
    border: 1px solid rgba(45, 33, 27, 0.08);
    color: #201713;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bw-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .bw-testimonials__card {
    height: 100%;
    display: grid;
    gap: 16px;
    padding: 26px;
    border-radius: 28px;
    background: rgba(255, 252, 248, 0.92);
    border: 1px solid rgba(45, 33, 27, 0.08);
    box-shadow: 0 18px 50px rgba(35, 24, 19, 0.07);
  }

  .bw-testimonials__stars {
    color: #a66a43;
    font-size: 16px;
    letter-spacing: 0.18em;
  }

  .bw-testimonials__quote {
    margin: 0;
    color: #41332c;
    font-size: 16px;
    line-height: 1.9;
  }

  .bw-testimonials__author {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .bw-testimonials__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(180deg, #2a1d16 0%, #4b3528 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #f8f1eb;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .bw-testimonials__name {
    margin: 0;
    color: #201713;
    font-size: 16px;
    font-weight: 700;
  }

  .bw-testimonials__meta {
    color: #7a675b;
    font-size: 13px;
    line-height: 1.6;
  }

  @media (max-width: 1100px) {
    .bw-testimonials__grid {
      grid-template-columns: 1fr;
    }

    .bw-testimonials__header {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .bw-testimonials {
      padding: 10px 16px 54px;
    }
  }
</style>

<section class="bw-testimonials">
  <div class="bw-testimonials__inner">
    <div class="bw-testimonials__header">
      <div>
        <span class="bw-testimonials__eyebrow">Loved by Bluewud homes</span>
        <h2 class="bw-testimonials__title">Stories from homes that chose Bluewud.</h2>
        <p class="bw-testimonials__copy">From first apartment setups to full-room upgrades, customers return to Bluewud for furniture that looks good, lasts well, and fits into everyday life.</p>
      </div>
      <div class="bw-testimonials__stats">
        <span class="bw-testimonials__stat">20 Lakh+ Customers</span>
        <span class="bw-testimonials__stat">15+ Years</span>
        <span class="bw-testimonials__stat">Pan-India Reach</span>
      </div>
    </div>

    <div class="bw-testimonials__grid">
      <article class="bw-testimonials__card">
        <div class="bw-testimonials__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="bw-testimonials__quote">"The finish looked even better in person. Delivery updates were clear, and the unit brought the whole room together beautifully."</p>
        <div class="bw-testimonials__author">
          <span class="bw-testimonials__avatar">RK</span>
          <div>
            <h3 class="bw-testimonials__name">Ritika Kapoor</h3>
            <div class="bw-testimonials__meta">Mumbai - Living room upgrade</div>
          </div>
        </div>
      </article>

      <article class="bw-testimonials__card">
        <div class="bw-testimonials__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="bw-testimonials__quote">"We were buying online for the first time, but the product details and support made it easy to decide. The bed looks beautiful."</p>
        <div class="bw-testimonials__author">
          <span class="bw-testimonials__avatar">AS</span>
          <div>
            <h3 class="bw-testimonials__name">Aman Sethi</h3>
            <div class="bw-testimonials__meta">Delhi NCR - Bedroom purchase</div>
          </div>
        </div>
      </article>

      <article class="bw-testimonials__card">
        <div class="bw-testimonials__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="bw-testimonials__quote">"This was our second Bluewud order and the quality stayed consistent. Practical, well-finished, and absolutely worth it."</p>
        <div class="bw-testimonials__author">
          <span class="bw-testimonials__avatar">NM</span>
          <div>
            <h3 class="bw-testimonials__name">Neha Malhotra</h3>
            <div class="bw-testimonials__meta">Bengaluru - Repeat customer</div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
