    <script>
    (function () {
      function handleFirstTab(e) {
        if (e.keyCode === 9) { // the "I am a keyboard user" key
          document.body.classList.add('user-is-tabbing');
          window.removeEventListener('keydown', handleFirstTab);
        }
      }
      window.addEventListener('keydown', handleFirstTab);
    })();
    </script>

    {% unless settings.reduce_animations %}
      <script>
        (function () {
          var preloadTimeout = window.setTimeout(function () {
            document.body.classList.add('bw-page-ready');
            document.body.classList.remove('bw-motion-preload');
          }, 1200);

          if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.body.classList.add('bw-page-ready');
            document.body.classList.remove('bw-motion-preload');
            window.clearTimeout(preloadTimeout);
            return;
          }

          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              document.body.classList.add('bw-page-ready');
              document.body.classList.remove('bw-motion-preload');
              window.clearTimeout(preloadTimeout);
            });
          });

          window.addEventListener('pageshow', function () {
            document.body.classList.add('bw-page-ready');
            document.body.classList.remove('bw-motion-preload');
            document.body.classList.remove('bw-page-leaving');
            window.clearTimeout(preloadTimeout);
          });

          var revealTargets = document.querySelectorAll([
            '.bw-hero',
            '.bw-trust__intro',
            '.bw-trust__card',
            '.bw-categories__card',
            '.bw-banner',
            '.bw-featured__header',
            '.bw-featured__card',
            '.bw-testimonials__header',
            '.bw-testimonials__shell',
            '.bw-newsletter',
            '.bw-page__hero',
            '.bw-page__content',
            '.bw-page__support',
            '.bw-contact__card',
            '.bw-contact__panel',
            '.bw-collection__hero',
            '.bw-collection__toolbar',
            '.bw-product__panel',
            '.bw-product__reviews',
            '.bw-product__related'
          ].join(','));

          if (revealTargets.length) {
            revealTargets.forEach(function (node, index) {
              node.classList.add('bw-reveal');
              node.style.transitionDelay = Math.min((index % 6) * 60, 260) + 'ms';
            });

            if ('IntersectionObserver' in window) {
              var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                  if (!entry.isIntersecting) return;
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                });
              }, {
                threshold: 0.16,
                rootMargin: '0px 0px -8% 0px'
              });

              revealTargets.forEach(function (node) {
                observer.observe(node);
              });
            } else {
              revealTargets.forEach(function (node) {
                node.classList.add('is-visible');
              });
            }
          }

          document.addEventListener('click', function (event) {
            if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

            var link = event.target.closest('a[href]');
            if (!link) return;
            if (link.target && link.target !== '_self') return;
            if (link.hasAttribute('download') || link.dataset.noMotion !== undefined) return;
            if (link.getAttribute('role') === 'button' || link.hasAttribute('aria-controls') || link.hasAttribute('data-fancybox') || link.hasAttribute('data-modal-open')) return;
            if (link.closest('.search-modal, [data-modal-container], [data-modal-container-1], [data-photoswipe], [data-atc-banner], .swym-button, .iWishAdd')) return;

            var href = link.getAttribute('href');
            if (!href || href.charAt(0) === '#' || href.indexOf('mailto:') === 0 || href.indexOf('tel:') === 0 || href.indexOf('javascript:') === 0) return;

            var url;
            try {
              url = new URL(link.href, window.location.href);
            } catch (error) {
              return;
            }

            if (url.origin !== window.location.origin) return;
            if (url.pathname === window.location.pathname && url.search === window.location.search && url.hash) return;
            if (url.pathname.indexOf('/apps/') === 0 || url.pathname.indexOf('/cart') === 0 || url.pathname.indexOf('/checkout') === 0) return;

            document.body.classList.add('bw-page-leaving');

            event.preventDefault();
            window.setTimeout(function () {
              window.location.assign(url.href);
            }, 180);
          });
        })();
      </script>
    {% endunless %}

