<!doctype html>
<html class="no-js no-touch" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="IE=edge">

    <link rel="preconnect" href="https://cdn.shopify.com">
    <link rel="preconnect" href="https://fonts.shopifycdn.com">
    <link rel="preconnect" href="https://v.shopify.com">
    <link rel="preconnect" href="https://cdn.shopifycloud.com">

    <title>
      {{- page_title -}}

      {%- if current_tags -%}
        {% capture cat_array %}{%- render 'advanced-tag-loop' -%}{% endcapture %}
        {% assign cat_array = cat_array | split: '|' %}
        {% assign title_tags = '' %}
        {% assign meta_tags = current_tags | join: ', ' %}
        {%- for tag in current_tags -%}
          {% assign is_advanced_tag = false %}
          {% assign cat = tag | split: '_' | first %}

          {%- unless cat == tag -%}
            {%- if cat_array contains cat -%}
              {% assign is_advanced_tag = true %}
              {% assign title_tags = title_tags | append: ', ' | append: tag | replace_first: '_', ': ' %}
            {%- endif -%}
          {%- endunless -%}

          {%- unless is_advanced_tag -%}
            {% assign title_tags = title_tags | append: ', ' | append: tag %}
          {%- endunless -%}
        {%- endfor -%}
        {{ 'general.title.tags' | t: tags: title_tags | remove_first: ', ' }}
      {%- endif -%}

      {%- if current_page != 1 -%}
        {{- 'general.title.page' | t: page: current_page -}}
      {%- endif -%}

      {%- unless page_title contains shop.name -%}
        {{- 'general.title.shop' | t: shop: shop.name -}}
      {%- endunless -%}
    </title>

    {% if page_description != blank %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'favicon' %}

    {% if template contains 'collection' and current_tags %}
      <meta name="robots" content="noindex" />
      <link rel="canonical" href="{{ shop.url }}{{ collection.url }}" />
    {% else %}
      <link rel="canonical" href="{{ canonical_url }}" />
    {% endif %}

    <meta name="viewport" content="width=device-width">

    {% assign twitter_handle = settings.social_twitter | split: 'twitter.com/' | last %}
    {%
      render 'social-meta-tags',
      twitter_handle: twitter_handle
    %}

    <link rel="preload" href="{{ settings.type_menu | font_url }}" as="font" crossorigin="anonymous">
    <link rel="preload" as="style" href="{{ 'wooden-master.css' | asset_url }}">

    {% include 'buddha-megamenu' %}
  {{ content_for_header }}





    {{ 'wooden-master.css' | asset_url | stylesheet_tag }}
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    {% comment %}Inject theme-object begin{% endcomment %}
    <script>
      window.Theme = window.Theme || {};
      window.Theme.routes = {
        "root_url": "{{ routes.root_url }}",
        "account_url": "{{ routes.account_url }}",
        "account_login_url": "{{ routes.account_login_url }}",
        "account_logout_url": "{{ routes.account_logout_url }}",
        "account_register_url": "{{ routes.account_register_url }}",
        "account_addresses_url": "{{ routes.account_addresses_url }}",
        "collections_url": "{{ routes.collections_url }}",
        "all_products_collection_url": "{{ routes.all_products_collection_url }}",
        "search_url": "{{ routes.search_url }}",
        "cart_url": "{{ routes.cart_url }}",
        "cart_add_url": "{{ routes.cart_add_url }}",
        "cart_change_url": "{{ routes.cart_change_url }}",
        "cart_clear_url": "{{ routes.cart_clear_url }}",
        "product_recommendations_url": "{{ routes.product_recommendations_url }}",
      };
    </script>
     
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Quattrocento:wght@400;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --bw-font-sans: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --bw-font-serif: 'Quattrocento', Georgia, serif;
        --bw-brand-ink: #211713;
        --bw-brand-blue: #355a6d;
        --bw-brand-warm: #a66a43;
        --bw-brand-sand: #f8f3ed;
        --bw-motion-ease: cubic-bezier(0.22, 1, 0.36, 1);
        --bw-motion-ease-soft: cubic-bezier(0.16, 1, 0.3, 1);
        --bw-motion-fast: 180ms;
        --bw-motion-base: 320ms;
        --bw-motion-slow: 620ms;
      }

      html {
        scroll-behavior: smooth;
      }

      [data-modal-container],
      [data-modal-container-1],
      [data-photoswipe] {
        display: none;
      }

      .modal-visible [data-modal-container],
      .modal-1-visible [data-modal-container-1],
      [data-photoswipe].pswp--open,
      [data-photoswipe].pswp--visible {
        display: block;
      }

      body.bw-motion-preload [data-site-header],
      body.bw-motion-preload .site-main {
        opacity: 0;
        transform: translateY(18px);
      }

      body.bw-page-ready [data-site-header],
      body.bw-page-ready .site-main,
      body.bw-page-leaving [data-site-header],
      body.bw-page-leaving .site-main {
        transition:
          opacity var(--bw-motion-slow) var(--bw-motion-ease-soft),
          transform var(--bw-motion-slow) var(--bw-motion-ease-soft);
      }

      body.bw-page-ready [data-site-header],
      body.bw-page-ready .site-main {
        opacity: 1;
        transform: none;
      }

      body.bw-page-leaving [data-site-header],
      body.bw-page-leaving .site-main {
        opacity: 0;
        transform: translateY(14px);
      }

      .bw-reveal {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity var(--bw-motion-slow) var(--bw-motion-ease-soft),
          transform var(--bw-motion-slow) var(--bw-motion-ease-soft);
        will-change: opacity, transform;
      }

      .bw-reveal.is-visible {
        opacity: 1;
        transform: none;
      }

      :where(
        .bw-header__cta,
        .bw-header__icon-link,
        .bw-header__menu-button,
        .bw-header__drawer-close,
        .bw-header__nav-link,
        .bw-header__support-link,
        .bw-header__utility-link,
        .bw-trust__card,
        .bw-trust__link,
        .bw-categories__card,
        .bw-featured__card,
        .bw-featured__cta,
        .bw-collection__card,
        .bw-collection__chip,
        .bw-collection__cta,
        .bw-product__thumb,
        .bw-product__option-chip,
        .bw-product__atc,
        .bw-product__buy-now,
        .bw-product__related-card,
        .bw-product__related-link,
        .bw-contact__card,
        .bw-contact__card-link,
        .bw-contact__submit,
        .bw-page__support-card,
        .bw-page__support-card a
      ) {
        transition:
          transform var(--bw-motion-base) var(--bw-motion-ease),
          box-shadow var(--bw-motion-base) var(--bw-motion-ease),
          border-color var(--bw-motion-base) var(--bw-motion-ease),
          background-color var(--bw-motion-base) var(--bw-motion-ease),
          color var(--bw-motion-fast) ease;
      }

      :where(
        .bw-trust__card,
        .bw-categories__card,
        .bw-featured__card,
        .bw-collection__card,
        .bw-product__related-card,
        .bw-contact__card,
        .bw-page__support-card
      ):hover {
        transform: translateY(-3px);
      }

      :where(
        .bw-header__cta,
        .bw-featured__cta,
        .bw-collection__cta,
        .bw-product__atc,
        .bw-product__buy-now,
        .bw-product__related-link,
        .bw-contact__card-link,
        .bw-contact__submit
      ):active {
        transform: translateY(0) scale(0.985);
      }

      .jdgm-widget,
      .jdgm-all-reviews-page,
      .jdgm-all-reviews-widget {
        font-family: var(--bw-font-sans) !important;
        color: #201713;
      }

      .jdgm-star,
      .jdgm-prev-badge__stars,
      .jdgm-carousel-item__rating {
        color: var(--bw-brand-warm) !important;
      }

      .bw-product__rating .jdgm-widget.jdgm-preview-badge {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
      }

      .bw-product__rating .jdgm-prev-badge {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        color: #5e4d44;
        font-size: 13px;
        font-weight: 600;
      }

      .bw-product__rating .jdgm-star {
        font-size: 14px !important;
        margin-right: 1px !important;
      }

      .bw-product__rating .jdgm-prev-badge__text {
        color: #6b5b53 !important;
        font-size: 12px !important;
        font-weight: 700 !important;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .bw-product__reviews .jdgm-widget.jdgm-review-widget,
      #judgeme_all_reviews_page .jdgm-all-reviews-widget {
        background: transparent !important;
        color: #201713 !important;
      }

      .bw-product__reviews .jdgm-rev,
      #judgeme_all_reviews_page .jdgm-rev {
        padding: 20px 22px !important;
        border-radius: 24px !important;
        border: 1px solid rgba(45, 33, 27, 0.08) !important;
        background: rgba(255, 255, 255, 0.86) !important;
        box-shadow: 0 18px 42px rgba(35, 24, 19, 0.06) !important;
        margin-bottom: 14px !important;
      }

      .bw-product__reviews .jdgm-rev__header,
      #judgeme_all_reviews_page .jdgm-rev__header {
        margin-bottom: 10px !important;
      }

      .bw-product__reviews .jdgm-rev__title,
      #judgeme_all_reviews_page .jdgm-rev__title {
        color: #201713 !important;
        font-size: 18px !important;
        font-weight: 700 !important;
        letter-spacing: -0.02em;
      }

      .bw-product__reviews .jdgm-rev__body,
      #judgeme_all_reviews_page .jdgm-rev__body {
        color: #5e4d44 !important;
        font-size: 14px !important;
        line-height: 1.8 !important;
      }

      .bw-product__reviews .jdgm-rev__author,
      .bw-product__reviews .jdgm-rev__timestamp,
      #judgeme_all_reviews_page .jdgm-rev__author,
      #judgeme_all_reviews_page .jdgm-rev__timestamp {
        color: #7a675b !important;
        font-size: 12px !important;
        font-weight: 600 !important;
      }

      .bw-product__reviews .jdgm-star,
      #judgeme_all_reviews_page .jdgm-star,
      .bw-testimonials__live .jdgm-star {
        font-size: 14px !important;
      }

      .bw-product__reviews .jdgm-sort-dropdown,
      .bw-product__reviews .jdgm-write-rev-link,
      #judgeme_all_reviews_page .jdgm-sort-dropdown,
      #judgeme_all_reviews_page .jdgm-write-rev-link {
        min-height: 42px !important;
        border-radius: 999px !important;
        border: 1px solid rgba(45, 33, 27, 0.12) !important;
        background: rgba(255, 255, 255, 0.92) !important;
        color: #201713 !important;
        font-family: var(--bw-font-sans) !important;
        font-size: 12px !important;
        font-weight: 700 !important;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        box-shadow: none !important;
      }

      .bw-product__reviews .jdgm-write-rev-link,
      #judgeme_all_reviews_page .jdgm-write-rev-link {
        display: inline-flex !important;
        align-items: center;
        justify-content: center;
        padding: 0 16px !important;
        background: #201713 !important;
        color: #f8f1eb !important;
        text-decoration: none !important;
      }

      .bw-product__reviews .jdgm-paginate__page,
      #judgeme_all_reviews_page .jdgm-paginate__page {
        min-width: 38px !important;
        min-height: 38px !important;
        border-radius: 999px !important;
        border: 1px solid rgba(45, 33, 27, 0.1) !important;
        background: rgba(255, 255, 255, 0.9) !important;
        color: #201713 !important;
        font-weight: 700 !important;
      }

      .bw-product__reviews .jdgm-paginate__page.jdgm-curt,
      #judgeme_all_reviews_page .jdgm-paginate__page.jdgm-curt {
        background: #201713 !important;
        color: #f8f1eb !important;
        border-color: #201713 !important;
      }

      .bw-testimonials__live .jdgm-all-reviews-text a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(45, 33, 27, 0.08);
        color: #201713;
        text-decoration: none;
      }

      .bw-testimonials__live .jdgm-all-reviews-text__text,
      .bw-testimonials__live .jdgm-carousel-number-of-reviews {
        color: #6b5b53 !important;
        font-size: 12px !important;
        font-weight: 700 !important;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .bw-testimonials__live .jdgm-carousel-title,
      #judgeme_all_reviews_page .jdgm-all-reviews-page__title {
        color: #201713 !important;
        font-family: var(--bw-font-sans) !important;
        font-size: clamp(24px, 3vw, 32px) !important;
        font-weight: 800 !important;
        line-height: 1.08 !important;
        letter-spacing: -0.03em;
      }

      .bw-testimonials__live .jdgm-carousel-title-and-link,
      #judgeme_all_reviews_page .jdgm-all-reviews-page__description {
        margin-bottom: 16px !important;
      }

      .bw-testimonials__live .jdgm-carousel-item {
        padding: 20px !important;
        border-radius: 24px !important;
        border: 1px solid rgba(45, 33, 27, 0.08) !important;
        background: rgba(255, 255, 255, 0.88) !important;
        box-shadow: 0 18px 42px rgba(35, 24, 19, 0.06) !important;
      }

      .bw-testimonials__live .jdgm-carousel-item__review {
        color: #5e4d44 !important;
        font-size: 14px !important;
        line-height: 1.8 !important;
      }

      .bw-testimonials__live .jdgm-carousel-item__reviewer-name,
      .bw-testimonials__live .jdgm-carousel-item__product {
        color: #201713 !important;
        font-size: 13px !important;
        font-weight: 700 !important;
      }

      #judgeme_all_reviews_page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 24px 72px;
      }

      #judgeme_all_reviews_page .jdgm-all-reviews-page__wrapper {
        display: grid;
        gap: 20px;
      }

      #judgeme_all_reviews_page .jdgm-all-reviews-page__description {
        color: #64544a;
        font-size: 15px;
        line-height: 1.8;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        body.bw-motion-preload [data-site-header],
        body.bw-motion-preload .site-main,
        .bw-reveal {
          opacity: 1;
          transform: none;
          transition: none !important;
        }

        :where(
          .bw-header__cta,
          .bw-header__icon-link,
          .bw-header__menu-button,
          .bw-header__drawer-close,
          .bw-header__nav-link,
          .bw-header__support-link,
          .bw-header__utility-link,
          .bw-trust__card,
          .bw-trust__link,
          .bw-categories__card,
          .bw-featured__card,
          .bw-featured__cta,
          .bw-collection__card,
          .bw-collection__chip,
          .bw-collection__cta,
          .bw-product__thumb,
          .bw-product__option-chip,
          .bw-product__atc,
          .bw-product__buy-now,
          .bw-product__related-card,
          .bw-product__related-link,
          .bw-contact__card,
          .bw-contact__card-link,
          .bw-contact__submit,
          .bw-page__support-card,
          .bw-page__support-card a
        ) {
          transition: none !important;
        }
      }
    </style>
    
