{% comment %} Fresh Hero Section {% endcomment %}
<style>
.hero { background: linear-gradient(135deg, #f5f0eb 0%, #e8e0d8 100%); padding: 80px 30px; }
.hero-inner { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.hero-content h1 { font-size: 52px; font-weight: 700; color: #1a1a1a; margin: 0 0 20px; font-family: 'Poppins', sans-serif; line-height: 1.15; }
.hero-content p { font-size: 18px; color: #555; margin: 0 0 30px; line-height: 1.7; }
.hero-buttons { display: flex; gap: 15px; flex-wrap: wrap; }
.btn-primary { display: inline-block; padding: 16px 36px; background: #c47d4e; color: white; text-decoration: none; font-weight: 600; border-radius: 6px; }
.btn-primary:hover { background: #a86840; }
.btn-secondary { display: inline-block; padding: 16px 36px; background: transparent; color: #1a1a1a; text-decoration: none; font-weight: 600; border: 2px solid #1a1a1a; border-radius: 6px; }
.btn-secondary:hover { background: #1a1a1a; color: white; }
.hero-image img { width: 100%; height: auto; border-radius: 12px; }
@media (max-width: 968px) { .hero-inner { grid-template-columns: 1fr; text-align: center; } .hero-buttons { justify-content: center; } .hero-content h1 { font-size: 36px; } }
</style>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <h1>Furniture That Tells Your Story</h1>
      <p>Discover handcrafted furniture that transforms your house into a home. Premium quality, timeless designs.</p>
      <div class="hero-buttons">
        <a href="/collections/all" class="btn-primary">Shop Now</a>
        <a href="/collections/living-room" class="btn-secondary">Explore Collection</a>
      </div>
    </div>
    <div class="hero-image">
      <div style="background: linear-gradient(135deg, #ddd, #ccc); aspect-ratio: 4/3; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 60px; color: #888;">
        🛋️
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
