}

.emi-icon {
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
}

.cod-emi-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cod-emi-label {
  font-weight: 700;
  font-size: 14px;
  color: #212529;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.cod-emi-desc {
  font-size: 12px;
