{% if section.settings.Shipping_line != blank %}
<div class="shipping_date">  
  {% capture msg %}
  {% assign x = settings.shipping_time | plus: 0 %}
  {% assign y = product.metafields.my_fields.estimate_shipping_time | plus: 0 %}
  {% assign z = section.settings.upto_time | plus: 0 %}
  {% assign total = x | plus: y %}
  {% assign three_total = total | plus: z %}
  {% assign msg = section.settings.Shipping_line | replace: '{x}', total | replace: '{y}', three_total %}
  {{ msg }}
  {% endcapture %}
  {% if selected_variant.available %}  
  <p>{{ msg }}</p>
  {% else %}
  {% if product.metafields.my_fields.soldout_message != blank %}
  <p>{{ product.metafields.my_fields.soldout_message }}</p>
  {% else %}
  <p>{{ msg }}</p>
  {% endif %}
  {% endif %}
</div>
{% endif %}

