<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Handle quantity selector toggle between dropdown and input for 10+
    var quantitySelect = document.querySelector('[data-product-quantity-select]');
    var quantityInputWrapper = document.querySelector('[data-quantity-input-wrapper]');
    var quantityInput = document.querySelector('[data-product-quantity-input]');

    if (quantitySelect && quantityInputWrapper && quantityInput) {
      quantitySelect.addEventListener('change', function() {
        if (this.value === '10+') {
          quantityInputWrapper.classList.remove('hidden');
          quantitySelect.closest('.form-field--qty-select').classList.add('hidden');
          quantityInput.focus();
        }
      });

      // Reset to dropdown when quantity input is cleared or set to < 10
      quantityInput.addEventListener('input', function() {
        var qty = parseInt(this.value, 10);
        if (qty && qty < 10 && qty > 0) {
          quantityInputWrapper.classList.add('hidden');
          quantitySelect.closest('.form-field--qty-select').classList.remove('hidden');
          quantitySelect.value = qty;
        }
      });
    }
  });
</script>
{% endform %}
