{% comment %}
  Product FAQ Accordion
  Based on wooden.com product page FAQ section
{% endcomment %}

{%- style -%}
  .ws-product-faq {
    margin-top: 40px;
    margin-bottom: 40px;
  }

  .ws-product-faq__title {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ws-product-faq__title svg {
    color: #28a745;
  }

  .ws-product-faq__list {
    border: 1px solid #e9ecef;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }

  .ws-product-faq__item {
    border-bottom: 1px solid #e9ecef;
  }

  .ws-product-faq__item:last-child {
    border-bottom: none;
  }

  .ws-product-faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1a;
    text-align: left;
    transition: background-color 0.2s ease;
  }

  .ws-product-faq__question:hover {
    background-color: #f8f9fa;
  }

  .ws-product-faq__question-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .ws-product-faq__item.active .ws-product-faq__question-icon {
    transform: rotate(180deg);
  }

  .ws-product-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ws-product-faq__item.active .ws-product-faq__answer {
    max-height: 500px;
  }

  .ws-product-faq__answer-inner {
    padding: 0 20px 16px 20px;
    color: #6c757d;
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .ws-product-faq__title {
      font-size: 20px;
    }

    .ws-product-faq__question {
      font-size: 14px;
      padding: 14px 16px;
    }

    .ws-product-faq__answer-inner {
      padding: 0 16px 14px 16px;
      font-size: 13px;
    }
  }
{%- endstyle -%}

<div class="ws-product-faq container mx-auto px-4">
  <h3 class="ws-product-faq__title">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
    </svg>
    Frequently Asked Questions
  </h3>

  <div class="ws-product-faq__list">
    {% comment %} FAQ Item 1 {% endcomment %}
    <div class="ws-product-faq__item">
      <button class="ws-product-faq__question" type="button" aria-expanded="false">
        <span>What is the delivery time for this product?</span>
        <span class="ws-product-faq__question-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </button>
      <div class="ws-product-faq__answer">
        <div class="ws-product-faq__answer-inner">
          The delivery time typically ranges from 5-7 business days depending on your location. Free shipping is available on orders above Rs. 500. Our delivery partner will contact you 24 hours before the scheduled delivery date.
        </div>
      </div>
    </div>

    {% comment %} FAQ Item 2 {% endcomment %}
    <div class="ws-product-faq__item">
      <button class="ws-product-faq__question" type="button" aria-expanded="false">
        <span>What is the warranty period for this product?</span>
        <span class="ws-product-faq__question-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </button>
      <div class="ws-product-faq__answer">
        <div class="ws-product-faq__answer-inner">
          This product comes with a 1 Year Manufacturer Warranty covering manufacturing defects and structural issues. The warranty does not cover wear and tear, misuse, or damage caused by improper assembly.
        </div>
      </div>
    </div>

    {% comment %} FAQ Item 3 {% endcomment %}
    <div class="ws-product-faq__item">
      <button class="ws-product-faq__question" type="button" aria-expanded="false">
        <span>Is assembly included with the product?</span>
        <span class="ws-product-faq__question-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </button>
      <div class="ws-product-faq__answer">
        <div class="ws-product-faq__answer-inner">
          Yes, professional assembly service is available for this product at no additional cost. Our expert team will assemble the product at your doorstep within 2-3 hours of delivery. You can opt for self-assembly if you prefer, as all necessary tools and instructions are included.
        </div>
      </div>
    </div>

    {% comment %} FAQ Item 4 {% endcomment %}
    <div class="ws-product-faq__item">
      <button class="ws-product-faq__question" type="button" aria-expanded="false">
        <span>What payment options are available?</span>
        <span class="ws-product-faq__question-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </button>
      <div class="ws-product-faq__answer">
        <div class="ws-product-faq__answer-inner">
          We offer multiple payment options including Credit/Debit Cards, Net Banking, UPI, Wallets, and EMI options. Cash on Delivery (COD) is also available for orders up to Rs. 50,000. All transactions are 100% secure with encrypted payment gateways.
        </div>
      </div>
    </div>

    {% comment %} FAQ Item 5 {% endcomment %}
    <div class="ws-product-faq__item">
      <button class="ws-product-faq__question" type="button" aria-expanded="false">
        <span>What is the return policy?</span>
        <span class="ws-product-faq__question-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </button>
      <div class="ws-product-faq__answer">
        <div class="ws-product-faq__answer-inner">
          We offer a 30-day easy return policy. If you're not satisfied with your purchase, you can return the product in its original condition with all packaging. A pickup will be arranged within 24-48 hours. Refunds are processed within 5-7 business days after product inspection.
        </div>
      </div>
    </div>

    {% comment %} FAQ Item 6 {% endcomment %}
    <div class="ws-product-faq__item">
      <button class="ws-product-faq__question" type="button" aria-expanded="false">
        <span>Can I customize the color or size?</span>
        <span class="ws-product-faq__question-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </button>
      <div class="ws-product-faq__answer">
        <div class="ws-product-faq__answer-inner">
          Yes, we offer customization options for color and size. Please contact our customer support team before placing the order to discuss available options. Customized products may require additional 3-5 business days for delivery and are non-returnable.
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqItems = document.querySelectorAll('.ws-product-faq__item');

    faqItems.forEach(item => {
      const question = item.querySelector('.ws-product-faq__question');

      question.addEventListener('click', function() {
        const isActive = item.classList.contains('active');

        // Close all other items
        faqItems.forEach(otherItem => {
          otherItem.classList.remove('active');
          otherItem.querySelector('.ws-product-faq__question').setAttribute('aria-expanded', 'false');
        });

        // Toggle current item
        if (!isActive) {
          item.classList.add('active');
          question.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
