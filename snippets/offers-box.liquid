{%- comment -%}
  Wooden PDP component: Detailed Offers Box
{%- endcomment -%}

<aside class="offers-box" aria-label="Bank offers and EMI plans" data-offers-box>
  <div class="offers-box__heading">
    <span class="offers-box__title">Offers &amp; EMI</span>
    <span class="offers-box__badge">Trusted payments</span>
  </div>
  <div class="offers-box__items">
    <div class="offers-box__item">
      <span class="offers-box__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="presentation" focusable="false">
          <path d="M12 2.4l7.5 3.3v6.2c0 4.4-3.2 8.3-7.5 9.7-4.3-1.4-7.5-5.3-7.5-9.7V5.7L12 2.4z" fill="currentColor" opacity="0.2"></path>
          <path d="M12 2.4l7.5 3.3v6.2c0 4.4-3.2 8.3-7.5 9.7-4.3-1.4-7.5-5.3-7.5-9.7V5.7L12 2.4zm0 2.4L6 7v4.9c0 3.4 2.4 6.4 6 7.8 3.6-1.4 6-4.4 6-7.8V7l-6-2.2z" fill="currentColor"></path>
          <path d="M10.3 12.8l-1.6-1.6-1.2 1.2 2.8 2.8 5-5-1.2-1.2-3.8 3.8z" fill="currentColor"></path>
        </svg>
      </span>
      <div class="offers-box__content">
        <span class="offers-box__label">Bank Offers</span>
        <span class="offers-box__text">10% off on HDFC Cards, up to ₹2,500.</span>
      </div>
    </div>
    <div class="offers-box__item">
      <span class="offers-box__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="presentation" focusable="false">
          <path d="M4 6.5h16a1.5 1.5 0 0 1 1.5 1.5v8a1.5 1.5 0 0 1-1.5 1.5H4A1.5 1.5 0 0 1 2.5 16v-8A1.5 1.5 0 0 1 4 6.5z" fill="currentColor" opacity="0.2"></path>
          <path d="M4 6.5h16a1.5 1.5 0 0 1 1.5 1.5v8a1.5 1.5 0 0 1-1.5 1.5H4A1.5 1.5 0 0 1 2.5 16v-8A1.5 1.5 0 0 1 4 6.5zm0 1.5v8h16v-8H4z" fill="currentColor"></path>
          <path d="M6.5 12h5v1.5h-5V12zm7.5 0h3.5v1.5H14V12z" fill="currentColor"></path>
        </svg>
      </span>
      <div class="offers-box__content">
        <span class="offers-box__label">EMI Plans</span>
        <span class="offers-box__text">Starts at ₹2,100/mo with no-cost EMI.</span>
      </div>
    </div>
  </div>
</aside>

<style>
.offers-box {
  margin-top: 16px;
  padding: 16px;
  background: linear-gradient(135deg, #fff3e0 0%, #fff8e1 100%);
  border-radius: 12px;
  border: 1px solid #ffe0b2;
}

.offers-box__heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.offers-box__title {
  font-weight: 700;
  font-size: 14px;
  color: #e65100;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.offers-box__badge {
  font-size: 11px;
  color: #f57c00;
  background: rgba(255, 152, 0, 0.15);
  padding: 4px 8px;
  border-radius: 20px;
  font-weight: 500;
}

.offers-box__items {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.offers-box__item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px;
  background: white;
  border-radius: 10px;
  box-shadow: 0 2px 8px rgba(230, 81, 0, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.offers-box__item:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(230, 81, 0, 0.15);
}

.offers-box__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #ff9800 0%, #ffc107 100%);
  border-radius: 8px;
  flex-shrink: 0;
}

.offers-box__icon svg {
  width: 20px;
  height: 20px;
  color: white;
}

.offers-box__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex: 1;
}

.offers-box__label {
  font-weight: 600;
  font-size: 13px;
  color: #e65100;
}

.offers-box__text {
  font-size: 12px;
  color: #757575;
  line-height: 1.4;
}

@media (max-width: 768px) {
  .offers-box {
    padding: 12px;
  }

  .offers-box__title {
    font-size: 13px;
  }

  .offers-box__item {
    padding: 8px;
  }

  .offers-box__icon {
    width: 32px;
    height: 32px;
  }

  .offers-box__label {
    font-size: 12px;
  }

  .offers-box__text {
    font-size: 11px;
  }
}
</style>
