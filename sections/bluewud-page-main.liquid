{% comment %} Bluewud Generic Page {% endcomment %}
{%- style -%}
  .page-content {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 30px;
  }
  .page-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .page-header h1 {
    font-size: 40px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 15px;
    font-family: 'Poppins', sans-serif;
  }
  .page-header p {
    font-size: 16px;
    color: #666;
    margin: 0;
  }
  .page-body {
    font-size: 16px;
    line-height: 1.8;
    color: #444;
  }
  .page-body h2 {
    font-size: 28px;
    font-weight: 600;
    margin: 40px 0 20px;
    color: #1a1a1a;
  }
  .page-body h3 {
    font-size: 22px;
    font-weight: 600;
    margin: 30px 0 15px;
    color: #1a1a1a;
  }
  .page-body p {
    margin-bottom: 20px;
  }
  .page-body ul, .page-body ol {
    margin-bottom: 20px;
    padding-left: 25px;
  }
  .page-body li {
    margin-bottom: 10px;
  }
  .page-body a {
    color: #c47d4e;
    text-decoration: underline;
  }
  .page-body img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 20px 0;
  }
  .contact-form {
    background: #f9f9f9;
    padding: 40px;
    border-radius: 12px;
    margin-top: 40px;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #333;
    margin-bottom: 8px;
  }
  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 14px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 15px;
    font-family: inherit;
  }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: #c47d4e;
  }
  .form-group textarea {
    min-height: 150px;
    resize: vertical;
  }
  .submit-btn {
    padding: 16px 40px;
    background: #c47d4e;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
  }
  .submit-btn:hover {
    background: #a86840;
  }
  .contact-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-top: 50px;
  }
  .contact-item {
    text-align: center;
    padding: 30px;
    background: #f9f9f9;
    border-radius: 12px;
  }
  .contact-item-icon {
    font-size: 40px;
    margin-bottom: 15px;
  }
  .contact-item h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .contact-item p {
    color: #666;
    margin: 0;
    font-size: 14px;
  }
  @media (max-width: 768px) {
    .contact-info { grid-template-columns: 1fr; }
    .contact-form { padding: 25px; }
  }
{%- endstyle -%}

<div class="page-content">
  <div class="page-header">
    <h1>{{ page.title }}</h1>
  </div>
  
  <div class="page-body">
    {{ page.content }}
  </div>
  
  {% if page.template_suffix == 'contact' or page.title contains 'Contact' %}
  <div class="contact-info">
    <div class="contact-item">
      <div class="contact-item-icon">📧</div>
      <h3>Email Us</h3>
      <p>support@bluewud.com</p>
    </div>
    <div class="contact-item">
      <div class="contact-item-icon">📞</div>
      <h3>Call Us</h3>
      <p>+91 8383013068</p>
    </div>
    <div class="contact-item">
      <div class="contact-item-icon">📍</div>
      <h3>Visit Us</h3>
      <p>Mumbai, India</p>
    </div>
  </div>
  
  <form class="contact-form" action="/contact" method="post">
    <input type="hidden" name="form_type" value="contact">
    <input type="hidden" name="utf8" value="✓">
    
    <div class="form-group">
      <label for="name">Your Name</label>
      <input type="text" id="name" name="contact[name]" required>
    </div>
    
    <div class="form-group">
      <label for="email">Email Address</label>
      <input type="email" id="email" name="contact[email]" required>
    </div>
    
    <div class="form-group">
      <label for="phone">Phone Number</label>
      <input type="tel" id="phone" name="contact[phone]">
    </div>
    
    <div class="form-group">
      <label for="message">Message</label>
      <textarea id="message" name="contact[body]" required></textarea>
    </div>
    
    <button type="submit" class="submit-btn">Send Message</button>
  </form>
  {% endif %}
</div>

{% schema %}
{
  "name": "Page",
  "presets": [
    {
      "name": "Page"
    }
  ]
}
{% endschema %}
