{% comment %} Bluewud Cart Page {% endcomment %}
{%- style -%}
  .cart-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 50px 30px;
  }
  .cart-header {
    margin-bottom: 40px;
  }
  .cart-header h1 {
    font-size: 36px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    font-family: 'Poppins', sans-serif;
  }
  .cart-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .cart-empty-icon {
    font-size: 80px;
    margin-bottom: 20px;
  }
  .cart-empty h2 {
    font-size: 24px;
    margin-bottom: 15px;
  }
  .cart-empty p {
    color: #888;
    margin-bottom: 30px;
  }
  .cart-empty a {
    display: inline-block;
    padding: 15px 35px;
    background: #c47d4e;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
  }
  .cart-content {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 50px;
  }
  .cart-items {
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
  }
  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 20px;
    padding: 25px;
    border-bottom: 1px solid #eee;
    align-items: center;
  }
  .cart-item:last-child {
    border-bottom: none;
  }
  .cart-item-image {
    aspect-ratio: 1;
    background: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
  }
  .cart-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item-details h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .cart-item-details h3 a {
    color: #1a1a1a;
    text-decoration: none;
  }
  .cart-item-variant {
    font-size: 14px;
    color: #888;
    margin-bottom: 10px;
  }
  .cart-item-price {
    font-size: 16px;
    font-weight: 600;
    color: #c47d4e;
  }
  .cart-item-remove {
    color: #e74c3c;
    font-size: 14px;
    text-decoration: underline;
    cursor: pointer;
  }
  .cart-summary {
    background: #f9f9f9;
    border-radius: 12px;
    padding: 30px;
    height: fit-content;
  }
  .cart-summary h2 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #ddd;
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    font-size: 15px;
  }
  .summary-row.total {
    font-size: 18px;
    font-weight: 700;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #ddd;
  }
  .checkout-btn {
    width: 100%;
    padding: 18px;
    background: #c47d4e;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 25px;
    transition: background 0.3s;
  }
  .checkout-btn:hover {
    background: #a86840;
  }
  .free-shipping-progress {
    margin-top: 20px;
    padding: 15px;
    background: #fff8f5;
    border-radius: 8px;
    text-align: center;
  }
  .progress-bar {
    height: 6px;
    background: #eee;
    border-radius: 3px;
    margin-top: 10px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: #27ae60;
    border-radius: 3px;
  }
  .continue-shopping {
    display: block;
    text-align: center;
    margin-top: 15px;
    color: #666;
    text-decoration: underline;
  }
  @media (max-width: 968px) {
    .cart-content { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<div class="cart-page">
  <div class="cart-header">
    <h1>Shopping Cart</h1>
  </div>
  
  {% if cart.items.size == 0 %}
    <div class="cart-empty">
      <div class="cart-empty-icon">🛒</div>
      <h2>Your cart is empty</h2>
      <p>Looks like you haven't added anything to your cart yet.</p>
      <a href="/collections/all">Start Shopping</a>
    </div>
  {% else %}
    <div class="cart-content">
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item-image">
              {% if item.image != blank %}
                {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
              {% else %}
                <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:30px;color:#aaa;">🛋️</div>
              {% endif %}
            </div>
            
            <div class="cart-item-details">
              <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
              {% if item.variant.title != 'Default Title' %}
                <p class="cart-item-variant">{{ item.variant.title }}</p>
              {% endif %}
              <p class="cart-item-price">{{ item.price | money }}</p>
            </div>
            
            <div>
              <form method="post" action="/cart/update">
                <input type="hidden" name="updates[]" value="{{ item.key }}">
                <input type="number" name="quantity" value="{{ item.quantity }}" min="0" style="width:60px;padding:8px;text-align:center;border:1px solid #ddd;border-radius:4px;">
              </form>
              <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item-remove">Remove</a>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div class="cart-summary">
        <h2>Order Summary</h2>
        
        <div class="summary-row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span>Calculated at checkout</span>
        </div>
        <div class="summary-row">
          <span>Tax</span>
          <span>Calculated at checkout</span>
        </div>
        
        <button class="checkout-btn" onclick="window.location.href='/checkout'">
          Proceed to Checkout
        </button>
        
        {% assign free_shipping_threshold = 999 %}
        {% assign current_total = cart.total_price %}
        {% assign progress = current_total | times: 100 | divided_by: free_shipping_threshold %}
        {% if progress > 100 %}{% assign progress = 100 %}{% endif %}
        
        <div class="free-shipping-progress">
          {% if current_total >= free_shipping_threshold %}
            <p>🎉 You've unlocked FREE shipping!</p>
          {% else %}
            <p>Add ₹{{ free_shipping_threshold | minus: current_total | money }} more for FREE shipping</p>
            <div class="progress-bar">
              <div class="progress-fill" style="width: {{ progress }}%"></div>
            </div>
          {% endif %}
        </div>
        
        <a href="/collections/all" class="continue-shopping">Continue Shopping</a>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart Page",
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
