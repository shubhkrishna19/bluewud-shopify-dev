{% comment %} Fresh Product Page Main Section {% endcomment %}
<style>
.product-page { max-width: 1400px; margin: 0 auto; padding: 40px 30px; }
.product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
.product-gallery-main { aspect-ratio: 1; background: #f5f5f5; border-radius: 12px; overflow: hidden; margin-bottom: 15px; }
.product-gallery-main img { width: 100%; height: 100%; object-fit: cover; }
.gallery-thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.thumb { aspect-ratio: 1; background: #f5f5f5; border-radius: 8px; overflow: hidden; }
.thumb img { width: 100%; height: 100%; object-fit: cover; }
.product-info h1 { font-size: 32px; font-weight: 700; color: #1a1a1a; margin: 0 0 15px; }
.product-price { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
.price-current { font-size: 28px; font-weight: 700; color: #c47d4e; }
.price-original { font-size: 18px; color: #999; text-decoration: line-through; }
.add-to-cart { width: 100%; padding: 18px; background: #c47d4e; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; margin-bottom: 20px; }
.add-to-cart:hover { background: #a86840; }
.delivery-info { background: #f9f9f9; padding: 20px; border-radius: 8px; }
.delivery-item { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; font-size: 14px; color: #555; }
@media (max-width: 968px) { .product-grid { grid-template-columns: 1fr; } }
</style>

<div class="product-page">
  <div class="product-grid">
    <div class="product-gallery">
      <div class="product-gallery-main">
        {% if product.featured_image != blank %}
          {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'eager' }}
        {% else %}
          <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:60px;color:#aaa;">🛋️</div>
        {% endif %}
      </div>
      <div class="gallery-thumbs">
        {% for image in product.images limit: 4 %}
          <div class="thumb">{{ image | image_url: width: 200 | image_tag: loading: 'lazy' }}</div>
        {% endfor %}
      </div>
    </div>
    <div class="product-info">
      <h1>{{ product.title }}</h1>
      <div class="product-price">
        <span class="price-current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="price-original">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="add-to-cart">🛒 Add to Cart</button>
      </form>
      <div class="delivery-info">
        <div class="delivery-item">🚚 Free Shipping on Orders Above ₹999</div>
        <div class="delivery-item">↩️ Easy 30-Day Returns</div>
        <div class="delivery-item">🛡️ 7 Years Warranty</div>
      </div>
      {% if product.description != blank %}
      <div style="margin-top:30px;padding-top:30px;border-top:1px solid #eee;">
        <h3>Description</h3>
        {{ product.description }}
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Page",
  "presets": [{ "name": "Product Page" }]
}
{% endschema %}
