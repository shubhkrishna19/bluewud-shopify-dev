              </tr>
              <tr class="border-b border-[var(--color-border-primary)]">
                <td class="py-3 px-4 font-bold text-[var(--color-text-primary)] bg-[var(--color-bg-secondary)]">Color</td>
                <td class="py-3 px-4 text-[var(--color-text-secondary)]">Walnut Finish</td>
              </tr>
