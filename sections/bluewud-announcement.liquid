{% comment %} Bluewud Announcement Bar {% endcomment %}
{%- style -%}
  .announcement-bar {
    background: #1a1a1a;
    color: #ffffff;
    padding: 12px 20px;
    text-align: center;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    position: relative;
  }
  .announcement-bar a {
    color: #ffffff;
    text-decoration: underline;
  }
  .announcement-bar a:hover {
    color: #f5f5f5;
  }
{%- endstyle -%}

{% if section.settings.text != blank %}
  <div class="announcement-bar">
    {{ section.settings.text }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Free Shipping on Orders Above ₹999"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
