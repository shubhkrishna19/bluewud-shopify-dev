{% comment %}
  Wooden: Category Navigation Strip (H-06)
  Horizontal category navigation below hero section
  Shows furniture categories: TV Units, Beds, Wardrobes, Shelves, Tables, Shoe Racks, Dressers, etc.
{% endcomment %}

<section class="ws-category-strip" aria-label="Shop by Category">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <h2 class="ws-category-strip__heading">{{ section.settings.title }}</h2>
    {% else %}
      <h2 class="ws-category-strip__heading">Shop by Category</h2>
    {% endif %}
    <div class="ws-category-strip__wrapper">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="ws-category-item" {{ block.shopify_attributes }}>
          <div class="ws-category-item__image-wrapper">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '120x120', crop: 'center' }}"
                   alt="{{ block.settings.title | escape }}"
                   class="ws-category-item__image"
                   width="120"
                   height="120"
                   loading="lazy">
            {% else %}
              <div class="ws-category-item__placeholder">
                {% case block.settings.title %}
                  {% when 'TV Units' or 'TV Unit' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline></svg>
                  {% when 'Beds' or 'Bed' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"></path><path d="M2 8h18a2 2 0 0 1 2 2v10"></path><path d="M2 17h20"></path><path d="M6 8v9"></path></svg>
                  {% when 'Wardrobes' or 'Wardrobe' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                  {% when 'Shelves' or 'Shelf' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"></path><path d="M3 9h18"></path><path d="M3 15h18"></path></svg>
                  {% when 'Tables' or 'Table' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="12" x2="21" y2="12"></line></svg>
                  {% when 'Shoe Racks' or 'Shoe Rack' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line><line x1="2" y1="16" x2="22" y2="16"></line></svg>
                  {% when 'Dressers' or 'Dresser' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="12" x2="20" y2="12"></line><circle cx="12" cy="17" r="1"></circle></svg>
                  {% when 'Sofas' or 'Sofa' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"></path><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H6v-2a2 2 0 0 0-4 0Z"></path><path d="M4 18v2"></path><path d="M20 18v2"></path></svg>
                  {% when 'Dining' or 'Dining Set' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v10"></path><path d="M18.5 8a2.5 2.5 0 0 1 0 5"></path><path d="M12 12v10"></path><line x1="12" y1="12" x2="18.5" y2="8"></line><circle cx="7" cy="17" r="3"></circle><circle cx="17" cy="17" r="3"></circle></svg>
                  {% when 'Study' or 'Study Table' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                  {% when 'Chairs' or 'Chair' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3"></path><path d="M3 11v5a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H7v-2a2 2 0 0 0-4 0Z"></path><path d="M5 18v2"></path><path d="M19 18v2"></path></svg>
                  {% when 'Kids Room' or 'Kids' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"></circle><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2"></path><path d="M16 3l-2 3-2-3"></path><path d="M12 14v4"></path></svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                {% endcase %}
              </div>
            {% endif %}
          </div>
          <span class="ws-category-item__title">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WS Category Strip",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "TV Units"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WS Category Strip",
      "blocks": [
        { "type": "category", "settings": { "title": "TV Units", "link": "/collections/tv-units" } },
        { "type": "category", "settings": { "title": "Beds", "link": "/collections/beds" } },
        { "type": "category", "settings": { "title": "Wardrobes", "link": "/collections/wardrobes" } },
        { "type": "category", "settings": { "title": "Shelves", "link": "/collections/shelves" } },
        { "type": "category", "settings": { "title": "Tables", "link": "/collections/tables" } },
        { "type": "category", "settings": { "title": "Shoe Racks", "link": "/collections/shoe-racks" } },
        { "type": "category", "settings": { "title": "Dressers", "link": "/collections/dressers" } },
        { "type": "category", "settings": { "title": "Sofas", "link": "/collections/sofas" } },
        { "type": "category", "settings": { "title": "Dining", "link": "/collections/dining-sets" } },
        { "type": "category", "settings": { "title": "Study", "link": "/collections/study-tables" } },
        { "type": "category", "settings": { "title": "Chairs", "link": "/collections/chairs" } },
        { "type": "category", "settings": { "title": "Kids Room", "link": "/collections/kids-room" } }
      ]
    }
  ]
}
{% endschema %}
