<section class="ws-press">
  <div class="page-width">
    <div class="ws-press__header">
      <h2 class="ws-press__title">Recognized by the best</h2>
    </div>
    <div class="ws-press__container">
        <div class="ws-press__items">
          <div class="ws-press-item">
            <svg class="ws-press-logo" viewBox="0 0 120 40" fill="currentColor">
              <text x="10" y="28" font-family="Georgia, serif" font-size="18" font-weight="bold">FORBES</text>
            </svg>
          </div>
          <div class="ws-press-item">
            <svg class="ws-press-logo" viewBox="0 0 120 40" fill="currentColor">
              <text x="10" y="28" font-family="Arial, sans-serif" font-size="16" font-weight="bold">Business</text>
            </svg>
          </div>
          <div class="ws-press-item">
            <svg class="ws-press-logo" viewBox="0 0 120 40" fill="currentColor">
              <text x="10" y="28" font-family="Arial, sans-serif" font-size="14" font-weight="bold">TechCrunch</text>
            </svg>
          </div>
          <div class="ws-press-item">
            <svg class="ws-press-logo" viewBox="0 0 120 40" fill="currentColor">
              <text x="10" y="28" font-family="Georgia, serif" font-size="16" font-weight="bold">Vogue</text>
            </svg>
          </div>
          <div class="ws-press-item">
            <svg class="ws-press-logo" viewBox="0 0 120 40" fill="currentColor">
              <text x="10" y="28" font-family="Arial, sans-serif" font-size="14" font-weight="bold">Elle Decor</text>
            </svg>
          </div>
          <div class="ws-press-item">
            <svg class="ws-press-logo" viewBox="0 0 120 40" fill="currentColor">
              <text x="10" y="28" font-family="Arial, sans-serif" font-size="14" font-weight="bold">Architect</text>
            </svg>
          </div>
        </div>
    </div>
  </div>
</section>



