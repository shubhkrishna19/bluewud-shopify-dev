{% comment %} Bluewud Categories Section {% endcomment %}
{%- style -%}
  .bluewud-categories {
    padding: 70px 30px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .section-title {
    text-align: center;
    margin-bottom: 50px;
  }
  .section-title h2 {
    font-size: 36px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 12px;
    font-family: 'Poppins', sans-serif;
  }
  .section-title p {
    font-size: 16px;
    color: #666;
    margin: 0;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }
  .category-item {
    text-align: center;
    text-decoration: none;
    transition: transform 0.3s ease;
  }
  .category-item:hover {
    transform: translateY(-5px);
  }
  .category-image {
    width: 100%;
    aspect-ratio: 1;
    background: #f5f5f5;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
  }
  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .category-item h3 {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
  }
  .category-item span {
    font-size: 12px;
    color: #888;
  }
  @media (max-width: 968px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .bluewud-categories { padding: 50px 20px; }
    .section-title h2 { font-size: 28px; }
  }
{%- endstyle -%}

<div class="bluewud-categories">
  <div class="section-title">
    <h2>Shop by Category</h2>
    <p>Find the perfect furniture for every room</p>
  </div>
  
  <div class="categories-grid">
    <a href="/collections/sofas" class="category-item">
      <div class="category-image">🛋️</div>
      <h3>Sofa Sets</h3>
      <span>200+ Designs</span>
    </a>
    
    <a href="/collections/beds" class="category-item">
      <div class="category-image">🛏️</div>
      <h3>Beds</h3>
      <span>150+ Designs</span>
    </a>
    
    <a href="/collections/dining" class="category-item">
      <div class="category-image">🍽️</div>
