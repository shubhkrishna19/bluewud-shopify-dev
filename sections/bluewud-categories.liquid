      <span>80+ Designs</span>
    </a>
    
    <a href="/collections/wardrobes" class="category-item">
      <div class="category-image">🚪</div>
      <h3>Wardrobes</h3>
      <span>100+ Designs</span>
    </a>
    
    <a href="/collections/tv-units" class="category-item">
      <div class="category-image">📺</div>
      <h3>TV Units</h3>
      <span>75+ Designs</span>
    </a>
    
    <a href="/collections/study-tables" class="category-item">
