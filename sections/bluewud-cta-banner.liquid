{% comment %} Bluewud CTA Banner {% endcomment %}
{%- style -%}
  .bluewud-cta {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
    padding: 80px 30px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 10% 90%, rgba(196, 125, 78, 0.3) 0%, transparent 40%),
      radial-gradient(circle at 90% 10%, rgba(196, 125, 78, 0.2) 0%, transparent 40%);
  }
  .cta-inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .cta-inner h2 {
    font-size: 40px;
    font-weight: 700;
    color: white;
    margin: 0 0 20px;
    font-family: 'Poppins', sans-serif;
  }
  .cta-inner p {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    margin: 0 0 35px;
    line-height: 1.7;
  }
  .cta-button {
    display: inline-block;
    padding: 18px 45px;
    background: #c47d4e;
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    border-radius: 6px;
    transition: all 0.3s ease;
  }
  .cta-button:hover {
    background: #a86840;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(196, 125, 78, 0.4);
  }
  @media (max-width: 768px) {
    .cta-inner h2 { font-size: 28px; }
    .cta-inner p { font-size: 16px; }
    .bluewud-cta { padding: 60px 20px; }
  }
{%- endstyle -%}

<div class="bluewud-cta">
  <div class="cta-bg"></div>
  <div class="cta-inner">
    <h2>{{ section.settings.heading | default: "Custom Furniture, Made Your Way" }}</h2>
    <p>{{ section.settings.text | default: "Get personalized furniture tailored to your style and space." }}</p>
    <a href="{{ section.settings.link | default: '/pages/contact' }}" class="cta-button">
      {{ section.settings.cta | default: "Get Custom Quote" }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "cta",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
