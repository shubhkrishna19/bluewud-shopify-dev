<footer class="ws-footer" aria-label="Wooden Footer">
  <!-- Trust Strip -->
  <div class="ws-footer__trust-strip">
    <div class="page-width">
      <div class="grid">
        <div class="ws-trust-item">
          <div class="ws-trust-item__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h4>100% Quality</h4>
          <p>Inspected at Every Step</p>
        </div>
        <div class="ws-trust-item">
          <div class="ws-trust-item__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h4>Fast Delivery</h4>
          <p>Across 300+ Cities</p>
        </div>
        <div class="ws-trust-item">
          <div class="ws-trust-item__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          </div>
          <h4>Secure Payment</h4>
          <p>SSL Encrypted Gateway</p>
        </div>
        <div class="ws-trust-item">
          <div class="ws-trust-item__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          </div>
          <h4>24/7 Support</h4>
          <p>We are here to help</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="ws-footer__main">
    <div class="page-width">
      <div class="grid">
        <!-- Brand Column -->
        <div class="ws-footer-brand">
          <h3>{{ section.settings.brand_title | default: 'Wooden' }}</h3>
          <p>{{ section.settings.brand_description | default: 'Experience the finest wood furniture collection at our online furniture store. We provide durable and stylish home furniture for every corner of your room.' }}</p>

          {%- if section.settings.enable_social_links -%}
          <div class="ws-footer-social">
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_linkedin_link != blank -%}
              <a href="{{ settings.social_linkedin_link }}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            {%- endif -%}
          </div>
          {%- endif -%}
        </div>

        <!-- About Us Column -->
        <div class="ws-footer-links">
          <h4>{{ section.settings.about_menu_title | default: 'About Us' }}</h4>
          <ul>
            {%- if section.settings.about_menu != blank and linklists[section.settings.about_menu].links.size > 0 -%}
              {%- for link in linklists[section.settings.about_menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="/pages/about-us">About Us</a></li>
              <li><a href="/pages/our-story">Our Story</a></li>
              <li><a href="/pages/store-locator">Experience Stores</a></li>
              <li><a href="/pages/interior-design">Interior Design</a></li>
              <li><a href="/pages/careers">Careers</a></li>
              <li><a href="/pages/press">Press & Media</a></li>
            {%- endif -%}
          </ul>
        </div>

        <!-- Customer Service Column -->
        <div class="ws-footer-links">
          <h4>{{ section.settings.customer_service_menu_title | default: 'Customer Service' }}</h4>
          <ul>
            {%- if section.settings.customer_service_menu != blank and linklists[section.settings.customer_service_menu].links.size > 0 -%}
              {%- for link in linklists[section.settings.customer_service_menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="/pages/contact-us">Contact Us</a></li>
              <li><a href="/pages/faqs">FAQs</a></li>
              <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
              <li><a href="/pages/return-policy">Return Policy</a></li>
              <li><a href="/pages/cancellation">Order Cancellation</a></li>
              <li><a href="/pages/tracking">Track Order</a></li>
            {%- endif -%}
          </ul>
        </div>

        <!-- Quick Links Column -->
        <div class="ws-footer-links">
          <h4>{{ section.settings.quick_links_menu_title | default: 'Quick Links' }}</h4>
          <ul>
            {%- if section.settings.quick_links_menu != blank and linklists[section.settings.quick_links_menu].links.size > 0 -%}
              {%- for link in linklists[section.settings.quick_links_menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="/collections/sofa">Sofas</a></li>
              <li><a href="/collections/bed">Beds</a></li>
              <li><a href="/collections/dining-table">Dining Tables</a></li>
              <li><a href="/collections/wardrobe">Wardrobes</a></li>
              <li><a href="/collections/office-furniture">Office Furniture</a></li>
              <li><a href="/collections/kids-furniture">Kids Furniture</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>

      <!-- Contact Info Row -->
      <div class="ws-footer-contact">
        <div class="ws-footer-contact__item">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          <span>{{ section.settings.phone_number | default: '+91-9314444747' }}</span>
        </div>
        <div class="ws-footer-contact__item">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          <span>{{ section.settings.email | default: 'info@wooden.com' }}</span>
        </div>
      </div>

      <!-- Newsletter Section -->
      {%- if section.settings.enable_newsletter -%}
      <div class="ws-footer-newsletter">
        <div class="ws-footer-newsletter__content">
          <h3>{{ section.settings.newsletter_heading | default: 'Subscribe to Our Newsletter' }}</h3>
          <p>{{ section.settings.newsletter_description | default: 'Get exclusive deals and early access to new products.' }}</p>
          {%- form 'customer', id: 'ContactFooterNewsletter', class: 'ws-newsletter-form' -%}
            {%- if form.posted_successfully? -%}
              <p class="ws-newsletter-success" role="status">{{ 'footer.newsletter_success' | t }}</p>
            {%- else -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="ws-newsletter-input-group">
                <input
                  type="email"
                  name="contact[email]"
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email address' }}"
                  required
                  aria-required="true"
                  autocomplete="email"
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                    aria-describedby="ContactFooterNewsletter-error"
                  {% endif %}
                >
                <button type="submit" name="commit" aria-label="Subscribe">
                  {{ section.settings.newsletter_button_text | default: 'Subscribe' }}
                </button>
              </div>
              {%- if form.errors contains 'email' -%}
                <p class="ws-newsletter-error" id="ContactFooterNewsletter-error" role="alert">
                  {{ form.errors.translated_fields['email'] | capitalize }}: {{ form.errors.messages['email'] }}.
                </p>
              {%- endif -%}
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
      {%- endif -%}

      <!-- Footer Bottom -->
      <div class="ws-footer-bottom">
        <p>&copy; {{ 'now' | date: "%Y" }} <strong>{{ section.settings.copyright_text | default: 'Wooden' }}</strong>. {{ section.settings.copyright_tagline | default: 'All rights reserved.' }}</p>
        <div class="ws-footer-payments">
          <span class="ws-payment-label">{{ section.settings.payment_label | default: 'We Accept' }}</span>
          {%- if section.settings.enable_payment_icons -%}
          <div class="ws-payment-icons">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>
          {%- else -%}
          <div class="ws-payment-icons">
            <img src="https://cdn.shopify.com/s/files/1/0551/9246/0451/files/visa.svg" loading="lazy" alt="Visa" onerror="this.style.display='none'">
            <img src="https://cdn.shopify.com/s/files/1/0551/9246/0451/files/mastercard.svg" loading="lazy" alt="Mastercard" onerror="this.style.display='none'">
            <img src="https://cdn.shopify.com/s/files/1/0551/9246/0451/files/amex.svg" loading="lazy" alt="American Express" onerror="this.style.display='none'">
            <img src="https://cdn.shopify.com/s/files/1/0551/9246/0451/files/rupay.svg" loading="lazy" alt="RuPay" onerror="this.style.display='none'">
            <img src="https://cdn.shopify.com/s/files/1/0551/9246/0451/files/paytm.svg" loading="lazy" alt="Paytm" onerror="this.style.display='none'">
            <img src="https://cdn.shopify.com/s/files/1/0551/9246/0451/files/upi.svg" loading="lazy" alt="UPI" onerror="this.style.display='none'">
          </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "WS Premium Footer",
  "tag": "footer",
  "class": "ws-footer-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Brand Settings"
    },
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand Title",
      "default": "Wooden"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Experience the finest wood furniture collection at our online furniture store. We provide durable and stylish home furniture for every corner of your room."
    },
    {
      "type": "checkbox",
      "id": "enable_social_links",
      "label": "Enable Social Links",
      "default": true,
      "info": "Configure social links in Theme Settings > Social media"
    },
    {
      "type": "header",
      "content": "Footer Menus"
    },
    {
      "type": "text",
      "id": "about_menu_title",
      "label": "About Us Column Title",
      "default": "About Us"
    },
    {
      "type": "link_list",
      "id": "about_menu",
      "label": "About Us Menu"
    },
    {
      "type": "text",
      "id": "customer_service_menu_title",
      "label": "Customer Service Column Title",
      "default": "Customer Service"
    },
    {
      "type": "link_list",
      "id": "customer_service_menu",
      "label": "Customer Service Menu"
    },
    {
      "type": "text",
      "id": "quick_links_menu_title",
      "label": "Quick Links Column Title",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "quick_links_menu",
      "label": "Quick Links Menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "enable_newsletter",
      "label": "Enable Newsletter Signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Subscribe to Our Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_description",
      "label": "Newsletter Description",
      "default": "Get exclusive deals and early access to new products."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email Placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "label": "Button Text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "+91-9314444747"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "info@wooden.com"
    },
    {
      "type": "header",
      "content": "Payment & Copyright"
    },
    {
      "type": "checkbox",
      "id": "enable_payment_icons",
      "label": "Use Shopify Payment Icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_label",
      "label": "Payment Label",
      "default": "We Accept"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Brand Name",
      "default": "Wooden"
    },
    {
      "type": "text",
      "id": "copyright_tagline",
      "label": "Copyright Tagline",
      "default": "All rights reserved."
    }
  ],
  "presets": [
    {
      "name": "WS Premium Footer"
    }
  ]
}
{% endschema %}
