
{% comment %}
  Wooden Hero Hybrid Section
  Full-width promotional banner with main hero content
{% endcomment %}

{%- style -%}
  .ws-hero-promotional-banner {
    background: linear-gradient(90deg, #C7431A 0%, #E85D2D 50%, #C7431A 100%);
    padding: 12px 0;
    position: relative;
    overflow: hidden;
  }

  .ws-hero-promotional-banner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.15) 50%, transparent 100%);
    animation: ws-promo-shimmer 3s infinite;
  }

  @keyframes ws-promo-shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .ws-hero-promotional-banner .ws-promo-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    text-align: center;
  }

  .ws-hero-promotional-banner .ws-promo-icon {
    font-size: 1.2rem;
  }

  .ws-hero-promotional-banner .ws-promo-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #ffffff;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ws-hero-promotional-banner .ws-promo-highlight {
    background: #ffffff;
    color: #C7431A;
    padding: 4px 16px;
    border-radius: 4px;
    font-weight: 800;
    font-size: 1rem;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(199, 67, 26, 0.2);
  }

  .ws-hero-promotional-banner .ws-promo-link {
    color: #ffffff;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.9rem;
  }

  .ws-hero-promotional-banner .ws-promo-link:hover {
    color: #FFE4D6;
  }

  @media (max-width: 768px) {
    .ws-hero-promotional-banner {
      padding: 10px 0;
    }

    .ws-hero-promotional-banner .ws-promo-content {
      gap: 10px;
    }

    .ws-hero-promotional-banner .ws-promo-text {
      font-size: 0.8rem;
    }

    .ws-hero-promotional-banner .ws-promo-highlight {
      font-size: 0.85rem;
      padding: 3px 12px;
    }
  }
{%- endstyle -%}

{% if section.settings.show_promotional_banner %}
  <div class="ws-hero-promotional-banner">
    <div class="page-width">
      <div class="ws-promo-content">
        {% if section.settings.promotional_icon != blank %}
          <span class="ws-promo-icon">{{ section.settings.promotional_icon }}</span>
        {% else %}
          <span class="ws-promo-icon">🔥</span>
        {% endif %}
        <span class="ws-promo-text">{{ section.settings.promotional_text }}</span>
        <span class="ws-promo-highlight">{{ section.settings.promotional_highlight }}</span>
        {% if section.settings.promotional_link_text != blank and section.settings.promotional_link != blank %}
          <a href="{{ section.settings.promotional_link }}" class="ws-promo-link">{{ section.settings.promotional_link_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

<section id="ws-hero-{{ section.id }}" class="wooden-hero-hybrid color-{{ section.settings.color_scheme }}" data-ws-hero>
  <div class="wooden-hero-hybrid__inner">
    <div class="wooden-hero-hybrid__content-box whisper-glass" data-aos="zoom-in">
      <div class="wooden-hero-hybrid__content">
        {% if section.settings.eyebrow != blank %}
          <p class="wooden-hero-hybrid__eyebrow" data-aos="fade-up">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="wooden-hero-hybrid__heading" data-aos="fade-up" data-aos-delay="100">
            {{ section.settings.heading | escape }}
          </h1>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="wooden-hero-hybrid__subheading" data-aos="fade-up" data-aos-delay="200">
            {{ section.settings.subheading | escape }}
          </p>
        {% endif %}
        <div class="wooden-hero-hybrid__actions" data-aos="fade-up" data-aos-delay="300">
          {% if section.settings.primary_button_label != blank %}
            <a class="wooden-hero-hybrid__button button" href="{{ section.settings.primary_button_link }}">
              {{ section.settings.primary_button_label | escape }}
            </a>
          {% endif %}
          {% if section.settings.secondary_button_label != blank %}
            <a class="wooden-hero-hybrid__button button button--secondary" href="{{ section.settings.secondary_button_link }}">
              {{ section.settings.secondary_button_label | escape }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
    <div class="wooden-hero-hybrid__media" data-aos="fade-left">
      {% if section.settings.primary_image != blank %}
        <div class="wooden-hero-hybrid__image-wrapper wooden-hero-hybrid__image-wrapper--primary">
           {{ section.settings.primary_image | image_url: width: 2000 | image_tag:
             class: 'wooden-hero-hybrid__image wooden-hero-hybrid__image--primary',
             loading: 'eager',
             fetchpriority: 'high',
             widths: '800, 1200, 1600, 2000',
             alt: section.settings.primary_image.alt
           }}
        </div>
      {% else %}
        <div class="wooden-hero-hybrid__image-wrapper wooden-hero-hybrid__image-wrapper--primary">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'wooden-hero-hybrid__image wooden-hero-hybrid__image--primary' }}
        </div>
      {% endif %}
      {% if section.settings.secondary_image != blank %}
        <div class="wooden-hero-hybrid__image-wrapper wooden-hero-hybrid__image-wrapper--secondary">
           {{ section.settings.secondary_image | image_url: width: 1200 | image_tag:
             class: 'wooden-hero-hybrid__image wooden-hero-hybrid__image--secondary',
             loading: 'lazy',
             widths: '400, 800, 1200',
             alt: section.settings.secondary_image.alt
           }}
        </div>
      {% endif %}
    </div>
  </div>
</section>




{% schema %}
{
  "name": "Wooden Hero Hybrid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.hero.presets.promotional_banner"
    },
    {
      "type": "checkbox",
      "id": "show_promotional_banner",
      "label": "t:sections.hero.presets.show_promotional_banner",
      "default": true
    },
    {
      "type": "text",
      "id": "promotional_icon",
      "label": "t:sections.hero.presets.promotional_icon",
      "default": "🔥",
      "info": "t:sections.hero.presets.promotional_icon_info"
    },
    {
      "type": "text",
      "id": "promotional_text",
      "label": "t:sections.hero.presets.promotional_text",
      "default": "Furniture"
    },
    {
      "type": "text",
      "id": "promotional_highlight",
      "label": "t:sections.hero.presets.promotional_highlight",
      "default": "UPTO 50% OFF"
    },
    {
      "type": "text",
      "id": "promotional_link_text",
      "label": "t:sections.hero.presets.promotional_link_text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "promotional_link",
      "label": "t:sections.hero.presets.promotional_link"
    },
    {
      "type": "header",
      "content": "t:sections.hero.presets.hero_content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero.presets.eyebrow",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.presets.heading",
      "default": "Crafted for modern living"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.hero.presets.subheading",
      "default": "Bring Wooden-inspired comfort home with premium materials and a fresh design story."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "t:sections.hero.presets.primary_button_label",
      "default": "Shop sofas"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "t:sections.hero.presets.primary_button_link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "t:sections.hero.presets.secondary_button_label",
      "default": "Explore collections"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "t:sections.hero.presets.secondary_button_link"
    },
    {
      "type": "header",
      "content": "t:sections.hero.presets.hero_images"
    },
    {
      "type": "image_picker",
      "id": "primary_image",
      "label": "t:sections.hero.presets.primary_image"
    },
    {
      "type": "image_picker",
      "id": "secondary_image",
      "label": "t:sections.hero.presets.secondary_image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.hero.presets.color_scheme",
      "default": "background-1"
    }
  ],
  "presets": [
    {
      "name": "Wooden Hero Hybrid"
    }
  ]
}
{% endschema %}
