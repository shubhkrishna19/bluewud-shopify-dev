{% comment %}
  Wooden: Homepage Video Section (H-08)
{% endcomment %}


<section class="ws-video" aria-label="Product Showcase">
  <div class="page-width">
    <div class="ws-video__container">
      <div class="ws-video__overlay">
        <h2 class="ws-video__title" data-aos="fade-up">Experience Real Furniture in Your Home</h2>
        <p class="ws-video__subtitle" data-aos="fade-up" data-aos-delay="100">
          <span class="ws-video__subtitle-line"></span>
          Factory Direct Quality
        </p>
      </div>

      {% comment %} Video with poster image fallback {% endcomment %}
      <div class="ws-video__media-wrapper">
        <video class="ws-video__media" autoplay muted loop playsinline poster="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=1920&q=80">
          <source src="https://cdn.shopify.com/s/files/1/0806/7294/0133/files/wooden-showcase.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>
        <div class="ws-video__fallback">
          <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=1920&q=80" alt="Furniture showroom" class="ws-video__fallback-image">
        </div>
      </div>

      <div class="ws-video__play-button-wrapper">
         <div class="ws-video__play-button">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
         </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WS HP Video",
  "settings": [],
  "presets": [
    {
      "name": "WS HP Video"
    }
  ]
}
{% endschema %}
