<script
  type="application/json"
  data-section-type="static-blog"
  data-section-id="{{ section.id }}">
</script>

{% assign featured_post = section.settings.featured_post %}
{% assign paginate_by = section.settings.posts_per_page_range | times: 1 %}

{% assign show_featured = false %}
{% if featured_post != '' and featured_post != blank %}
  {% assign show_featured = true %}

  {% comment %}
    Don't show highlighted post if is not first page, or if tags are active
  {% endcomment %}
  {% if paginate.current_page != 1 and current_tags != blank %}
    {% assign show_featured = false %}
  {% endif %}
{% endif %}

<section class="blog--container">
  <header class="blog-title">
    <h1>{{ blog.title }}</h1>
    {% if section.settings.show_rss_link %}
      <a href="{{ blog.url }}.atom">
        {% render 'icon-rss' %}
        <span class="visually-hidden">{{ 'general.accessibility.rss' | t | escape }}</span>
      </a>
    {% endif %}
  </header>

  {% paginate blog.articles by paginate_by %}

    {% if show_featured %}
      {% comment %} Get the featured article from the current blog {% endcomment %}
      {% assign featured_article = nil %}
      {% for article in blog.articles %}
        {% if article.handle == featured_post %}
          {% assign featured_article = article %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% if featured_article != nil %}
        {%
          render 'article-excerpt-featured',
          article: featured_article,
          section: section
        %}
      {% endif %}
    {% endif %}

    <ul class="blog--inner">
      {% for article in blog.articles %}
        {% comment %} Skip the featured post if it's being displayed {% endcomment %}
        {% if show_featured and article.handle == featured_post %}
          {% continue %}
        {% endif %}
        {%
          render 'article-excerpt',
          article: article,
          section: section
          %}
      {% else %}
        <article class="blog--no-results">
          <h2 class="blog--no-results-title">
            {{ 'blog.general.empty_blog' | t }}
          </h2>
        </article>
      {% endfor %}
    </ul>

    {% render 'pagination', paginate: paginate %}
  {% endpaginate %}

  {% if section.settings.show_newsletter_signup %}
    <div class="blog-newsletter-signup">
      <div class="blog-newsletter-signup-content">
        <h3 class="blog-newsletter-signup-title">{{ 'blog.newsletter.title' | t }}</h3>
        <p class="blog-newsletter-signup-text">{{ 'blog.newsletter.description' | t }}</p>

        {% form 'customer' %}
          <input type="hidden" name="contact[tags]" value="blog">
          <div class="blog-newsletter-form">
            <div class="form-field">
              <input
                type="email"
                id="newsletter-email"
                class="form-field-input form-field-text"
                name="contact[email]"
                placeholder="{{ 'blog.newsletter.email_placeholder' | t }}"
                required
              >
              <label class="form-field-title" for="newsletter-email">
                {{ 'blog.newsletter.email_label' | t }}
              </label>
            </div>
            <button class="button-primary blog-newsletter-submit" type="submit">
              {{ 'blog.newsletter.submit' | t }}
            </button>
          </div>

          {% if form.posted_successfully? %}
            <p class="newsletter-success-message">{{ 'blog.newsletter.success' | t }}</p>
          {% endif %}
        {% endform %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Blog pages",
  "class": "blog--section section--canonical",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_rss_link",
      "label": "Show RSS link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date published",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show post author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show post excerpt",
      "default": true
    },
    {
      "type": "article",
      "id": "featured_post",
      "label": "Featured post"
    },
    {
      "type": "range",
      "id": "posts_per_page_range",
      "label": "Posts per page",
      "min": 6,
      "max": 12,
      "step": 3,
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_newsletter_signup",
      "label": "Show email newsletter signup",
      "default": true
    }
  ]
}

{% endschema %}