<script>
  // Mobile menu toggle functionality
  document.addEventListener('DOMContentLoaded', function() {
    const menuToggle = document.querySelector('.header__icon--menu');
    const menuDrawer = document.querySelector('.menu-drawer-container');

    if (menuToggle && menuDrawer) {
      menuToggle.addEventListener('click', function() {
        menuDrawer.classList.toggle('menu-open');
        document.body.style.overflow = menuDrawer.classList.contains('menu-open') ? 'hidden' : '';
      });

      // Close menu when clicking overlay
      const backdrop = document.querySelector('.menu-drawer__backdrop');
      if (backdrop) {
        backdrop.addEventListener('click', function() {
          menuDrawer.classList.remove('menu-open');
          document.body.style.overflow = '';
        });
      }

      // Close menu on escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && menuDrawer.classList.contains('menu-open')) {
          menuDrawer.classList.remove('menu-open');
          document.body.style.overflow = '';
        }
      });
    }

    // Mobile submenu toggle
    const menuItems = document.querySelectorAll('.menu-drawer__menu-item--parent');
    menuItems.forEach(function(item) {
      item.addEventListener('click', function(e) {
        const submenu = this.nextElementSibling;
        if (submenu && submenu.classList.contains('menu-drawer__submenu')) {
          e.preventDefault();
          submenu.classList.toggle('active');
          this.classList.toggle('active');
        }
      });
    });
  });
</script>

